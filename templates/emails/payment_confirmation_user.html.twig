<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Confirmation de paiement</title>
</head>
<body style="margin:0;padding:0;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,'Helvetica Neue',Arial,sans-serif;background:#f3f4f6;">
    <table width="100%" cellpadding="0" cellspacing="0" style="background:#f3f4f6;padding:40px 20px;">
        <tr>
            <td align="center">
                <table width="600" cellpadding="0" cellspacing="0" style="background:#ffffff;border-radius:16px;overflow:hidden;box-shadow:0 10px 25px rgba(0,0,0,0.1);">
                    
                    {# Header avec gradient #}
                    <tr>
                        <td style="background:linear-gradient(135deg,#10b981 0%,#059669 100%);padding:40px 30px;text-align:center;">
                            <div style="background:rgba(255,255,255,0.2);width:80px;height:80px;border-radius:50%;margin:0 auto 20px;display:flex;align-items:center;justify-content:center;backdrop-filter:blur(10px);">
                                <span style="font-size:48px;">✅</span>
                            </div>
                            <h1 style="margin:0;color:#ffffff;font-size:28px;font-weight:700;letter-spacing:-0.5px;">
                                Paiement confirmé !
                            </h1>
                            <p style="margin:10px 0 0;color:rgba(255,255,255,0.9);font-size:16px;">
                                Votre transaction a été traitée avec succès
                            </p>
                        </td>
                    </tr>

                    {# Contenu principal #}
                    <tr>
                        <td style="padding:40px 30px;">
                            <p style="margin:0 0 20px;color:#374151;font-size:16px;line-height:1.6;">
                                Bonjour <strong>{{ user.nom|default('') }} {{ user.prenom|default('') }}</strong>,
                            </p>
                            <p style="margin:0 0 30px;color:#6b7280;font-size:15px;line-height:1.6;">
                                Nous vous confirmons que votre paiement via Stripe a été effectué avec succès. Voici les détails de votre transaction :
                            </p>

                            {# Carte de détails #}
                            <div style="background:linear-gradient(135deg,#f9fafb 0%,#f3f4f6 100%);border-radius:12px;padding:25px;margin-bottom:30px;border:1px solid #e5e7eb;">
                                <table width="100%" cellpadding="0" cellspacing="0">
                                    <tr>
                                        <td style="padding:8px 0;color:#6b7280;font-size:14px;">Transaction</td>
                                        <td align="right" style="padding:8px 0;color:#111827;font-size:14px;font-weight:600;">
                                            #{{ transaction.idTransaction|default('—') }}
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="padding:8px 0;color:#6b7280;font-size:14px;">Catégorie</td>
                                        <td align="right" style="padding:8px 0;">
                                            <span style="background:#dbeafe;color:#1e40af;padding:4px 12px;border-radius:20px;font-size:12px;font-weight:600;text-transform:uppercase;">
                                                {{ transaction.categorie|default('Paiement') }}
                                            </span>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="padding:8px 0;color:#6b7280;font-size:14px;">Date</td>
                                        <td align="right" style="padding:8px 0;color:#111827;font-size:14px;font-weight:600;">
                                            {{ transaction.dateTransaction|default('now'|date('d/m/Y')) }}
                                        </td>
                                    </tr>
                                    {% if transaction.nomDestinataire|default('') != '' %}
                                    <tr>
                                        <td style="padding:8px 0;color:#6b7280;font-size:14px;">Bénéficiaire</td>
                                        <td align="right" style="padding:8px 0;color:#111827;font-size:14px;font-weight:600;">
                                            {{ transaction.nomDestinataire }}
                                        </td>
                                    </tr>
                                    {% endif %}
                                    <tr>
                                        <td colspan="2" style="padding:20px 0 8px;border-top:2px solid #e5e7eb;">
                                            <div style="text-align:right;">
                                                <div style="color:#6b7280;font-size:13px;margin-bottom:5px;">Montant payé</div>
                                                <div style="color:#10b981;font-size:32px;font-weight:700;line-height:1;">
                                                    {{ transaction.montant_value|default(0)|number_format(3, '.', ' ') }} <span style="font-size:20px;">DT</span>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                </table>
                            </div>

                            {% if transaction.description|default('') != '' %}
                            <div style="background:#fef3c7;border-left:4px solid #f59e0b;padding:15px 20px;border-radius:8px;margin-bottom:30px;">
                                <div style="color:#92400e;font-size:13px;font-weight:600;margin-bottom:5px;">📝 Description</div>
                                <div style="color:#78350f;font-size:14px;line-height:1.5;">
                                    {{ transaction.description }}
                                </div>
                            </div>
                            {% endif %}

                            <p style="margin:0 0 20px;color:#6b7280;font-size:14px;line-height:1.6;">
                                Le montant a été débité de votre compte. Vous pouvez consulter tous les détails de cette transaction dans votre espace client.
                            </p>

                            {# Bouton CTA #}
                            <div style="text-align:center;margin:30px 0;">
                                <a href="{{ url('portal_dashboard', {tab: 'transactions'}) }}" 
                                   style="display:inline-block;background:linear-gradient(135deg,#10b981 0%,#059669 100%);color:#ffffff;text-decoration:none;padding:14px 32px;border-radius:10px;font-weight:600;font-size:15px;box-shadow:0 4px 12px rgba(16,185,129,0.3);">
                                    Voir mes transactions
                                </a>
                            </div>
                        </td>
                    </tr>

                    {# Footer #}
                    <tr>
                        <td style="background:#f9fafb;padding:30px;text-align:center;border-top:1px solid #e5e7eb;">
                            <p style="margin:0 0 10px;color:#9ca3af;font-size:13px;">
                                Cet email a été envoyé automatiquement par <strong style="color:#6b7280;">Nexora Bank</strong>
                            </p>
                            <p style="margin:0;color:#9ca3af;font-size:12px;">
                                © {{ 'now'|date('Y') }} Nexora Bank. Tous droits réservés.
                            </p>
                        </td>
                    </tr>

                </table>
            </td>
        </tr>
    </table>
</body>
</html>
