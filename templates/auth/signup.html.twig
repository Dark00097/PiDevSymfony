{% extends 'base.html.twig' %}

{% block title %}Inscription — Nexora Bank{% endblock %}
{% block body_class %}auth-body{% endblock %}

{% block stylesheets %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Space+Grotesk:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="{{ asset('styles/interfaces/auth-login.css?v=20260411-4') }}">
<link rel="stylesheet" href="{{ asset('styles/interfaces/auth-signup.css?v=20260411-3') }}">
{% endblock %}

{% block body %}
{% set signup_old = signup_old|default({}) %}
{% set signup_errors = signup_errors|default({}) %}
{% set signup_otp = signup_old.otp|default('') %}

<div class="auth-bg" aria-hidden="true">
  <div class="auth-orb auth-orb--1"></div>
  <div class="auth-orb auth-orb--2"></div>
  <div class="auth-orb auth-orb--3"></div>
  <div class="auth-grid"></div>
  <div class="auth-lines">
    <span></span><span></span><span></span>
    <span></span><span></span><span></span>
  </div>
</div>

<main class="auth-shell">

  {# ════════════════════
     LEFT PANEL
  ════════════════════ #}
  <aside class="auth-side">

    <a href="{{ path('home') }}" class="auth-back">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
           stroke="currentColor" stroke-width="2.5">
        <line x1="19" y1="12" x2="5" y2="12"/>
        <polyline points="12 19 5 12 12 5"/>
      </svg>
      Retour à l'accueil
    </a>

    <div class="auth-brand">
      <div class="auth-logo-ring">
        <img src="{{ asset('images/logo.png') }}" alt="Nexora">
        <div class="alr-pulse"></div>
        <div class="alr-pulse alr-pulse--2"></div>
      </div>
      <div>
        <span class="auth-eyebrow">PLATEFORME BANCAIRE</span>
        <strong class="auth-brand-name">NEXORA</strong>
      </div>
      <div class="auth-live-badge">
        <span class="live-dot"></span>LIVE
      </div>
    </div>

    <div class="auth-hero-text">
      <h1>
        Rejoignez<br>
        Nexora<span class="accent-dot">.</span>
      </h1>
      <p>
        Créez votre compte en quelques minutes.
        Votre dossier est validé par un administrateur
        avant activation complète.
      </p>
    </div>

    {# Steps tracker #}
    <div class="steps-track">
      <div class="step-item step-item--done">
        <div class="step-bubble">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="3">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
        </div>
        <div class="step-content">
          <strong>Vos informations</strong>
          <span>Nom, email, téléphone</span>
        </div>
      </div>
      <div class="step-line"></div>
      <div class="step-item step-item--active">
        <div class="step-bubble">2</div>
        <div class="step-content">
          <strong>Vérification OTP</strong>
          <span>Code par email/SMS</span>
        </div>
      </div>
      <div class="step-line"></div>
      <div class="step-item">
        <div class="step-bubble">3</div>
        <div class="step-content">
          <strong>Validation admin</strong>
          <span>Activation sous 24h</span>
        </div>
      </div>
    </div>

    {# Benefits #}
    <div class="benefits-list">
      <div class="benefit">
        <div class="benefit-icon">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2.5">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
        </div>
        <span>Tableau de bord bancaire complet</span>
      </div>
      <div class="benefit">
        <div class="benefit-icon">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2.5">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
        </div>
        <span>Gestion multi-devises & multi-comptes</span>
      </div>
      <div class="benefit">
        <div class="benefit-icon">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2.5">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
        </div>
        <span>Programme cashback dès l'activation</span>
      </div>
      <div class="benefit">
        <div class="benefit-icon">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2.5">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
        </div>
        <span>Face ID & sécurité AES-256</span>
      </div>
      <div class="benefit">
        <div class="benefit-icon">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2.5">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
        </div>
        <span>Demandes de crédit en ligne</span>
      </div>
    </div>

    <p class="auth-side-foot">© 2025 Nexora Bank · Inscription sécurisée</p>

  </aside>

  {# ════════════════════
     RIGHT — FORM
  ════════════════════ #}
  <section class="auth-right su-right">

    <div class="auth-glass-card su-card">

      <div class="agc-rainbow"></div>

      <div class="su-header">
        <div class="su-header-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="1.5">
            <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
            <circle cx="8.5" cy="7" r="4"/>
            <line x1="20" y1="8" x2="20" y2="14"/>
            <line x1="23" y1="11" x2="17" y2="11"/>
          </svg>
        </div>
        <div>
          <h2>Créer mon compte</h2>
          <p>Remplissez les informations ci-dessous</p>
        </div>
        <div class="agc-shield">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
        </div>
      </div>

      {% include '_flashes.html.twig' %}

      <form method="post" class="su-form" id="suForm" novalidate>
        <input type="hidden" name="action" id="signupAction" value="signup">

        {# Row 1: name + email #}
        <div class="su-row">
          <div class="field-group">
            <label class="field-label" for="su-name">Nom complet</label>
            <div class="field-wrap{{ signup_errors.full_name is defined ? ' field-wrap--invalid' : '' }}" data-field>
              <span class="field-icon">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2">
                  <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                  <circle cx="12" cy="7" r="4"/>
                </svg>
              </span>
              <input type="text" id="su-name" name="full_name"
                     placeholder="Jean Dupont"
                     value="{{ signup_old.full_name|default('') }}"
                     minlength="3"
                     required autocomplete="name">
            </div>
            {% if signup_errors.full_name is defined %}
              <small class="field-error">{{ signup_errors.full_name }}</small>
            {% endif %}
          </div>

          <div class="field-group">
            <label class="field-label" for="su-email">Adresse email</label>
            <div class="field-wrap{{ signup_errors.email is defined ? ' field-wrap--invalid' : '' }}" data-field>
              <span class="field-icon">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                  <polyline points="22,6 12,13 2,6"/>
                </svg>
              </span>
              <input type="email" id="su-email" name="email"
                     placeholder="vous@exemple.com"
                     value="{{ signup_old.email|default('') }}"
                     required autocomplete="email">
              <span class="field-check" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="3">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
              </span>
            </div>
            {% if signup_errors.email is defined %}
              <small class="field-error">{{ signup_errors.email }}</small>
            {% endif %}
          </div>
        </div>

        {# Row 2: phone #}
        <div class="field-group">
          <label class="field-label" for="su-tel">Numéro de téléphone</label>
          <div class="field-wrap{{ signup_errors.telephone is defined ? ' field-wrap--invalid' : '' }}" data-field>
            <span class="field-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                   stroke="currentColor" stroke-width="2">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.38 2 2 0 0 1 3.6 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.4a16 16 0 0 0 7.69 7.69"/>
              </svg>
            </span>
            <input type="tel" id="su-tel" name="telephone"
                   placeholder="+33 6 12 34 56 78"
                   value="{{ signup_old.telephone|default('') }}"
                   pattern="^\+?[0-9][0-9\s\-]{6,19}$"
                   required autocomplete="tel">
          </div>
          {% if signup_errors.telephone is defined %}
            <small class="field-error">{{ signup_errors.telephone }}</small>
          {% endif %}
        </div>

        {# OTP block #}
        <div class="otp-card">
          <div class="otp-card-header">
            <div class="otp-card-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                   stroke="currentColor" stroke-width="2.5">
                <path d="M21.2 8.4c.5.38.8.97.8 1.6v10a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V10a2 2 0 0 1 2-2h3.8"/>
                <rect x="8" y="2" width="8" height="8" rx="1"/>
                <path d="M10 6h4"/>
              </svg>
            </div>
            <div>
              <strong>Vérification OTP</strong>
              <span>Recevez un code à 6 chiffres par email</span>
            </div>
            <div class="otp-badge" id="otpBadge">Non envoyé</div>
          </div>

          <div class="otp-inputs-row">
            <div class="otp-digits{{ signup_errors.otp is defined ? ' field-wrap--invalid' : '' }}" id="otpDigits">
              <input class="otp-digit" type="text" name="otp_digit_1" value="{{ signup_otp|slice(0, 1) }}" maxlength="1" pattern="[0-9]" inputmode="numeric" autocomplete="one-time-code">
              <input class="otp-digit" type="text" name="otp_digit_2" value="{{ signup_otp|slice(1, 1) }}" maxlength="1" pattern="[0-9]" inputmode="numeric">
              <input class="otp-digit" type="text" name="otp_digit_3" value="{{ signup_otp|slice(2, 1) }}" maxlength="1" pattern="[0-9]" inputmode="numeric">
              <div class="otp-sep">—</div>
              <input class="otp-digit" type="text" name="otp_digit_4" value="{{ signup_otp|slice(3, 1) }}" maxlength="1" pattern="[0-9]" inputmode="numeric">
              <input class="otp-digit" type="text" name="otp_digit_5" value="{{ signup_otp|slice(4, 1) }}" maxlength="1" pattern="[0-9]" inputmode="numeric">
              <input class="otp-digit" type="text" name="otp_digit_6" value="{{ signup_otp|slice(5, 1) }}" maxlength="1" pattern="[0-9]" inputmode="numeric">
            </div>
            <input type="hidden" name="otp" id="otpHidden" value="{{ signup_otp }}">
            {% if signup_errors.otp is defined %}
              <small class="field-error">{{ signup_errors.otp }}</small>
            {% endif %}
          </div>

          <div class="otp-actions">
            <button type="submit" name="action" value="send_otp"
                    class="otp-send-btn" id="otpSendBtn">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                   stroke="currentColor" stroke-width="2.5">
                <line x1="22" y1="2" x2="11" y2="13"/>
                <polygon points="22 2 15 22 11 13 2 9 22 2"/>
              </svg>
              Envoyer le code
            </button>
            <span class="otp-timer" id="otpTimer" style="display:none"></span>
          </div>
        </div>

        {# Passwords row #}
        <div class="su-row">
          <div class="field-group">
            <label class="field-label" for="su-pw">Mot de passe</label>
            <div class="field-wrap{{ signup_errors.password is defined ? ' field-wrap--invalid' : '' }}" data-field id="pwWrap">
              <span class="field-icon">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2">
                  <rect x="3" y="11" width="18" height="11" rx="2"/>
                  <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                </svg>
              </span>
              <input type="password" id="su-pw" name="password"
                     placeholder="••••••••" minlength="8" required autocomplete="new-password">
              <button type="button" class="field-eye" data-eye="su-pw">
                <svg class="eye-show" width="16" height="16" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                  <circle cx="12" cy="12" r="3"/>
                </svg>
                <svg class="eye-hide" width="16" height="16" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="2"
                     style="display:none">
                  <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/>
                  <line x1="1" y1="1" x2="23" y2="23"/>
                </svg>
              </button>
            </div>
            {% if signup_errors.password is defined %}
              <small class="field-error">{{ signup_errors.password }}</small>
            {% endif %}
            {# Strength #}
            <div class="pw-strength">
              <div class="pw-track">
                <div class="pw-segment"></div>
                <div class="pw-segment"></div>
                <div class="pw-segment"></div>
                <div class="pw-segment"></div>
              </div>
              <span class="pw-label" id="pwLabel">—</span>
            </div>
          </div>

          <div class="field-group">
            <label class="field-label" for="su-cpw">Confirmation</label>
            <div class="field-wrap{{ signup_errors.confirm_password is defined ? ' field-wrap--invalid' : '' }}" data-field id="cpwWrap">
              <span class="field-icon">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                </svg>
              </span>
              <input type="password" id="su-cpw" name="confirm_password"
                     placeholder="••••••••" required autocomplete="new-password">
              <span class="field-check" id="cpwCheck" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="3">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
              </span>
            </div>
            {% if signup_errors.confirm_password is defined %}
              <small class="field-error">{{ signup_errors.confirm_password }}</small>
            {% endif %}
          </div>
        </div>

        {# Terms #}
        <label class="nx-check terms-check{{ signup_errors.terms is defined ? ' field-wrap--invalid' : '' }}">
          <input type="checkbox" name="terms" {{ signup_old.terms|default('0') == '1' ? 'checked' : '' }} required>
          <span class="nx-check-box"></span>
          <span>
            J'accepte les
            <a href="#" class="terms-link">conditions d'utilisation</a>
            et la
            <a href="#" class="terms-link">politique de confidentialité</a>
            de Nexora Bank.
          </span>
        </label>
        {% if signup_errors.terms is defined %}
          <small class="field-error">{{ signup_errors.terms }}</small>
        {% endif %}

        {# Submit #}
        <button class="nx-submit nx-submit--signup" type="submit" name="action" value="signup" id="signupSubmitBtn">
          <span class="nx-submit-text">Créer mon compte</span>
          <span class="nx-submit-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2.5">
              <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
              <circle cx="8.5" cy="7" r="4"/>
              <line x1="20" y1="8" x2="20" y2="14"/>
              <line x1="23" y1="11" x2="17" y2="11"/>
            </svg>
          </span>
          <span class="nx-submit-glow"></span>
        </button>

      </form>

      <div class="agc-footer">
        <span>Déjà un compte ?</span>
        <a href="{{ path('login') }}" class="agc-footer-link">
          Se connecter
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="3">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
      </div>

    </div>
  </section>

</main>

<script>
(function () {
  'use strict';

  document.addEventListener('DOMContentLoaded', function () {
    initFocus();
    initEyes();
    initEmailValidation();
    initPasswordStrength();
    initConfirmMatch();
    initOtpDigits();
    initOtpTimer();
    initSignupSubmitSync();
  });

  /* Focus rings */
  function initFocus() {
    document.querySelectorAll('[data-field] input').forEach(function (inp) {
      var w = inp.closest('[data-field]');
      inp.addEventListener('focus', function () { w.classList.add('field-wrap--focus'); });
      inp.addEventListener('blur',  function () { w.classList.remove('field-wrap--focus'); });
    });
  }

  /* Eye toggles */
  function initEyes() {
    document.querySelectorAll('.field-eye[data-eye]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var inp = document.getElementById(btn.dataset.eye);
        if (!inp) return;
        var show = inp.type === 'password';
        inp.type = show ? 'text' : 'password';
        btn.querySelector('.eye-show').style.display = show ? 'none' : '';
        btn.querySelector('.eye-hide').style.display = show ? ''     : 'none';
      });
    });
  }

  /* Email green checkmark */
  function initEmailValidation() {
    document.querySelectorAll('input[type="email"]').forEach(function (inp) {
      inp.addEventListener('input', function () {
        var w = inp.closest('[data-field]');
        if (w) w.classList.toggle('field-wrap--valid', inp.validity.valid && inp.value.length > 0);
      });
    });
  }

  /* Password strength */
  function initPasswordStrength() {
    var pw   = document.getElementById('su-pw');
    var segs = document.querySelectorAll('.pw-segment');
    var lbl  = document.getElementById('pwLabel');
    if (!pw || !segs.length) return;

    var levels = [
      { color: '#ff607a', label: '—',            min: 0  },
      { color: '#ff607a', label: 'Très faible',  min: 1  },
      { color: '#ffb347', label: 'Faible',        min: 2  },
      { color: '#ffd447', label: 'Moyen',         min: 3  },
      { color: '#00B4A0', label: 'Fort',          min: 4  },
      { color: '#00dc78', label: 'Très fort',     min: 5  }
    ];

    pw.addEventListener('input', function () {
      var v = pw.value;
      var score = 0;
      if (v.length >= 8)          score++;
      if (v.length >= 12)         score++;
      if (/[A-Z]/.test(v))        score++;
      if (/[0-9]/.test(v))        score++;
      if (/[^A-Za-z0-9]/.test(v)) score++;
      var lvl = levels[Math.min(score, 5)];
      segs.forEach(function (s, i) {
        s.style.background = i < Math.ceil(score * segs.length / 5)
          ? lvl.color : '';
      });
      if (lbl) { lbl.textContent = lvl.label; lbl.style.color = lvl.color; }
    });
  }

  /* Confirm password match */
  function initConfirmMatch() {
    var pw   = document.getElementById('su-pw');
    var cpw  = document.getElementById('su-cpw');
    var wrap = document.getElementById('cpwWrap');
    var chk  = document.getElementById('cpwCheck');
    if (!pw || !cpw || !wrap) return;

    cpw.addEventListener('input', function () {
      var match = cpw.value.length > 0 && cpw.value === pw.value;
      wrap.classList.toggle('field-wrap--valid',   match);
      wrap.classList.toggle('field-wrap--invalid', !match && cpw.value.length > 0);
      if (chk) chk.style.opacity = match ? '1' : '0';
    });
  }

  /* OTP digit boxes → hidden input */
  function initOtpDigits() {
    var digits  = document.querySelectorAll('.otp-digit');
    var hidden  = document.getElementById('otpHidden');
    if (!digits.length || !hidden) return;

    var syncHidden = function () {
      var val = '';
      digits.forEach(function (d) { val += d.value; });
      hidden.value = val.replace(/\D/g, '').slice(0, 6);
      digits.forEach(function (d) {
        d.classList.toggle('otp-digit--filled', d.value.length > 0);
      });
    };

    digits.forEach(function (inp, idx) {
      inp.addEventListener('input', function () {
        inp.value = inp.value.replace(/\D/g, '').slice(-1);
        if (inp.value && idx < digits.length - 1) {
          digits[idx + 1].focus();
        }
        syncHidden();
      });
      inp.addEventListener('keydown', function (e) {
        if (e.key === 'Backspace' && !inp.value && idx > 0) {
          digits[idx - 1].focus();
        }
      });
      inp.addEventListener('paste', function (e) {
        e.preventDefault();
        var pasted = (e.clipboardData || window.clipboardData)
          .getData('text').replace(/\D/g, '').slice(0, 6);
        pasted.split('').forEach(function (ch, i) {
          if (digits[i]) { digits[i].value = ch; digits[i].classList.add('otp-digit--filled'); }
        });
        hidden.value = pasted.replace(/\D/g, '').slice(0, 6);
        var next = Math.min(pasted.length, digits.length - 1);
        digits[next].focus();
      });
    });

    syncHidden();
  }

  /* OTP countdown */
  function initOtpTimer() {
    var sendBtn = document.getElementById('otpSendBtn');
    var timer   = document.getElementById('otpTimer');
    var badge   = document.getElementById('otpBadge');
    var action  = document.getElementById('signupAction');
    if (!sendBtn) return;

    sendBtn.addEventListener('click', function () {
      if (action) {
        action.value = 'send_otp';
      }
      if (timer) { timer.style.display = 'none'; }
      if (badge) { badge.textContent = 'Envoyé ✓'; badge.classList.add('otp-badge--sent'); }
    });
  }

  function initSignupSubmitSync() {
    var form = document.getElementById('suForm');
    var action = document.getElementById('signupAction');
    var hidden = document.getElementById('otpHidden');
    var digits = document.querySelectorAll('.otp-digit');
    if (!form || !action || !hidden || !digits.length) return;

    form.addEventListener('submit', function (event) {
      var submitter = event.submitter;
      if (submitter && submitter.name === 'action' && submitter.value) {
        action.value = submitter.value;
      } else if (!action.value) {
        action.value = 'signup';
      }

      var otp = '';
      digits.forEach(function (d) {
        otp += (d.value || '').replace(/\D/g, '').slice(-1);
      });
      hidden.value = otp.slice(0, 6);
    });
  }

})();
</script>

{% endblock %}
