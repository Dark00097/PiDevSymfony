{% extends 'base.html.twig' %}

{% block title %}Nexora — Recuperation du mot de passe{% endblock %}
{% block body_class %}rp-body{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
{% endblock %}

{% block body %}
<style>
/* ══════════════════════════════════════════════════════════════════════
   RESET PASSWORD PAGE — Full Redesign
   White background · Blue/Teal palette
   ══════════════════════════════════════════════════════════════════════ */

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

.rp-body {
    font-family: 'Inter', 'Segoe UI', system-ui, -apple-system, sans-serif;
    background: #f0f4f8;
    min-height: 100vh;
    display: flex;
    align-items: stretch;
    color: #0a2540;
}

/* ══════════════════════════════════════════════════════════════════════
   SHELL — two columns
   ══════════════════════════════════════════════════════════════════════ */
.rp-shell {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 100vh;
    width: 100%;
}

/* ══════════════════════════════════════════════════════════════════════
   LEFT PANEL
   ══════════════════════════════════════════════════════════════════════ */
.rp-left {
    background: linear-gradient(150deg, #0a2540 0%, #1565c0 55%, #00bcd4 100%);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 48px 52px;
    position: relative;
    overflow: hidden;
}

/* Decorative circles */
.rp-left::before {
    content: '';
    position: absolute;
    width: 480px; height: 480px;
    background: rgba(255,255,255,.04);
    border-radius: 50%;
    top: -160px; right: -140px;
    pointer-events: none;
}

.rp-left::after {
    content: '';
    position: absolute;
    width: 280px; height: 280px;
    background: rgba(0,188,212,.08);
    border-radius: 50%;
    bottom: -80px; left: -60px;
    pointer-events: none;
}

/* Logo */
.rp-logo {
    display: flex;
    align-items: center;
    gap: 12px;
    position: relative;
    z-index: 1;
}

.rp-logo-img {
    width: 44px; height: 44px;
    border-radius: 14px;
    background: rgba(255,255,255,.12);
    border: 1px solid rgba(255,255,255,.2);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    flex-shrink: 0;
}

.rp-logo-img img {
    width: 100%; height: 100%;
    object-fit: contain;
}

.rp-logo-text strong {
    display: block;
    font-size: 15px;
    font-weight: 900;
    color: #fff;
    letter-spacing: 1.5px;
    line-height: 1;
}

.rp-logo-text small {
    display: block;
    font-size: 10px;
    color: rgba(255,255,255,.55);
    margin-top: 2px;
    letter-spacing: 0.4px;
}

/* Center hero content */
.rp-left-hero {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 24px;
}

/* Big shield icon */
.rp-shield-ring {
    width: 90px; height: 90px;
    border-radius: 28px;
    background: rgba(255,255,255,.1);
    border: 1px solid rgba(255,255,255,.18);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 36px;
    color: #7dd3fc;
    backdrop-filter: blur(8px);
    box-shadow: 0 16px 40px rgba(0,0,0,.15);
}

.rp-left-hero h1 {
    font-size: clamp(24px, 2.5vw, 36px);
    font-weight: 900;
    color: #fff;
    line-height: 1.15;
    letter-spacing: -0.5px;
}

.rp-left-hero h1 span {
    color: #7dd3fc;
}

.rp-left-hero p {
    font-size: 14px;
    color: rgba(255,255,255,.65);
    line-height: 1.65;
    max-width: 340px;
}

/* Step indicators */
.rp-steps {
    display: flex;
    flex-direction: column;
    gap: 12px;
}

.rp-step {
    display: flex;
    align-items: center;
    gap: 12px;
}

.rp-step-num {
    width: 32px; height: 32px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 800;
    flex-shrink: 0;
    border: 1.5px solid rgba(255,255,255,.25);
    color: rgba(255,255,255,.6);
    transition: all .3s;
}

.rp-step.active .rp-step-num {
    background: #00bcd4;
    border-color: #00bcd4;
    color: #fff;
    box-shadow: 0 4px 12px rgba(0,188,212,.4);
}

.rp-step.done .rp-step-num {
    background: rgba(34,197,94,.2);
    border-color: rgba(34,197,94,.4);
    color: #86efac;
}

.rp-step-info strong {
    display: block;
    font-size: 13px;
    font-weight: 700;
    color: rgba(255,255,255,.85);
    line-height: 1.2;
}

.rp-step-info small {
    display: block;
    font-size: 11px;
    color: rgba(255,255,255,.45);
    margin-top: 2px;
}

.rp-step.active .rp-step-info strong { color: #fff; }
.rp-step.active .rp-step-info small  { color: rgba(255,255,255,.65); }

/* Step connector line */
.rp-step-connector {
    width: 1px;
    height: 14px;
    background: rgba(255,255,255,.15);
    margin-left: 15px;
}

/* Security note */
.rp-security-note {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 16px;
    background: rgba(255,255,255,.07);
    border: 1px solid rgba(255,255,255,.1);
    border-radius: 12px;
    font-size: 12px;
    color: rgba(255,255,255,.6);
    position: relative;
    z-index: 1;
}

.rp-security-note i { color: #00bcd4; font-size: 14px; flex-shrink: 0; }

/* Bottom footer of left panel */
.rp-left-foot {
    display: flex;
    align-items: center;
    gap: 16px;
    position: relative;
    z-index: 1;
}

.rp-left-foot a {
    font-size: 12px;
    color: rgba(255,255,255,.5);
    text-decoration: none;
    transition: color .15s;
}

.rp-left-foot a:hover { color: rgba(255,255,255,.85); }

.rp-left-foot-sep {
    width: 3px; height: 3px;
    border-radius: 50%;
    background: rgba(255,255,255,.25);
}

/* ══════════════════════════════════════════════════════════════════════
   RIGHT PANEL — Form area
   ══════════════════════════════════════════════════════════════════════ */
.rp-right {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 48px 52px;
    background: #fff;
    position: relative;
}

/* Subtle background pattern */
.rp-right::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
        radial-gradient(circle at 10% 20%, rgba(21,101,192,.03) 0%, transparent 50%),
        radial-gradient(circle at 90% 80%, rgba(0,188,212,.03) 0%, transparent 50%);
    pointer-events: none;
}

.rp-form-wrap {
    width: 100%;
    max-width: 420px;
    position: relative;
    z-index: 1;
}

/* Form header */
.rp-form-header {
    margin-bottom: 28px;
}

.rp-form-tag {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 5px 12px;
    border-radius: 999px;
    background: linear-gradient(120deg, rgba(21,101,192,.1), rgba(0,188,212,.08));
    border: 1px solid rgba(21,101,192,.15);
    font-size: 11px;
    font-weight: 800;
    color: #1565c0;
    text-transform: uppercase;
    letter-spacing: 0.7px;
    margin-bottom: 14px;
}

.rp-form-tag i { font-size: 11px; }

.rp-form-title {
    font-size: clamp(22px, 2vw, 28px);
    font-weight: 900;
    color: #0a2540;
    letter-spacing: -0.4px;
    line-height: 1.1;
}

.rp-form-sub {
    font-size: 13px;
    color: #7294ae;
    margin-top: 6px;
    line-height: 1.5;
}

/* Progress bar */
.rp-progress-wrap {
    margin-bottom: 24px;
}

.rp-progress-labels {
    display: flex;
    justify-content: space-between;
    margin-bottom: 8px;
}

.rp-progress-label {
    font-size: 11px;
    font-weight: 700;
    color: #8aafc8;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    transition: color .3s;
}

.rp-progress-label.active { color: #1565c0; }
.rp-progress-label.done   { color: #16a34a; }

.rp-progress-label-dot {
    width: 20px; height: 20px;
    border-radius: 50%;
    border: 2px solid currentColor;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 9px;
    font-weight: 800;
    transition: all .3s;
}

.rp-progress-label.active .rp-progress-label-dot {
    background: #1565c0;
    border-color: #1565c0;
    color: #fff;
    box-shadow: 0 3px 8px rgba(21,101,192,.3);
}

.rp-progress-label.done .rp-progress-label-dot {
    background: #16a34a;
    border-color: #16a34a;
    color: #fff;
}

.rp-progress-track {
    height: 5px;
    background: #e8f0f8;
    border-radius: 999px;
    overflow: hidden;
    position: relative;
}

.rp-progress-fill {
    height: 100%;
    border-radius: 999px;
    background: linear-gradient(90deg, #1565c0, #00bcd4);
    transition: width .5s ease;
}

/* ── Form ── */
.rp-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
}

/* Section label */
.rp-section-label {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    font-weight: 800;
    color: #1565c0;
    text-transform: uppercase;
    letter-spacing: 0.8px;
}

.rp-section-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, #c3d9f5, transparent);
}

/* Field */
.rp-field { display: flex; flex-direction: column; gap: 5px; }

.rp-label {
    font-size: 11px;
    font-weight: 700;
    color: #4e7490;
    display: flex;
    align-items: center;
    gap: 5px;
}

.rp-label i { color: #1565c0; font-size: 10px; }

.rp-input-wrap { position: relative; }

.rp-input-icon {
    position: absolute;
    left: 13px; top: 50%;
    transform: translateY(-50%);
    color: #8aafc8; font-size: 13px;
    pointer-events: none;
    z-index: 1;
}

.rp-input {
    width: 100%;
    min-height: 46px;
    border-radius: 13px;
    border: 1.5px solid #ccddef;
    background: #f7faff;
    padding: 0 14px 0 40px;
    font: inherit;
    font-size: 14px;
    color: #0a2540;
    outline: none;
    appearance: none;
    transition: border-color .2s, box-shadow .2s, background .2s;
}

.rp-input:focus {
    border-color: #1e88e5;
    background: #fff;
    box-shadow: 0 0 0 3px rgba(30,136,229,.12);
}

.rp-input::placeholder { color: #aabece; font-size: 13px; }

.rp-input.is-valid   { border-color: #22c55e; background: #f0fdf4; }
.rp-input.is-invalid { border-color: #e53935; background: #fff5f5; }

/* Eye toggle */
.rp-eye-btn {
    position: absolute;
    right: 13px; top: 50%;
    transform: translateY(-50%);
    background: none; border: none;
    color: #8aafc8; cursor: pointer;
    font-size: 14px; padding: 2px 4px;
    transition: color .15s;
}

.rp-eye-btn:hover { color: #1565c0; }

/* OTP row — special layout */
.rp-otp-group {
    display: flex;
    flex-direction: column;
    gap: 10px;
}

.rp-otp-input-row {
    display: flex;
    gap: 10px;
}

.rp-otp-input-row .rp-input-wrap { flex: 1; }

.rp-otp-input {
    letter-spacing: 8px;
    text-align: center;
    font-size: 20px;
    font-weight: 800;
    font-variant-numeric: tabular-nums;
    color: #1565c0;
}

.rp-otp-actions {
    display: flex;
    gap: 8px;
}

/* Password strength */
.rp-pw-strength { display: flex; flex-direction: column; gap: 5px; margin-top: 4px; }

.rp-pw-bars { display: flex; gap: 4px; }

.rp-pw-bar {
    flex: 1;
    height: 4px;
    border-radius: 999px;
    background: #e8f0f8;
    transition: background .3s;
}

.rp-pw-label {
    font-size: 11px;
    font-weight: 700;
    color: #8aafc8;
}

/* Hint */
.rp-hint {
    display: flex;
    align-items: flex-start;
    gap: 7px;
    font-size: 12px;
    color: #7294ae;
    line-height: 1.5;
    padding: 10px 13px;
    background: #f7faff;
    border: 1px solid #dde8f5;
    border-radius: 11px;
}

.rp-hint i { color: #1565c0; flex-shrink: 0; margin-top: 1px; font-size: 12px; }

/* OTP timer */
.rp-otp-timer {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: #7294ae;
    font-weight: 600;
}

.rp-otp-timer i { color: #f59e0b; font-size: 12px; }

#rp-timer-val { color: #1565c0; font-weight: 800; }

/* ── Buttons ── */
.rp-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    min-height: 46px;
    padding: 0 20px;
    border-radius: 13px;
    font: inherit;
    font-size: 14px;
    font-weight: 700;
    cursor: pointer;
    border: none;
    text-decoration: none;
    transition: all .2s;
    white-space: nowrap;
}

.rp-btn i { font-size: 14px; }

.rp-btn-primary {
    background: linear-gradient(120deg, #1565c0, #1e88e5);
    color: #fff;
    box-shadow: 0 6px 20px rgba(21,101,192,.28);
    width: 100%;
}

.rp-btn-primary:hover {
    opacity: .92;
    box-shadow: 0 8px 26px rgba(21,101,192,.38);
    transform: translateY(-1px);
}

.rp-btn-primary:active { transform: scale(.98); }

.rp-btn-outline {
    background: transparent;
    color: #1565c0;
    border: 1.5px solid #c3d9f5;
    flex: 1;
}

.rp-btn-outline:hover { background: #eaf2fd; }

.rp-btn-teal {
    background: linear-gradient(120deg, #00838f, #00bcd4);
    color: #fff;
    box-shadow: 0 4px 14px rgba(0,188,212,.22);
    flex: 1;
}

.rp-btn-teal:hover { opacity: .9; }

.rp-btn-ghost {
    background: #f0f4f8;
    color: #5b80a0;
    border: 1px solid #dde8f5;
}

.rp-btn-ghost:hover { background: #e2ecf8; color: #0a2540; }

/* Form actions row */
.rp-form-actions { display: flex; flex-direction: column; gap: 10px; margin-top: 4px; }

/* Divider */
.rp-divider {
    display: flex;
    align-items: center;
    gap: 10px;
    color: #b8cfe0;
    font-size: 11px;
    font-weight: 700;
}

.rp-divider::before,
.rp-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: #e2eaf4;
}

/* Links row */
.rp-links {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    flex-wrap: wrap;
}

.rp-links a {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-weight: 700;
    color: #5b80a0;
    text-decoration: none;
    padding: 8px 14px;
    border-radius: 10px;
    border: 1px solid #dde8f5;
    background: #f7faff;
    transition: all .15s;
}

.rp-links a:hover {
    background: #eaf2fd;
    color: #1565c0;
    border-color: #c3d9f5;
}

.rp-links a i { font-size: 12px; }

/* Flash messages */
.rp-flash {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 14px;
    border-radius: 12px;
    font-size: 13px;
    font-weight: 600;
    border: 1px solid transparent;
}

.rp-flash i { font-size: 14px; flex-shrink: 0; }

.rp-flash-success { background: #dcfce7; color: #166534; border-color: #bbf7d0; }
.rp-flash-error   { background: #fee2e2; color: #991b1b; border-color: #fecaca; }
.rp-flash-warning { background: #fef3c7; color: #92400e; border-color: #fde68a; }
.rp-flash-info    { background: #dbeafe; color: #1e40af; border-color: #bfdbfe; }

/* ══════════════════════════════════════════════════════════════════════
   RESPONSIVE
   ══════════════════════════════════════════════════════════════════════ */
@media (max-width: 960px) {
    .rp-shell { grid-template-columns: 1fr; }
    .rp-left  { min-height: 280px; padding: 32px 28px; }
    .rp-left-hero h1 { font-size: 24px; }
    .rp-shield-ring { width: 64px; height: 64px; font-size: 26px; }
    .rp-steps { display: none; }
    .rp-right { padding: 36px 24px; }
}

@media (max-width: 500px) {
    .rp-left { padding: 24px 20px; }
    .rp-right { padding: 24px 20px; }
    .rp-otp-actions { flex-direction: column; }
    .rp-links { flex-direction: column; gap: 8px; }
    .rp-links a { justify-content: center; }
}
</style>

<div class="rp-shell">

    {# ════════════ LEFT PANEL ════════════ #}
    <aside class="rp-left">

        {# Logo #}
        <div class="rp-logo">
            <div class="rp-logo-img">
                <img src="{{ asset('images/logo.png') }}" alt="Nexora logo"
                     onerror="this.style.display='none'">
            </div>
            <div class="rp-logo-text">
                <strong>NEXORA</strong>
                <small>Banque privee</small>
            </div>
        </div>

        {# Hero content #}
        <div class="rp-left-hero">
            <div class="rp-shield-ring">
                <i class="fa-solid fa-shield-halved"></i>
            </div>

            <div>
                <h1>
                    Recuperation du<br>
                    <span>mot de passe</span>
                </h1>
                <p style="margin-top:12px;">
                    Retrouvez l'acces a votre compte en trois etapes simples et securisees.
                    Votre securite est notre priorite.
                </p>
            </div>

            {# Step list #}
            <div class="rp-steps" id="rp-step-list">
                <div class="rp-step active" id="rp-step-1">
                    <div class="rp-step-num">
                        <i class="fa-solid fa-check" style="font-size:9px; display:none;" id="rp-s1-check"></i>
                        <span id="rp-s1-num">1</span>
                    </div>
                    <div class="rp-step-info">
                        <strong>Saisir votre email</strong>
                        <small>Nous vous enverrons un code OTP</small>
                    </div>
                </div>
                <div class="rp-step-connector"></div>

                <div class="rp-step" id="rp-step-2">
                    <div class="rp-step-num">
                        <i class="fa-solid fa-check" style="font-size:9px; display:none;" id="rp-s2-check"></i>
                        <span id="rp-s2-num">2</span>
                    </div>
                    <div class="rp-step-info">
                        <strong>Verifier le code OTP</strong>
                        <small>Code a 6 chiffres valide 5 minutes</small>
                    </div>
                </div>
                <div class="rp-step-connector"></div>

                <div class="rp-step" id="rp-step-3">
                    <div class="rp-step-num">
                        <i class="fa-solid fa-check" style="font-size:9px; display:none;" id="rp-s3-check"></i>
                        <span id="rp-s3-num">3</span>
                    </div>
                    <div class="rp-step-info">
                        <strong>Nouveau mot de passe</strong>
                        <small>Choisissez un mot de passe fort</small>
                    </div>
                </div>
            </div>

            {# Security note #}
            <div class="rp-security-note">
                <i class="fa-solid fa-lock"></i>
                <span>Connexion chiffree SSL/TLS · Donnees protegees</span>
            </div>
        </div>

        {# Footer #}
        <div class="rp-left-foot">
            <a href="{{ path('home') }}">Accueil</a>
            <div class="rp-left-foot-sep"></div>
            <a href="{{ path('login') }}">Connexion</a>
            <div class="rp-left-foot-sep"></div>
            <a href="#">Aide</a>
        </div>

    </aside>

    {# ════════════ RIGHT PANEL — Form ════════════ #}
    <main class="rp-right">
        <div class="rp-form-wrap">

            {# Form header #}
            <div class="rp-form-header">
                <div class="rp-form-tag">
                    <i class="fa-solid fa-key"></i>
                    Recuperation de compte
                </div>
                <div class="rp-form-title">Mot de passe oublie ?</div>
                <div class="rp-form-sub">
                    Suivez les etapes pour reinitialiser votre mot de passe en toute securite.
                </div>
            </div>

            {# Progress indicator #}
            <div class="rp-progress-wrap">
                <div class="rp-progress-labels">
                    <div class="rp-progress-label active" id="rp-lbl-1">
                        <div class="rp-progress-label-dot">1</div>
                        Email
                    </div>
                    <div class="rp-progress-label" id="rp-lbl-2">
                        <div class="rp-progress-label-dot">2</div>
                        OTP
                    </div>
                    <div class="rp-progress-label" id="rp-lbl-3">
                        <div class="rp-progress-label-dot">3</div>
                        Mot de passe
                    </div>
                </div>
                <div class="rp-progress-track">
                    <div class="rp-progress-fill" id="rp-progress-fill" style="width:16%;"></div>
                </div>
            </div>

            {# Flash messages #}
            <div id="rp-flashes" style="margin-bottom:16px; display:flex; flex-direction:column; gap:8px;">
                {% for type, messages in app.flashes(['success','error','warning','info']) %}
                    {% for message in messages %}
                        {% set flash_icons = {
                            success: 'fa-circle-check',
                            error:   'fa-circle-xmark',
                            warning: 'fa-triangle-exclamation',
                            info:    'fa-circle-info'
                        } %}
                        <div class="rp-flash rp-flash-{{ type }}">
                            <i class="fa-solid {{ flash_icons[type]|default('fa-info') }}"></i>
                            <span>{{ message }}</span>
                            <button onclick="this.closest('.rp-flash').remove()"
                                    style="margin-left:auto;background:none;border:none;
                                           cursor:pointer;color:inherit;font-size:13px;opacity:.6;"
                                    type="button">
                                <i class="fa-solid fa-xmark"></i>
                            </button>
                        </div>
                    {% endfor %}
                {% endfor %}
            </div>

            {# THE FORM #}
            <form method="post" class="rp-form" id="rp-form">

                {# ── STEP 1: Email ── #}
                <div id="rp-section-email">
                    <div class="rp-section-label" style="margin-bottom:10px;">
                        <i class="fa-solid fa-envelope"></i>
                        <span>Etape 1 — Votre email</span>
                        <div class="rp-section-line"></div>
                    </div>

                    <div class="rp-field">
                        <label class="rp-label">
                            <i class="fa-solid fa-envelope"></i>
                            Adresse email
                            <span style="color:#e53935;">*</span>
                        </label>
                        <div class="rp-input-wrap">
                            <i class="fa-solid fa-envelope rp-input-icon"></i>
                            <input class="rp-input" type="email" name="email"
                                   value="{{ reset_email|default('') }}"
                                   placeholder="votre@email.com"
                                   id="rp-email-input" required
                                   autocomplete="email">
                        </div>
                    </div>

                    <div class="rp-hint" style="margin-top:6px;">
                        <i class="fa-solid fa-circle-info"></i>
                        Entrez l'adresse email associee a votre compte Nexora. Nous vous enverrons un code OTP.
                    </div>

                    <div style="margin-top:14px;">
                        <button class="rp-btn rp-btn-primary" type="submit"
                                name="action" value="send_otp" id="rp-send-otp-btn">
                            <i class="fa-solid fa-paper-plane"></i>
                            Envoyer le code OTP
                        </button>
                    </div>
                </div>

                {# ── STEP 2: OTP ── #}
                <div id="rp-section-otp">
                    <div class="rp-section-label" style="margin-bottom:10px;">
                        <i class="fa-solid fa-key"></i>
                        <span>Etape 2 — Code OTP</span>
                        <div class="rp-section-line"></div>
                    </div>

                    <div class="rp-otp-group">
                        <div class="rp-field">
                            <label class="rp-label">
                                <i class="fa-solid fa-hashtag"></i>
                                Code de verification
                                <span style="
                                    margin-left:6px;
                                    padding:2px 8px;
                                    border-radius:999px;
                                    background:#fef9c3;
                                    color:#92400e;
                                    font-size:10px;
                                    font-weight:700;">
                                    valide 5 min
                                </span>
                            </label>
                            <div class="rp-otp-input-row">
                                <div class="rp-input-wrap">
                                    <i class="fa-solid fa-hashtag rp-input-icon"></i>
                                    <input class="rp-input rp-otp-input" type="text"
                                           name="otp" placeholder="000000"
                                           maxlength="6" inputmode="numeric"
                                           id="rp-otp-input" autocomplete="one-time-code">
                                </div>
                            </div>
                        </div>

                        {# OTP timer #}
                        <div class="rp-otp-timer" id="rp-otp-timer" style="display:none;">
                            <i class="fa-solid fa-clock"></i>
                            Expire dans : <span id="rp-timer-val">5:00</span>
                        </div>

                        <div class="rp-otp-actions">
                            <button class="rp-btn rp-btn-outline" type="submit"
                                    name="action" value="send_otp">
                                <i class="fa-solid fa-rotate"></i>
                                Renvoyer
                            </button>
                            <button class="rp-btn rp-btn-teal" type="submit"
                                    name="action" value="verify_otp" id="rp-verify-btn">
                                <i class="fa-solid fa-shield-halved"></i>
                                Verifier
                            </button>
                        </div>
                    </div>

                    <div class="rp-hint" style="margin-top:6px;">
                        <i class="fa-solid fa-triangle-exclamation"></i>
                        Ne partagez jamais votre code OTP. Nexora ne vous le demandera jamais.
                    </div>
                </div>

                {# ── STEP 3: New password ── #}
                <div id="rp-section-password">
                    <div class="rp-section-label" style="margin-bottom:10px;">
                        <i class="fa-solid fa-lock"></i>
                        <span>Etape 3 — Nouveau mot de passe</span>
                        <div class="rp-section-line"></div>
                    </div>

                    <div class="rp-field">
                        <label class="rp-label">
                            <i class="fa-solid fa-lock"></i>
                            Nouveau mot de passe
                        </label>
                        <div class="rp-input-wrap">
                            <i class="fa-solid fa-lock rp-input-icon"></i>
                            <input class="rp-input" type="password"
                                   name="new_password" id="rp-new-pw"
                                   placeholder="••••••••••••"
                                   autocomplete="new-password">
                            <button type="button" class="rp-eye-btn" data-rp-eye>
                                <i class="fa-solid fa-eye"></i>
                            </button>
                        </div>
                        <div class="rp-pw-strength">
                            <div class="rp-pw-bars">
                                <div class="rp-pw-bar" id="rp-bar-1"></div>
                                <div class="rp-pw-bar" id="rp-bar-2"></div>
                                <div class="rp-pw-bar" id="rp-bar-3"></div>
                                <div class="rp-pw-bar" id="rp-bar-4"></div>
                            </div>
                            <span class="rp-pw-label" id="rp-pw-label">—</span>
                        </div>
                    </div>

                    <div class="rp-field">
                        <label class="rp-label">
                            <i class="fa-solid fa-check-double"></i>
                            Confirmation du mot de passe
                        </label>
                        <div class="rp-input-wrap" id="rp-conf-wrap">
                            <i class="fa-solid fa-check rp-input-icon"></i>
                            <input class="rp-input" type="password"
                                   name="confirm_password" id="rp-conf-pw"
                                   placeholder="••••••••••••"
                                   autocomplete="new-password">
                            <button type="button" class="rp-eye-btn" data-rp-eye>
                                <i class="fa-solid fa-eye"></i>
                            </button>
                        </div>
                    </div>

                    <div class="rp-hint" style="margin-top:2px;">
                        <i class="fa-solid fa-circle-info"></i>
                        Minimum 8 caracteres · Majuscules · Chiffres · Caracteres speciaux recommandes
                    </div>

                    <div class="rp-form-actions">
                        <button class="rp-btn rp-btn-primary" type="submit"
                                name="action" value="reset_password" id="rp-reset-btn">
                            <i class="fa-solid fa-floppy-disk"></i>
                            Mettre a jour le mot de passe
                        </button>
                    </div>
                </div>

            </form>

            {# Divider #}
            <div class="rp-divider" style="margin: 20px 0;">OU</div>

            {# Navigation links #}
            <div class="rp-links">
                <a href="{{ path('login') }}">
                    <i class="fa-solid fa-arrow-left"></i>
                    Retour connexion
                </a>
                <a href="{{ path('home') }}">
                    <i class="fa-solid fa-house"></i>
                    Accueil
                </a>
            </div>

        </div>
    </main>

</div>

<script>
(function () {
    'use strict';

    /* ── helpers ── */
    const $ = id => document.getElementById(id);

    /* ══════════════════════════════════════════════════════
       STEP PROGRESS — detect which step based on flash/state
    ══════════════════════════════════════════════════════ */
    let currentStep = 1;

    /* Check if OTP was sent (flash or URL param) */
    const urlParams = new URLSearchParams(location.search);
    const otpSent   = urlParams.get('otp_sent')   === '1';
    const otpOk     = urlParams.get('otp_ok')     === '1';

    /* Check flash messages to determine step */
    const flashEls = document.querySelectorAll('.rp-flash');
    let otpSentFlash = false;
    let otpOkFlash   = false;

    flashEls.forEach(el => {
        const txt = el.textContent.toLowerCase();
        if (txt.includes('otp') && (txt.includes('envoye') || txt.includes('sent')))  otpSentFlash = true;
        if (txt.includes('otp') && (txt.includes('verif') || txt.includes('valid')))  otpOkFlash = true;
    });

    if (otpOk   || otpOkFlash)   currentStep = 3;
    else if (otpSent || otpSentFlash) currentStep = 2;

    function updateProgress(step) {
        const fill   = $('rp-progress-fill');
        const lbl1   = $('rp-lbl-1');
        const lbl2   = $('rp-lbl-2');
        const lbl3   = $('rp-lbl-3');
        const sLeft1 = $('rp-step-1');
        const sLeft2 = $('rp-step-2');
        const sLeft3 = $('rp-step-3');

        const pct = step === 1 ? 16 : step === 2 ? 50 : 100;
        if (fill) fill.style.width = pct + '%';

        [lbl1, lbl2, lbl3].forEach((el, i) => {
            if (!el) return;
            el.classList.remove('active', 'done');
            if (i + 1 < step)  el.classList.add('done');
            if (i + 1 === step) el.classList.add('active');
        });

        [sLeft1, sLeft2, sLeft3].forEach((el, i) => {
            if (!el) return;
            el.classList.remove('active', 'done');
            if (i + 1 < step)  el.classList.add('done');
            if (i + 1 === step) el.classList.add('active');
        });
    }

    updateProgress(currentStep);

    /* ══════════════════════════════════════════════════════
       OTP COUNTDOWN TIMER
    ══════════════════════════════════════════════════════ */
    function startOtpTimer(seconds) {
        const timerWrap = $('rp-otp-timer');
        const timerVal  = $('rp-timer-val');
        if (!timerWrap || !timerVal) return;

        timerWrap.style.display = 'flex';
        let remaining = seconds;

        const iv = setInterval(() => {
            remaining--;
            const m = Math.floor(remaining / 60);
            const s = remaining % 60;
            timerVal.textContent = `${m}:${String(s).padStart(2, '0')}`;
            if (remaining <= 30) timerVal.style.color = '#e53935';
            if (remaining <= 0) {
                clearInterval(iv);
                timerVal.textContent = 'Expire';
                timerVal.style.color = '#e53935';
            }
        }, 1000);
    }

    if (currentStep === 2) startOtpTimer(300);

    /* ══════════════════════════════════════════════════════
       OTP INPUT AUTO FORMAT
    ══════════════════════════════════════════════════════ */
    const otpInput = $('rp-otp-input');

    if (otpInput) {
        otpInput.addEventListener('input', () => {
            otpInput.value = otpInput.value.replace(/\D/g, '').slice(0, 6);
            if (otpInput.value.length === 6) {
                otpInput.classList.add('is-valid');
            } else {
                otpInput.classList.remove('is-valid');
            }
        });
    }

    /* ══════════════════════════════════════════════════════
       EMAIL VALIDATION — live
    ══════════════════════════════════════════════════════ */
    const emailInput = $('rp-email-input');

    if (emailInput) {
        emailInput.addEventListener('blur', () => {
            const valid = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailInput.value);
            emailInput.classList.toggle('is-valid',   valid && emailInput.value.length > 0);
            emailInput.classList.toggle('is-invalid', !valid && emailInput.value.length > 0);
        });
        emailInput.addEventListener('input', () => {
            emailInput.classList.remove('is-valid', 'is-invalid');
        });
    }

    /* ══════════════════════════════════════════════════════
       PASSWORD STRENGTH
    ══════════════════════════════════════════════════════ */
    const newPw   = $('rp-new-pw');
    const bars    = [1, 2, 3, 4].map(i => $('rp-bar-' + i));
    const pwLabel = $('rp-pw-label');
    const confPw  = $('rp-conf-pw');
    const confWrap= $('rp-conf-wrap');

    const levels = [
        { c: '#e8f0f8', l: '—'          },
        { c: '#e53935', l: 'Tres faible' },
        { c: '#f59e0b', l: 'Faible'      },
        { c: '#fbbf24', l: 'Moyen'       },
        { c: '#00bcd4', l: 'Fort'        },
        { c: '#22c55e', l: 'Tres fort'   }
    ];

    function scorePassword(v) {
        let s = 0;
        if (v.length >= 8)           s++;
        if (v.length >= 12)          s++;
        if (/[A-Z]/.test(v))         s++;
        if (/[0-9]/.test(v))         s++;
        if (/[^A-Za-z0-9]/.test(v))  s++;
        return s;
    }

    if (newPw) {
        newPw.addEventListener('input', () => {
            const sc     = newPw.value.length ? scorePassword(newPw.value) : 0;
            const lvl    = levels[Math.min(sc, 5)];
            const filled = Math.ceil(sc * 4 / 5);

            bars.forEach((bar, i) => {
                if (bar) bar.style.background = i < filled ? lvl.c : '';
            });

            if (pwLabel) {
                pwLabel.textContent = lvl.l;
                pwLabel.style.color = lvl.c;
            }
        });
    }

    if (confPw && confWrap) {
        confPw.addEventListener('input', () => {
            const match = confPw.value.length > 0 && confPw.value === (newPw ? newPw.value : '');
            const confInput = confWrap.querySelector('input');
            if (confInput) {
                confInput.classList.toggle('is-valid',   match);
                confInput.classList.toggle('is-invalid', !match && confPw.value.length > 0);
            }
        });
    }

    /* ══════════════════════════════════════════════════════
       EYE TOGGLE
    ══════════════════════════════════════════════════════ */
    document.querySelectorAll('[data-rp-eye]').forEach(btn => {
        btn.addEventListener('click', () => {
            const wrap = btn.closest('.rp-input-wrap');
            if (!wrap) return;
            const inp = wrap.querySelector('input');
            if (!inp) return;
            const show = inp.type === 'password';
            inp.type = show ? 'text' : 'password';
            const icon = btn.querySelector('i');
            if (icon) icon.className = show ? 'fa-solid fa-eye-slash' : 'fa-solid fa-eye';
        });
    });

    /* ══════════════════════════════════════════════════════
       BUTTON LOADING STATE on submit
    ══════════════════════════════════════════════════════ */
    const form = $('rp-form');
    if (form) {
        form.addEventListener('submit', function (e) {
            const clickedBtn = form.querySelector('[type="submit"]:focus') ||
                               form.querySelector('[type="submit"]');

            if (clickedBtn) {
                setTimeout(() => {
                    clickedBtn.disabled = true;
                    const icon = clickedBtn.querySelector('i');
                    if (icon) icon.className = 'fa-solid fa-spinner fa-spin';
                }, 0);
            }
        });
    }

    /* ══════════════════════════════════════════════════════
       FLASH AUTO-DISMISS
    ══════════════════════════════════════════════════════ */
    flashEls.forEach(el => {
        setTimeout(() => {
            el.style.transition = 'opacity .5s, max-height .5s, padding .5s, margin .5s';
            el.style.opacity    = '0';
            el.style.maxHeight  = '0';
            el.style.overflow   = 'hidden';
            el.style.padding    = '0';
            setTimeout(() => el.remove(), 520);
        }, 6000);
    });

})();
</script>

{% endblock %}