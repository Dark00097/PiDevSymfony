<!DOCTYPE html>
<html>
<head>
    <title>DEBUG - Test Formulaire</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 20px; }
        .form-group { margin: 10px 0; }
        label { display: block; font-weight: bold; }
        input, select { padding: 5px; margin: 5px 0; }
        button { padding: 10px 20px; background: #007bff; color: white; border: none; cursor: pointer; }
        .debug { background: #f8f9fa; padding: 10px; margin: 10px 0; border: 1px solid #ddd; }
    </style>
</head>
<body>
    <h1>🔧 DEBUG - Test Formulaire Transaction</h1>
    
    <div class="debug">
        <strong>URL de test:</strong> {{ app.request.uri }}<br>
        <strong>Méthode:</strong> {{ app.request.method }}<br>
        <strong>Route:</strong> {{ app.request.attributes.get('_route') }}
    </div>

    {% if app.request.method == 'POST' %}
        <div class="debug" style="background: #d4edda; border-color: #c3e6cb;">
            <h3>✅ DONNÉES POST REÇUES:</h3>
            {% for key, value in app.request.request.all %}
                <strong>{{ key }}:</strong> {{ value }}<br>
            {% endfor %}
        </div>
    {% endif %}

    <form method="post" action="{{ path('debug_form') }}">
        <div class="form-group">
            <label>Compte:</label>
            <select name="compte" required>
                <option value="">Sélectionner</option>
                <option value="107">Compte 107 (Test)</option>
                <option value="108">Compte 108 (Test)</option>
            </select>
        </div>
        
        <div class="form-group">
            <label>Date:</label>
            <input type="date" name="dateTransaction" value="{{ 'now'|date('Y-m-d') }}" required>
        </div>
        
        <div class="form-group">
            <label>Type:</label>
            <input type="radio" name="typeTransaction" value="DEPOT" checked> Dépôt
        </div>
        
        <div class="form-group">
            <label>Montant:</label>
            <input type="number" step="0.01" name="montant" value="100.00" required>
        </div>
        
        <div class="form-group">
            <label>Devise:</label>
            <select name="currency">
                <option value="TND" selected>TND</option>
            </select>
        </div>
        
        <div class="form-group">
            <input type="hidden" name="tab" value="transactions">
            <button type="submit" name="action" value="transaction_save">
                🚀 ENREGISTRER TEST
            </button>
        </div>
    </form>
    
    <script>
        document.querySelector('form').addEventListener('submit', function(e) {
            console.log('=== SOUMISSION FORMULAIRE DEBUG ===');
            console.log('Action:', this.action);
            console.log('Méthode:', this.method);
            
            const formData = new FormData(this);
            console.log('Données:');
            for (let [key, value] of formData.entries()) {
                console.log(key + ':', value);
            }
            console.log('=== FIN DEBUG ===');
        });
    </script>
</body>
</html>