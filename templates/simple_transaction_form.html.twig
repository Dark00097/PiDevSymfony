<!DOCTYPE html>
<html>
<head>
    <title>🔧 Transaction Simple - SANS JavaScript</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 20px; background: #f5f5f5; }
        .container { max-width: 600px; margin: 0 auto; background: white; padding: 20px; border-radius: 8px; }
        .form-group { margin: 15px 0; }
        label { display: block; font-weight: bold; margin-bottom: 5px; }
        input, select { padding: 10px; width: 100%; border: 1px solid #ddd; border-radius: 4px; font-size: 16px; }
        button { padding: 15px 30px; background: #28a745; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 16px; font-weight: bold; }
        .result { padding: 15px; margin: 20px 0; border-radius: 4px; font-weight: bold; }
        .success { background: #d4edda; color: #155724; border: 1px solid #c3e6cb; }
        .error { background: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; }
    </style>
</head>
<body>
    <div class="container">
        <h1>🔧 Transaction Simple - SANS JavaScript</h1>
        
        {% if result %}
            <div class="result success">{{ result }}</div>
        {% endif %}

        {% if error %}
            <div class="result error">{{ error }}</div>
        {% endif %}

        <form method="post" action="{{ path('simple_transaction_test') }}">
            <input type="hidden" name="tab" value="transactions">
            <input type="hidden" name="action" value="transaction_save">
            
            <div class="form-group">
                <label>🏦 Compte:</label>
                <select name="compte" required>
                    <option value="">-- Sélectionner --</option>
                    {% for account in accounts %}
                        <option value="{{ account.idCompte }}">
                            {{ account.numeroCompte }} - {{ account.solde }} DT
                        </option>
                    {% endfor %}
                </select>
            </div>
            
            <div class="form-group">
                <label>📅 Date:</label>
                <input type="date" name="dateTransaction" value="{{ 'now'|date('Y-m-d') }}" required>
            </div>
            
            <div class="form-group">
                <label>🔄 Type:</label>
                <select name="typeTransaction" required>
                    <option value="DEPOT" selected>Dépôt</option>
                    <option value="RETRAIT">Retrait</option>
                    <option value="VIREMENT">Virement</option>
                    <option value="PAIEMENT">Paiement</option>
                </select>
            </div>
            
            <div class="form-group">
                <label>💰 Montant (DT):</label>
                <input type="number" step="0.01" name="montant" value="100.00" required>
            </div>
            
            <div class="form-group">
                <label>💱 Devise:</label>
                <select name="currency">
                    <option value="TND" selected>TND - Dinar Tunisien</option>
                    <option value="EUR">EUR - Euro</option>
                    <option value="USD">USD - Dollar</option>
                </select>
            </div>
            
            <div class="form-group">
                <label>📝 Description:</label>
                <input type="text" name="description" value="Test transaction simple">
            </div>
            
            <div class="form-group">
                <button type="submit">🚀 ENREGISTRER TRANSACTION</button>
            </div>
        </form>
    </div>
</body>
</html>