{% extends 'base.html.twig' %}

{% block title %}Nexora Dashboard{% endblock %}
{% block body_class %}dashboard-body{% endblock %}

{% block body %}
    <div class="dashboard-shell">
        <aside class="sidebar">
            <div class="sidebar-brand">
                <img src="{{ asset('images/logo.png') }}" alt="Nexora logo">
                <div>
                    <span>NEXORA</span>
                    <small>{{ mode == 'admin' ? 'Admin Banking System' : 'Client Banking System' }}</small>
                </div>
            </div>

            <nav class="sidebar-nav">
                {% for item in tabs %}
                    <a class="sidebar-link {{ item.key == tab ? 'is-active' : '' }}"
                       href="{{ path(route_name, { tab: item.key }) }}">
                        {{ item.label }}
                    </a>
                {% endfor %}
            </nav>

            <div class="sidebar-footer">
                <div class="sidebar-user">
                    <strong>{{ current_user.prenom }} {{ current_user.nom }}</strong>
                    <span>{{ current_user.role }}</span>
                </div>
                <a class="btn btn-secondary btn-full" href="{{ path('logout') }}">Deconnexion</a>
            </div>
        </aside>

        <main class="dashboard-main">
            <header class="topbar">
                <div>
                    <p class="eyebrow">{{ mode == 'admin' ? 'Back Office' : 'Client Portal' }}</p>
                    <h1>{{ tab|replace({'_': ' '})|title }}</h1>
                </div>
                <div class="topbar-meta">
                    <span class="notif-pill">{{ notifications_count }} notifications</span>
                    <span class="topbar-role">{{ current_user.email }}</span>
                </div>
            </header>

            {% include '_flashes.html.twig' %}

            <section class="summary-grid">
                {% if mode == 'admin' %}
                    <article class="summary-card"><strong>{{ summary.users_total }}</strong><span>Utilisateurs</span></article>
                    <article class="summary-card"><strong>{{ summary.users_pending }}</strong><span>En attente</span></article>
                    <article class="summary-card"><strong>{{ summary.accounts_total }}</strong><span>Comptes</span></article>
                    <article class="summary-card"><strong>{{ summary.transactions_total }}</strong><span>Transactions</span></article>
                    <article class="summary-card"><strong>{{ summary.credits_total }}</strong><span>Credits</span></article>
                    <article class="summary-card"><strong>{{ summary.cashback_total|number_format(2, '.', ' ') }}</strong><span>Cashback</span></article>
                {% else %}
                    <article class="summary-card"><strong>{{ summary.accounts_total }}</strong><span>Mes comptes</span></article>
                    <article class="summary-card"><strong>{{ summary.transactions_total }}</strong><span>Mes transactions</span></article>
                    <article class="summary-card"><strong>{{ summary.credits_total }}</strong><span>Mes credits</span></article>
                    <article class="summary-card"><strong>{{ summary.cashback_pending|number_format(2, '.', ' ') }}</strong><span>Cashback attente</span></article>
                    <article class="summary-card"><strong>{{ summary.cashback_credited|number_format(2, '.', ' ') }}</strong><span>Cashback credite</span></article>
                {% endif %}
            </section>

            {% if tab in ['dashboard', 'overview'] %}
                <section class="panel-grid">
                    <article class="panel-card">
                        <h2>Transactions recentes</h2>
                        <div class="table-wrap">
                            <table class="data-table">
                                <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Utilisateur</th>
                                    <th>Categorie</th>
                                    <th>Montant</th>
                                    <th>Statut</th>
                                </tr>
                                </thead>
                                <tbody>
                                {% for item in summary.recent_transactions %}
                                    <tr>
                                        <td>{{ item.idTransaction }}</td>
                                        <td>{{ item.user_name|default('-') }}</td>
                                        <td>{{ item.categorie }}</td>
                                        <td>{{ item.montant_value|number_format(2, '.', ' ') }}</td>
                                        <td>{{ item.typeTransaction|default('-') }}</td>
                                    </tr>
                                {% else %}
                                    <tr><td colspan="5">No recent data.</td></tr>
                                {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </article>

                    <article class="panel-card">
                        <h2>Notifications</h2>
                        <div class="notification-list">
                            {% for item in notifications %}
                                <div class="notification-item">
                                    <strong>{{ item.title }}</strong>
                                    <p>{{ item.message }}</p>
                                    <small>{{ item.created_at }}</small>
                                </div>
                            {% else %}
                                <p>No notifications.</p>
                            {% endfor %}
                        </div>
                    </article>
                </section>

                {% if feature_links is defined and feature_links is not empty %}
                    <section class="panel-card">
                        <div class="panel-header">
                            <h2>{{ mode == 'admin' ? 'Advanced Admin Features' : 'Advanced Portal Features' }}</h2>
                            <span class="topbar-role">Symfony parity modules</span>
                        </div>
                        <div class="actions quick-actions">
                            {% for item in feature_links %}
                                <a class="btn btn-secondary" href="{{ item.href }}">{{ item.label }}</a>
                            {% endfor %}
                        </div>
                    </section>
                {% endif %}
            {% endif %}

            {% if tab == 'users' %}
                <section class="panel-card">
                    <h2>Gestion Utilisateurs</h2>
                    <form method="post" class="editor-form">
                        <input type="hidden" name="tab" value="users">
                        <input type="hidden" name="action" value="user_save">
                        <label><span>ID pour modifier</span><input type="number" name="idUser"></label>
                        <label><span>Nom</span><input type="text" name="nom" required></label>
                        <label><span>Prenom</span><input type="text" name="prenom" required></label>
                        <label><span>Email</span><input type="email" name="email" required></label>
                        <label><span>Telephone</span><input type="text" name="telephone" required></label>
                        <label><span>Role</span><input type="text" name="role" value="ROLE_USER"></label>
                        <label><span>Status</span><input type="text" name="status" value="PENDING"></label>
                        <label><span>Nouveau mot de passe</span><input type="text" name="password"></label>
                        <button class="btn btn-primary" type="submit">Create / Update</button>
                    </form>

                    <div class="table-wrap">
                        <table class="data-table">
                            <thead><tr><th>ID</th><th>Nom</th><th>Email</th><th>Role</th><th>Status</th><th>Actions</th></tr></thead>
                            <tbody>
                            {% for item in items %}
                                <tr>
                                    <td>{{ item.idUser }}</td>
                                    <td>{{ item.prenom }} {{ item.nom }}</td>
                                    <td>{{ item.email }}</td>
                                    <td>{{ item.role }}</td>
                                    <td>{{ item.status }}</td>
                                    <td class="actions">
                                        <form method="post">
                                            <input type="hidden" name="tab" value="users">
                                            <input type="hidden" name="action" value="user_status">
                                            <input type="hidden" name="idUser" value="{{ item.idUser }}">
                                            <select name="status">
                                                {% for status in ['PENDING', 'ACTIVE', 'DECLINED', 'INACTIVE', 'BANNED'] %}
                                                    <option value="{{ status }}" {{ item.status == status ? 'selected' : '' }}>{{ status }}</option>
                                                {% endfor %}
                                            </select>
                                            <button class="btn btn-secondary" type="submit">Status</button>
                                        </form>
                                        <form method="post">
                                            <input type="hidden" name="tab" value="users">
                                            <input type="hidden" name="action" value="user_delete">
                                            <input type="hidden" name="idUser" value="{{ item.idUser }}">
                                            <button class="btn btn-danger" type="submit">Delete</button>
                                        </form>
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </section>
            {% endif %}

            {% if tab == 'accounts' %}
                <section class="panel-card">
                    <h2>Comptes Bancaires</h2>
                    <form method="post" class="editor-form">
                        <input type="hidden" name="tab" value="accounts">
                        <input type="hidden" name="action" value="account_save">
                        <label><span>ID pour modifier</span><input type="number" name="idCompte"></label>
                        {% if mode == 'admin' %}
                            <label><span>Utilisateur</span>
                                <select name="idUser">
                                    <option value="">Sans proprietaire</option>
                                    {% for u in support.users|default([]) %}
                                        <option value="{{ u.idUser }}">{{ u.idUser }} - {{ u.prenom }} {{ u.nom }}</option>
                                    {% endfor %}
                                </select>
                            </label>
                        {% endif %}
                        <label><span>Numero</span><input type="text" name="numeroCompte" required></label>
                        <label><span>Solde</span><input type="number" step="0.01" name="solde" required></label>
                        <label><span>Date</span><input type="date" name="dateOuverture" value="{{ 'now'|date('Y-m-d') }}"></label>
                        <label><span>Statut</span><input type="text" name="statutCompte" value="Actif"></label>
                        <label><span>Plafond retrait</span><input type="number" step="0.01" name="plafondRetrait"></label>
                        <label><span>Plafond virement</span><input type="number" step="0.01" name="plafondVirement"></label>
                        <label><span>Type</span><input type="text" name="typeCompte" value="Courant"></label>
                        <button class="btn btn-primary" type="submit">Create / Update</button>
                    </form>

                    <div class="table-wrap">
                        <table class="data-table">
                            <thead><tr><th>ID</th><th>Numero</th><th>Solde</th><th>Type</th><th>Owner</th><th>Delete</th></tr></thead>
                            <tbody>
                            {% for item in items %}
                                <tr>
                                    <td>{{ item.idCompte }}</td>
                                    <td>{{ item.numeroCompte }}</td>
                                    <td>{{ item.solde }}</td>
                                    <td>{{ item.typeCompte }}</td>
                                    <td>{{ item.owner_name|default('-') }}</td>
                                    <td>
                                        <form method="post">
                                            <input type="hidden" name="tab" value="accounts">
                                            <input type="hidden" name="action" value="account_delete">
                                            <input type="hidden" name="idCompte" value="{{ item.idCompte }}">
                                            <button class="btn btn-danger" type="submit">Delete</button>
                                        </form>
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </section>
            {% endif %}

            {% if tab == 'transactions' %}
                <section class="panel-card">
                    <h2>Transactions</h2>
                    <form method="post" class="editor-form">
                        <input type="hidden" name="tab" value="transactions">
                        <input type="hidden" name="action" value="transaction_save">
                        <label><span>ID pour modifier</span><input type="number" name="idTransaction"></label>
                        {% if mode == 'admin' %}
                            <label><span>Utilisateur</span>
                                <select name="idUser">
                                    {% for u in support.users|default([]) %}
                                        <option value="{{ u.idUser }}">{{ u.idUser }} - {{ u.prenom }} {{ u.nom }}</option>
                                    {% endfor %}
                                </select>
                            </label>
                        {% endif %}
                        <label><span>Compte</span>
                            <select name="idCompte">
                                <option value="">Sans compte</option>
                                {% for account in support.accounts|default([]) %}
                                    <option value="{{ account.idCompte }}">{{ account.idCompte }} - {{ account.numeroCompte }}</option>
                                {% endfor %}
                            </select>
                        </label>
                        <label><span>Categorie</span><input type="text" name="categorie" required></label>
                        <label><span>Date</span><input type="date" name="dateTransaction" value="{{ 'now'|date('Y-m-d') }}"></label>
                        <label><span>Montant</span><input type="number" step="0.01" name="montant" required></label>
                        <label><span>Type</span><input type="text" name="typeTransaction" value="DEPOT"></label>
                        <label><span>Description</span><input type="text" name="description"></label>
                        <button class="btn btn-primary" type="submit">Create / Update</button>
                    </form>

                    <div class="table-wrap">
                        <table class="data-table">
                            <thead><tr><th>ID</th><th>User</th><th>Categorie</th><th>Montant</th><th>Anomalie</th><th>Delete</th></tr></thead>
                            <tbody>
                            {% for item in items %}
                                <tr>
                                    <td>{{ item.idTransaction }}</td>
                                    <td>{{ item.user_name|default('-') }}</td>
                                    <td>{{ item.categorie }}</td>
                                    <td>{{ item.montant_value|number_format(2, '.', ' ') }}</td>
                                    <td>{{ item.is_anomalie ? 'Oui' : 'Non' }}</td>
                                    <td>
                                        <form method="post">
                                            <input type="hidden" name="tab" value="transactions">
                                            <input type="hidden" name="action" value="transaction_delete">
                                            <input type="hidden" name="idTransaction" value="{{ item.idTransaction }}">
                                            <button class="btn btn-danger" type="submit">Delete</button>
                                        </form>
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </section>
            {% endif %}

            {% if tab == 'credits' %}
                <section class="panel-card">
                    <h2>Credits</h2>
                    <form method="post" class="editor-form">
                        <input type="hidden" name="tab" value="credits">
                        <input type="hidden" name="action" value="credit_save">
                        <label><span>ID pour modifier</span><input type="number" name="idCredit"></label>
                        {% if mode == 'admin' %}
                            <label><span>Utilisateur</span>
                                <select name="idUser">
                                    {% for u in support.users|default([]) %}
                                        <option value="{{ u.idUser }}">{{ u.idUser }} - {{ u.prenom }} {{ u.nom }}</option>
                                    {% endfor %}
                                </select>
                            </label>
                        {% endif %}
                        <label><span>Compte</span>
                            <select name="idCompte">
                                {% for account in support.accounts|default([]) %}
                                    <option value="{{ account.idCompte }}">{{ account.idCompte }} - {{ account.numeroCompte }}</option>
                                {% endfor %}
                            </select>
                        </label>
                        <label><span>Type</span><input type="text" name="typeCredit" required></label>
                        <label><span>Montant</span><input type="number" step="0.01" name="montantDemande" required></label>
                        <label><span>Duree</span><input type="number" name="duree" required></label>
                        <label><span>Taux</span><input type="number" step="0.01" name="tauxInteret" required></label>
                        <label><span>Salaire</span><input type="number" step="0.01" name="salaire"></label>
                        <label><span>Contrat</span><input type="text" name="typeContrat"></label>
                        <label><span>Anciennete</span><input type="number" name="ancienneteAnnees"></label>
                        <button class="btn btn-primary" type="submit">Create / Update</button>
                    </form>

                    <div class="table-wrap">
                        <table class="data-table">
                            <thead><tr><th>ID</th><th>User</th><th>Type</th><th>Montant</th><th>Mensualite</th><th>Risk</th><th>Delete</th></tr></thead>
                            <tbody>
                            {% for item in items %}
                                <tr>
                                    <td>{{ item.idCredit }}</td>
                                    <td>{{ item.user_name|default('-') }}</td>
                                    <td>{{ item.typeCredit }}</td>
                                    <td>{{ item.montantDemande }}</td>
                                    <td>{{ item.mensualite }}</td>
                                    <td>{{ item.risk_score }}</td>
                                    <td>
                                        <form method="post">
                                            <input type="hidden" name="tab" value="credits">
                                            <input type="hidden" name="action" value="credit_delete">
                                            <input type="hidden" name="idCredit" value="{{ item.idCredit }}">
                                            <button class="btn btn-danger" type="submit">Delete</button>
                                        </form>
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </section>
            {% endif %}

            {% if tab == 'garanties' %}
                <section class="panel-card">
                    <h2>Garanties</h2>
                    <form method="post" class="editor-form">
                        <input type="hidden" name="tab" value="garanties">
                        <input type="hidden" name="action" value="garantie_save">
                        <label><span>ID pour modifier</span><input type="number" name="idGarantie"></label>
                        <label><span>Credit</span>
                            <select name="idCredit">
                                {% for credit in support.credits|default([]) %}
                                    <option value="{{ credit.idCredit }}">{{ credit.idCredit }} - {{ credit.typeCredit }}</option>
                                {% endfor %}
                            </select>
                        </label>
                        <label><span>Type</span><input type="text" name="typeGarantie" required></label>
                        <label><span>Description</span><input type="text" name="description"></label>
                        <label><span>Valeur estimee</span><input type="number" step="0.01" name="valeurEstimee" required></label>
                        <label><span>Valeur retenue</span><input type="number" step="0.01" name="valeurRetenue"></label>
                        <label><span>Nom garant</span><input type="text" name="nomGarant"></label>
                        <button class="btn btn-primary" type="submit">Create / Update</button>
                    </form>

                    <div class="table-wrap">
                        <table class="data-table">
                            <thead><tr><th>ID</th><th>Credit</th><th>Type</th><th>Valeur</th><th>Delete</th></tr></thead>
                            <tbody>
                            {% for item in items %}
                                <tr>
                                    <td>{{ item.idGarantie }}</td>
                                    <td>{{ item.idCredit }}</td>
                                    <td>{{ item.typeGarantie }}</td>
                                    <td>{{ item.valeurRetenue }}</td>
                                    <td>
                                        <form method="post">
                                            <input type="hidden" name="tab" value="garanties">
                                            <input type="hidden" name="action" value="garantie_delete">
                                            <input type="hidden" name="idGarantie" value="{{ item.idGarantie }}">
                                            <button class="btn btn-danger" type="submit">Delete</button>
                                        </form>
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </section>
            {% endif %}

            {% if tab == 'cashback' %}
                <section class="panel-card">
                    <h2>Cashback</h2>
                    <form method="post" class="editor-form">
                        <input type="hidden" name="tab" value="cashback">
                        <input type="hidden" name="action" value="cashback_save">
                        <label><span>ID pour modifier</span><input type="number" name="id_cashback"></label>
                        {% if mode == 'admin' %}
                            <label><span>Utilisateur</span>
                                <select name="id_user">
                                    {% for u in support.users|default([]) %}
                                        <option value="{{ u.idUser }}">{{ u.idUser }} - {{ u.prenom }} {{ u.nom }}</option>
                                    {% endfor %}
                                </select>
                            </label>
                        {% endif %}
                        <label><span>Partenaire</span>
                            <select name="id_partenaire">
                                <option value="">Libre</option>
                                {% for partner in support.partners|default([]) %}
                                    <option value="{{ partner.idPartenaire }}">{{ partner.nom }}</option>
                                {% endfor %}
                            </select>
                        </label>
                        <label><span>Nom partenaire</span><input type="text" name="partenaire_nom" required></label>
                        <label><span>Montant achat</span><input type="number" step="0.01" name="montant_achat" required></label>
                        <label><span>Date achat</span><input type="date" name="date_achat" value="{{ 'now'|date('Y-m-d') }}"></label>
                        <label><span>Statut</span><input type="text" name="statut" value="En attente"></label>
                        <button class="btn btn-primary" type="submit">Create / Update</button>
                    </form>

                    <div class="table-wrap">
                        <table class="data-table">
                            <thead><tr><th>ID</th><th>Partenaire</th><th>Montant</th><th>Cashback</th><th>Delete</th>{% if mode == 'admin' %}<th>Reward</th>{% else %}<th>Rate</th>{% endif %}</tr></thead>
                            <tbody>
                            {% for item in items %}
                                <tr>
                                    <td>{{ item.id_cashback }}</td>
                                    <td>{{ item.partenaire_nom }}</td>
                                    <td>{{ item.montant_achat }}</td>
                                    <td>{{ item.montant_cashback }}</td>
                                    <td>
                                        <form method="post">
                                            <input type="hidden" name="tab" value="cashback">
                                            <input type="hidden" name="action" value="cashback_delete">
                                            <input type="hidden" name="id_cashback" value="{{ item.id_cashback }}">
                                            <button class="btn btn-danger" type="submit">Delete</button>
                                        </form>
                                    </td>
                                    {% if mode == 'admin' %}
                                        <td>
                                            <form method="post" class="mini-form">
                                                <input type="hidden" name="tab" value="cashback">
                                                <input type="hidden" name="action" value="cashback_reward">
                                                <input type="hidden" name="id_cashback" value="{{ item.id_cashback }}">
                                                <input type="number" step="0.01" name="bonus_amount" placeholder="Bonus">
                                                <input type="text" name="bonus_note" placeholder="Note">
                                                <button class="btn btn-secondary" type="submit">Reward</button>
                                            </form>
                                        </td>
                                    {% else %}
                                        <td>
                                            <form method="post" class="mini-form">
                                                <input type="hidden" name="tab" value="cashback">
                                                <input type="hidden" name="action" value="cashback_rating">
                                                <input type="hidden" name="id_cashback" value="{{ item.id_cashback }}">
                                                <input type="number" step="0.1" max="5" min="0" name="user_rating" placeholder="Note">
                                                <input type="text" name="user_rating_comment" placeholder="Comment">
                                                <button class="btn btn-secondary" type="submit">Rate</button>
                                            </form>
                                        </td>
                                    {% endif %}
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </section>
            {% endif %}

            {% if tab == 'partners' %}
                <section class="panel-card">
                    <h2>Partenaires</h2>
                    <form method="post" class="editor-form">
                        <input type="hidden" name="tab" value="partners">
                        <input type="hidden" name="action" value="partner_save">
                        <label><span>ID pour modifier</span><input type="number" name="idPartenaire"></label>
                        <label><span>Nom</span><input type="text" name="nom" required></label>
                        <label><span>Categorie</span><input type="text" name="categorie" required></label>
                        <label><span>Description</span><input type="text" name="description"></label>
                        <label><span>Ville</span><input type="text" name="ville"></label>
                        <label><span>Taux</span><input type="number" step="0.01" name="tauxCashback"></label>
                        <label><span>Taux max</span><input type="number" step="0.01" name="tauxCashbackMax"></label>
                        <label><span>Plafond</span><input type="number" step="0.01" name="plafondMensuel"></label>
                        <label><span>Status</span><input type="text" name="status" value="Actif"></label>
                        <label><span>Rating</span><input type="number" step="0.1" min="0" max="5" name="rating" value="4"></label>
                        <button class="btn btn-primary" type="submit">Create / Update</button>
                    </form>

                    <div class="table-wrap">
                        <table class="data-table">
                            <thead><tr><th>ID</th><th>Nom</th><th>Categorie</th><th>Ville</th><th>Rating</th><th>Delete</th></tr></thead>
                            <tbody>
                            {% for item in items %}
                                <tr>
                                    <td>{{ item.idPartenaire }}</td>
                                    <td>{{ item.nom }}</td>
                                    <td>{{ item.categorie }}</td>
                                    <td>{{ item.ville|default('-') }}</td>
                                    <td>{{ item.rating }}</td>
                                    <td>
                                        <form method="post">
                                            <input type="hidden" name="tab" value="partners">
                                            <input type="hidden" name="action" value="partner_delete">
                                            <input type="hidden" name="idPartenaire" value="{{ item.idPartenaire }}">
                                            <button class="btn btn-danger" type="submit">Delete</button>
                                        </form>
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </section>
            {% endif %}

            {% if tab == 'complaints' %}
                <section class="panel-card">
                    <h2>Reclamations</h2>
                    <form method="post" class="editor-form">
                        <input type="hidden" name="tab" value="complaints">
                        <input type="hidden" name="action" value="reclamation_save">
                        <label><span>ID pour modifier</span><input type="number" name="idReclamation"></label>
                        {% if mode == 'admin' %}
                            <label><span>Utilisateur</span>
                                <select name="idUser">
                                    {% for u in support.users|default([]) %}
                                        <option value="{{ u.idUser }}">{{ u.idUser }} - {{ u.prenom }} {{ u.nom }}</option>
                                    {% endfor %}
                                </select>
                            </label>
                        {% endif %}
                        <label><span>Transaction</span>
                            <select name="idTransaction">
                                <option value="">Sans transaction</option>
                                {% for transaction in support.transactions|default([]) %}
                                    <option value="{{ transaction.idTransaction }}">{{ transaction.idTransaction }} - {{ transaction.categorie }}</option>
                                {% endfor %}
                            </select>
                        </label>
                        <label><span>Date</span><input type="date" name="dateReclamation" value="{{ 'now'|date('Y-m-d') }}"></label>
                        <label><span>Type</span><input type="text" name="typeReclamation" required></label>
                        <label class="wide"><span>Description</span><input type="text" name="description" required></label>
                        <label><span>Status</span><input type="text" name="status" value="En attente"></label>
                        <button class="btn btn-primary" type="submit">Create / Update</button>
                    </form>

                    <div class="table-wrap">
                        <table class="data-table">
                            <thead><tr><th>ID</th><th>User</th><th>Type</th><th>Status</th><th>Blur</th><th>Delete</th></tr></thead>
                            <tbody>
                            {% for item in items %}
                                <tr>
                                    <td>{{ item.idReclamation }}</td>
                                    <td>{{ item.user_name|default('-') }}</td>
                                    <td>{{ item.typeReclamation }}</td>
                                    <td>{{ item.status }}</td>
                                    <td>
                                        {% if mode == 'admin' %}
                                            <form method="post">
                                                <input type="hidden" name="tab" value="complaints">
                                                <input type="hidden" name="action" value="reclamation_blur">
                                                <input type="hidden" name="idReclamation" value="{{ item.idReclamation }}">
                                                <input type="hidden" name="is_blurred" value="{{ item.is_blurred ? '0' : '1' }}">
                                                <button class="btn btn-secondary" type="submit">{{ item.is_blurred ? 'Unblur' : 'Blur' }}</button>
                                            </form>
                                        {% else %}
                                            {{ item.is_blurred ? 'Blurred' : 'Visible' }}
                                        {% endif %}
                                    </td>
                                    <td>
                                        <form method="post">
                                            <input type="hidden" name="tab" value="complaints">
                                            <input type="hidden" name="action" value="reclamation_delete">
                                            <input type="hidden" name="idReclamation" value="{{ item.idReclamation }}">
                                            <button class="btn btn-danger" type="submit">Delete</button>
                                        </form>
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </section>
            {% endif %}

            {% if tab == 'vaults' %}
                <section class="panel-card">
                    <h2>Coffres Virtuels</h2>
                    <form method="post" class="editor-form">
                        <input type="hidden" name="tab" value="vaults">
                        <input type="hidden" name="action" value="vault_save">
                        <label><span>ID pour modifier</span><input type="number" name="idCoffre"></label>
                        {% if mode == 'admin' %}
                            <label><span>Utilisateur</span>
                                <select name="idUser">
                                    <option value="">Sans utilisateur</option>
                                    {% for u in support.users|default([]) %}
                                        <option value="{{ u.idUser }}">{{ u.idUser }} - {{ u.prenom }} {{ u.nom }}</option>
                                    {% endfor %}
                                </select>
                            </label>
                        {% endif %}
                        <label><span>Compte</span>
                            <select name="idCompte">
                                <option value="">Sans compte</option>
                                {% for account in support.accounts|default([]) %}
                                    <option value="{{ account.idCompte }}">{{ account.idCompte }} - {{ account.numeroCompte }}</option>
                                {% endfor %}
                            </select>
                        </label>
                        <label><span>Nom</span><input type="text" name="nom" required></label>
                        <label><span>Objectif</span><input type="number" step="0.01" name="objectifMontant" required></label>
                        <label><span>Montant actuel</span><input type="number" step="0.01" name="montantActuel"></label>
                        <label><span>Status</span><input type="text" name="status" value="Actif"></label>
                        <button class="btn btn-primary" type="submit">Create / Update</button>
                    </form>

                    <div class="table-wrap">
                        <table class="data-table">
                            <thead><tr><th>ID</th><th>Nom</th><th>Objectif</th><th>Actuel</th><th>Delete</th></tr></thead>
                            <tbody>
                            {% for item in items %}
                                <tr>
                                    <td>{{ item.idCoffre }}</td>
                                    <td>{{ item.nom }}</td>
                                    <td>{{ item.objectifMontant }}</td>
                                    <td>{{ item.montantActuel }}</td>
                                    <td>
                                        <form method="post">
                                            <input type="hidden" name="tab" value="vaults">
                                            <input type="hidden" name="action" value="vault_delete">
                                            <input type="hidden" name="idCoffre" value="{{ item.idCoffre }}">
                                            <button class="btn btn-danger" type="submit">Delete</button>
                                        </form>
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </section>
            {% endif %}

            {% if tab == 'profile' %}
                <section class="panel-card">
                    <h2>Mon Profil</h2>
                    <form method="post" class="editor-form">
                        <input type="hidden" name="tab" value="profile">
                        <input type="hidden" name="action" value="profile_save">
                        <label><span>Nom</span><input type="text" name="nom" value="{{ current_user.nom }}" required></label>
                        <label><span>Prenom</span><input type="text" name="prenom" value="{{ current_user.prenom }}" required></label>
                        <label><span>Telephone</span><input type="text" name="telephone" value="{{ current_user.telephone }}"></label>
                        <label><span>Chemin image profil</span><input type="text" name="profile_image_path" value="{{ current_user.profile_image_path }}"></label>
                        <label><span>Biometrie</span>
                            <select name="biometric_enabled">
                                <option value="0" {{ not current_user.biometric_enabled ? 'selected' : '' }}>Disabled</option>
                                <option value="1" {{ current_user.biometric_enabled ? 'selected' : '' }}>Enabled</option>
                            </select>
                        </label>
                        <button class="btn btn-primary" type="submit">Mettre a jour</button>
                    </form>
                </section>
            {% endif %}

            {% if tab == 'notifications' %}
                <section class="panel-card">
                    <div class="panel-header">
                        <h2>Notifications</h2>
                        <form method="post">
                            <input type="hidden" name="tab" value="notifications">
                            <input type="hidden" name="action" value="notifications_read">
                            <button class="btn btn-secondary" type="submit">Mark all as read</button>
                        </form>
                    </div>

                    <div class="notification-list">
                        {% for item in items %}
                            <div class="notification-item">
                                <strong>{{ item.title }}</strong>
                                <p>{{ item.message }}</p>
                                <small>{{ item.created_at }}</small>
                            </div>
                        {% else %}
                            <p>No notifications.</p>
                        {% endfor %}
                    </div>
                </section>
            {% endif %}
        </main>
    </div>
{% endblock %}
