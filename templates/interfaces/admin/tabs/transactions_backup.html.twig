/* ── Reclamation table enhancements ── */
.nx-rec__table thead th{background:linear-gradient(to bottom,#f5f8fd,#eef3fb);color:#4a6080}
.nx-rec__table tbody tr:hover td{background:rgba(232,162,2,.04)}
