.nx-tx__act-btn{width:30px;height:30px;border-radius:8px;border:none;display:grid;place-items:center;cursor:pointer;font-size:.8rem;transition:all .18s ease;text-decoration:none}.nx-tx__act-btn.edit{background:#e8f5e9;color:#2e7d32;border:1px solid #a5d6a7}.nx-tx__act-btn.del{background:#ffebee;color:#c62828;border:1px solid #ef9a9a}.nx-tx__act-btn.view{background:#fff8e1;color:#e65100;border:1px solid #ffcc80}
