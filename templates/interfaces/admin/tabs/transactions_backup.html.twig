.nx-tx__form{display:flex;flex-direction:column;gap:.7rem;padding:1rem 1.15rem 1.15rem}.nx-tx__form label{display:flex;flex-direction:column;gap:.3rem;font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.45px;color:var(--na-muted)}.nx-tx__form input[type="text"],.nx-tx__form input[type="number"],.nx-tx__form input[type="date"],.nx-tx__form select,.nx-tx__form textarea{width:100%;box-sizing:border-box;border:1px solid var(--na-border);border-radius:9px;font-size:.82rem;color:var(--na-txt);background:var(--na-bg);outline:none;font-family:inherit}.nx-tx__form input[type="text"],.nx-tx__form input[type="number"],.nx-tx__form input[type="date"],.nx-tx__form select{height:38px;padding:0 .8rem}.nx-tx__form textarea{padding:.7rem .8rem;min-height:88px;resize:vertical}.nx-tx__form input:focus,.nx-tx__form select:focus,.nx-tx__form textarea:focus,.nx-tx__search-input:focus,.nx-tx__sort-select:focus{border-color:var(--na-teal);box-shadow:0 0 0 3px rgba(17,183,170,.12);background:#fff}
