  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && modal.style.display === 'flex') {
      modal.style.display = 'none';
      document.body.style.overflow = '';
    }
  });

  function runAnalyse() {
    console.log('[AI Analysis] Starting analysis...');
    var loading = document.getElementById('analyse-loading');
    var result  = document.getElementById('analyse-result');
    var error   = document.getElementById('analyse-error');
    var stats   = document.getElementById('analyse-stats');

    console.log('[AI Analysis] Elements:', {
      loading: !!loading,
      result: !!result,
      error: !!error,
      stats: !!stats
    });

    loading.style.display = 'block';
    result.style.display  = 'none';
    error.style.display   = 'none';
    stats.style.display   = 'none';
    result.innerHTML      = '';
    error.textContent     = '';

    console.log('[AI Analysis] Fetching from API...');
    fetch('{{ path('admin_api_reclamations_analyse') }}', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' }
    })
    .then(function(r) { 
      console.log('[AI Analysis] Response status:', r.status);
      return r.json(); 
    })
    .then(function(data) {
      console.log('[AI Analysis] Data received:', data);
      loading.style.display = 'none';

      if (data.error) {
        console.error('[AI Analysis] Error from API:', data.error);
        error.textContent    = '⚠ ' + data.error;
        error.style.display  = 'block';
        return;
      }

      // Stats rapides
      if (data.stats) {
        var s = data.stats;
        stats.style.display = 'block';
        stats.innerHTML = renderStats(s);
        console.log('[AI Analysis] Stats rendered');
      }

      // Texte de l'analyse
      result.style.display = 'block';
      result.innerHTML = formatAnalyse(data.analyse || '');
      console.log('[AI Analysis] Analysis rendered');
    })
    .catch(function(err) {
      console.error('[AI Analysis] Fetch error:', err);
      loading.style.display = 'none';
      error.textContent     = '⚠ Erreur réseau : ' + err.message;
      error.style.display   = 'block';
    });
  }

  function renderStats(s) {

    var statusColors = {'Valide':'#16a34a','Ferme':'#dc2626','Attende':'#d97706','En attente':'#d97706','Ouvert':'#2563eb'};

    var typeColors   = ['#6366f1','#0ea5e9','#f59e0b','#10b981','#ef4444','#8b5cf6','#ec4899'];

    var kpiHtml = '<div style="display:flex;gap:.8rem;flex-wrap:wrap;padding:1rem 1.5rem;background:#f8faff;border-bottom:1px solid #e8f0fb;">';

    kpiHtml += '<div style="background:#fff;border:1px solid #e0e7ff;border-radius:12px;padding:.7rem 1.2rem;text-align:center;min-width:90px;"><div style="font-size:1.6rem;font-weight:900;color:#4f46e5;">' + s.total + '</div><div style="font-size:.7rem;color:#6b7280;font-weight:700;text-transform:uppercase;">Total</div></div>';

    Object.keys(s.by_status || {}).forEach(function(k) {

      var c = statusColors[k] || '#6366f1';

      kpiHtml += '<div style="background:#fff;border:1px solid #e0e7ff;border-radius:12px;padding:.7rem 1.2rem;text-align:center;min-width:90px;"><div style="font-size:1.6rem;font-weight:900;color:' + c + ';">' + s.by_status[k] + '</div><div style="font-size:.7rem;color:#6b7280;font-weight:700;text-transform:uppercase;">' + escHtml(k) + '</div></div>';

    });

    kpiHtml += '</div>';

    var chartsHtml = '<div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;padding:1rem 1.5rem;background:#f8faff;border-bottom:1px solid #e8f0fb;">';

    chartsHtml += '<div style="background:#fff;border-radius:14px;padding:1rem;border:1px solid #e8f0fb;"><div style="font-size:.75rem;font-weight:800;color:#4f46e5;text-transform:uppercase;margin-bottom:.6rem;"><i class="fa-solid fa-chart-pie"></i> Statuts</div><canvas id="chart-status" height="160"></canvas></div>';

    chartsHtml += '<div style="background:#fff;border-radius:14px;padding:1rem;border:1px solid #e8f0fb;"><div style="font-size:.75rem;font-weight:800;color:#4f46e5;text-transform:uppercase;margin-bottom:.6rem;"><i class="fa-solid fa-chart-bar"></i> Types</div><canvas id="chart-types" height="160"></canvas></div>';

    chartsHtml += '</div>';

    var tableHtml = '<div style="padding:0 1.5rem 1rem;"><div style="font-size:.75rem;font-weight:800;color:#4f46e5;text-transform:uppercase;margin-bottom:.6rem;"><i class="fa-solid fa-table"></i> Detail par type</div><table style="width:100%;border-collapse:collapse;font-size:.82rem;"><thead><tr style="background:#f1f5f9;"><th style="padding:.5rem .8rem;text-align:left;color:#374151;font-weight:800;">Type</th><th style="padding:.5rem .8rem;text-align:center;color:#374151;font-weight:800;">Nb</th><th style="padding:.5rem .8rem;text-align:left;color:#374151;font-weight:800;">Proportion</th></tr></thead><tbody>';

    var total = s.total || 1; var ti = 0;

    Object.keys(s.by_type || {}).forEach(function(k) {

      var n = s.by_type[k]; var pct = Math.round((n/total)*100);

      var col = typeColors[ti % typeColors.length]; ti++;

      var bg = ti%2===0 ? '#f8faff' : '#fff';

      tableHtml += '<tr style="background:'+bg+';border-bottom:1px solid #f1f5f9;"><td style="padding:.5rem .8rem;color:#1e293b;font-weight:600;">'+escHtml(k)+'</td><td style="padding:.5rem .8rem;text-align:center;font-weight:800;color:'+col+';">'+n+'</td><td style="padding:.5rem .8rem;"><div style="display:flex;align-items:center;gap:.5rem;"><div style="flex:1;height:8px;background:#e2e8f0;border-radius:4px;overflow:hidden;"><div style="height:100%;background:'+col+';width:'+pct+'%;border-radius:4px;"></div></div><span style="font-size:.75rem;color:#6b7280;min-width:30px;">'+pct+'%</span></div></td></tr>';

    });

    tableHtml += '</tbody></table></div>';

    setTimeout(function() {

      var ctxS = document.getElementById('chart-status');

      if (ctxS && window.Chart) {

        var sl = Object.keys(s.by_status||{}); var sd = sl.map(function(k){return s.by_status[k];}); var sb = sl.map(function(k){return statusColors[k]||'#6366f1';});

        new Chart(ctxS,{type:'doughnut',data:{labels:sl,datasets:[{data:sd,backgroundColor:sb,borderWidth:2,borderColor:'#fff'}]},options:{responsive:true,plugins:{legend:{position:'bottom',labels:{font:{size:11}}}}}});

      }

      var ctxT = document.getElementById('chart-types');

      if (ctxT && window.Chart) {

        var tl = Object.keys(s.by_type||{}).map(function(k){return k.length>18?k.substring(0,16)+'...':k;}); var td = Object.values(s.by_type||{}); var tb = tl.map(function(_,i){return typeColors[i%typeColors.length];});

        new Chart(ctxT,{type:'bar',data:{labels:tl,datasets:[{label:'Reclamations',data:td,backgroundColor:tb,borderRadius:6,borderSkipped:false}]},options:{responsive:true,plugins:{legend:{display:false}},scales:{y:{beginAtZero:true,ticks:{stepSize:1}},x:{ticks:{font:{size:10}}}}}});

      }

    },100);

    return kpiHtml + chartsHtml + tableHtml;

  }



  function formatAnalyse(text) {

    var icons = {'1.':'<i class="fa-solid fa-file-lines"></i>','2.':'<i class="fa-solid fa-triangle-exclamation"></i>','3.':'<i class="fa-solid fa-face-meh"></i>','4.':'<i class="fa-solid fa-lightbulb"></i>','5.':'<i class="fa-solid fa-shield-halved"></i>'};

    var lines = text.split('\n'); var html = '<div style="padding:0 1.5rem 1rem;">'; var inSection = false;

    lines.forEach(function(line) {

      line = line.trim(); if (!line) return;

      var sm = line.match(/^(\d+)\.\s+(.+)/);

      if (sm && parseInt(sm[1])<=5) {

        if (inSection) html += '</div>';

        html += '<div class="analyse-section" style="background:#fff;border:1px solid #e8f0fb;border-radius:12px;padding:1rem;margin-bottom:.8rem;"><h4 style="margin:0 0 .5rem;font-size:.8rem;font-weight:800;color:#4f46e5;text-transform:uppercase;display:flex;align-items:center;gap:6px;">'+(icons[sm[1]+'.']||'<i class="fa-solid fa-circle"></i>')+' '+escHtml(sm[2])+'</h4>';

        inSection = true; return;

      }

      if (line.toLowerCase().includes('faible')) html += '<p style="margin:.2rem 0;font-size:.84rem;"><span class="analyse-risk-low">ðŸŸ¢ '+escHtml(line)+'</span></p>';

      else if (line.toLowerCase().includes('elev')) html += '<p style="margin:.2rem 0;font-size:.84rem;"><span class="analyse-risk-high">ðŸ”´ '+escHtml(line)+'</span></p>';

      else if (line.toLowerCase().includes('moyen')) html += '<p style="margin:.2rem 0;font-size:.84rem;"><span class="analyse-risk-medium">ðŸŸ¡ '+escHtml(line)+'</span></p>';

      else if (line.startsWith('-')||line.startsWith('â€¢')) html += '<div style="display:flex;gap:.5rem;align-items:flex-start;margin:.2rem 0;font-size:.84rem;color:#374151;"><span style="color:#6366f1;margin-top:2px;">&#9658;</span><span>'+escHtml(line.replace(/^[-â€¢]\s*/,''))+'</span></div>';

      else html += '<p style="margin:.2rem 0;font-size:.84rem;color:#374151;">'+escHtml(line)+'</p>';

    });

    if (inSection) html += '</div>'; html += '</div>';

    return html || '<p>'+escHtml(text)+'</p>';

  }



  function escHtml(str) { return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
</script>
