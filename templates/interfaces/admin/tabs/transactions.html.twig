<section class="nx-tx">
  <header class="nx-tx__hero">
    <div class="nx-tx__hero-left">
      <span class="nx-tx__hero-icon"><i class="fa-solid fa-building-columns"></i></span>
      <div class="nx-tx__hero-text">
        <h2>Gestion Transactions Bancaires</h2>
        <p>Gerer et superviser les donnees des transactions</p>
      </div>
    </div>
    <div class="nx-tx__hero-actions">
      <a class="na-btn na-btn--ghost" id="nx-export-btn" href="{{ path('admin_transactions_export_pdf', { q: transaction_query.q, sort: transaction_query.sort, dir: transaction_query.dir }) }}" target="_blank"><i class="fa-solid fa-file-pdf"></i> Exporter PDF</a>
      <a class="na-btn na-btn--primary" href="#nx-tx-form"><i class="fa-solid fa-plus"></i> Ajouter</a>
    </div>
  </header>

  <div class="nx-tx__tabs">
    <a class="nx-tx__tab {{ active_panel == 'transaction' ? 'is-active' : '' }}" href="{{ path(route_name, { tab: 'transactions', panel: 'transaction' }) }}"><i class="fa-solid fa-right-left"></i> Transaction</a>
    <a class="nx-tx__tab {{ active_panel == 'reclamation' ? 'is-active' : '' }}" href="{{ path(route_name, { tab: 'transactions', panel: 'reclamation' }) }}"><i class="fa-solid fa-comments"></i> Reclamation</a>
    <span class="nx-tx__tabs-spacer"></span>
    <button class="nx-tx__stats-link" type="button" id="nx-tx-stats-toggle"><i class="fa-solid fa-chart-pie"></i> Statistiques</button>
  </div>

  {% if active_panel == 'transaction' %}
    <div class="nx-tx__stats-panel" id="nx-tx-stats-panel">
      <div class="nx-tx__stats-head">
        <div>
          <h3>Statistiques des transactions</h3>
          <p>Repartition des transactions selon la categorie, avec pourcentage et montant total.</p>
        </div>
        <button type="button" class="nx-tx__stats-close" id="nx-tx-stats-close"><i class="fa-solid fa-xmark"></i></button>
      </div>
      {% set initial_segments = [] %}
      {% for stat in transaction_stats.categories|default([]) %}
        {% set start = loop.first ? 0 : initial_segments|last.end %}
        {% set end = start + stat.percentage %}
        {% set initial_segments = initial_segments|merge([{ start: start, end: end, color: stat.color }]) %}
      {% endfor %}
      {% set donut_background = '' %}
      {% for segment in initial_segments %}
        {% set donut_background = donut_background ~ segment.color ~ ' ' ~ segment.start ~ '% ' ~ segment.end ~ '%' ~ (not loop.last ? ', ' : '') %}
      {% endfor %}
      <div class="nx-tx__stats-card">
        <div class="nx-tx__stats-donut-wrap">
          <div class="nx-tx__stats-donut" id="nx-category-donut" style="background:conic-gradient({{ donut_background != '' ? donut_background : '#dbe7f3 0 100%' }});">
            <div class="nx-tx__stats-center">
              <div>
                <strong id="nx-stats-total">{{ transaction_stats.total|default(transaction_items|length) }}</strong>
                <small id="nx-stats-amount">{{ transaction_stats.total_amount|default(0)|number_format(2, '.', ' ') }} DT</small>
              </div>
            </div>
          </div>
        </div>
        <div class="nx-tx__stats-legend" id="nx-category-legend">
          {% for stat in transaction_stats.categories|default([]) %}
            <div class="nx-tx__stats-row" data-category-row="{{ stat.label }}">
              <strong><span class="nx-tx__stats-dot" style="background:{{ stat.color }}"></span>{{ stat.label }}</strong>
              <b>{{ stat.count }}</b>
              <span>{{ stat.percentage|number_format(1, '.', '') }}%</span>
              <span>{{ stat.amount|number_format(2, '.', ' ') }} DT</span>
            </div>
          {% else %}
            <div class="nx-tx__stats-row"><strong>Aucune categorie</strong><span>0</span><span>0%</span><span>0.00 DT</span></div>
          {% endfor %}
        </div>
      </div>
    </div>

    <div class="nx-tx__kpis" id="nx-tx-summary">
      <div class="nx-tx__kpi"><span class="nx-tx__kpi-icon"><i class="fa-solid fa-wallet"></i></span><div class="nx-tx__kpi-body"><strong>{{ accounts|length }}</strong><small>Comptes relies</small></div></div>
      <div class="nx-tx__kpi"><span class="nx-tx__kpi-icon"><i class="fa-solid fa-building-columns"></i></span><div class="nx-tx__kpi-body"><strong>{{ summary.transactions_total|default(all_transaction_items|length) }}</strong><small>Transactions total</small></div></div>
      <div class="nx-tx__kpi"><span class="nx-tx__kpi-icon"><i class="fa-solid fa-layer-group"></i></span><div class="nx-tx__kpi-body"><strong id="nx-tx-lines">{{ transaction_items|length }}</strong><small>Lignes affichees</small></div></div>
    </div>

    <div class="nx-tx__grid">
      <article class="nx-tx__panel" id="nx-tx-form">
        <div class="nx-tx__panel-head">
          <div class="nx-tx__panel-head-left">
            <h3><i class="fa-solid fa-right-left" style="color:var(--na-teal);margin-right:.4rem"></i>Transaction</h3>
            <p>Ajouter ou modifier une transaction</p>
          </div>
        </div>
        <form method="post" class="nx-tx__form" id="nx-transaction-form" novalidate>
          <input type="hidden" name="tab" value="transactions">
          <input type="hidden" name="panel" value="transaction">
          <input type="hidden" name="action" value="transaction_save">
          <input type="hidden" name="idTransaction" id="f-idTransaction" value="{{ tx.idTransaction|default('') }}">
          <input type="hidden" name="q" value="{{ transaction_query.q }}">
          <input type="hidden" name="sort" value="{{ transaction_query.sort }}">
          <input type="hidden" name="dir" value="{{ transaction_query.dir }}">
          
          <div class="nx-tx__form-label-id">
            <i class="fa-solid fa-pen-to-square"></i>
            <span id="f-mode-label">{{ tx.idTransaction is defined ? 'Modification transaction #' ~ tx.idTransaction : 'Nouvelle transaction' }}</span>
          </div>
          
          <div class="nx-tx__form-divider"></div>
          
          {# Champs de base #}
          <label>
            <span>Compte source <em style="color:#dc2626">*</em></span>
            <select name="compte" id="f-compte" class="nx-tx__field-input" required>
              <option value="">-- Selectionner --</option>
              {% for account in accounts %}
                <option value="{{ account.idCompte }}" data-solde="{{ account.solde }}" {{ tx.idCompte|default('') == account.idCompte ? 'selected' : '' }}>
                  {{ account.numeroCompte }} ({{ account.solde }} DT)
                </option>
              {% endfor %}
            </select>
            <small class="nx-tx__field-feedback is-neutral" id="f-compte-feedback">Veuillez selectionner un compte.</small>
          </label>
          
          <label>
            <span>Date Transaction <em style="color:#dc2626">*</em></span>
            <input type="date" name="dateTransaction" id="f-dateTransaction" class="nx-tx__field-input" value="{{ tx.dateTransaction|default('now'|date('Y-m-d')) }}" required>
            <small class="nx-tx__field-feedback is-neutral" id="f-dateTransaction-feedback">Veuillez choisir une date valide.</small>
          </label>
          
          <label>
            <span>Description</span>
            <textarea name="description" id="f-description" class="nx-tx__field-input" placeholder="Description de la transaction">{{ tx.description|default('') }}</textarea>
            <small class="nx-tx__field-feedback is-neutral" id="f-description-feedback">Champ optionnel.</small>
          </label>
          
          <div class="nx-tx__form-divider"></div>
          
          {# Type de transaction - Boutons radio améliorés #}
          <label>
            <span>Type Transaction <em style="color:#dc2626">*</em></span>
            <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:.65rem;margin-top:.6rem">
              <label class="type-radio-label type-radio-depot">
                <input type="radio" name="typeTransaction" value="DEPOT" {{ not tx or tx.typeTransaction|default('DEPOT')|upper == 'DEPOT' ? 'checked' : '' }}>
                <span class="type-radio-content">
                  <i class="fa-solid fa-arrow-down"></i>
                  <span>DÉPÔT</span>
                </span>
              </label>
              <label class="type-radio-label type-radio-retrait">
                <input type="radio" name="typeTransaction" value="RETRAIT" {{ tx and tx.typeTransaction|default('')|upper == 'RETRAIT' ? 'checked' : '' }}>
                <span class="type-radio-content">
                  <i class="fa-solid fa-arrow-up"></i>
                  <span>RETRAIT</span>
                </span>
              </label>
              <label class="type-radio-label type-radio-virement">
                <input type="radio" name="typeTransaction" value="VIREMENT" {{ tx and tx.typeTransaction|default('')|upper == 'VIREMENT' ? 'checked' : '' }}>
                <span class="type-radio-content">
                  <i class="fa-solid fa-right-left"></i>
                  <span>VIREMENT</span>
                </span>
              </label>
              <label class="type-radio-label type-radio-paiement">
                <input type="radio" name="typeTransaction" value="PAIEMENT" {{ tx and tx.typeTransaction|default('')|upper == 'PAIEMENT' ? 'checked' : '' }}>
                <span class="type-radio-content">
                  <i class="fa-solid fa-credit-card"></i>
                  <span>PAIEMENT</span>
                </span>
              </label>
            </div>
            <small class="nx-tx__field-feedback is-neutral" id="f-typeTransaction-feedback">Veuillez selectionner un type.</small>
          </label>
          
          <div class="nx-tx__form-divider"></div>
          
          {# Section DEPOT #}
          <div class="section-depot" style="display:none">
            <label>
              <span>Montant <em style="color:#dc2626">*</em></span>
              <input type="number" step="0.01" min="0" name="montant" id="f-montant-depot" class="nx-tx__field-input" placeholder="0.00" value="{{ tx and tx.typeTransaction|upper == 'DEPOT' ? tx.montant_value|default('') : '' }}">
              <small class="nx-tx__field-feedback is-neutral" id="f-montant-depot-feedback">Le montant doit etre superieur a 0.</small>
            </label>
          </div>
          
          {# Section RETRAIT #}
          <div class="section-retrait" style="display:none">
            <label>
              <span>Montant <em style="color:#dc2626">*</em></span>
              <input type="number" step="0.01" min="0" name="montant" id="f-montant-retrait" class="nx-tx__field-input" placeholder="0.00" value="{{ tx and tx.typeTransaction|upper == 'RETRAIT' ? tx.montant_value|default('') : '' }}">
              <small class="nx-tx__field-feedback is-neutral" id="f-montant-retrait-feedback">Le montant doit etre superieur a 0.</small>
            </label>
            <small style="font-size:.72rem;color:#ff9800;margin-top:8px;display:block">
              <i class="fa-solid fa-triangle-exclamation"></i> Solde disponible: <strong id="solde-disponible">0.00 DT</strong>
            </small>
          </div>
          
          {# Section VIREMENT #}
          <div class="section-virement" style="display:none">
            <label>
              <span>Numéro compte destinataire <em style="color:#dc2626">*</em></span>
              <input type="text" name="compteDestinataire" id="f-compteDestinataire" class="nx-tx__field-input" placeholder="Ex: 1234567890" value="{{ tx and tx.typeTransaction|upper == 'VIREMENT' ? tx.idCompteDestinataire|default('') : '' }}">
              <small class="nx-tx__field-feedback is-neutral" id="f-compteDestinataire-feedback">Minimum 5 chiffres.</small>
            </label>
            <label>
              <span>Nom destinataire <em style="color:#dc2626">*</em></span>
              <input type="text" name="nomDestinataire" id="f-nomDestinataire" class="nx-tx__field-input" placeholder="Nom complet" value="{{ tx and tx.typeTransaction|upper == 'VIREMENT' ? tx.nomDestinataire|default('') : '' }}">
              <small class="nx-tx__field-feedback is-neutral" id="f-nomDestinataire-feedback">Minimum 3 caracteres.</small>
            </label>
            <label>
              <span>Email destinataire</span>
              <input type="email" name="emailDestinataire" id="f-emailDestinataire" class="nx-tx__field-input" placeholder="email@example.com" value="{{ tx and tx.typeTransaction|upper == 'VIREMENT' ? tx.emailDestinataire|default('') : '' }}">
              <small class="nx-tx__field-feedback is-neutral" id="f-emailDestinataire-feedback">Optionnel.</small>
            </label>
            <label>
              <span>Montant <em style="color:#dc2626">*</em></span>
              <input type="number" step="0.01" min="0" name="montant" id="f-montant-virement" class="nx-tx__field-input" placeholder="0.00" value="{{ tx and tx.typeTransaction|upper == 'VIREMENT' ? tx.montant_value|default('') : '' }}">
              <small class="nx-tx__field-feedback is-neutral" id="f-montant-virement-feedback">Le montant doit etre superieur a 0.</small>
            </label>
          </div>
          
          {# Section PAIEMENT #}
          <div class="section-paiement" style="display:none">
            <label>
              <span>Catégorie <em style="color:#dc2626">*</em></span>
              <select name="categorie" id="f-categorie" class="nx-tx__field-input">
                <option value="">-- Selectionner --</option>
                {% for category in transaction_categories %}
                  <option value="{{ category }}" {{ tx and tx.categorie == category ? 'selected' : '' }}>{{ category }}</option>
                {% endfor %}
              </select>
              <small class="nx-tx__field-feedback is-neutral" id="f-categorie-feedback">Veuillez selectionner une categorie.</small>
            </label>
            <label>
              <span>Montant à payer <em style="color:#dc2626">*</em></span>
              <input type="number" step="0.01" min="0" name="montantPaye" id="f-montantPaye" class="nx-tx__field-input" placeholder="0.00" value="{{ tx and tx.typeTransaction|upper == 'PAIEMENT' ? tx.montantPaye_value|default('') : '' }}">
              <small class="nx-tx__field-feedback is-neutral" id="f-montantPaye-feedback">Le montant doit etre superieur a 0.</small>
            </label>
            <label>
              <span>Bénéficiaire</span>
              <input type="text" name="nomDestinataire" id="f-nomBenef" class="nx-tx__field-input" placeholder="Nom (optionnel)" value="{{ tx and tx.typeTransaction|upper == 'PAIEMENT' ? tx.nomDestinataire|default('') : '' }}">
            </label>
            <label>
              <span>Email bénéficiaire</span>
              <input type="email" name="emailDestinataire" id="f-emailBenef" class="nx-tx__field-input" placeholder="email@example.com (optionnel)" value="{{ tx and tx.typeTransaction|upper == 'PAIEMENT' ? tx.emailDestinataire|default('') : '' }}">
              <small class="nx-tx__field-feedback is-neutral" id="f-emailBenef-feedback">Optionnel.</small>
            </label>
            
            <div style="margin-top:15px;padding:12px;background:rgba(99,102,241,0.1);border-radius:8px;border:1px solid rgba(99,102,241,0.3)">
              <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px">
                <i class="fa-solid fa-shield-halved" style="color:#6366f1;font-size:18px"></i>
                <strong style="color:#4f46e5;font-size:.85rem">Paiement sécurisé via Stripe</strong>
              </div>
              <p style="font-size:.75rem;color:#6b7280;margin:0 0 12px 0">
                Après enregistrement, vous serez redirigé vers Stripe pour payer.
              </p>
              <button type="button" id="btn-payer-stripe" class="na-btn na-btn--save" style="width:100%;background:linear-gradient(135deg,#6366f1 0%,#4f46e5 100%)">
                <i class="fa-solid fa-lock"></i> Enregistrer et payer avec Stripe
              </button>
            </div>
          </div>
          
          <div class="nx-tx__form-actions">
            <button class="na-btn na-btn--save" type="submit"><i class="fa-solid fa-floppy-disk"></i> Enregistrer</button>
            <button class="na-btn na-btn--reset" type="button" onclick="nxResetTransactionForm()"><i class="fa-solid fa-rotate-left"></i> Annuler</button>
          </div>
        </form>
      </article>
      <article class="nx-tx__panel" id="nx-tx-table-panel">
        <div class="nx-tx__panel-head">
          <div class="nx-tx__panel-head-left">
            <h3>Liste des Transactions</h3>
            <p>Gestion complete des transactions bancaires</p>
          </div>
          <span class="nx-tx__row-count" id="nx-tx-count">{{ transaction_items|length }} transaction{{ transaction_items|length != 1 ? 's' : '' }}</span>
        </div>
        <form method="get" class="nx-tx__search" id="nx-tx-search-form">
          <input type="hidden" name="tab" value="transactions">
          <input type="hidden" name="panel" value="transaction">
          <div class="nx-tx__search-box">
            <div class="nx-tx__search-wrap">
              <i class="fa-solid fa-magnifying-glass"></i>
              <input class="nx-tx__search-input" type="text" name="q" id="nx-tx-search-input" value="{{ transaction_query.q }}" placeholder="Recherche avancee: compte, categorie, type, montant, utilisateur...">
            </div>
            <div class="nx-tx__suggestions" id="nx-tx-suggestions" hidden></div>
          </div>
          <select class="nx-tx__sort-select" id="nx-tx-sort-field" name="sort" title="Trier par">
            {% for field, label in transaction_sort_fields %}
              <option value="{{ field }}" {{ transaction_query.sort == field ? 'selected' : '' }}>{{ label }}</option>
            {% endfor %}
          </select>
          <input type="hidden" id="nx-tx-dir-input" name="dir" value="{{ transaction_query.dir|default('desc') }}">
          <button class="nx-tx__sort-dir" id="nx-tx-sort-dir" title="Ordre" type="button"><i class="fa-solid {{ transaction_query.dir == 'asc' ? 'fa-arrow-up-a-z' : 'fa-arrow-down-z-a' }}"></i></button>
        </form>
        <div class="nx-tx__table-wrap">
          <table class="nx-tx__table" id="nx-tx-table">
            <thead>
              <tr>
                <th><i class="fa-solid fa-building-columns" style="margin-right:.4rem;opacity:.7"></i>N° Compte</th>
                <th><i class="fa-solid fa-paper-plane" style="margin-right:.4rem;opacity:.7"></i>Compte Dest.</th>
                <th><i class="fa-solid fa-tag" style="margin-right:.4rem;opacity:.7"></i>Catégorie</th>
                <th><i class="fa-regular fa-calendar" style="margin-right:.4rem;opacity:.7"></i>Date</th>
                <th><i class="fa-solid fa-coins" style="margin-right:.4rem;opacity:.7"></i>Montant</th>
                <th><i class="fa-solid fa-layer-group" style="margin-right:.4rem;opacity:.7"></i>Type</th>
                <th><i class="fa-solid fa-wallet" style="margin-right:.4rem;opacity:.7"></i>Montant Payé</th>
                <th><i class="fa-solid fa-align-left" style="margin-right:.4rem;opacity:.7"></i>Description</th>
                <th><i class="fa-solid fa-bolt" style="margin-right:.4rem;opacity:.7"></i>Actions</th>
              </tr>
            </thead>
            <tbody>
              {% for item in transaction_items %}
                {% set type_key = item.typeTransaction|default('')|lower %}
                {% set category_key = item.categorie|default('')|lower|replace({' ': '-', 'ê': 'e', 'é': 'e', 'è': 'e', 'à': 'a', 'â': 'a', 'ù': 'u'}) %}
                <tr tabindex="0" data-id="{{ item.idTransaction }}" data-user-id="{{ item.resolved_user_id|default(item.idUser|default('')) }}" data-id-compte="{{ item.idCompte|default('') }}" data-numero-compte="{{ item.numeroCompte|default('') }}" data-compte-dest="{{ item.idCompteDestinataire|default('') }}" data-numero-compte-dest="{{ item.numeroCompteDestinataire|default('') }}" data-categorie="{{ item.categorie|default('') }}" data-date="{{ item.dateTransaction|default('') }}" data-montant="{{ item.montant_value|default(0) }}" data-type="{{ item.typeTransaction|default('') }}" data-montant-paye="{{ item.montantPaye_value|default(0) }}" data-description="{{ item.description|default('') }}" data-user-name="{{ item.user_name|default('') }}" data-account-type="{{ item.linked_account.typeCompte|default('') }}" data-account-status="{{ item.linked_account.statutCompte|default('') }}" data-account-solde="{{ item.linked_account.solde|default('') }}">
                  <td><span class="nx-tx__num">{{ item.numeroCompte|default('-') }}</span></td>
                  <td><span class="nx-tx__num">{{ item.numeroCompteDestinataire|default('-') }}</span></td>
                  <td><span class="nx-tx__tag {{ category_key ? 'cat-' ~ category_key : 'cat-default' }}">{{ item.categorie|default('-') }}</span></td>
                  <td><span class="nx-tx__date">{{ item.dateTransaction|default('-') }}</span></td>
                  <td><span class="nx-tx__amount">{{ item.montant_value|default(0)|number_format(2, '.', ' ') }} <em>DT</em></span></td>
                  <td><span class="nx-tx__tag is-{{ 'paiement' in type_key ? 'debit' : ('virement' in type_key ? 'virement' : 'credit') }}">{{ item.typeTransaction|default('-') }}</span></td>
                  <td><span class="nx-tx__paid">{{ item.montantPaye_value|default(0)|number_format(2, '.', ' ') }} <em>DT</em></span></td>
                  <td><span class="nx-tx__desc">{{ item.description|default('-') }}</span></td>
                  <td>
                    <div class="nx-tx__act-group">
                      <button type="button" class="nx-tx__act-btn edit" title="Modifier" onclick="nxEditTransaction(this.closest('tr'))"><i class="fa-solid fa-pen-to-square"></i></button>
                      <form method="post" style="display:inline">
                        <input type="hidden" name="tab" value="transactions">
                        <input type="hidden" name="panel" value="transaction">
                        <input type="hidden" name="action" value="transaction_delete">
                        <input type="hidden" name="idTransaction" value="{{ item.idTransaction }}">
                        <input type="hidden" name="q" value="{{ transaction_query.q }}">
                        <input type="hidden" name="sort" value="{{ transaction_query.sort }}">
                        <input type="hidden" name="dir" value="{{ transaction_query.dir }}">
                        <button type="submit" class="nx-tx__act-btn del" title="Supprimer" onclick="return confirm('Supprimer cette transaction ?')"><i class="fa-solid fa-trash-can"></i></button>
                      </form>
                      <button type="button" class="nx-tx__act-btn view" title="Voir" onclick="nxViewTransaction(this.closest('tr'))"><i class="fa-solid fa-eye"></i></button>
                    </div>
                  </td>
                </tr>
              {% else %}
                <tr><td colspan="9" class="nx-tx__empty"><i class="fa-solid fa-right-left"></i>Aucune transaction enregistree.</td></tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
        
        {# Pagination Controls #}
        {% set pagination = support.pagination|default({ current_page: 1, total_pages: 1, total_items: 0, per_page: 3, has_prev: false, has_next: false }) %}
        {% if pagination.total_pages > 1 %}
          <div style="display:flex;align-items:center;justify-content:space-between;padding:1rem 1.2rem;border-top:1px solid var(--na-border);background:var(--na-bg)">
            <span style="font-size:.78rem;color:var(--na-muted)">
              Page <strong>{{ pagination.current_page }}</strong> sur <strong>{{ pagination.total_pages }}</strong> 
              ({{ pagination.total_items }} transaction{{ pagination.total_items > 1 ? 's' : '' }})
            </span>
            <div style="display:flex;gap:.5rem">
              {% if pagination.has_prev %}
                <a href="{{ path(route_name, { tab: 'transactions', panel: 'transaction', page: pagination.current_page - 1, q: transaction_query.q, sort: transaction_query.sort, dir: transaction_query.dir }) }}" 
                   class="na-btn na-btn--ghost" style="padding:.4rem .8rem;font-size:.75rem">
                  <i class="fa-solid fa-chevron-left"></i> Précédent
                </a>
              {% else %}
                <button disabled class="na-btn na-btn--ghost" style="padding:.4rem .8rem;font-size:.75rem;opacity:.4;cursor:not-allowed">
                  <i class="fa-solid fa-chevron-left"></i> Précédent
                </button>
              {% endif %}
              
              {% for page in 1..pagination.total_pages %}
                {% if page == pagination.current_page %}
                  <button class="na-btn na-btn--primary" style="padding:.4rem .8rem;font-size:.75rem;min-width:36px">{{ page }}</button>
                {% elseif page == 1 or page == pagination.total_pages or (page >= pagination.current_page - 1 and page <= pagination.current_page + 1) %}
                  <a href="{{ path(route_name, { tab: 'transactions', panel: 'transaction', page: page, q: transaction_query.q, sort: transaction_query.sort, dir: transaction_query.dir }) }}" 
                     class="na-btn na-btn--ghost" style="padding:.4rem .8rem;font-size:.75rem;min-width:36px">{{ page }}</a>
                {% elseif page == pagination.current_page - 2 or page == pagination.current_page + 2 %}
                  <span style="padding:.4rem .4rem;color:var(--na-muted)">...</span>
                {% endif %}
              {% endfor %}
              
              {% if pagination.has_next %}
                <a href="{{ path(route_name, { tab: 'transactions', panel: 'transaction', page: pagination.current_page + 1, q: transaction_query.q, sort: transaction_query.sort, dir: transaction_query.dir }) }}" 
                   class="na-btn na-btn--ghost" style="padding:.4rem .8rem;font-size:.75rem">
                  Suivant <i class="fa-solid fa-chevron-right"></i>
                </a>
              {% else %}
                <button disabled class="na-btn na-btn--ghost" style="padding:.4rem .8rem;font-size:.75rem;opacity:.4;cursor:not-allowed">
                  Suivant <i class="fa-solid fa-chevron-right"></i>
                </button>
              {% endif %}
            </div>
          </div>
        {% endif %}
      </article>
    </div>
  {% else %}
    <div class="nx-tx__kpis" id="nx-tx-summary">
      <div class="nx-tx__kpi"><span class="nx-tx__kpi-icon"><i class="fa-solid fa-comments"></i></span><div class="nx-tx__kpi-body"><strong>{{ reclamation_items|length }}</strong><small>Total reclamations</small></div></div>
      <div class="nx-tx__kpi"><span class="nx-tx__kpi-icon"><i class="fa-solid fa-right-left"></i></span><div class="nx-tx__kpi-body"><strong>{{ all_transaction_items|length }}</strong><small>Transactions reliees</small></div></div>
      <div class="nx-tx__kpi"><span class="nx-tx__kpi-icon"><i class="fa-solid fa-flag"></i></span><div class="nx-tx__kpi-body"><strong id="nx-rec-lines">{{ reclamation_items|length }}</strong><small>Lignes affichees</small></div></div>
    </div>
    <div class="nx-tx__grid nx-tx__grid--full">
      {# ── Tableau réclamations ── #}
      <article class="nx-tx__panel" id="nx-rec-table-panel">
        <div class="nx-tx__panel-head">
          <div class="nx-tx__panel-head-left">
            <h3>Liste des Reclamations</h3>
            <p>Gestion complete des reclamations bancaires</p>
          </div>
          <span class="nx-tx__row-count" id="nx-rec-count">{{ reclamation_items|length }} reclamation{{ reclamation_items|length != 1 ? 's' : '' }}</span>
          <button type="button" id="btn-analyse-reclamations"
                  style="display:inline-flex;align-items:center;gap:.5rem;padding:.5rem 1.1rem;border-radius:9px;background:linear-gradient(135deg,#6366f1,#4f46e5);color:#fff;border:none;font-size:.82rem;font-weight:700;cursor:pointer;box-shadow:0 3px 10px rgba(99,102,241,.35);transition:all .2s ease;">
            <i class="fa-solid fa-brain"></i> Analyse IA
          </button>
        </div>
        <form method="get" class="nx-tx__search" id="nx-rec-search-form">
          <input type="hidden" name="tab" value="transactions">
          <input type="hidden" name="panel" value="reclamation">
          <div class="nx-tx__search-box">
            <div class="nx-tx__search-wrap">
              <i class="fa-solid fa-magnifying-glass"></i>
              <input class="nx-tx__search-input" type="text" name="q" id="nx-rec-search-input" value="{{ reclamation_query.q }}" placeholder="Recherche: type, status, transaction, utilisateur...">
            </div>
            <div class="nx-tx__suggestions" id="nx-rec-suggestions" hidden></div>
          </div>
          <select class="nx-tx__sort-select" id="nx-rec-sort-field" name="sort" title="Trier par">
            {% for field, label in reclamation_sort_fields %}
              <option value="{{ field }}" {{ reclamation_query.sort == field ? 'selected' : '' }}>{{ label }}</option>
            {% endfor %}
          </select>
          <input type="hidden" id="nx-rec-dir-input" name="dir" value="{{ reclamation_query.dir|default('desc') }}">
          <button class="nx-tx__sort-dir" id="nx-rec-sort-dir" title="Ordre" type="button"><i class="fa-solid {{ reclamation_query.dir == 'asc' ? 'fa-arrow-up-a-z' : 'fa-arrow-down-z-a' }}"></i></button>
        </form>
        <div class="rec-cards-container" id="nx-rec-cards">
          {% for item in reclamation_items %}
            {% set status_key = item.status|default('')|lower|replace({' ': '-', 'é': 'e', 'è': 'e', 'ê': 'e'}) %}
            {% set type_key = item.typeReclamation|default('')|lower|replace({' ': '-', 'é': 'e', 'è': 'e', 'ê': 'e', 'à': 'a'}) %}
            {% set status_class = status_key in ['valide'] ? 'status-valide' : (status_key in ['ferme'] ? 'status-ferme' : (status_key in ['signalee'] ? 'status-signalee' : 'status-attende')) %}
            {% set is_inappropriate = item.is_inappropriate|default(0) == 1 %}
            {% set is_blurred = item.is_blurred|default(0) == 1 %}
            
            <div class="rec-card {{ is_inappropriate ? 'is-inappropriate' : '' }}"
                 data-id="{{ item.idReclamation }}"
                 data-date="{{ item.dateReclamation|default('') }}"
                 data-type="{{ item.typeReclamation|default('') }}"
                 data-status="{{ item.status|default('') }}"
                 data-id-transaction="{{ item.idTransaction|default('') }}"
                 data-numero-compte="{{ item.numeroCompte|default('') }}"
                 data-user-id="{{ item.resolved_user_id|default(item.idUser|default('')) }}"
                 data-user-name="{{ item.user_name|default('') }}"
                 data-description="{{ item.description|default('') }}"
                 data-inappropriate="{{ item.is_inappropriate|default(0) }}"
                 data-blurred="{{ item.is_blurred|default(0) }}"
                 data-transaction-type="{{ item.transaction_type|default('') }}"
                 data-transaction-category="{{ item.transaction_category|default('') }}"
                 style="animation-delay:{{ loop.index0 * 0.05 }}s">
              
              <div class="rec-card__header">
                <div class="rec-card__id">
                  <i class="fa-solid fa-hashtag"></i>
                  <span>{{ item.idReclamation }}</span>
                </div>
                <h4 class="rec-card__type">
                  {% set sentiment_emoji = {
                    'angry': '😠',
                    'sad': '😢',
                    'worried': '😰',
                    'neutral': '😐',
                    'happy': '😊'
                  } %}
                  <span class="sentiment-emoji" title="Sentiment: {{ item.sentiment|default('neutral') }}">
                    {{ sentiment_emoji[item.sentiment|default('neutral')] ?? '😐' }}
                  </span>
                  <i class="fa-solid fa-flag" style="margin-right:.4rem;opacity:.8"></i>
                  {{ item.typeReclamation|default('Type inconnu') }}
                </h4>
              </div>
              
              <div class="rec-card__body">
                <div class="rec-card__row">
                  <div class="rec-card__icon icon-user">
                    <i class="fa-solid fa-user"></i>
                  </div>
                  <div class="rec-card__content">
                    <div class="rec-card__label">Utilisateur</div>
                    <div class="rec-card__value">{{ item.user_name|default('Inconnu') }}</div>
                  </div>
                </div>
                
                <div class="rec-card__row">
                  <div class="rec-card__icon icon-date">
                    <i class="fa-regular fa-calendar"></i>
                  </div>
                  <div class="rec-card__content">
                    <div class="rec-card__label">Date de réclamation</div>
                    <div class="rec-card__value">{{ item.dateReclamation|date('d/m/Y') }}</div>
                  </div>
                </div>
                
                <div class="rec-card__row">
                  <div class="rec-card__icon icon-tx">
                    <i class="fa-solid fa-right-left"></i>
                  </div>
                  <div class="rec-card__content">
                    <div class="rec-card__label">Transaction liée</div>
                    <div class="rec-card__value">#{{ item.idTransaction|default('-') }}</div>
                  </div>
                </div>
                
                <div class="rec-card__desc">
                  <div class="rec-card__desc-label">
                    <i class="fa-solid fa-align-left"></i>
                    Description
                    {% if is_inappropriate %}
                      <span class="rec-badword-badge" style="margin-left:auto">
                        <i class="fa-solid fa-triangle-exclamation"></i> Badword
                      </span>
                    {% endif %}
                  </div>
                  <div class="rec-card__desc-text {{ is_blurred ? 'rec-desc-blurred' : '' }}">
                    {{ is_blurred ? '[CONTENU MODÉRÉ PAR L\'ADMINISTRATEUR]' : (item.description|default('Aucune description')) }}
                  </div>
                </div>
              </div>
              
              <div class="rec-card__footer">
                <div style="flex:1">
                  <span class="rec-card__status {{ status_class }}">
                    {% if status_key == 'valide' %}<i class="fa-solid fa-circle-check"></i>
                    {% elseif status_key == 'ferme' %}<i class="fa-solid fa-circle-xmark"></i>
                    {% elseif status_key == 'signalee' %}<i class="fa-solid fa-triangle-exclamation"></i>
                    {% else %}<i class="fa-solid fa-clock"></i>{% endif %}
                    {{ item.status|default('En attente') }}
                  </span>
                </div>
                
                <div class="rec-card__actions">
                  <button type="button" class="rec-card__btn btn-ai" title="Répondre avec IA" onclick="respondWithAI({{ item.idReclamation }}, '{{ item.user_name|default('Utilisateur')|e('js') }}', '{{ item.typeReclamation|default('')|e('js') }}', '{{ item.description|default('')|e('js') }}')">
                    <i class="fa-solid fa-wand-magic-sparkles"></i>
                  </button>
                  <button type="button" class="rec-card__btn btn-edit" title="Modifier" onclick="nxEditReclamation(this.closest('.rec-card'))">
                    <i class="fa-solid fa-pen-to-square"></i>
                  </button>
                  <button type="button" class="rec-card__btn btn-view" title="Voir détails" onclick="nxViewReclamation(this.closest('.rec-card'))">
                    <i class="fa-solid fa-eye"></i>
                  </button>
                  <form method="post" style="display:inline">
                    <input type="hidden" name="tab" value="transactions">
                    <input type="hidden" name="panel" value="reclamation">
                    <input type="hidden" name="action" value="reclamation_delete">
                    <input type="hidden" name="idReclamation" value="{{ item.idReclamation }}">
                    <input type="hidden" name="q" value="{{ reclamation_query.q }}">
                    <input type="hidden" name="sort" value="{{ reclamation_query.sort }}">
                    <input type="hidden" name="dir" value="{{ reclamation_query.dir }}">
                    <button type="submit" class="rec-card__btn btn-delete" title="Supprimer" onclick="return confirm('Supprimer cette réclamation ?')">
                      <i class="fa-solid fa-trash-can"></i>
                    </button>
                  </form>
                </div>
                
                {% if is_inappropriate and not is_blurred %}
                  <div class="rec-card__moderation">
                    <div class="rec-card__mod-label">
                      <i class="fa-solid fa-shield-halved"></i>
                      Modération requise
                    </div>
                    <div class="rec-card__mod-actions">
                      <button type="button" class="rec-moderate-btn rec-moderate-btn--accept" 
                              onclick="moderateReclamation({{ item.idReclamation }}, 'accept')"
                              title="Accepter la réclamation">
                        <i class="fa-solid fa-check"></i>
                      </button>
                      <button type="button" class="rec-moderate-btn rec-moderate-btn--blur" 
                              onclick="moderateReclamation({{ item.idReclamation }}, 'blur')"
                              title="Flouter le contenu">
                        <i class="fa-solid fa-eye-slash"></i>
                      </button>
                    </div>
                  </div>
                {% elseif is_blurred %}
                  <div class="rec-card__moderation">
                    <span class="rec-moderated-badge">
                      <i class="fa-solid fa-check-circle"></i> Contenu modéré
                    </span>
                  </div>
                {% endif %}
              </div>
            </div>
          {% else %}
            <div class="rec-empty-state" style="grid-column:1/-1">
              <i class="fa-solid fa-flag"></i>
              <p>Aucune réclamation enregistrée</p>
            </div>
          {% endfor %}
        </div>
      </article>
    </div>
  {% endif %}
</section>
{% set detail_tx = view_transaction ?: {} %}
{% set detail_account = view_transaction and view_transaction.linked_account is defined and view_transaction.linked_account ? view_transaction.linked_account : {} %}
{% set detail_type_key = detail_tx.typeTransaction|default('')|lower %}
{% set detail_category_key = detail_tx.categorie|default('')|lower|replace({' ': '-', 'ê': 'e', 'é': 'e', 'è': 'e', 'à': 'a', 'â': 'a', 'ù': 'u'}) %}
<div class="nx-tx__modal {% if view_transaction %}is-open{% endif %}" id="nx-tx-modal" {% if view_transaction %}aria-hidden="false"{% else %}aria-hidden="true"{% endif %}>
  <div class="nx-tx__modal-dialog" role="dialog" aria-modal="true" aria-labelledby="nx-tx-modal-title">
    <div class="nx-tx__modal-head">
      <div class="nx-tx__modal-title">
        <div class="nx-tx__modal-icon"><i class="fa-solid fa-receipt"></i></div>
        <div class="nx-tx__modal-copy">
          <h3 id="nx-tx-modal-title">Details de la transaction</h3>
          <p>Toutes les informations importantes de la transaction selectionnee.</p>
        </div>
      </div>
      <button type="button" class="nx-tx__modal-close" id="nx-tx-modal-close" aria-label="Fermer"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <div class="nx-tx__modal-body">
      <div class="nx-tx__modal-banner">
        <div class="nx-tx__spotlight">
          <small>Montant transaction</small>
          <strong id="d-montant">{{ detail_tx.montant_value|default(0)|number_format(2, '.', ' ') }} DT</strong>
          <p>
            <span class="nx-tx__tag {{ detail_category_key ? 'cat-' ~ detail_category_key : 'cat-default' }}" id="d-categorie-badge">{{ detail_tx.categorie|default('-') }}</span>
            <span class="nx-tx__tag {{ 'paiement' in detail_type_key ? 'is-debit' : ('virement' in detail_type_key ? 'is-virement' : 'is-credit') }}" id="d-type-badge">{{ detail_tx.typeTransaction|default('-') }}</span>
          </p>
        </div>
        <div class="nx-tx__mini-stack">
          <div class="nx-tx__mini-card"><small>ID transaction</small><strong id="d-id">{{ detail_tx.idTransaction is defined ? '#' ~ detail_tx.idTransaction : '-' }}</strong></div>
          <div class="nx-tx__mini-card"><small>Numero compte</small><strong id="d-numero">{{ detail_tx.numeroCompte|default('-') }}</strong></div>
        </div>
      </div>
      <div class="nx-tx__modal-grid">
        <div class="nx-tx__modal-field"><small>Date transaction</small><strong id="d-date">{{ detail_tx.dateTransaction|default('-') }}</strong></div>
        <div class="nx-tx__modal-field"><small>Compte source</small><strong id="d-idcompte">{{ detail_tx.numeroCompte|default(detail_tx.idCompte|default('-')) }}</strong></div>
        <div class="nx-tx__modal-field"><small>Compte destinataire</small><strong id="d-comptedestinataire">{{ detail_tx.numeroCompteDestinataire|default('-') }}</strong></div>
        <div class="nx-tx__modal-field"><small>ID utilisateur</small><strong id="d-userid">{{ detail_tx.resolved_user_id|default(detail_tx.idUser|default('-')) }}</strong></div>
        <div class="nx-tx__modal-field"><small>Utilisateur</small><strong id="d-username">{{ detail_tx.user_name|default('-') }}</strong></div>
        <div class="nx-tx__modal-field"><small>Montant paye</small><strong id="d-montantpaye">{{ detail_tx.montantPaye_value|default(0)|number_format(2, '.', ' ') }} DT</strong></div>
        <div class="nx-tx__modal-field"><small>Type compte lie</small><strong id="d-typecompte">{{ detail_account.typeCompte|default('-') }}</strong></div>
        <div class="nx-tx__modal-field"><small>Statut compte lie</small><strong id="d-statutcompte">{{ detail_account.statutCompte|default('-') }}</strong></div>
        <div class="nx-tx__modal-field"><small>Solde compte lie</small><strong id="d-soldecompte">{% if detail_account.solde is defined and detail_account.solde is not null %}{{ detail_account.solde|number_format(2, '.', ' ') }} DT{% else %}-{% endif %}</strong></div>
        <div class="nx-tx__modal-field is-wide"><small>Description</small><strong id="d-description">{{ detail_tx.description|default('-') }}</strong></div>
      </div>
    </div>
  </div>
</div>
{% set detail_rec = view_reclamation ?: {} %}
{% set detail_rec_tx = view_reclamation and view_reclamation.linked_transaction is defined and view_reclamation.linked_transaction ? view_reclamation.linked_transaction : {} %}
<div class="nx-tx__modal {% if active_panel == 'reclamation' and view_reclamation %}is-open{% endif %}" id="nx-rec-modal" {% if active_panel == 'reclamation' and view_reclamation %}aria-hidden="false"{% else %}aria-hidden="true"{% endif %}>
  <div class="nx-tx__modal-dialog" role="dialog" aria-modal="true" aria-labelledby="nx-rec-modal-title">
    <div class="nx-tx__modal-head">
      <div class="nx-tx__modal-title">
        <div class="nx-tx__modal-icon"><i class="fa-solid fa-flag"></i></div>
        <div class="nx-tx__modal-copy">
          <h3 id="nx-rec-modal-title">Details de la reclamation</h3>
          <p>Toutes les informations importantes de la reclamation selectionnee.</p>
        </div>
      </div>
      <button type="button" class="nx-tx__modal-close" id="nx-rec-modal-close" aria-label="Fermer"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <div class="nx-tx__modal-body">
      <div class="nx-tx__modal-banner">
        <div class="nx-tx__spotlight">
          <small>Type reclamation</small>
          <strong id="vr-type">{{ detail_rec.typeReclamation|default('-') }}</strong>
          <p><span class="nx-tx__tag cat-default" id="vr-status">{{ detail_rec.status|default('-') }}</span></p>
        </div>
        <div class="nx-tx__mini-stack">
          <div class="nx-tx__mini-card"><small>ID reclamation</small><strong id="vr-id">{{ detail_rec.idReclamation is defined ? '#' ~ detail_rec.idReclamation : '-' }}</strong></div>
          <div class="nx-tx__mini-card"><small>ID transaction</small><strong id="vr-txid">{{ detail_rec.idTransaction is defined ? '#' ~ detail_rec.idTransaction : '-' }}</strong></div>
        </div>
      </div>
      <div class="nx-tx__modal-grid">
        <div class="nx-tx__modal-field"><small>Date reclamation</small><strong id="vr-date">{{ detail_rec.dateReclamation|default('-') }}</strong></div>
        <div class="nx-tx__modal-field"><small>Numero compte</small><strong id="vr-numero">{{ detail_rec.numeroCompte|default('-') }}</strong></div>
        <div class="nx-tx__modal-field"><small>ID utilisateur</small><strong id="vr-userid">{{ detail_rec.resolved_user_id|default(detail_rec.idUser|default('-')) }}</strong></div>
        <div class="nx-tx__modal-field"><small>Utilisateur</small><strong id="vr-username">{{ detail_rec.user_name|default('-') }}</strong></div>
        <div class="nx-tx__modal-field"><small>Transaction liee type</small><strong id="vr-txtype">{{ detail_rec.transaction_type|default('-') }}</strong></div>
        <div class="nx-tx__modal-field"><small>Transaction liee categorie</small><strong id="vr-txcat">{{ detail_rec.transaction_category|default('-') }}</strong></div>
        <div class="nx-tx__modal-field"><small>Inappropriee</small><strong id="vr-inappropriate">{{ detail_rec.is_inappropriate|default(0) ? 'Oui' : 'Non' }}</strong></div>
        <div class="nx-tx__modal-field"><small>Flou</small><strong id="vr-blurred">{{ detail_rec.is_blurred|default(0) ? 'Oui' : 'Non' }}</strong></div>
        <div class="nx-tx__modal-field is-wide"><small>Description</small><strong id="vr-description">{{ detail_rec.description|default('-') }}</strong></div>
      </div>
    </div>
  </div>
</div>

{# ═══ MODAL RÉPONSE IA ═══ #}
<div class="ai-response-modal" id="ai-response-modal" aria-hidden="true">
  <div class="ai-response-modal__overlay" onclick="closeAIResponseModal()"></div>
  <div class="ai-response-modal__dialog">
    <div class="ai-response-modal__header">
      <div class="ai-response-modal__icon">
        <i class="fa-solid fa-wand-magic-sparkles"></i>
      </div>
      <div class="ai-response-modal__title">
        <h3>Réponse générée par IA</h3>
        <p>Modifiez la réponse si nécessaire avant de l'envoyer</p>
      </div>
      <button type="button" class="ai-response-modal__close" onclick="closeAIResponseModal()" aria-label="Fermer">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>
    
    <div class="ai-response-modal__body">
      <div class="ai-response-modal__info">
        <div class="ai-response-modal__info-item">
          <i class="fa-solid fa-user"></i>
          <span id="ai-user-name">-</span>
        </div>
        <div class="ai-response-modal__info-item">
          <i class="fa-solid fa-envelope"></i>
          <span id="ai-user-email">-</span>
        </div>
        <div class="ai-response-modal__info-item">
          <i class="fa-solid fa-flag"></i>
          <span id="ai-reclamation-type">-</span>
        </div>
      </div>
      
      <div class="ai-response-modal__content">
        <label for="ai-response-text">
          <i class="fa-solid fa-pen-to-square"></i>
          Réponse à envoyer
        </label>
        <textarea id="ai-response-text" rows="12" placeholder="Génération de la réponse en cours..."></textarea>
        <div class="ai-response-modal__char-count">
          <span id="ai-char-count">0</span> caractères
        </div>
      </div>
    </div>
    
    <div class="ai-response-modal__footer">
      <button type="button" class="ai-response-modal__btn ai-response-modal__btn--cancel" onclick="closeAIResponseModal()">
        <i class="fa-solid fa-xmark"></i>
        Annuler
      </button>
      <button type="button" class="ai-response-modal__btn ai-response-modal__btn--regenerate" onclick="regenerateAIResponse()">
        <i class="fa-solid fa-rotate"></i>
        Régénérer
      </button>
      <button type="button" class="ai-response-modal__btn ai-response-modal__btn--send" onclick="sendAIResponse()">
        <i class="fa-solid fa-paper-plane"></i>
        Envoyer l'email
      </button>
    </div>
  </div>
</div>

<style>
.ai-response-modal{position:fixed;inset:0;display:none;align-items:center;justify-content:center;z-index:2000;animation:fadeIn .3s ease}
.ai-response-modal.is-open{display:flex}
.ai-response-modal__overlay{position:absolute;inset:0;background:rgba(15,23,42,.6);backdrop-filter:blur(8px)}
.ai-response-modal__dialog{position:relative;width:min(700px,90vw);max-height:85vh;background:#fff;border-radius:20px;box-shadow:0 25px 50px rgba(0,0,0,.25);overflow:hidden;animation:slideUp .4s cubic-bezier(0.34,1.56,0.64,1)}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@keyframes slideUp{from{opacity:0;transform:translateY(30px) scale(0.95)}to{opacity:1;transform:translateY(0) scale(1)}}
.ai-response-modal__header{background:linear-gradient(135deg,#8b5cf6 0%,#7c3aed 100%);color:#fff;padding:1.5rem 1.8rem;display:flex;align-items:center;gap:1rem;position:relative;overflow:hidden}
.ai-response-modal__header::before{content:'';position:absolute;top:-50%;right:-10%;width:200px;height:200px;border-radius:50%;background:radial-gradient(circle,rgba(255,255,255,.15) 0%,transparent 70%);animation:pulse 3s ease-in-out infinite}
@keyframes pulse{0%,100%{transform:scale(1);opacity:.5}50%{transform:scale(1.1);opacity:.8}}
.ai-response-modal__icon{width:50px;height:50px;border-radius:14px;background:rgba(255,255,255,.2);display:grid;place-items:center;font-size:1.4rem;flex-shrink:0;position:relative;z-index:1}
.ai-response-modal__title{flex:1;position:relative;z-index:1}
.ai-response-modal__title h3{margin:0 0 .3rem;font-size:1.15rem;font-weight:800}
.ai-response-modal__title p{margin:0;font-size:.8rem;opacity:.9}
.ai-response-modal__close{width:40px;height:40px;border:none;border-radius:12px;background:rgba(255,255,255,.15);color:#fff;cursor:pointer;display:grid;place-items:center;font-size:1.1rem;transition:all .2s;position:relative;z-index:1}
.ai-response-modal__close:hover{background:rgba(255,255,255,.25);transform:rotate(90deg)}
.ai-response-modal__body{padding:1.8rem;max-height:calc(85vh - 200px);overflow-y:auto}
.ai-response-modal__info{display:flex;gap:1rem;margin-bottom:1.5rem;flex-wrap:wrap}
.ai-response-modal__info-item{display:flex;align-items:center;gap:.5rem;padding:.6rem 1rem;background:linear-gradient(135deg,#f8fafc,#f1f5f9);border-radius:10px;font-size:.85rem;color:#475569;font-weight:600;border:1px solid #e2e8f0}
.ai-response-modal__info-item i{color:#8b5cf6;font-size:1rem}
.ai-response-modal__content label{display:flex;align-items:center;gap:.5rem;font-size:.85rem;font-weight:700;color:#334155;margin-bottom:.8rem;text-transform:uppercase;letter-spacing:.5px}
.ai-response-modal__content label i{color:#8b5cf6}
.ai-response-modal__content textarea{width:100%;padding:1rem;border:2px solid #e2e8f0;border-radius:12px;font-size:.9rem;font-family:inherit;line-height:1.6;color:#1e293b;resize:vertical;transition:all .2s;box-sizing:border-box}
.ai-response-modal__content textarea:focus{outline:none;border-color:#8b5cf6;box-shadow:0 0 0 4px rgba(139,92,246,.1)}
.ai-response-modal__char-count{text-align:right;font-size:.75rem;color:#94a3b8;margin-top:.5rem}
.ai-response-modal__footer{padding:1.2rem 1.8rem;background:#f8fafc;border-top:2px solid #e2e8f0;display:flex;gap:.8rem;justify-content:flex-end}
.ai-response-modal__btn{display:inline-flex;align-items:center;gap:.5rem;padding:.7rem 1.3rem;border-radius:10px;font-size:.85rem;font-weight:700;border:none;cursor:pointer;transition:all .2s;font-family:inherit}
.ai-response-modal__btn--cancel{background:#fff;color:#64748b;border:2px solid #e2e8f0}
.ai-response-modal__btn--cancel:hover{border-color:#cbd5e1;transform:translateY(-2px)}
.ai-response-modal__btn--regenerate{background:linear-gradient(135deg,#f59e0b,#d97706);color:#fff;box-shadow:0 4px 12px rgba(245,158,11,.3)}
.ai-response-modal__btn--regenerate:hover{transform:translateY(-2px);box-shadow:0 6px 16px rgba(245,158,11,.4)}
.ai-response-modal__btn--send{background:linear-gradient(135deg,#8b5cf6,#7c3aed);color:#fff;box-shadow:0 4px 12px rgba(139,92,246,.3)}
.ai-response-modal__btn--send:hover{transform:translateY(-2px);box-shadow:0 6px 16px rgba(139,92,246,.4)}
.ai-response-modal__btn:disabled{opacity:.5;cursor:not-allowed;transform:none !important}
</style>

<script>
(() => {
  const form = document.getElementById('nx-transaction-form');
  const searchInput = document.getElementById('nx-tx-search-input');
  const suggestions = document.getElementById('nx-tx-suggestions');
  const sortField = document.getElementById('nx-tx-sort-field');
  const dirInput = document.getElementById('nx-tx-dir-input');
  const dirButton = document.getElementById('nx-tx-sort-dir');
  const searchForm = document.getElementById('nx-tx-search-form');
  const table = document.getElementById('nx-tx-table');
  const count = document.getElementById('nx-tx-count');
  const exportBtn = document.getElementById('nx-export-btn');
  const statsToggle = document.getElementById('nx-tx-stats-toggle');
  const statsPanel = document.getElementById('nx-tx-stats-panel');
  const statsClose = document.getElementById('nx-tx-stats-close');
  const modal = document.getElementById('nx-tx-modal');
  const modalClose = document.getElementById('nx-tx-modal-close');
  if (!form) return;

  // ═══ GESTION DES SECTIONS CONDITIONNELLES ═══
  const typeRadios = document.querySelectorAll('input[name="typeTransaction"]');
  const sectionDepot = document.querySelector('.section-depot');
  const sectionRetrait = document.querySelector('.section-retrait');
  const sectionVirement = document.querySelector('.section-virement');
  const sectionPaiement = document.querySelector('.section-paiement');
  const btnPayerStripe = document.getElementById('btn-payer-stripe');
  const compteSelect = document.getElementById('f-compte');
  const soldeDisplay = document.getElementById('solde-disponible');

  function hideAllSections() {
    if (sectionDepot) sectionDepot.style.display = 'none';
    if (sectionRetrait) sectionRetrait.style.display = 'none';
    if (sectionVirement) sectionVirement.style.display = 'none';
    if (sectionPaiement) sectionPaiement.style.display = 'none';
  }

  function showSectionForType(type) {
    hideAllSections();
    switch(type) {
      case 'DEPOT':
        if (sectionDepot) sectionDepot.style.display = 'block';
        break;
      case 'RETRAIT':
        if (sectionRetrait) sectionRetrait.style.display = 'block';
        updateSoldeDisplay();
        break;
      case 'VIREMENT':
        if (sectionVirement) sectionVirement.style.display = 'block';
        break;
      case 'PAIEMENT':
        if (sectionPaiement) sectionPaiement.style.display = 'block';
        break;
    }
  }

  function updateSoldeDisplay() {
    if (!compteSelect || !soldeDisplay) return;
    const selectedOption = compteSelect.options[compteSelect.selectedIndex];
    const solde = selectedOption?.dataset?.solde || '0';
    soldeDisplay.textContent = `${Number(solde).toFixed(2)} DT`;
  }

  typeRadios.forEach(radio => {
    radio.addEventListener('change', () => {
      showSectionForType(radio.value);
    });
  });

  if (compteSelect) {
    compteSelect.addEventListener('change', updateSoldeDisplay);
  }

  // Bouton Stripe pour PAIEMENT
  if (btnPayerStripe) {
    btnPayerStripe.addEventListener('click', () => {
      console.log('[Stripe] Bouton cliqué');
      
      // Ajouter le champ action pour indiquer qu'on veut payer
      let actionInput = form.querySelector('input[name="action"]');
      if (!actionInput) {
        actionInput = document.createElement('input');
        actionInput.type = 'hidden';
        actionInput.name = 'action';
        form.appendChild(actionInput);
      }
      actionInput.value = 'transaction_save';
      
      console.log('[Stripe] Soumission du formulaire');
      form.submit();
    });
  }

  // Afficher la section appropriée au chargement
  const checkedRadio = document.querySelector('input[name="typeTransaction"]:checked');
  if (checkedRadio) {
    showSectionForType(checkedRadio.value);
  }
  updateSoldeDisplay();

  let selectedRow = null;
  let searchTimer = null;

  const setValue = (id, value) => { const el = document.getElementById(id); if (el) el.value = value ?? ''; };
  const setText = (id, value) => { const el = document.getElementById(id); if (el) el.textContent = value ?? '-'; };
  const transactionFieldIds = ['f-compte','f-compteDestinataire','f-nomDestinataire','f-emailDestinataire','f-emailBenef','f-categorie','f-dateTransaction','f-montant-depot','f-montant-retrait','f-montant-virement','f-description','f-montantPaye'];
  const transactionNeutralMessages = {
    'f-compte': 'Veuillez selectionner un compte.',
    'f-compteDestinataire': 'Optionnel. Compte destinataire pour un virement.',
    'f-nomDestinataire': 'Minimum 2 caracteres.',
    'f-emailDestinataire': 'Optionnel.',
    'f-emailBenef': 'Optionnel.',
    'f-categorie': 'Veuillez selectionner une categorie.',
    'f-dateTransaction': 'Veuillez choisir une date valide.',
    'f-montant-depot': 'Le montant doit etre superieur a 0.',
    'f-montant-retrait': 'Le montant doit etre superieur a 0.',
    'f-montant-virement': 'Le montant doit etre superieur a 0.',
    'f-description': 'Champ optionnel.',
    'f-montantPaye': 'Le montant doit etre superieur a 0.',
  };
  let transactionValidationStarted = false;
  const formatMoney = (value) => { const amount = Number(value); return Number.isFinite(amount) ? `${amount.toFixed(2)} DT` : '-'; };
  const setFieldState = (id, state, message) => {
    const input = document.getElementById(id);
    const feedback = document.getElementById(`${id}-feedback`);
    if (!input || !feedback) return state === 'valid';
    input.classList.remove('is-error', 'is-valid');
    feedback.classList.remove('is-error', 'is-valid', 'is-neutral');
    if (state === 'error') {
      input.classList.add('is-error');
      feedback.classList.add('is-error');
    } else if (state === 'valid') {
      input.classList.add('is-valid');
      feedback.classList.add('is-valid');
    } else {
      feedback.classList.add('is-neutral');
    }
    feedback.textContent = message;
    return state === 'valid';
  };
  const resetTransactionValidationState = () => {
    transactionValidationStarted = false;
    transactionFieldIds.forEach((fieldId) => {
      setFieldState(fieldId, 'neutral', transactionNeutralMessages[fieldId] || '');
    });
  };
  const today = '{{ 'now'|date('Y-m-d') }}';
  const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/;
  const ACCOUNT_RE = /^[a-zA-Z0-9\-]{3,30}$/;
  const isSectionVisible = (selector) => { const s = document.querySelector(selector); return s && s.style.display !== 'none'; };
  const validateTransactionField = (id) => {
    const element = document.getElementById(id);
    // Skip validation si le champ est dans une section cachée
    if (element && element.closest('.section-depot, .section-retrait, .section-virement, .section-paiement')) {
      const section = element.closest('.section-depot, .section-retrait, .section-virement, .section-paiement');
      if (section.style.display === 'none') return true;
    }
    const value = String(element?.value ?? '').trim();
    switch (id) {
      case 'f-compte':
        return value !== '' ? setFieldState(id, 'valid', 'Compte valide.') : setFieldState(id, 'error', 'Veuillez selectionner un compte.');
      case 'f-compteDestinataire':
        if (isSectionVisible('.section-virement')) {
          if (value === '') return setFieldState(id, 'error', 'Le compte destinataire est obligatoire pour un virement.');
          if (!ACCOUNT_RE.test(value)) return setFieldState(id, 'error', 'Numero invalide — 3 a 30 caracteres alphanumeriques.');
          return setFieldState(id, 'valid', 'Compte destinataire valide.');
        }
        return setFieldState(id, 'valid', 'Champ optionnel.');
      case 'f-nomDestinataire':
        if (isSectionVisible('.section-virement')) {
          if (value === '') return setFieldState(id, 'error', 'Le nom du destinataire est obligatoire pour un virement.');
          if (value.length < 2) return setFieldState(id, 'error', 'Le nom doit contenir au moins 2 caracteres.');
          if (value.length > 100) return setFieldState(id, 'error', 'Le nom ne doit pas depasser 100 caracteres.');
          return setFieldState(id, 'valid', 'Nom destinataire valide.');
        }
        return true;
      case 'f-emailDestinataire':
        if (value === '') return setFieldState(id, 'valid', 'Champ optionnel.');
        if (!EMAIL_RE.test(value)) return setFieldState(id, 'error', 'Format email invalide (ex: nom@domaine.com).');
        return setFieldState(id, 'valid', 'Email valide.');
      case 'f-emailBenef':
        if (value === '') return setFieldState(id, 'valid', 'Champ optionnel.');
        if (!EMAIL_RE.test(value)) return setFieldState(id, 'error', 'Format email invalide (ex: nom@domaine.com).');
        return setFieldState(id, 'valid', 'Email valide.');
      case 'f-categorie':
        if (isSectionVisible('.section-paiement')) {
          return value !== '' ? setFieldState(id, 'valid', 'Categorie valide.') : setFieldState(id, 'error', 'Veuillez selectionner une categorie.');
        }
        return true;
      case 'f-dateTransaction':
        if (value === '') return setFieldState(id, 'error', 'La date de transaction est obligatoire.');
        if (value > today) return setFieldState(id, 'error', 'La date ne doit pas etre dans le futur.');
        return setFieldState(id, 'valid', 'Date valide.');
      case 'f-montant-depot':
      case 'f-montant-retrait':
      case 'f-montant-virement': {
        if (value === '') return setFieldState(id, 'error', 'Le montant est obligatoire.');
        const num = Number(value);
        if (num <= 0) return setFieldState(id, 'error', 'Le montant doit etre superieur a 0.');
        if (num > 1000000) return setFieldState(id, 'error', 'Montant trop eleve (max 1 000 000).');
        const dec = (value.split('.')[1] || '').length;
        if (dec > 2) return setFieldState(id, 'error', 'Maximum 2 decimales autorisees.');
        if (id === 'f-montant-retrait') {
          const compteEl = document.getElementById('f-compte');
          const solde = parseFloat(compteEl?.options[compteEl.selectedIndex]?.dataset.solde || 0);
          if (num > solde) return setFieldState(id, 'error', `Solde insuffisant — disponible : ${solde.toFixed(2)} DT.`);
        }
        return setFieldState(id, 'valid', `${num.toFixed(2)} DT (valide).`);
      }
      case 'f-montant':
        if (element && element.closest('.section-depot, .section-retrait, .section-virement')) {
          const section = element.closest('.section-depot, .section-retrait, .section-virement');
          if (section.style.display !== 'none') {
            if (value === '') return setFieldState(id, 'error', 'Le montant est obligatoire.');
            if (Number(value) <= 0) return setFieldState(id, 'error', 'Le montant doit etre superieur a 0.');
            if (Number(value) > 1000000) return setFieldState(id, 'error', 'Montant trop eleve (max 1 000 000).');
            return setFieldState(id, 'valid', 'Montant valide.');
          }
        }
        return true;
      case 'f-typeTransaction':
        return value !== '' ? setFieldState(id, 'valid', 'Type de transaction valide.') : setFieldState(id, 'error', 'Veuillez selectionner un type de transaction.');
      case 'f-description':
        if (value === '') return setFieldState(id, 'valid', 'Champ optionnel.');
        if (value.length > 255) return setFieldState(id, 'error', `Maximum 255 caracteres (${value.length}/255).`);
        return setFieldState(id, 'valid', `${value.length}/255 caracteres.`);
      case 'f-montantPaye':
        if (isSectionVisible('.section-paiement')) {
          if (value === '') return setFieldState(id, 'error', 'Le montant a payer est obligatoire.');
          if (Number(value) <= 0) return setFieldState(id, 'error', 'Le montant doit etre superieur a 0.');
          if (Number(value) > 1000000) return setFieldState(id, 'error', 'Montant trop eleve (max 1 000 000).');
          return setFieldState(id, 'valid', 'Montant a payer valide.');
        }
        return true;
      default:
        return true;
    }
  };
  const validateTransactionForm = () => {
    const commonFields = ['f-compte', 'f-dateTransaction', 'f-description'];
    const selectedType = document.querySelector('input[name="typeTransaction"]:checked')?.value;
    let fieldsToValidate = [...commonFields];
    switch(selectedType) {
      case 'DEPOT':
        fieldsToValidate.push('f-montant-depot');
        break;
      case 'RETRAIT':
        fieldsToValidate.push('f-montant-retrait');
        break;
      case 'VIREMENT':
        fieldsToValidate.push('f-compteDestinataire', 'f-nomDestinataire', 'f-emailDestinataire', 'f-montant-virement');
        break;
      case 'PAIEMENT':
        fieldsToValidate.push('f-categorie', 'f-montantPaye', 'f-emailBenef');
        break;
    }
    return fieldsToValidate.every(fieldId => {
      const element = document.getElementById(fieldId);
      if (!element) return true;
      return validateTransactionField(fieldId);
    });
  };
  const categoryClass = (value) => {
    const normalized = String(value || '').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/\s+/g, '-');
    return normalized ? `cat-${normalized}` : 'cat-default';
  };
  const categoryColors = {
    'Alimentation': '#14b8a6',
    'Education': '#2563eb',
    'Loyer': '#7c3aed',
    'Restaurant': '#ea580c',
    'Vetements': '#db2777',
    'Assurance sante': '#ca8a04',
    'Autre': '#64748b',
  };
  const canonicalType = (value) => {
    const v = String(value || '').toLowerCase();
    if (v.includes('paiement')) return 'debit';
    if (v.includes('virement')) return 'virement';
    return 'credit';
  };
  const openModal = () => { if (!modal) return; modal.classList.add('is-open'); modal.setAttribute('aria-hidden', 'false'); document.body.style.overflow = 'hidden'; };
  const closeModal = () => { if (!modal) return; modal.classList.remove('is-open'); modal.setAttribute('aria-hidden', 'true'); document.body.style.overflow = ''; };
  const visibleRows = () => Array.from(table?.querySelectorAll('tbody tr') || []).filter((row) => row.children.length > 1 && row.style.display !== 'none');
  const searchValueForRow = (row) => [row.dataset.id,row.dataset.userId,row.dataset.userName,row.dataset.idCompte,row.dataset.numeroCompte,row.dataset.compteDest,row.dataset.numeroCompteDest,row.dataset.categorie,row.dataset.date,row.dataset.montant,row.dataset.type,row.dataset.montantPaye,row.dataset.description,row.dataset.accountType,row.dataset.accountStatus,row.textContent].join(' ').toLowerCase();
  const buildExportUrl = () => {
    const params = new URLSearchParams();
    params.set('q', searchInput?.value || '');
    params.set('sort', sortField?.value || 'dateTransaction');
    params.set('dir', dirInput?.value || 'desc');
    if (selectedRow?.dataset.id) params.set('idTransaction', selectedRow.dataset.id);
    return `{{ path('admin_transactions_export_pdf') }}?${params.toString()}`;
  };
  const updateExportLink = () => { if (exportBtn) exportBtn.href = buildExportUrl(); };
  const selectRow = (row) => {
    if (!row || row.children.length <= 1) return;
    table?.querySelectorAll('tbody tr').forEach((item) => item.classList.remove('is-selected'));
    row.classList.add('is-selected');
    selectedRow = row;
    updateExportLink();
  };
  const renderSuggestions = (rows, query) => {
    if (!suggestions) return;
    const q = String(query || '').trim().toLowerCase();
    if (q === '') { suggestions.hidden = true; suggestions.innerHTML = ''; return; }
    const matches = rows.slice(0, 5);
    if (matches.length === 0) {
      suggestions.hidden = false;
      suggestions.innerHTML = '<div class="nx-tx__suggestion"><strong>Aucun resultat</strong><span>Essayez un compte, categorie, type ou description</span></div>';
      return;
    }
    suggestions.hidden = false;
    suggestions.innerHTML = matches.map((row) => `<button type="button" class="nx-tx__suggestion" data-suggest-id="${row.dataset.id}"><strong>${row.dataset.numeroCompte || '-'} · ${row.dataset.categorie || '-'}</strong><span>${row.dataset.type || '-'} · ${Number(row.dataset.montant || 0).toFixed(2)} DT</span></button>`).join('');
    suggestions.querySelectorAll('[data-suggest-id]').forEach((button) => {
      button.addEventListener('click', () => {
        const row = table?.querySelector(`tbody tr[data-id="${button.getAttribute('data-suggest-id')}"]`);
        if (!row) return;
        selectRow(row);
        row.scrollIntoView({ behavior: 'smooth', block: 'center' });
        suggestions.hidden = true;
      });
    });
  };
  const updateVisibleCount = () => {
    const visible = visibleRows().length;
    count.textContent = `${visible} transaction${visible !== 1 ? 's' : ''}`;
    const lines = document.getElementById('nx-tx-lines');
    if (lines) lines.textContent = String(visible);
  };
  const updateStats = () => {
    const rows = visibleRows();
    const stats = { total: rows.length, amount: 0, categories: {} };
    rows.forEach((row) => {
      const amount = Number(row.dataset.montant || 0);
      const category = row.dataset.categorie || 'Autre';
      stats.amount += amount;
      if (!stats.categories[category]) {
        stats.categories[category] = { label: category, count: 0, amount: 0, percentage: 0, color: categoryColors[category] || categoryColors.Autre };
      }
      stats.categories[category].count += 1;
      stats.categories[category].amount += amount;
    });

    const categories = Object.values(stats.categories).sort((left, right) => {
      const countDiff = right.count - left.count;
      return countDiff !== 0 ? countDiff : left.label.localeCompare(right.label);
    });
    categories.forEach((item) => {
      item.percentage = stats.total > 0 ? ((item.count / stats.total) * 100) : 0;
    });

    const donut = document.getElementById('nx-category-donut');
    if (donut) {
      let start = 0;
      const segments = categories.map((item) => {
        const end = start + item.percentage;
        const part = `${item.color} ${start}% ${end}%`;
        start = end;
        return part;
      });
      donut.style.background = `conic-gradient(${segments.length ? segments.join(', ') : '#dbe7f3 0 100%'})`;
    }

    const totalEl = document.getElementById('nx-stats-total');
    const amountEl = document.getElementById('nx-stats-amount');
    if (totalEl) totalEl.textContent = String(stats.total);
    if (amountEl) amountEl.textContent = `${stats.amount.toFixed(2)} DT`;

    const legend = document.getElementById('nx-category-legend');
    if (legend) {
      legend.innerHTML = categories.length
        ? categories.map((item) => `<div class="nx-tx__stats-row"><strong><span class="nx-tx__stats-dot" style="background:${item.color}"></span>${item.label}</strong><b>${item.count}</b><span>${item.percentage.toFixed(1)}%</span><span>${item.amount.toFixed(2)} DT</span></div>`).join('')
        : '<div class="nx-tx__stats-row"><strong>Aucune categorie</strong><span>0</span><span>0.0%</span><span>0.00 DT</span></div>';
    }
  };
  const applyLiveSearch = () => {
    if (!table || !searchInput) return;
    const query = searchInput.value.trim().toLowerCase();
    const bodyRows = Array.from(table.querySelectorAll('tbody tr')).filter((row) => row.children.length > 1);
    const matches = [];
    bodyRows.forEach((row) => {
      const show = query === '' || searchValueForRow(row).includes(query);
      row.style.display = show ? '' : 'none';
      if (show) matches.push(row);
    });
    if (selectedRow && selectedRow.style.display === 'none') { selectedRow.classList.remove('is-selected'); selectedRow = null; }
    renderSuggestions(matches, query);
    updateVisibleCount();
    updateStats();
    updateExportLink();
  };
  const toggleStatsPanel = (open) => {
    if (!statsPanel) return;
    const shouldOpen = open ?? !statsPanel.classList.contains('is-open');
    statsPanel.classList.toggle('is-open', shouldOpen);
    if (shouldOpen) setTimeout(updateStats, 30);
  };

  if (modal?.classList.contains('is-open')) document.body.style.overflow = 'hidden';

  window.nxResetTransactionForm = () => {
    setValue('f-idTransaction', '');
    setValue('f-compte', '');
    setValue('f-compteDestinataire', '');
    setValue('f-categorie', '');
    setValue('f-dateTransaction', '{{ 'now'|date('Y-m-d') }}');
    setValue('f-montant', '');
    setValue('f-typeTransaction', '');
    setValue('f-description', '');
    setValue('f-montantPaye', '');
    const label = document.getElementById('f-mode-label');
    if (label) label.textContent = 'Nouvelle transaction';
    resetTransactionValidationState();
  };

  window.nxEditTransaction = (row) => {
    if (!row) return;
    setValue('f-idTransaction', row.dataset.id);
    setValue('f-compte', row.dataset.idCompte);
    setValue('f-compteDestinataire', row.dataset.compteDest);
    setValue('f-categorie', row.dataset.categorie);
    setValue('f-dateTransaction', row.dataset.date);
    setValue('f-montant', row.dataset.montant);
    setValue('f-typeTransaction', row.dataset.type);
    setValue('f-description', row.dataset.description);
    setValue('f-montantPaye', row.dataset.montantPaye);
    const label = document.getElementById('f-mode-label');
    if (label) label.textContent = `Modification transaction #${row.dataset.id}`;
    selectRow(row);
    resetTransactionValidationState();
    form.scrollIntoView({ behavior: 'smooth', block: 'start' });
  };

  window.nxViewTransaction = (row) => {
    if (!row || !modal) return;
    selectRow(row);
    setText('d-id', row.dataset.id ? `#${row.dataset.id}` : '-');
    setText('d-date', row.dataset.date || '-');
    setText('d-numero', row.dataset.numeroCompte || '-');
    setText('d-idcompte', row.dataset.numeroCompte || row.dataset.idCompte || '-');
    setText('d-comptedestinataire', row.dataset.numeroCompteDest || '-');
    setText('d-userid', row.dataset.userId || '-');
    setText('d-username', row.dataset.userName || '-');
    setText('d-typecompte', row.dataset.accountType || '-');
    setText('d-statutcompte', row.dataset.accountStatus || '-');
    setText('d-soldecompte', row.dataset.accountSolde ? formatMoney(row.dataset.accountSolde) : '-');
    setText('d-montant', formatMoney(row.dataset.montant));
    setText('d-montantpaye', formatMoney(row.dataset.montantPaye));
    setText('d-description', row.dataset.description || '-');
    const categoryBadge = document.getElementById('d-categorie-badge');
    if (categoryBadge) { categoryBadge.textContent = row.dataset.categorie || '-'; categoryBadge.className = `nx-tx__tag ${categoryClass(row.dataset.categorie)}`; }
    const typeBadge = document.getElementById('d-type-badge');
    if (typeBadge) { const typeValue = row.dataset.type || '-'; typeBadge.textContent = typeValue; typeBadge.className = `nx-tx__tag ${canonicalType(typeValue) === 'debit' ? 'is-debit' : (canonicalType(typeValue) === 'virement' ? 'is-virement' : 'is-credit')}`; }
    openModal();
  };

  modalClose?.addEventListener('click', closeModal);
  modal?.addEventListener('click', (event) => { if (event.target === modal) closeModal(); });
  document.addEventListener('keydown', (event) => { if (event.key === 'Escape' && modal?.classList.contains('is-open')) closeModal(); });
  statsToggle?.addEventListener('click', () => toggleStatsPanel());
  statsClose?.addEventListener('click', () => toggleStatsPanel(false));
  transactionFieldIds.forEach((fieldId) => {
    const field = document.getElementById(fieldId);
    field?.addEventListener('input', () => { if (transactionValidationStarted) validateTransactionField(fieldId); });
    field?.addEventListener('change', () => { if (transactionValidationStarted) validateTransactionField(fieldId); });
    field?.addEventListener('blur', () => { if (transactionValidationStarted) validateTransactionField(fieldId); });
  });
  form.addEventListener('submit', (event) => {
    transactionValidationStarted = true;
    if (!validateTransactionForm()) {
      event.preventDefault();
    }
  });
  dirButton?.addEventListener('click', () => {
    dirInput.value = dirInput.value === 'asc' ? 'desc' : 'asc';
    const icon = dirButton.querySelector('i');
    if (icon) icon.className = 'fa-solid ' + (dirInput.value === 'asc' ? 'fa-arrow-up-a-z' : 'fa-arrow-down-z-a');
    updateExportLink();
    searchForm?.submit();
  });
  sortField?.addEventListener('change', () => { updateExportLink(); searchForm?.submit(); });
  searchInput?.addEventListener('input', () => { clearTimeout(searchTimer); searchTimer = setTimeout(applyLiveSearch, 120); });
  searchInput?.addEventListener('keydown', (event) => { if (event.key === 'Enter') { event.preventDefault(); applyLiveSearch(); } });
  document.addEventListener('click', (event) => { if (suggestions && !event.target.closest('#nx-tx-search-form')) suggestions.hidden = true; });
  table?.querySelectorAll('tbody tr').forEach((row) => {
    if (row.children.length <= 1) return;
    row.addEventListener('click', (event) => { if (event.target.closest('button, a, form')) return; selectRow(row); });
    row.addEventListener('keydown', (event) => { if (event.key === 'Enter' || event.key === ' ') { event.preventDefault(); selectRow(row); } });
  });

  updateVisibleCount();
  updateStats();
  updateExportLink();
  resetTransactionValidationState();
  setTimeout(updateStats, 60);
})();
</script>
<script>
(() => {
  const form = document.getElementById('nx-reclamation-form');
  const searchInput = document.getElementById('nx-rec-search-input');
  const suggestions = document.getElementById('nx-rec-suggestions');
  const sortField = document.getElementById('nx-rec-sort-field');
  const dirInput = document.getElementById('nx-rec-dir-input');
  const dirButton = document.getElementById('nx-rec-sort-dir');
  const searchForm = document.getElementById('nx-rec-search-form');
  const table = document.getElementById('nx-rec-table');
  const count = document.getElementById('nx-rec-count');
  const modal = document.getElementById('nx-rec-modal');
  const modalClose = document.getElementById('nx-rec-modal-close');
  if (!form) return;

  let selectedRow = null;
  let searchTimer = null;

  const setValue = (id, value) => { const el = document.getElementById(id); if (el) el.value = value ?? ''; };
  const setText = (id, value) => { const el = document.getElementById(id); if (el) el.textContent = value ?? '-'; };
  const reclamationFieldIds = ['r-dateReclamation','r-typeReclamation','r-description','r-status','r-idTransaction'];
  const reclamationNeutralMessages = {
    'r-dateReclamation': 'Veuillez choisir une date valide.',
    'r-typeReclamation': 'Veuillez selectionner un type de reclamation.',
    'r-description': 'La description doit contenir au moins 10 caracteres.',
    'r-status': 'Veuillez selectionner un status.',
    'r-idTransaction': 'Veuillez selectionner une transaction.',
  };
  let reclamationValidationStarted = false;
  const setFieldState = (id, state, message) => {
    const input = document.getElementById(id);
    const feedback = document.getElementById(`${id}-feedback`);
    if (!input || !feedback) return state === 'valid';
    input.classList.remove('is-error', 'is-valid');
    feedback.classList.remove('is-error', 'is-valid', 'is-neutral');
    if (state === 'error') {
      input.classList.add('is-error');
      feedback.classList.add('is-error');
    } else if (state === 'valid') {
      input.classList.add('is-valid');
      feedback.classList.add('is-valid');
    } else {
      feedback.classList.add('is-neutral');
    }
    feedback.textContent = message;
    return state === 'valid';
  };
  const resetReclamationValidationState = () => {
    reclamationValidationStarted = false;
    reclamationFieldIds.forEach((fieldId) => {
      setFieldState(fieldId, 'neutral', reclamationNeutralMessages[fieldId] || '');
    });
  };
  const today = '{{ 'now'|date('Y-m-d') }}';
  const validateReclamationField = (id) => {
    const value = String(document.getElementById(id)?.value ?? '').trim();
    switch (id) {
      case 'r-dateReclamation':
        if (value === '') return setFieldState(id, 'error', 'La date de reclamation est obligatoire.');
        if (value > today) return setFieldState(id, 'error', 'La date ne doit pas etre dans le futur.');
        return setFieldState(id, 'valid', 'Date valide.');
      case 'r-typeReclamation':
        return value !== '' ? setFieldState(id, 'valid', 'Type de reclamation valide.') : setFieldState(id, 'error', 'Veuillez selectionner un type de reclamation.');
      case 'r-description':
        if (value === '') return setFieldState(id, 'error', 'La description est obligatoire.');
        if (value.length < 10) return setFieldState(id, 'error', 'La description doit contenir au moins 10 caracteres.');
        return setFieldState(id, 'valid', 'Description valide.');
      case 'r-status':
        return value !== '' ? setFieldState(id, 'valid', 'Status valide.') : setFieldState(id, 'error', 'Veuillez selectionner un status.');
      case 'r-idTransaction':
        return value !== '' ? setFieldState(id, 'valid', 'Transaction valide.') : setFieldState(id, 'error', 'Veuillez selectionner une transaction.');
      default:
        return true;
    }
  };
  const validateReclamationForm = () => reclamationFieldIds.every(validateReclamationField);
  const visibleRows = () => Array.from(document.querySelectorAll('.rec-card') || []).filter((card) => card.style.display !== 'none');
  const haystack = (card) => [card.dataset.id,card.dataset.date,card.dataset.type,card.dataset.status,card.dataset.idTransaction,card.dataset.numeroCompte,card.dataset.userId,card.dataset.userName,card.dataset.description,card.dataset.transactionType,card.dataset.transactionCategory,card.textContent].join(' ').toLowerCase();
  const selectRow = (card) => {
    if (!card) return;
    document.querySelectorAll('.rec-card').forEach((item) => item.classList.remove('is-selected'));
    card.classList.add('is-selected');
    selectedRow = card;
  };
  const renderSuggestions = (cards, query) => {
    if (!suggestions) return;
    const q = String(query || '').trim().toLowerCase();
    if (q === '') { suggestions.hidden = true; suggestions.innerHTML = ''; return; }
    const matches = cards.slice(0, 5);
    if (matches.length === 0) {
      suggestions.hidden = false;
      suggestions.innerHTML = '<div class="nx-tx__suggestion"><strong>Aucun resultat</strong><span>Essayez type, status, transaction ou utilisateur</span></div>';
      return;
    }
    suggestions.hidden = false;
    suggestions.innerHTML = matches.map((card) => `<button type="button" class="nx-tx__suggestion" data-suggest-id="${card.dataset.id}"><strong>#${card.dataset.id} · ${card.dataset.type || '-'}</strong><span>${card.dataset.status || '-'} · ${card.dataset.userName || '-'}</span></button>`).join('');
    suggestions.querySelectorAll('[data-suggest-id]').forEach((button) => {
      button.addEventListener('click', () => {
        const card = document.querySelector(`.rec-card[data-id="${button.getAttribute('data-suggest-id')}"]`);
        if (!card) return;
        selectRow(card);
        card.scrollIntoView({ behavior: 'smooth', block: 'center' });
        suggestions.hidden = true;
      });
    });
  };
  const updateVisibleCount = () => {
    const visible = visibleRows().length;
    count.textContent = `${visible} reclamation${visible !== 1 ? 's' : ''}`;
    const lines = document.getElementById('nx-rec-lines');
    if (lines) lines.textContent = String(visible);
  };
  const applySearch = () => {
    if (!searchInput) return;
    const query = searchInput.value.trim().toLowerCase();
    const cards = Array.from(document.querySelectorAll('.rec-card'));
    const matches = [];
    cards.forEach((card) => {
      const show = query === '' || haystack(card).includes(query);
      card.style.display = show ? '' : 'none';
      if (show) matches.push(card);
    });
    if (selectedRow && selectedRow.style.display === 'none') { selectedRow.classList.remove('is-selected'); selectedRow = null; }
    renderSuggestions(matches, query);
    updateVisibleCount();
  };

  window.nxResetReclamationForm = () => {
    setValue('r-idReclamation', '');
    setValue('r-dateReclamation', '{{ 'now'|date('Y-m-d') }}');
    setValue('r-typeReclamation', '');
    setValue('r-description', '');
    setValue('r-status', '');
    setValue('r-idTransaction', '');
    const label = document.getElementById('r-mode-label');
    if (label) label.textContent = 'Nouvelle reclamation';
    resetReclamationValidationState();
  };

  window.nxEditReclamation = (card) => {
    if (!card) return;
    setValue('r-idReclamation', card.dataset.id);
    setValue('r-dateReclamation', card.dataset.date);
    setValue('r-typeReclamation', card.dataset.type);
    setValue('r-description', card.dataset.description);
    setValue('r-status', card.dataset.status);
    setValue('r-idTransaction', card.dataset.idTransaction);
    const label = document.getElementById('r-mode-label');
    if (label) label.textContent = `Modification reclamation #${card.dataset.id}`;
    selectRow(card);
    resetReclamationValidationState();
    form.scrollIntoView({ behavior: 'smooth', block: 'start' });
  };

  window.nxViewReclamation = (card) => {
    if (!card || !modal) return;
    selectRow(card);
    setText('vr-id', card.dataset.id ? `#${card.dataset.id}` : '-');
    setText('vr-date', card.dataset.date || '-');
    setText('vr-type', card.dataset.type || '-');
    setText('vr-status', card.dataset.status || '-');
    setText('vr-txid', card.dataset.idTransaction ? `#${card.dataset.idTransaction}` : '-');
    setText('vr-numero', card.dataset.numeroCompte || '-');
    setText('vr-userid', card.dataset.userId || '-');
    setText('vr-username', card.dataset.userName || '-');
    setText('vr-txtype', card.dataset.transactionType || '-');
    setText('vr-txcat', card.dataset.transactionCategory || '-');
    setText('vr-inappropriate', card.dataset.inappropriate === '1' ? 'Oui' : 'Non');
    setText('vr-blurred', card.dataset.blurred === '1' ? 'Oui' : 'Non');
    setText('vr-description', card.dataset.description || '-');
    modal.classList.add('is-open');
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  };

  modalClose?.addEventListener('click', () => {
    modal.classList.remove('is-open');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  });
  modal?.addEventListener('click', (event) => {
    if (event.target === modal) {
      modal.classList.remove('is-open');
      modal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }
  });

  reclamationFieldIds.forEach((fieldId) => {
    const field = document.getElementById(fieldId);
    field?.addEventListener('input', () => { if (reclamationValidationStarted) validateReclamationField(fieldId); });
    field?.addEventListener('change', () => { if (reclamationValidationStarted) validateReclamationField(fieldId); });
    field?.addEventListener('blur', () => { if (reclamationValidationStarted) validateReclamationField(fieldId); });
  });
  form.addEventListener('submit', (event) => {
    reclamationValidationStarted = true;
    if (!validateReclamationForm()) {
      event.preventDefault();
    }
  });
  dirButton?.addEventListener('click', () => {
    dirInput.value = dirInput.value === 'asc' ? 'desc' : 'asc';
    const icon = dirButton.querySelector('i');
    if (icon) icon.className = 'fa-solid ' + (dirInput.value === 'asc' ? 'fa-arrow-up-a-z' : 'fa-arrow-down-z-a');
    searchForm?.submit();
  });
  sortField?.addEventListener('change', () => searchForm?.submit());
  searchInput?.addEventListener('input', () => { clearTimeout(searchTimer); searchTimer = setTimeout(applySearch, 120); });
  searchInput?.addEventListener('keydown', (event) => { if (event.key === 'Enter') { event.preventDefault(); applySearch(); } });
  document.addEventListener('click', (event) => { if (suggestions && !event.target.closest('#nx-rec-search-form')) suggestions.hidden = true; });
  document.querySelectorAll('.rec-card').forEach((card) => {
    card.addEventListener('click', (event) => { if (event.target.closest('button, a, form')) return; selectRow(card); });
  });

  updateVisibleCount();
  resetReclamationValidationState();
})();

// ═══ MODERATION FUNCTION ═══
window.moderateReclamation = async (reclamationId, action) => {
  if (!reclamationId || !action) {
    console.error('[Moderation] Invalid parameters:', { reclamationId, action });
    return;
  }

  console.log('[Moderation] Starting moderation:', { reclamationId, action });

  try {
    const formData = new FormData();
    formData.append('idReclamation', reclamationId);
    formData.append('action', action);

    const response = await fetch('/portal/api/reclamation/moderate', {
      method: 'POST',
      body: formData
    });

    const data = await response.json();
    console.log('[Moderation] Response:', data);

    if (data.success) {
      // Recharger la page pour afficher les changements
      window.location.reload();
    } else {
      alert('Erreur lors de la modération: ' + (data.message || data.error || 'Erreur inconnue'));
    }
  } catch (error) {
    console.error('[Moderation] Error:', error);
    alert('Erreur lors de la modération. Veuillez réessayer.');
  }
};

// ═══ AI RESPONSE FUNCTION ═══
var currentReclamationData = null;

window.respondWithAI = async (reclamationId, userName, reclamationType, description) => {
  if (!reclamationId) {
    alert('ID de réclamation invalide');
    return;
  }

  // Stocker les données de la réclamation
  currentReclamationData = {
    reclamationId,
    userName,
    reclamationType,
    description
  };

  // Ouvrir la modal
  openAIResponseModal();

  // Générer la réponse
  await generateAIResponseForModal();
};

function openAIResponseModal() {
  const modal = document.getElementById('ai-response-modal');
  if (!modal) return;
  
  modal.classList.add('is-open');
  modal.setAttribute('aria-hidden', 'false');
  document.body.style.overflow = 'hidden';
  
  // Réinitialiser le textarea
  const textarea = document.getElementById('ai-response-text');
  if (textarea) {
    textarea.value = 'Génération de la réponse en cours...';
    textarea.disabled = true;
  }
}

window.closeAIResponseModal = function() {
  const modal = document.getElementById('ai-response-modal');
  if (!modal) return;
  
  modal.classList.remove('is-open');
  modal.setAttribute('aria-hidden', 'true');
  document.body.style.overflow = '';
  currentReclamationData = null;
};

async function generateAIResponseForModal() {
  if (!currentReclamationData) return;
  
  const { reclamationId, userName, reclamationType, description } = currentReclamationData;
  
  // Mettre à jour les infos dans la modal
  document.getElementById('ai-user-name').textContent = userName;
  document.getElementById('ai-reclamation-type').textContent = reclamationType;
  
  const textarea = document.getElementById('ai-response-text');
  
  try {
    // Appeler l'API pour générer la réponse (sans envoyer l'email)
    const formData = new FormData();
    formData.append('reclamationId', reclamationId);
    formData.append('userName', userName);
    formData.append('reclamationType', reclamationType);
    formData.append('description', description);
    formData.append('generateOnly', '1'); // Nouveau paramètre pour ne pas envoyer l'email

    const response = await fetch('/admin/api/reclamation/respond-ai', {
      method: 'POST',
      body: formData
    });

    const data = await response.json();
    console.log('[AI Response] Response:', data);

    if (data.success) {
      textarea.value = data.response;
      textarea.disabled = false;
      document.getElementById('ai-user-email').textContent = data.email || '-';
      updateCharCount();
    } else {
      textarea.value = 'Erreur lors de la génération: ' + (data.message || data.error || 'Erreur inconnue');
      textarea.disabled = false;
    }
  } catch (error) {
    console.error('[AI Response] Error:', error);
    textarea.value = 'Erreur lors de la génération de la réponse. Veuillez réessayer.';
    textarea.disabled = false;
  }
}

window.regenerateAIResponse = async function() {
  const btn = event.target.closest('.ai-response-modal__btn--regenerate');
  const originalHTML = btn.innerHTML;
  btn.disabled = true;
  btn.innerHTML = '<i class="fa-solid fa-circle-notch fa-spin"></i> Génération...';
  
  await generateAIResponseForModal();
  
  btn.disabled = false;
  btn.innerHTML = originalHTML;
};

window.sendAIResponse = async function() {
  if (!currentReclamationData) return;
  
  const textarea = document.getElementById('ai-response-text');
  const response = textarea.value.trim();
  
  if (!response || response === 'Génération de la réponse en cours...') {
    alert('Veuillez attendre que la réponse soit générée');
    return;
  }
  
  if (!confirm('Envoyer cet email à ' + currentReclamationData.userName + ' ?')) {
    return;
  }
  
  const btn = event.target.closest('.ai-response-modal__btn--send');
  const originalHTML = btn.innerHTML;
  btn.disabled = true;
  btn.innerHTML = '<i class="fa-solid fa-circle-notch fa-spin"></i> Envoi...';
  
  try {
    const formData = new FormData();
    formData.append('reclamationId', currentReclamationData.reclamationId);
    formData.append('userName', currentReclamationData.userName);
    formData.append('reclamationType', currentReclamationData.reclamationType);
    formData.append('description', currentReclamationData.description);
    formData.append('customResponse', response); // Envoyer la réponse modifiée
    formData.append('sendEmail', '1'); // Indiquer qu'on veut envoyer l'email

    const apiResponse = await fetch('/admin/api/reclamation/respond-ai', {
      method: 'POST',
      body: formData
    });

    const data = await apiResponse.json();
    console.log('[AI Send] Response:', data);

    if (data.success) {
      alert('✅ Email envoyé avec succès à ' + currentReclamationData.userName + ' !');
      closeAIResponseModal();
    } else {
      alert('❌ Erreur: ' + (data.message || data.error || 'Erreur inconnue'));
      btn.disabled = false;
      btn.innerHTML = originalHTML;
    }
  } catch (error) {
    console.error('[AI Send] Error:', error);
    alert('❌ Erreur lors de l\'envoi de l\'email. Veuillez réessayer.');
    btn.disabled = false;
    btn.innerHTML = originalHTML;
  }
};

function updateCharCount() {
  const textarea = document.getElementById('ai-response-text');
  const charCount = document.getElementById('ai-char-count');
  if (textarea && charCount) {
    charCount.textContent = textarea.value.length;
  }
}

// Écouter les changements dans le textarea
document.addEventListener('DOMContentLoaded', () => {
  const textarea = document.getElementById('ai-response-text');
  if (textarea) {
    textarea.addEventListener('input', updateCharCount);
  }
});
</script>

