              <i class="fa-solid fa-rotate-right"></i>
              <span>Actualiser</span>
            </a>
            <a class="nx-prof__quick-item"
               href="{{ path('admin_features', { section: 'security' }) }}">
              <i class="fa-solid fa-fingerprint"></i>
              <span>Test Bio</span>
            </a>
            <a class="nx-prof__quick-item"
               href="{{ path('admin_features', { section: 'security' }) }}">
              <i class="fa-solid fa-sliders"></i>
              <span>Paramètres</span>
            </a>
          </div>
        </div>
      </article>

    </div>{# /right col #}
  </div>{# /grid #}

</section>

{# ── Scripts ── #}
<script defer src="https://cdn.jsdelivr.net/npm/face-api.js@0.22.2/dist/face-api.min.js"></script>
<script>
(() => {
  const descriptorInput = document.getElementById('nx-admin-bio-face-descriptor');
  const videoEl         = document.getElementById('nx-admin-bio-video');
  const statusEl        = document.getElementById('nx-admin-bio-status');
  const startBtn        = document.getElementById('nx-admin-bio-start');
  const captureBtn      = document.getElementById('nx-admin-bio-capture');

  if (!descriptorInput || !videoEl || !statusEl || !startBtn || !captureBtn) return;

  const MODEL_URL = 'https://cdn.jsdelivr.net/gh/justadudewhohacks/face-api.js@master/weights';
  let stream      = null;
  let modelsReady = false;

  const setStatus = (msg, icon = 'fa-circle-info') => {
    statusEl.innerHTML = `<i class="fa-solid ${icon}"></i> ${msg}`;
  };

  const ensureModels = async () => {
    if (modelsReady) return true;
    if (typeof window.faceapi === 'undefined') {
      setStatus('Chargement de la bibliothèque Face ID…', 'fa-spinner fa-spin');
      return false;
    }
    setStatus('Chargement des modèles IA…', 'fa-spinner fa-spin');
    await Promise.all([
      window.faceapi.nets.tinyFaceDetector.loadFromUri(MODEL_URL),
      window.faceapi.nets.faceLandmark68Net.loadFromUri(MODEL_URL),
      window.faceapi.nets.faceRecognitionNet.loadFromUri(MODEL_URL),
    ]);
    modelsReady = true;
    setStatus('Modèles chargés — caméra prête.', 'fa-check-circle');
    return true;
  };

  const startCamera = async () => {
    try {
      const ready = await ensureModels();
      if (!ready) return;
      stream = await navigator.mediaDevices.getUserMedia({
        video: { facingMode: 'user', width: { ideal: 640 }, height: { ideal: 480 } },
        audio: false
      });
      videoEl.srcObject = stream;
      await videoEl.play();
      setStatus('Caméra active — placez votre visage dans le cadre.', 'fa-video');
    } catch {
      setStatus('Impossible d\'accéder à la caméra.', 'fa-triangle-exclamation');
    }
  };

  const capture = async () => {
    try {
      const ready = await ensureModels();
      if (!ready) return;
      if (!videoEl.srcObject) await startCamera();

      setStatus('Analyse du visage…', 'fa-spinner fa-spin');

      const detection = await window.faceapi
        .detectSingleFace(videoEl, new window.faceapi.TinyFaceDetectorOptions({
          inputSize: 320, scoreThreshold: 0.45
        }))
        .withFaceLandmarks()
        .withFaceDescriptor();

      if (!detection) {
        descriptorInput.value = '';
        setStatus('Aucun visage détecté — réessayez.', 'fa-triangle-exclamation');
        return;
      }

      descriptorInput.value = JSON.stringify(Array.from(detection.descriptor));
      setStatus('Visage capturé — cliquez sur Enregistrer.', 'fa-check-circle');
    } catch {
      descriptorInput.value = '';
      setStatus('Capture biométrique échouée.', 'fa-circle-xmark');
    }
  };

  startBtn.addEventListener('click',   () => void startCamera());
  captureBtn.addEventListener('click', () => void capture());

  window.addEventListener('beforeunload', () => {
    if (stream) stream.getTracks().forEach(t => t.stop());
  });
})();
</script>