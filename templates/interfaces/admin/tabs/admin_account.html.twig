            </div>

            <button class="np-btn np-btn--primary" type="submit" style="width:100%">
              <i class="fa-solid fa-floppy-disk"></i> Enregistrer le Face ID
            </button>
          </form>

          <div class="nx-prof__bio-divider"></div>

        </div>{# /bio-form #}

        <div class="nx-prof__bio-remove-form">
