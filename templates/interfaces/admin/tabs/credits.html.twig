  border: 1px solid var(--na-border);
  border-radius: 8px;
  font-size: .81rem;
  color: var(--na-txt);
  background: var(--na-bg);
  outline: none;
  box-sizing: border-box;
  font-family: inherit;
  transition: border-color .2s, box-shadow .2s;
}
.nx-acc__search-input:focus {
  border-color: var(--na-teal);
  box-shadow: 0 0 0 3px rgba(17,183,170,.1);
  background: #fff;
}
.nx-acc__row-count {
  font-size: .72rem;
  color: var(--na-muted);
  background: var(--na-bg);
  border: 1px solid var(--na-border);
  border-radius: 20px;
  padding: .22rem .65rem;
  white-space: nowrap;
  font-weight: 600;
}

/* â”€â”€ Sort dropdown â”€â”€ */
.nx-acc__sort-select {
  height: 36px;
  padding: 0 .7rem;
  border: 1px solid var(--na-border);
  border-radius: 8px;
  font-size: .8rem;
  color: var(--na-txt);
  background: var(--na-bg);
  outline: none;
  font-family: inherit;
  cursor: pointer;
  transition: border-color .2s;
  flex-shrink: 0;
}
.nx-acc__sort-select:focus { border-color: var(--na-teal); }

.nx-acc__sort-dir {
  width: 36px; height: 36px;
  border: 1px solid var(--na-border);
  border-radius: 8px;
  background: var(--na-bg);
  color: var(--na-muted);
  font-size: .85rem;
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  transition: all .2s;
}
.nx-acc__sort-dir:hover { background: var(--na-teal); color: #fff; border-color: var(--na-teal); }

/* â”€â”€ Action icon buttons â”€â”€ */
.nx-acc__act-group {
  display: flex;
  align-items: center;
  gap: .35rem;
}
.nx-acc__act-btn {
  width: 30px; height: 30px;
  border-radius: 8px;
  border: none;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer;
  font-size: .78rem;
  transition: all .15s;
  text-decoration: none;
  background: transparent;
}
.nx-acc__act-btn:hover { transform: scale(1.12); }
.nx-acc__act-btn.edit  { background: #e8f5e9; color: #2e7d32; border: 1px solid #a5d6a7; }
.nx-acc__act-btn.edit:hover  { background: #2e7d32; color: #fff; border-color: transparent; }
.nx-acc__act-btn.del   { background: #ffebee; color: #c62828; border: 1px solid #ef9a9a; }
.nx-acc__act-btn.del:hover   { background: #c62828; color: #fff; border-color: transparent; }
.nx-acc__act-btn.view  { background: #fff8e1; color: #e65100; border: 1px solid #ffcc80; }
.nx-acc__act-btn.view:hover  { background: #e65100; color: #fff; border-color: transparent; }

/* â”€â”€ Clickable row â”€â”€ */
.nx-acc__table tbody tr { cursor: pointer; }
.nx-acc__table tbody tr.is-selected td { background: rgba(17,183,170,.07); }
.nx-acc__table tbody tr:hover td { background: rgba(17,183,170,.04); }
.nx-acc__table thead th.sortable { cursor: pointer; user-select: none; }
.nx-acc__table thead th.sortable:hover { color: var(--na-teal); }
.nx-acc__table thead th .sort-icon { margin-left: .3rem; opacity: .4; font-size: .65rem; }
.nx-acc__table thead th.sort-asc .sort-icon,
.nx-acc__table thead th.sort-desc .sort-icon { opacity: 1; color: var(--na-teal); }


/* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
   RESPONSIVE
â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
@media (max-width: 1100px) {
  .nx-acc__grid { grid-template-columns: 1fr; }
}
@media (max-width: 760px) {
  .nx-acc__kpis { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 560px) {
  .nx-acc             { padding: 1rem; gap: 1rem; }
  .nx-acc__hero       { flex-direction: column; align-items: flex-start; }
  .nx-acc__kpis       { grid-template-columns: 1fr; }
  .nx-acc__tabs       { gap: .25rem; }
}
</style>


<section class="nx-acc" data-active-panel="{{ active_panel }}" data-current-date="{{ current_date }}">

    <!-- ══ HEADER ══ -->
    <header class="nx-acc__hero">
        <div class="nx-acc__hero-left">
            <div class="nx-acc__hero-icon">
                <i class="fa-solid fa-folder-open"></i>
            </div>
            <div class="nx-acc__hero-text">
                <h2>Gestion des Crédits</h2>
                <p>Gérer et superviser les données de crédits et garanties</p>
            </div>
        </div>

        <div class="nx-acc__hero-actions">
            <a class="na-btn na-btn--primary" href="#nx-credits-form" id="nx-header-add-btn">
                <i class="fa-solid fa-plus"></i>
                <span>Ajouter</span>
            </a>
            <a class="na-btn na-btn--ghost" href="{{ path('admin_credits_export_pdf', { kind: 'credits' }) }}">
                <i class="fa-solid fa-file-export"></i> Exporter
            </a>
        </div>
    </header>

    <!-- ══ SUBTABS ══ -->
    <nav class="nx-acc__tabs">
        <a class="nx-acc__tab {{ active_panel == 'credit' ? 'is-active' : '' }}"
           href="{{ path(route_name, { tab: 'credits', panel: 'credit' }) }}">
            <i class="fa-solid fa-credit-card"></i>
            Crédit
        </a>
        <a class="nx-acc__tab {{ active_panel == 'garantie' ? 'is-active' : '' }}"
           href="{{ path(route_name, { tab: 'credits', panel: 'garantie' }) }}">
            <i class="fa-solid fa-shield-halved"></i>
            Garantie
        </a>
        <div class="nx-acc__tabs-spacer"></div>
        <a class="nx-acc__stats-link" id="nx-module-stats-btn" aria-expanded="false" href="#{{ stats_section_id }}">
            <i class="fa-solid fa-chart-pie"></i>
            <span>Statistiques</span>
        </a>


    </nav>
    <!-- STATS PANEL INJECTED -->
    <div class="nx-stats-panel" id="nx-admin-stats-panel">
      <div class="nx-stats-inner">
        <div class="nx-stats-header">
          <span class="nx-stats-header-icon"><i class="fa-solid fa-chart-pie"></i></span>
          <div>
            <h3>Statistiques des Crédits & Garanties</h3>
            <p id="stat-main-subtitle">Chargement...</p>
          </div>
          <button class="nx-stats-close" type="button"
                  onclick="document.getElementById('nx-admin-stats-panel').classList.remove('is-open')">
            <i class="fa-solid fa-xmark"></i>
          </button>
        </div>

        <div class="nx-stats-charts-row">
          
          <div class="nx-chart-card">
            <div class="nx-chart-card-head">
              <span class="nx-chart-dot" style="background:#00B4A0"></span>
              <strong>Crédits par Statut</strong>
            </div>
            <div class="nx-chart-wrap">
              <canvas id="nx-chart-status-canvas" width="200" height="200"></canvas>
            </div>
            <div class="nx-chart-legend" id="stat-credit-status"></div>
          </div>

          <div class="nx-chart-card">
            <div class="nx-chart-card-head">
              <span class="nx-chart-dot" style="background:#e8a202"></span>
              <strong>Garanties par Statut</strong>
            </div>
            <div class="nx-chart-wrap">
              <canvas id="nx-chart-garantie-status-canvas" width="200" height="200"></canvas>
            </div>
            <div class="nx-chart-legend" id="stat-garantie-status"></div>
          </div>

        </div>
      </div>
    </div>
    <style>
      .nx-stats-panel {
        display: none;
        background: var(--na-surface);
        border: 1px solid var(--na-border);
        border-radius: var(--na-radius);
        box-shadow: var(--na-shadow-lg);
        overflow: hidden;
        animation: nx-slide-down .25s ease;
        margin-bottom: 2rem;
      }
      .nx-stats-panel.is-open { display: block; }
      @keyframes nx-slide-down {
        from { opacity: 0; transform: translateY(-10px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      .nx-stats-inner { padding: 1.4rem 1.6rem; }
      .nx-stats-header {
        display: flex; align-items: center; gap: 1rem;
        margin-bottom: 1.4rem; padding-bottom: 1rem;
        border-bottom: 1px solid var(--na-border);
      }
      .nx-stats-header-icon {
        width: 42px; height: 42px; border-radius: 12px;
        background: linear-gradient(135deg, #00B4A0, #0d9e93);
        display: grid; place-items: center; color: #fff; font-size: 1.1rem; flex-shrink: 0;
      }
      .nx-stats-header h3 { font-size: .95rem; font-weight: 800; color: var(--na-txt); margin: 0 0 .15rem; }
      .nx-stats-header p  { font-size: .73rem; color: var(--na-muted); margin: 0; }
      .nx-stats-close {
        margin-left: auto; background: var(--na-bg); border: 1px solid var(--na-border);
        border-radius: 8px; width: 32px; height: 32px;
        display: grid; place-items: center; cursor: pointer; color: var(--na-muted); font-size: .85rem; transition: all .2s;
      }
      .nx-stats-close:hover { background: var(--na-red); color: #fff; border-color: transparent; }

      .nx-stats-charts-row {
        display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;
      }
      .nx-chart-card {
        background: var(--na-bg); border: 1px solid var(--na-border);
        border-radius: 12px; padding: 1.1rem 1.2rem;
        display: flex; flex-direction: column; gap: .85rem;
      }
      .nx-chart-card-head {
        display: flex; align-items: center; gap: .55rem;
        font-size: .85rem; font-weight: 700; color: var(--na-txt);
      }
      .nx-chart-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
      .nx-chart-wrap {
        display: flex; justify-content: center;
        height: 200px;
      }
      .nx-chart-wrap canvas { max-height: 200px; }
      
      .nx-chart-legend { display: flex; flex-direction: column; gap: .45rem; }
      .nx-chart-legend-row {
        display: flex; align-items: center; gap: .55rem;
        padding: .5rem .75rem; border-radius: 8px;
        background: var(--na-surface); border: 1px solid var(--na-border);
        font-size: .78rem; transition: transform .15s;
      }
      .nx-chart-legend-row:hover { transform: translateX(4px); border-color: var(--lc); }
      .nx-chart-legend-dot { width: 10px; height: 10px; border-radius: 50%; background: var(--lc); flex-shrink: 0; }
      .nx-chart-legend-label { flex: 1; color: var(--na-txt); font-weight: 600; }
      .nx-chart-legend-row strong { font-size: .9rem; font-weight: 900; color: var(--lc); }
      .nx-chart-legend-pct { font-size: .72rem; color: var(--na-muted); background: var(--na-bg); border-radius: 20px; padding: .1rem .5rem; }
      .nx-chart-legend-val { font-size: .72rem; color: var(--na-muted); margin-left: auto; }
    </style>
    <!-- END STATS PANEL -->
    
    
    

    <!-- ══════════════════════════════════
         GARANTIE PANEL
    ══════════════════════════════════ -->
    {% if active_panel == 'garantie' %}

        <div class="nx-acc__kpis">
            <article class="nx-acc__kpi">
                <span class="nx-acc__kpi-icon">
                    <i class="fa-solid fa-shield-halved"></i>
                </span>
                <div class="nx-acc__kpi-body">
                    <strong>{{ garantie_items|length }}</strong>
                    <small>Garanties enregistrées</small>
                </div>
            </article>
            <article class="nx-acc__kpi">
                <span class="nx-acc__kpi-icon">
                    <i class="fa-solid fa-file-invoice-dollar"></i>
                </span>
                <div class="nx-acc__kpi-body">
                    <strong>{{ credit_items|length }}</strong>
                    <small>Crédits reliés</small>
                </div>
            </article>
            <article class="nx-acc__kpi">
                <span class="nx-acc__kpi-icon">
                    <i class="fa-solid fa-hourglass-half"></i>
                </span>
                <div class="nx-acc__kpi-body">
                    <strong>{{ summary.credits_pending|default(0) }}</strong>
                    <small>Crédits en attente</small>
                </div>
            </article>
        </div>

        <!-- GARANTIE CONTENT -->
        <div class="nx-acc__grid">
            <article class="nx-acc__panel" id="nx-garanties-form">
                <div class="nx-acc__panel-head">
                    <div class="nx-acc__panel-head-left">
                        <h3>Garantie</h3>
                        <p>Ajouter ou modifier une garantie</p>
                    </div>
                </div>
                <form method="post" id="nx-garantie-form" class="nx-acc__form" enctype="multipart/form-data" novalidate>
                    <input type="hidden" name="tab" value="credits">
                    <input type="hidden" name="panel" value="garantie">
                    <input type="hidden" name="action" value="garantie_save">

                    <label class="nx-acc__form-label-id">
                        <i class="fa-solid fa-hashtag"></i>
                        <input type="number" name="idGarantie" id="nx-garantie-id" placeholder="ID (Auto)" readonly 
                               style="background:transparent; border:none; color:inherit; font-weight:700; width:100%; height:auto; padding:0; box-shadow:none;">
                    </label>

                    <label>
                        <span>Crédit Associé *</span>
                        <select name="idCredit" id="nx-garantie-credit">
                            <option value="">Sélectionner un crédit</option>
                            {% for credit in credit_items %}
                                <option value="{{ credit.idCredit }}">#{{ credit.idCredit }} - {{ credit.user_name|default('Inconnu') }} ({{ credit.typeCredit|default('Sans type') }})</option>
                            {% endfor %}
                        </select>
                        <span id="cr-err-garantie-idCredit" class="nx-field-error"></span>
                    </label>

                    <label>
                        <span>Type de Garantie *</span>
                        <select name="typeGarantie" id="nx-garantie-type">
                            <option value="">Sélectionner un type</option>
                            <option value="Hypothèque immobilière">Hypothèque immobilière</option>
                            <option value="Hypotheque immobiliere">Hypotheque immobiliere (alt)</option>
                            <option value="Gage de véhicule">Gage de véhicule</option>
                            <option value="Gage de vehicule">Gage de vehicule (alt)</option>
                            <option value="Caution solidaire">Caution solidaire</option>
                            <option value="Nantissement de fonds de commerce">Nantissement de fonds de commerce</option>
                            <option value="Dépôt au comptant">Dépôt au comptant</option>
                            <option value="Depot au comptant">Depot au comptant (alt)</option>
                            <option value="Garantie bancaire">Garantie bancaire</option>
                            <option value="Assurance crédit">Assurance crédit</option>
                            <option value="Assurance credit">Assurance credit (alt)</option>
                            <option value="Autres">Autres</option>
                        </select>
                        <span id="cr-err-garantie-typeGarantie" class="nx-field-error"></span>
                    </label>

                    <label>
                        <span>Description *</span>
                        <input type="text" name="description" id="nx-garantie-desc" placeholder="Détails de la garantie">
                        <span id="cr-err-garantie-description" class="nx-field-error"></span>
                    </label>

                    <label>
                        <span>Adresse du Bien *</span>
                        <input type="text" name="adresseBien" id="nx-garantie-address" placeholder="Ville, quartier, etc.">
                        <span id="cr-err-garantie-adresseBien" class="nx-field-error"></span>
                    </label>

                    <label>
                        <span>Valeur Estimée (DT) *</span>
                        <input type="number" step="0.01" name="valeurEstimee" id="nx-garantie-estimated" placeholder="0.00">
                        <span id="cr-err-garantie-valeurEstimee" class="nx-field-error"></span>
                    </label>

                    <label>
                        <span>Valeur Retenue (DT) *</span>
                        <input type="number" step="0.01" name="valeurRetenue" id="nx-garantie-retained" placeholder="0.00" data-manual="0">
                        <span id="cr-err-garantie-valeurRetenue" class="nx-field-error"></span>
                    </label>

                    <label>
                        <span>Date d'Évaluation *</span>
                        <input type="date" name="dateEvaluation" value="{{ current_date }}" min="{{ current_date }}" id="nx-garantie-date">
                        <span id="cr-err-garantie-dateEvaluation" class="nx-field-error"></span>
                    </label>

                    <label>
                        <span>Nom du Garant *</span>
                        <input type="text" name="nomGarant" id="nx-garantie-guarantor" placeholder="Prénom Nom" value="N/A">
                        <span id="cr-err-garantie-nomGarant" class="nx-field-error"></span>
                    </label>

                    <label>
                        <span>Statut</span>
                        <select name="statut" id="nx-garantie-status">
                            {% for status in ['Soumise', 'En cours_verification', 'Acceptee', 'Rejetee', 'Restituee'] %}
                                <option value="{{ status }}"{{ status == 'Soumise' ? ' selected' : '' }}>{{ status }}</option>
                            {% endfor %}
                        </select>
                    </label>

                    <label>
                        <span>Justificatif (Image) *</span>
                        <input type="file" name="documentJustificatif" id="nx-garantie-file" accept="image/jpeg,image/png,image/webp,image/gif">
                        <input type="hidden" name="existing_document" id="nx-garantie-file-existing">
                        <span id="cr-err-garantie-documentJustificatif" class="nx-field-error"></span>
                    </label>

                    <div class="nx-acc__form-actions">
                        <button class="na-btn na-btn--save" type="submit">
                            <i class="fa-solid fa-floppy-disk"></i> Enregistrer
                        </button>
                        <button class="na-btn na-btn--reset" type="reset">
                            <i class="fa-solid fa-rotate-left"></i> Annuler
                        </button>
                    </div>
                </form>
            </article>

            <!-- Table -->
            <article class="nx-acc__panel nx-acc__table-wrap">
                <div class="nx-acc__panel-head">
                    <div class="nx-acc__panel-head-left">
                        <h3>Liste des Garanties</h3>
                        <p>Gestion complète des garanties</p>
                    </div>
                </div>
                <div style="padding: 1rem 1.3rem; border-bottom: 1px solid var(--na-border); display: flex; align-items: center; gap: .75rem;">
                    <div style="flex:1; position: relative;">
                         <input type="search" id="nx-garantie-search" placeholder="Rechercher ID, type, garant, adresse..." 
                            style="width: 100%; height: 38px; border: 1px solid var(--na-border); border-radius: 9px; padding: 0 1rem 0 2rem; outline: none; font-size: .8rem;">
                         <i class="fa-solid fa-search" style="position: absolute; left: .7rem; top: 12px; color: var(--na-muted);"></i>
                    </div>
                    <select id="nx-garantie-sort" style="height: 38px; border: 1px solid var(--na-border); border-radius: 9px; padding: 0 1rem; outline: none; font-size: .8rem; background: var(--na-bg);">
                        <option value="default">Trier: ordre initial</option>
                        <option value="id-desc">ID plus récent</option>
                        <option value="id-asc">ID croissant</option>
                        <option value="credit-asc">ID Crédit</option>
                        <option value="type-asc">Type A-Z</option>
                        <option value="value-desc">Valeur la plus élevée</option>
                        <option value="status-asc">Statut A-Z</option>
                    </select>
                </div>
                <table class="nx-acc__table">
                    <thead>
                        <tr>
                            <th>N° Garantie</th>
                            <th>Crédit</th>
                            <th>Valeur Evaluée</th>
                            <th>Garant / Date</th>
                            <th>Type</th>
                            <th>Statut</th>
                            <th>Couverture</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="nx-garantie-tbody">
                        {% for item in garantie_items %}
                        <tr
                                class="nx-garantie-row"
                                data-garantie-id="{{ item.idGarantie }}"
                                data-garantie-credit-id="{{ item.idCredit|default('') }}"
                                data-garantie-type="{{ item.typeGarantie|default('')|e('html_attr') }}"
                                data-garantie-description="{{ item.description|default('')|e('html_attr') }}"
                                data-garantie-address="{{ item.adresseBien|default('')|e('html_attr') }}"
                                data-garantie-estimated="{{ item.valeurEstimee|default('') }}"
                                data-garantie-retained="{{ item.valeurRetenue|default('') }}"
                                data-garantie-date="{{ item.dateEvaluation|default(current_date)|slice(0, 10) }}"
                                data-garantie-guarantor="{{ item.nomGarant|default('')|e('html_attr') }}"
                                data-garantie-status="{{ item.statut|default('')|e('html_attr') }}"
                                data-garantie-document="{{ item.documentJustificatif|default('')|e('html_attr') }}"
                                data-search-index="{{ (item.idGarantie ~ ' ' ~ item.idCredit ~ ' ' ~ item.typeGarantie ~ ' ' ~ item.description ~ ' ' ~ item.statut|default('') ~ ' ' ~ item.nomGarant|default('') ~ ' ' ~ item.adresseBien|default(''))|lower|e('html_attr') }}"
                            >
                                {% set statusHtml = item.statut|default('Soumise')|lower %}
                                {% set statusCls = 'is-neutral' %}
                                {% if 'soumise' in statusHtml or 'attente' in statusHtml %} {% set statusCls = 'is-bloqué' %}
                                {% elseif 'cours' in statusHtml %} {% set statusCls = 'is-courant' %}
                                {% elseif 'accep' in statusHtml %} {% set statusCls = 'is-actif' %}
                                {% elseif 'rejet' in statusHtml %} {% set statusCls = 'is-fermé' %}
                                {% endif %}
                                {% set rat = item.valeurEstimee > 0 ? (item.valeurRetenue / item.valeurEstimee * 100)|round : 0 %}

                                <td><span class="nx-acc__num">#{{ item.idGarantie }}</span></td>
                                <td>
                                    <div style="font-weight: 600; color: var(--na-blue);">Crédit #{{ item.idCredit }}</div>
                                    <small style="color: var(--na-muted);">{{ item.credit_type|default('—') }}</small>
                                </td>
                                <td>
                                    <div class="nx-acc__amount">{{ item.valeurEstimee|number_format(2, '.', ' ') }} <em>DT</em></div>
                                    <small style="color:var(--na-muted); font-size:11px;">Retenue: {{ item.valeurRetenue|number_format(2, '.', ' ') }} DT</small>
                                </td>
                                <td>
                                    <div class="nx-acc__owner">
                                        <div class="nx-acc__owner-dot">{{ item.nomGarant|default('?')|first|upper }}</div>
                                        <div class="nx-acc__owner-name" style="display:flex;flex-direction:column;">
                                            <span>{{ item.nomGarant|default('—') }}</span>
                                            <span style="font-size:11px;color:var(--na-muted);">{{ item.dateEvaluation|default('—') }}</span>
                                        </div>
                                    </div>
                                </td>
                                <td><span class="nx-acc__tag is-épargne">{{ item.typeGarantie|default('—') }}</span></td>
                                <td><span class="nx-acc__tag {{ statusCls }}">{{ item.statut|default('—') }}</span></td>
                                <td>
                                    <div class="nx-acc__progress-wrap">
                                        <div class="nx-acc__progress-bar">
                                            <div class="nx-acc__progress-fill" style="width: {{ rat > 100 ? 100 : rat }}%;"></div>
                                        </div>
                                        <span class="nx-acc__progress-label">{{ rat }}% couvert</span>
                                    </div>
                                </td>
                                <td>
                                    <div style="display:flex;gap:4px;">
                                        <button class="na-btn na-btn--ghost-dark nx-garantie-edit-btn" type="button" aria-label="Modifier"><i class="fa-solid fa-pen"></i></button>
                                        <form method="post" style="margin:0;">
                                            <input type="hidden" name="tab" value="credits">
                                            <input type="hidden" name="panel" value="garantie">
                                            <input type="hidden" name="action" value="garantie_delete">
                                            <input type="hidden" name="idGarantie" value="{{ item.idGarantie }}">
                                            <button class="na-btn na-btn--danger" type="submit" onclick="return confirm('Confirmer la suppression ?')"><i class="fa-solid fa-trash"></i></button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr><td colspan="8" class="nx-acc__empty"><i class="fa-solid fa-folder-open fa-2x"></i><br>Aucune garantie.</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </article>
        </div>

    <!-- ══════════════════════════════════
         CREDITS PANEL 
    ══════════════════════════════════ -->
    {% else %}

        <div class="nx-acc__kpis">
            <article class="nx-acc__kpi">
                <span class="nx-acc__kpi-icon">
                    <i class="fa-solid fa-credit-card"></i>
                </span>
                <div class="nx-acc__kpi-body">
                    <strong>{{ credit_items|length }}</strong>
                    <small>Crédits Totaux</small>
                </div>
            </article>
            <article class="nx-acc__kpi">
                <span class="nx-acc__kpi-icon">
                    <i class="fa-solid fa-hourglass-half"></i>
                </span>
                <div class="nx-acc__kpi-body">
                    <strong>{{ summary.credits_pending|default(0) }}</strong>
                    <small>Crédits En Attente</small>
                </div>
            </article>
            <article class="nx-acc__kpi">
                <span class="nx-acc__kpi-icon">
                    <i class="fa-solid fa-users"></i>
                </span>
                <div class="nx-acc__kpi-body">
                    <strong>{{ users|length }}</strong>
                    <small>Utilisateurs Actifs</small>
                </div>
            </article>
        </div>

        <!-- CREDIT CONTENT -->
        <div class="nx-acc__grid">
            <article class="nx-acc__panel" id="nx-credits-form">
                <div class="nx-acc__panel-head">
                    <div class="nx-acc__panel-head-left">
                        <h3>Crédit</h3>
                        <p>Ajouter ou modifier un crédit</p>
                    </div>
                </div>
                <form method="post" id="nx-credit-form" class="nx-acc__form" novalidate>
                    <input type="hidden" name="tab" value="credits">
                    <input type="hidden" name="panel" value="credit">
                    <input type="hidden" name="action" value="credit_save">

                    <label class="nx-acc__form-label-id">
                        <i class="fa-solid fa-hashtag"></i>
                        <input type="number" name="idCredit" id="nx-credit-id" placeholder="ID (Auto)" readonly 
                               style="background:transparent; border:none; color:inherit; font-weight:700; width:100%; height:auto; padding:0; box-shadow:none;">
                    </label>

                    <label>
                        <span>Utilisateur *</span>
                        <select name="idUser" id="nx-credit-user">
                            <option value="">Sélectionner un utilisateur</option>
                            {% for user in users %}
                                <option value="{{ user.idUser }}">{{ user.nom }} {{ user.prenom }} ({{ user.email }})</option>
                            {% endfor %}
                        </select>
                        <span id="cr-err-idUser" class="nx-field-error"></span>
                    </label>

                    <label>
                        <span>Compte Rattaché *</span>
                        <select name="idCompte" id="nx-credit-account">
                            <option value="">Sélectionner un compte</option>
                            {% for account in accounts %}
                                <option value="{{ account.idCompte }}" data-user-id="{{ account.idUser|default('') }}">{{ account.numeroCompte }} (Solde: {{ account.solde }} DT)</option>
                            {% endfor %}
                        </select>
                        <span id="cr-err-idCompte" class="nx-field-error"></span>
                    </label>

                    <label>
                        <span>Type de Crédit *</span>
                        <select name="typeCredit" id="nx-credit-type">
                            <option value="">Sélectionner un type</option>
                            {% for type in ['Professionnel', 'Immobilier', 'Consommation', 'Automobile', 'Etudiant', 'Renouvelable'] %}
                                <option value="{{ type }}">{{ type }}</option>
                            {% endfor %}
                        </select>
                        <span id="cr-err-typeCredit" class="nx-field-error"></span>
                    </label>

                    <label>
                        <span>Montant Demandé (DT) *</span>
                        <input type="number" step="0.01" name="montantDemande" id="nx-credit-amount" placeholder="0.00">
                        <span id="cr-err-montantDemande" class="nx-field-error"></span>
                    </label>

                    <div style="display:flex;gap:1rem;">
                        <label style="flex:1;">
                            <span>Durée (Mois) *</span>
                            <input type="number" name="duree" id="nx-credit-duration" value="12">
                            <span id="cr-err-duree" class="nx-field-error"></span>
                        </label>
                        <label style="flex:1;">
                            <span>Taux/An (%) *</span>
                            <input type="number" step="0.01" name="tauxInteret" id="nx-credit-rate" value="8">
                            <span id="cr-err-tauxInteret" class="nx-field-error"></span>
                        </label>
                    </div>

                    <label>
                        <span>Autofinancement (DT)</span>
                        <input type="number" step="0.01" name="autofinancement" id="nx-credit-autofinancement" placeholder="0.00">
                        <span id="cr-err-autofinancement" class="nx-field-error"></span>
                    </label>

                    <label>
                        <span>Mensualité (DT) *</span>
                        <input type="number" step="0.01" name="mensualite" id="nx-credit-mensualite" placeholder="Calcule auto">
                        <span id="cr-err-mensualite" class="nx-field-error"></span>
                    </label>

                    <div class="nx-acc__form-divider"></div>

                    <label>
                        <span>Montant Accordé (DT)</span>
                        <input type="number" step="0.01" name="montantAccorde" id="nx-credit-approved" placeholder="Laisser vide = montant demandé">
                        <span id="cr-err-montantAccorde" class="nx-field-error"></span>
                    </label>

                    <label>
                        <span>Date Demande *</span>
                        <input type="date" name="dateDemande" id="nx-credit-date" value="{{ current_date }}" min="{{ current_date }}">
                        <span id="cr-err-dateDemande" class="nx-field-error"></span>
                    </label>

                    <div style="display:flex;gap:1rem;">
                        <label style="flex:1;">
                            <span>Salaire Mensuel *</span>
                            <input type="number" step="0.01" name="salaire" id="nx-credit-salary" value="2000">
                            <span id="cr-err-salaire" class="nx-field-error"></span>
                        </label>
                        <label style="flex:1;">
                            <span>Ancienneté (Ans)</span>
                            <input type="number" name="ancienneteAnnees" id="nx-credit-seniority" value="2">
                            <span id="cr-err-ancienneteAnnees" class="nx-field-error"></span>
                        </label>
                    </div>

                    <label>
                        <span>Type de Contrat *</span>
                        <select name="typeContrat" id="nx-credit-contract">
                            <option value="">Sélectionner un contrat</option>
                            <option value="CDI">CDI</option>
                            <option value="CDD">CDD</option>
                            <option value="Fonctionnaire">Fonctionnaire</option>
                            <option value="Freelance">Freelance</option>
                            <option value="SVP">SVP</option>
                            <option value="Autre">Autre</option>
                        </select>
                        <span id="cr-err-typeContrat" class="nx-field-error"></span>
                    </label>

                    <div class="nx-acc__form-divider"></div>

                    <label>
                        <span>Statut du Crédit</span>
                        <select name="statut" id="nx-credit-status">
                            {% for status in ['En attente', 'Accepte', 'En cours', 'Rejete', 'Cloture'] %}
                                <option value="{{ status }}"{{ status == 'En attente' ? ' selected' : '' }}>{{ status }}</option>
                            {% endfor %}
                        </select>
                    </label>

                    <div class="nx-acc__form-actions">
                        <button class="na-btn na-btn--save" type="submit">
                            <i class="fa-solid fa-floppy-disk"></i> Enregistrer
                        </button>
                        <button class="na-btn na-btn--reset" type="reset">
                            <i class="fa-solid fa-rotate-left"></i> Annuler
                        </button>
                    </div>
                </form>
            </article>

            <!-- Table -->
            <article class="nx-acc__panel nx-acc__table-wrap">
                <div class="nx-acc__panel-head">
                    <div class="nx-acc__panel-head-left">
                        <h3>Liste des Crédits</h3>
                        <p>Gestion de toutes les demandes de crédit</p>
                    </div>
                </div>
                <div style="padding: 1rem 1.3rem; border-bottom: 1px solid var(--na-border); display: flex; align-items: center; gap: .75rem;">
                    <div style="flex:1; position: relative;">
                         <input type="search" id="nx-credit-search" placeholder="Rechercher ID, utilisateur, compte, type, statut..." 
                            style="width: 100%; height: 38px; border: 1px solid var(--na-border); border-radius: 9px; padding: 0 1rem 0 2rem; outline: none; font-size: .8rem;">
                         <i class="fa-solid fa-search" style="position: absolute; left: .7rem; top: 12px; color: var(--na-muted);"></i>
                    </div>
                    <select id="nx-credit-sort" style="height: 38px; border: 1px solid var(--na-border); border-radius: 9px; padding: 0 1rem; outline: none; font-size: .8rem; background: var(--na-bg);">
                        <option value="default">Trier: ordre initial</option>
                        <option value="id-desc">ID plus récent</option>
                        <option value="id-asc">ID croissant</option>
                        <option value="amount-desc">Montant le plus élevé</option>
                        <option value="monthly-desc">Mensualité la plus élevée</option>
                        <option value="risk-desc">Risque le plus élevé</option>
                        <option value="user-asc">Utilisateur A-Z</option>
                        <option value="status-asc">Statut A-Z</option>
                    </select>
                </div>
                <table class="nx-acc__table">
                    <thead>
                        <tr>
                            <th>#Identifiant</th>
                            <th>N° Compte</th>
                            <th>Montant</th>
                            <th>Demande</th>
                            <th>Statut</th>
                            <th>Type</th>
                            <th>Propriétaire</th>
                            <th>Score Risque</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="nx-credit-tbody">
                        {% for item in credit_items %}
                        <tr
                                class="nx-credit-row"
                                data-credit-id="{{ item.idCredit }}"
                                data-credit-user-id="{{ item.idUser|default('') }}"
                                data-credit-account-id="{{ item.idCompte|default('') }}"
                                data-credit-type="{{ item.typeCredit|default('')|e('html_attr') }}"
                                data-credit-amount="{{ item.montantDemande|default('') }}"
                                data-credit-autofinancement="{{ item.autofinancement|default('') }}"
                                data-credit-duration="{{ item.duree|default('') }}"
                                data-credit-rate="{{ item.tauxInteret|default('') }}"
                                data-credit-monthly="{{ item.mensualite|default('') }}"
                                data-credit-approved="{{ item.montantAccorde|default('') }}"
                                data-credit-date="{{ item.dateDemande|default(current_date)|slice(0, 10) }}"
                                data-credit-salary="{{ item.salaire|default('') }}"
                                data-credit-contract="{{ item.typeContrat|default('')|e('html_attr') }}"
                                data-credit-seniority="{{ item.ancienneteAnnees|default('') }}"
                                data-credit-status="{{ item.statut|default('')|e('html_attr') }}"
                                data-credit-risk="{{ item.risk_score|default(0) }}"
                                data-search-index="{{ (item.idCredit ~ ' ' ~ item.user_name|default('') ~ ' ' ~ item.idCompte|default('') ~ ' ' ~ item.compte_numero|default('') ~ ' ' ~ item.typeCredit|default('') ~ ' ' ~ item.statut|default(''))|lower|e('html_attr') }}"
                            >
                                {% set creditStatus = item.statut|default('En attente')|lower %}
                                {% set creditStatusClass = 'nx-acc__tag is-bloqué' %}
                                {% if 'attente' in creditStatus %}
                                    {% set creditStatusClass = 'nx-acc__tag is-bloqué' %}
                                {% elseif 'cours' in creditStatus %}
                                    {% set creditStatusClass = 'nx-acc__tag is-courant' %}
                                {% elseif 'accept' in creditStatus %}
                                    {% set creditStatusClass = 'nx-acc__tag is-actif' %}
                                {% elseif 'rejet' in creditStatus or 'refus' in creditStatus %}
                                    {% set creditStatusClass = 'nx-acc__tag is-fermé' %}
                                {% elseif 'clot' in creditStatus %}
                                    {% set creditStatusClass = 'nx-acc__tag' %}
                                {% endif %}

                                {% set risk = item.risk_score|default(0) %}
                                {% set riskColor = 'var(--na-green)' %}
                                {% if risk > 70 %}{% set riskColor = 'var(--na-red)' %}
                                {% elseif risk > 40 %}{% set riskColor = 'var(--na-gold)' %}{% endif %}

                                <td><span class="nx-acc__num">#{{ item.idCredit }}</span></td>
                                <td>
                                    <div style="font-weight: 600; color: var(--na-blue);">{{ item.compte_numero|default('—') }}</div>
                                    <small style="color: var(--na-muted);">#C-{{ item.idCompte|default('—') }}</small>
                                </td>
                                <td>
                                    <div class="nx-acc__amount">{{ item.montantDemande|number_format(2, '.', ' ') }} <em>DT</em></div>
                                </td>
                                <td>
                                    <div style="display:flex;flex-direction:column;gap:3px;">
                                        <span>{{ item.dateDemande|default('—') }}</span>
                                        <small style="color:var(--na-muted);">{{ item.duree|default('—') }} mois · {{ item.mensualite|default(0)|number_format(2, '.', ' ') }} DT/m</small>
                                    </div>
                                </td>
                                <td><span class="{{ creditStatusClass }}">{{ item.statut|default('—') }}</span></td>
                                <td><span class="nx-acc__tag is-épargne">{{ item.typeCredit|default('—') }}</span></td>
                                <td>
                                    <div class="nx-acc__owner">
                                        <div class="nx-acc__owner-dot">{{ item.user_name|default('?')|first|upper }}</div>
                                        <div class="nx-acc__owner-name" style="display:flex;flex-direction:column;">
                                            <span>{{ item.user_name|default('—') }}</span>
                                            <span style="font-size:11px;color:var(--na-muted);">Salaire {{ item.salaire|default(0)|number_format(2, '.', ' ') }} DT</span>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="nx-acc__progress-wrap">
                                        <div class="nx-acc__progress-bar">
                                            <div class="nx-acc__progress-fill" style="width: {{ risk }}%; background: {{ riskColor }};"></div>
                                        </div>
                                        <span class="nx-acc__progress-label" style="display:flex;justify-content:space-between;width:100%;">
                                           <span>Score</span>
                                           <span>{{ risk }}/100</span>
                                        </span>
                                    </div>
                                </td>
                                <td>
                                    <div style="display:flex;gap:4px;">
                                        <button class="na-btn na-btn--ghost-dark nx-credit-edit-btn" type="button" aria-label="Modifier"><i class="fa-solid fa-pen"></i></button>
                                        {% if item.idUser|default(null) %}
                                            <a class="na-btn na-btn--ghost-dark" href="{{ path('admin_credits_export_pdf', { kind: 'credits' }) ~ '?userId=' ~ item.idUser }}" target="_blank"><i class="fa-solid fa-file-pdf"></i></a>
                                        {% endif %}
                                        <form method="post" style="margin:0;">
                                            <input type="hidden" name="tab" value="credits">
                                            <input type="hidden" name="panel" value="credit">
                                            <input type="hidden" name="action" value="credit_delete">
                                            <input type="hidden" name="idCredit" value="{{ item.idCredit }}">
                                            <button class="na-btn na-btn--danger" type="submit" onclick="return confirm('Confirmer la suppression ?')"><i class="fa-solid fa-trash"></i></button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr><td colspan="9" class="nx-acc__empty"><i class="fa-solid fa-folder-open fa-2x"></i><br>Aucun crédit.</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </article>
        </div>
    {% endif %}

</section>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
(() => {
    const moduleRoot = document.querySelector('.nx-module-screen') || document.querySelector('.nx-acc');
    if (!moduleRoot) return;

    const currentDate = (moduleRoot.dataset.currentDate || '').trim();

    const parseNumber = (value) => {
        const normalized = String(value || '').replace(',', '.').trim();
        if (normalized === '') return Number.NaN;
        const parsed = Number(normalized);
        return Number.isFinite(parsed) ? parsed : Number.NaN;
    };

    const normalizeIsoDate = (value) => {
        const raw = String(value || '').trim();
        if (raw === '') return '';
        const isoMatch = raw.match(/^(\d{4})-(\d{2})-(\d{2})/);
        if (isoMatch) return `${isoMatch[1]}-${isoMatch[2]}-${isoMatch[3]}`;
        const frMatch = raw.match(/^(\d{2})[\/-](\d{2})[\/-](\d{4})$/);
        if (frMatch) return `${frMatch[3]}-${frMatch[2]}-${frMatch[1]}`;
        return raw.length >= 10 ? raw.slice(0, 10) : raw;
    };

    const setFieldValue = (form, fieldName, value) => {
        if (!form) return;
        const field = form.querySelector(`[name="${fieldName}"]`);
        if (field) field.value = value || '';
    };

    const scrollToForm = (form) => {
        const card = form?.closest('.nx-acc__panel');
        if (card) card.scrollIntoView({ behavior: 'smooth', block: 'start' });
    };

    /* Validation Display Logic */
    const setFieldError = (field, messageElement, errorText) => {
        if (field) { field.classList.add('is-invalid'); field.classList.remove('is-valid'); }
        if (messageElement) {
            messageElement.textContent = errorText;
            messageElement.classList.add('is-visible');
        }
        return false;
    };
    const setFieldOk = (field, messageElement) => {
        if (field) { field.classList.remove('is-invalid'); field.classList.add('is-valid'); }
        if (messageElement) { messageElement.classList.remove('is-visible'); messageElement.textContent = ''; }
        return true;
    };
    const clearFieldValidation = (field, messageElement) => {
        if (field) { field.classList.remove('is-invalid', 'is-valid'); }
        if (messageElement) { messageElement.classList.remove('is-visible'); messageElement.textContent = ''; }
    };

    // ────────────────────────────────────────────────────────────────────────
    // CREDITS FORM & VALIDATION
    // ────────────────────────────────────────────────────────────────────────
    const creditForm = document.getElementById('nx-credit-form');
    let templateAccountOptions = [];

    const getField = (id) => document.getElementById(id);
    const getErrMsg = (id) => document.getElementById(`cr-err-${id}`);

    const crFields = {
        amount: getField('nx-credit-amount'),
        duration: getField('nx-credit-duration'),
        rate: getField('nx-credit-rate'),
        monthly: getField('nx-credit-mensualite'),
        approved: getField('nx-credit-approved'),
        autofinanc: getField('nx-credit-autofinancement'),
        date: getField('nx-credit-date'),
        salary: getField('nx-credit-salary'),
        seniority: getField('nx-credit-seniority'),
        user: getField('nx-credit-user'),
        account: getField('nx-credit-account'),
        type: getField('nx-credit-type'),
        contract: getField('nx-credit-contract')
    };

    const renderAccountOptions = (preferredValue = null) => {
        if (!crFields.user || !crFields.account) return;
        const selectedUserId = crFields.user.value;
        const previousValue = preferredValue || crFields.account.value;
        crFields.account.innerHTML = '';
        const placeholder = document.createElement('option');
        placeholder.value = '';
        placeholder.textContent = 'Sélectionner un compte';
        crFields.account.appendChild(placeholder);
        
        let visibleCount = 0;
        templateAccountOptions.forEach((opt) => {
            if (opt.value === '') return;
            if (selectedUserId !== '' && opt.userId !== '' && opt.userId !== selectedUserId) return;
            const option = document.createElement('option');
            option.value = opt.value;
            option.textContent = opt.label;
            option.dataset.userId = opt.userId;
            crFields.account.appendChild(option);
            visibleCount++;
        });

        if (visibleCount === 0) {
            placeholder.textContent = selectedUserId === '' ? 'Aucun compte' : 'Aucun compte pour cet utilisateur';
            crFields.account.disabled = true;
        } else {
            crFields.account.disabled = false;
        }
        crFields.account.value = Array.from(crFields.account.options).some(o => o.value === previousValue) ? previousValue : '';
    };

    const recalculateCreditFields = () => {
        if (!crFields.amount || !crFields.duration || !crFields.rate || !crFields.monthly || !crFields.approved) return;
        const amount = parseNumber(crFields.amount.value);
        const duration = parseNumber(crFields.duration.value);
        const rate = parseNumber(crFields.rate.value);

        if (!(amount > 0) || !(duration > 0)) {
            if (crFields.monthly.dataset.manual !== '1') crFields.monthly.value = '';
            if (crFields.approved.dataset.manual !== '1') crFields.approved.value = '';
            return;
        }

        const monthlyRate = Math.max(0, rate) / 100 / 12;
        const mensualite = monthlyRate <= 0 ? amount / duration : (amount * monthlyRate) / (1 - Math.pow(1 + monthlyRate, -duration));

        if (crFields.monthly.dataset.manual !== '1' || crFields.monthly.value.trim() === '') {
            crFields.monthly.value = mensualite.toFixed(2);
        }
        if (crFields.approved.dataset.manual !== '1' || crFields.approved.value.trim() === '') {
            crFields.approved.value = amount.toFixed(2);
        }
    };

    const validateCreditField = (fieldName) => {
        let field = null, err = null, val = '';
        switch(fieldName) {
            case 'idUser': field = crFields.user; err = getErrMsg('idUser'); break;
            case 'idCompte': field = crFields.account; err = getErrMsg('idCompte'); break;
            case 'typeCredit': field = crFields.type; err = getErrMsg('typeCredit'); break;
            case 'montantDemande': field = crFields.amount; err = getErrMsg('montantDemande'); break;
            case 'duree': field = crFields.duration; err = getErrMsg('duree'); break;
            case 'tauxInteret': field = crFields.rate; err = getErrMsg('tauxInteret'); break;
            case 'autofinancement': field = crFields.autofinanc; err = getErrMsg('autofinancement'); break;
            case 'mensualite': field = crFields.monthly; err = getErrMsg('mensualite'); break;
            case 'montantAccorde': field = crFields.approved; err = getErrMsg('montantAccorde'); break;
            case 'dateDemande': field = crFields.date; err = getErrMsg('dateDemande'); break;
            case 'salaire': field = crFields.salary; err = getErrMsg('salaire'); break;
            case 'typeContrat': field = crFields.contract; err = getErrMsg('typeContrat'); break;
        }
        if (!field) return true;
        val = field.value.trim();

        if (fieldName === 'idUser') {
            if (!val) return setFieldError(field, err, 'L\'utilisateur est requis.');
            return setFieldOk(field, err);
        }
        if (fieldName === 'idCompte') {
            if (!val) return setFieldError(field, err, 'Le compte est requis.');
            return setFieldOk(field, err);
        }
        if (fieldName === 'typeCredit') {
            if (!val) return setFieldError(field, err, 'Le type de crédit est requis.');
            return setFieldOk(field, err);
        }
        if (fieldName === 'typeContrat') {
            if (!val) return setFieldError(field, err, 'Le type de contrat est requis.');
            return setFieldOk(field, err);
        }
        if (fieldName === 'montantDemande') {
            const num = parseNumber(val);
            if (!val) return setFieldError(field, err, 'Le montant est requis.');
            if (num <= 0) return setFieldError(field, err, 'Le montant doit être positif.');
            if (num < 100 || num > 500000) return setFieldError(field, err, 'Le montant doit être entre 100 et 500k DT.');
            return setFieldOk(field, err);
        }
        if (fieldName === 'duree') {
            const num = parseNumber(val);
            if (!val) return setFieldError(field, err, 'La durée est requise.');
            if (num <= 0 || num > 360 || !Number.isInteger(num)) return setFieldError(field, err, 'Durée invalide (1-360 mois).');
            return setFieldOk(field, err);
        }
        if (fieldName === 'tauxInteret') {
            const num = parseNumber(val);
            if (!val) return setFieldError(field, err, 'Le taux est requis.');
            if (num < 0 || num > 30) return setFieldError(field, err, 'Taux invalide (0-30%).');
            return setFieldOk(field, err);
        }
        if (fieldName === 'mensualite' || fieldName === 'montantAccorde' || fieldName === 'autofinancement') {
             if (val && parseNumber(val) < 0) return setFieldError(field, err, 'La valeur ne peut pas être négative.');
             return setFieldOk(field, err);
        }
        if (fieldName === 'salaire') {
            const num = parseNumber(val);
            if (!val) return setFieldError(field, err, 'Le salaire est requis.');
            if (num <= 0) return setFieldError(field, err, 'Le salaire doit être positif.');
            return setFieldOk(field, err);
        }
        if (fieldName === 'dateDemande') {
            if (!val) return setFieldError(field, err, 'Date requise.');
            return setFieldOk(field, err);
        }
        return true;
    };

    if (creditForm) {
        if (crFields.account) {
            templateAccountOptions = Array.from(crFields.account.options).map(o => ({ value: o.value, label: o.textContent, userId: o.dataset.userId || '' }));
            crFields.user?.addEventListener('change', () => { renderAccountOptions(); validateCreditField('idUser'); });
            crFields.account?.addEventListener('change', () => { validateCreditField('idCompte'); });
            renderAccountOptions();
        }

        ['amount', 'duration', 'rate'].forEach(key => {
            crFields[key]?.addEventListener('input', () => { recalculateCreditFields(); validateCreditField('montantDemande'); validateCreditField('duree'); validateCreditField('tauxInteret'); });
        });

        ['monthly', 'approved'].forEach(key => {
            if (crFields[key]) {
                crFields[key].dataset.manual = '0';
                crFields[key].addEventListener('input', () => { if (creditForm.dataset.filling !== '1') crFields[key].dataset.manual = '1'; validateCreditField(key === 'monthly' ? 'mensualite' : 'montantAccorde'); });
            }
        });

        Object.keys(crFields).forEach(key => {
            if (crFields[key] && !['amount','duration','rate','monthly','approved','user','account'].includes(key)) {
                crFields[key].addEventListener('input', () => validateCreditField(crFields[key].name));
            }
        });

        creditForm.addEventListener('submit', (e) => {
            recalculateCreditFields();
            const fields = ['idUser', 'idCompte', 'typeCredit', 'montantDemande', 'duree', 'tauxInteret', 'mensualite', 'dateDemande', 'salaire', 'typeContrat'];
            const valid = fields.map(validateCreditField).every(r => r);
            if (!valid) e.preventDefault();
        });

        creditForm.addEventListener('reset', () => {
            setTimeout(() => {
                getField('nx-credit-id').value = '';
                crFields.monthly.dataset.manual = '0';
                crFields.approved.dataset.manual = '0';
                if (crFields.date && crFields.date.value === '') crFields.date.value = currentDate;
                setFieldValue(creditForm, 'statut', 'En attente');
                renderAccountOptions();
                recalculateCreditFields();
                Object.keys(crFields).forEach(k => { if(crFields[k]) clearFieldValidation(crFields[k], getErrMsg(crFields[k].name)); });
            }, 0);
        });
    }

    document.querySelectorAll('.nx-credit-edit-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            if (!creditForm) return;
            const row = btn.closest('.nx-credit-row');
            if (!row) return;

            creditForm.dataset.filling = '1';
            setFieldValue(creditForm, 'idCredit', row.dataset.creditId);
            setFieldValue(creditForm, 'idUser', row.dataset.creditUserId);
            setFieldValue(creditForm, 'typeCredit', row.dataset.creditType);
            setFieldValue(creditForm, 'montantDemande', row.dataset.creditAmount);
            setFieldValue(creditForm, 'autofinancement', row.dataset.creditAutofinancement);
            setFieldValue(creditForm, 'duree', row.dataset.creditDuration);
            setFieldValue(creditForm, 'tauxInteret', row.dataset.creditRate);
            setFieldValue(creditForm, 'mensualite', row.dataset.creditMonthly);
            setFieldValue(creditForm, 'montantAccorde', row.dataset.creditApproved);
            setFieldValue(creditForm, 'dateDemande', normalizeIsoDate(row.dataset.creditDate));
            setFieldValue(creditForm, 'statut', row.dataset.creditStatus || 'En attente');
            setFieldValue(creditForm, 'salaire', row.dataset.creditSalary);
            setFieldValue(creditForm, 'typeContrat', row.dataset.creditContract);
            setFieldValue(creditForm, 'ancienneteAnnees', row.dataset.creditSeniority);

            if (crFields.user) crFields.user.value = row.dataset.creditUserId || '';
            renderAccountOptions(row.dataset.creditAccountId || '');

            if (crFields.monthly) crFields.monthly.dataset.manual = '1';
            if (crFields.approved) crFields.approved.dataset.manual = '1';

            delete creditForm.dataset.filling;
            Object.keys(crFields).forEach(k => { if(crFields[k]) clearFieldValidation(crFields[k], getErrMsg(crFields[k].name)); });
            // validate valid fields to show green
            ['idUser', 'idCompte', 'typeCredit', 'montantDemande', 'duree', 'tauxInteret', 'salaire', 'typeContrat'].forEach(validateCreditField);

            scrollToForm(creditForm);
        });
    });

    // ────────────────────────────────────────────────────────────────────────
    // GARANTIE FORM & VALIDATION
    // ────────────────────────────────────────────────────────────────────────
    const garantieForm = document.getElementById('nx-garantie-form');
    
    // Check if garantie variables are present
    const gCredit = getField('nx-garantie-credit');
    const gType = getField('nx-garantie-type');
    const gEstimated = getField('nx-garantie-estimated');
    const gRetained = getField('nx-garantie-retained');
    const gGuarantor = getField('nx-garantie-guarantor');
    const gAddress = getField('nx-garantie-address');
    const gDesc = getField('nx-garantie-desc');
    const gDate = getField('nx-garantie-date');
    const gDoc = getField('nx-garantie-file');
    const gDocExisting = getField('nx-garantie-file-existing');

    const validateGarantieField = (fieldName) => {
        let field = null, err = null, val = '';
        switch(fieldName) {
            case 'idCredit': field = gCredit; err = getErrMsg('garantie-idCredit'); break;
            case 'typeGarantie': field = gType; err = getErrMsg('garantie-typeGarantie'); break;
            case 'valeurEstimee': field = gEstimated; err = getErrMsg('garantie-valeurEstimee'); break;
            case 'valeurRetenue': field = gRetained; err = getErrMsg('garantie-valeurRetenue'); break;
            case 'nomGarant': field = gGuarantor; err = getErrMsg('garantie-nomGarant'); break;
            case 'adresseBien': field = gAddress; err = getErrMsg('garantie-adresseBien'); break;
            case 'description': field = gDesc; err = getErrMsg('garantie-description'); break;
            case 'dateEvaluation': field = gDate; err = getErrMsg('garantie-dateEvaluation'); break;
            case 'documentJustificatif': field = gDoc; err = getErrMsg('garantie-documentJustificatif'); break;
        }
        if (!field && fieldName !== 'documentJustificatif') return true;
        if (field) val = field.value.trim();

        if (fieldName === 'idCredit') {
            if (!val) return setFieldError(field, err, 'Veuillez sélectionner un crédit associé.');
            return setFieldOk(field, err);
        }
        if (fieldName === 'typeGarantie') {
            if (!val) return setFieldError(field, err, 'Veuillez sélectionner un type.');
            return setFieldOk(field, err);
        }
        if (fieldName === 'valeurEstimee') {
            const num = parseNumber(val);
            if (!val) return setFieldError(field, err, 'Valeur estimée requise.');
            if (num <= 0) return setFieldError(field, err, 'La valeur doit être positive.');
            return setFieldOk(field, err);
        }
        if (fieldName === 'valeurRetenue') {
            const rnum = parseNumber(val);
            const enum_ = gEstimated ? parseNumber(gEstimated.value) : 0;
            if (!val) return setFieldError(field, err, 'Valeur retenue requise.');
            if (rnum <= 0) return setFieldError(field, err, 'La valeur doit être positive.');
            if (enum_ > 0 && rnum > enum_) return setFieldError(field, err, 'Ne doit pas dépasser l\'estimée.');
            return setFieldOk(field, err);
        }
        if (fieldName === 'description') {
            if (!val) return setFieldError(field, err, 'Description requise.');
            if (val.length < 5) return setFieldError(field, err, 'Description trop courte.');
            return setFieldOk(field, err);
        }
        if (fieldName === 'adresseBien') {
            if (!val) return setFieldError(field, err, 'Adresse requise.');
            if (val.length < 5) return setFieldError(field, err, 'Adresse trop courte.');
            return setFieldOk(field, err);
        }
        if (fieldName === 'nomGarant') {
            if (!val) return setFieldError(field, err, 'Garant requis.');
            return setFieldOk(field, err);
        }
        if (fieldName === 'dateEvaluation') {
             if (!val) return setFieldError(field, err, 'Date requise.');
             return setFieldOk(field, err);
        }
        if (fieldName === 'documentJustificatif') {
            const existingPath = gDocExisting ? gDocExisting.value.trim() : '';
            const file = gDoc?.files?.[0];
            const allowed = ['image/jpeg', 'image/png', 'image/webp', 'image/gif'];
            if (file && !allowed.includes(file.type)) return setFieldError(gDoc, err, 'Image invalide.');
            if (!file && !existingPath) return setFieldError(gDoc, err, 'Justificatif requis.');
            return setFieldOk(gDoc, err);
        }
        return true;
    };

    const syncRetainedValue = () => {
        if (!gEstimated || !gRetained) return;
        const est = parseNumber(gEstimated.value);
        if (est > 0 && gRetained.dataset.manual !== '1') {
            gRetained.value = (est * 0.8).toFixed(2);
        }
    };

    if (garantieForm) {
        const hooks = [
            { id: 'idCredit', f: gCredit },
            { id: 'typeGarantie', f: gType },
            { id: 'nomGarant', f: gGuarantor },
            { id: 'adresseBien', f: gAddress },
            { id: 'description', f: gDesc },
            { id: 'dateEvaluation', f: gDate }
        ];

        hooks.forEach(h => {
            if (h.f) h.f.addEventListener('input', () => validateGarantieField(h.id));
        });

        if (gEstimated) gEstimated.addEventListener('input', () => { syncRetainedValue(); validateGarantieField('valeurEstimee'); validateGarantieField('valeurRetenue'); });
        if (gRetained) gRetained.addEventListener('input', () => { gRetained.dataset.manual = '1'; validateGarantieField('valeurRetenue'); });
        if (gDoc) gDoc.addEventListener('change', () => validateGarantieField('documentJustificatif'));

        garantieForm.addEventListener('submit', (e) => {
            syncRetainedValue();
            const fields = ['idCredit', 'typeGarantie', 'valeurEstimee', 'valeurRetenue', 'nomGarant', 'adresseBien', 'description', 'dateEvaluation', 'documentJustificatif'];
            const valid = fields.map(validateGarantieField).every(v => v);
            if (!valid) e.preventDefault();
        });

        garantieForm.addEventListener('reset', () => {
            setTimeout(() => {
                getField('nx-garantie-id').value = '';
                if (gRetained) gRetained.dataset.manual = '0';
                if (gDate && gDate.value === '') gDate.value = currentDate;
                setFieldValue(garantieForm, 'statut', 'Soumise');
                if (gDocExisting) gDocExisting.value = '';
                hooks.forEach(h => clearFieldValidation(h.f, getErrMsg(`garantie-${h.id}`)));
                clearFieldValidation(gEstimated, getErrMsg('garantie-valeurEstimee'));
                clearFieldValidation(gRetained, getErrMsg('garantie-valeurRetenue'));
                clearFieldValidation(gDoc, getErrMsg('garantie-documentJustificatif'));
                syncRetainedValue();
            }, 0);
        });
    }

    document.querySelectorAll('.nx-garantie-edit-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            if (!garantieForm) return;
            const row = btn.closest('.nx-garantie-row');
            if (!row) return;

            setFieldValue(garantieForm, 'idGarantie', row.dataset.garantieId);
            setFieldValue(garantieForm, 'idCredit', row.dataset.garantieCreditId);
            setFieldValue(garantieForm, 'typeGarantie', row.dataset.garantieType);
            setFieldValue(garantieForm, 'description', row.dataset.garantieDescription);
            setFieldValue(garantieForm, 'adresseBien', row.dataset.garantieAddress);
            setFieldValue(garantieForm, 'valeurEstimee', row.dataset.garantieEstimated);
            setFieldValue(garantieForm, 'valeurRetenue', row.dataset.garantieRetained);
            setFieldValue(garantieForm, 'dateEvaluation', normalizeIsoDate(row.dataset.garantieDate));
            setFieldValue(garantieForm, 'nomGarant', row.dataset.garantieGuarantor);
            setFieldValue(garantieForm, 'statut', row.dataset.garantieStatus || 'Soumise');

            if (gRetained && (row.dataset.garantieRetained || '').trim() !== '') gRetained.dataset.manual = '1';
            if (gDocExisting) gDocExisting.value = row.dataset.garantieDocument || '';
            if (gDoc) gDoc.value = '';

            // Run validation passively
            ['idCredit', 'typeGarantie', 'description', 'adresseBien', 'valeurEstimee', 'valeurRetenue', 'dateEvaluation', 'nomGarant', 'documentJustificatif'].forEach(validateGarantieField);
            scrollToForm(garantieForm);
        });
    });

    // ────────────────────────────────────────────────────────────────────────
    // FILTER / SEARCH UTILITIES
    // ────────────────────────────────────────────────────────────────────────
    const filterTable = (searchInputId, selectSortId, tbodyId, rowClass) => {
        const searchInput = document.getElementById(searchInputId);
        const sortSelect = document.getElementById(selectSortId);
        const tbody = document.getElementById(tbodyId);
        if (!tbody || (!searchInput && !sortSelect)) return;

        const applyState = () => {
            const query = (searchInput?.value || '').toLowerCase().trim();
            const sortKey = sortSelect?.value || 'default';
            const rows = Array.from(tbody.querySelectorAll(`.${rowClass}`));

            rows.forEach((row, index) => {
                if (!row.dataset.originalIndex) row.dataset.originalIndex = index;
                const indexText = (row.dataset.searchIndex || '').toLowerCase();
                row.hidden = query !== '' && !indexText.includes(query);
            });

            const visibleRows = rows.filter(r => !r.hidden);
            visibleRows.sort((a,b) => {
                const idA = parseNumber(a.dataset.creditId || a.dataset.garantieId);
                const idB = parseNumber(b.dataset.creditId || b.dataset.garantieId);

                if (rowClass === 'nx-credit-row') {
                    const amA = parseNumber(a.dataset.creditAmount);
                    const amB = parseNumber(b.dataset.creditAmount);
                    const moA = parseNumber(a.dataset.creditMonthly);
                    const moB = parseNumber(b.dataset.creditMonthly);
                    const rkA = parseNumber(a.dataset.creditRisk);
                    const rkB = parseNumber(b.dataset.creditRisk);
                    const statA = (a.dataset.creditStatus||'').toLowerCase();
                    const statB = (b.dataset.creditStatus||'').toLowerCase();
                    const usA = (a.querySelector('.nx-acc__owner-name span')?.textContent||'').toLowerCase();
                    const usB = (b.querySelector('.nx-acc__owner-name span')?.textContent||'').toLowerCase();

                    switch(sortKey) {
                        case 'id-desc': return idB - idA;
                        case 'id-asc': return idA - idB;
                        case 'amount-desc': return amB - amA || idB - idA;
                        case 'monthly-desc': return moB - moA || idB - idA;
                        case 'risk-desc': return rkB - rkA || idB - idA;
                        case 'user-asc': return usA.localeCompare(usB);
                        case 'status-asc': return statA.localeCompare(statB);
                    }
                } else {
                    const valA = parseNumber(a.dataset.garantieEstimated);
                    const valB = parseNumber(b.dataset.garantieEstimated);
                    const statA = (a.dataset.garantieStatus||'').toLowerCase();
                    const statB = (b.dataset.garantieStatus||'').toLowerCase();
                    const cIdA = parseNumber(a.dataset.garantieCreditId);
                    const cIdB = parseNumber(b.dataset.garantieCreditId);
                    const tyA = (a.dataset.garantieType||'').toLowerCase();
                    const tyB = (b.dataset.garantieType||'').toLowerCase();
                    
                    switch(sortKey) {
                        case 'id-desc': return idB - idA;
                        case 'id-asc': return idA - idB;
                        case 'value-desc': return valB - valA || idB - idA;
                        case 'credit-asc': return cIdA - cIdB;
                        case 'type-asc': return tyA.localeCompare(tyB);
                        case 'status-asc': return statA.localeCompare(statB);
                    }
                }
                return parseNumber(a.dataset.originalIndex) - parseNumber(b.dataset.originalIndex);
            }).forEach(r => tbody.appendChild(r));
        };
        
        if (searchInput) searchInput.addEventListener('input', applyState);
        if (sortSelect) sortSelect.addEventListener('change', applyState);
        
        applyState();
    };

    filterTable('nx-credit-search', 'nx-credit-sort', 'nx-credit-tbody', 'nx-credit-row');
    filterTable('nx-garantie-search', 'nx-garantie-sort', 'nx-garantie-tbody', 'nx-garantie-row');

    
    
    /* ========================================================= */
    /* LOGIQUE STATISTIQUES ADMIN                                */
    /* ========================================================= */
    const statsBtn = document.getElementById('nx-module-stats-btn');
    const statsPanel = document.getElementById('nx-admin-stats-panel');
    const serverCreditStats = {{ credit_stats|json_encode|raw }};
    const serverGarantieStats = {{ garantie_stats|json_encode|raw }};
    let chart1 = null, chart3 = null;

    if (statsBtn && statsPanel) {
        // Change default behavior if needed
        statsBtn.addEventListener('click', (e) => {
            e.preventDefault();
            const isOpen = statsPanel.classList.contains('is-open');
            if (isOpen) {
                statsPanel.classList.remove('is-open');
                return;
            }
            statsPanel.classList.add('is-open');
            
            const creditRows = Array.from(document.querySelectorAll('.nx-credit-row'));
            const garantieRows = Array.from(document.querySelectorAll('.nx-garantie-row'));
            
            const cTotal = creditRows.length || Number(serverCreditStats.total || 0);
            const gTotal = garantieRows.length || Number(serverGarantieStats.total || 0);
            document.getElementById('stat-main-subtitle').textContent = `${cTotal} crédit${cTotal!=1?'s':''} · ${gTotal} garantie${gTotal!=1?'s':''} enregistrée${gTotal!=1?'s':''}`;

            const countBy = (rows, datasetKey) => rows.reduce((acc, row) => {
                let val = row.dataset[datasetKey];
                if (!val || val.trim() === '') val = 'Non spécifié';
                acc[val] = (acc[val] || 0) + 1;
                return acc;
            }, {});

            const sumBy = (rows, groupKey, sumKey) => rows.reduce((acc, row) => {
                 let val = row.dataset[groupKey];
                 if (!val || val.trim() === '') val = 'Non spécifié';
                 let amount = Number(row.dataset[sumKey] || 0);
                 acc[val] = (acc[val] || 0) + amount;
                 return acc;
            }, {});

            const resolveStats = (rows, groupKey, sumKey, fallbackCounts, fallbackAmounts) => {
                if (rows.length > 0) {
                    return {
                        counts: countBy(rows, groupKey),
                        amounts: sumBy(rows, groupKey, sumKey)
                    };
                }

                return {
                    counts: fallbackCounts || {},
                    amounts: fallbackAmounts || {}
                };
            };

            const buildDataset = (counts, amounts, emptyLabel) => {
                const labels = Object.keys(counts).filter((label) => Number(counts[label] || 0) > 0);

                if (!labels.length) {
                    return {
                        labels: [emptyLabel],
                        data: [1],
                        amounts: { [emptyLabel]: 0 },
                        isEmpty: true
                    };
                }

                return {
                    labels,
                    data: labels.map((label) => Number(counts[label] || 0)),
                    amounts,
                    isEmpty: false
                };
            };

            const statusStats = resolveStats(
                creditRows,
                'creditStatus',
                'creditAmount',
                serverCreditStats.counts,
                serverCreditStats.amounts
            );
            const garantieStatusStats = resolveStats(
                garantieRows,
                'garantieStatus',
                'garantieEstimated',
                serverGarantieStats.counts,
                serverGarantieStats.amounts
            );

            const cTotalAmount = creditRows.length > 0
                ? creditRows.reduce((a,b)=>a+Number(b.dataset.creditAmount||0),0)
                : Object.values(statusStats.amounts || {}).reduce((a, b) => a + Number(b || 0), 0);
            const gTotalAmount = garantieRows.length > 0
                ? garantieRows.reduce((a,b)=>a+Number(b.dataset.garantieEstimated||0),0)
                : Number(serverGarantieStats.total_estimee || 0);
            const unsecuredAmount = Math.max(0, cTotalAmount - gTotalAmount);

            // Exactly matching account colors: #00B4A0 for Active, #0A2540 for Fermé, #B8860B for Bloqué...
            // Let's use a nice mapped palette
            const colorsPalette = ['#00B4A0', '#0A2540', '#B8860B', '#ef4444', '#f97316'];
            
            // Chart Status
            const creditDataset = buildDataset(statusStats.counts, statusStats.amounts, 'Aucune donnee');
            const sLabels = creditDataset.labels;
            const sData = creditDataset.data;
            const sColors = sLabels.map((l,i) => {
                let lb = l.toLowerCase();
                if (creditDataset.isEmpty) return '#d6dee8';
                if(lb.includes('accept') || lb.includes('actif')) return '#00B4A0';
                if(lb.includes('rejet') || lb.includes('refus')) return '#ef4444';
                if(lb.includes('attente')) return '#0A2540';
                if(lb.includes('cours')) return '#B8860B';
                return colorsPalette[i % colorsPalette.length];
            });
            
            const buildLegend = (labels, data, amounts, total, colors, containerId, isEmpty = false) => {
                const container = document.getElementById(containerId);
                if(!container) return;
                container.innerHTML = '';
                labels.forEach((lbl, i) => {
                    let pct = isEmpty ? '0.0' : (total > 0 ? ((data[i] / total) * 100).toFixed(1) : 0);
                    let color = colors[i];
                    if (amounts) amounts[lbl] = Number(amounts[lbl] || 0);
                    let valStr = amounts ? amounts[lbl].toLocaleString('fr-FR', {minimumFractionDigits:2, maximumFractionDigits:2}) + ' DT' : data[i] + ' unités';
                    
                    // Same as .nx-chart-legend-row
                    container.innerHTML += `
                        <div class="nx-chart-legend-row" style="--lc:${color}">
                            <span class="nx-chart-legend-dot"></span>
                            <span class="nx-chart-legend-label">${lbl}</span>
                            <strong>${isEmpty ? 0 : data[i]}</strong>
                            <span class="nx-chart-legend-pct">${pct}%</span>
                            <span class="nx-chart-legend-val">${valStr}</span>
                        </div>
                    `;
                });
            };

            buildLegend(sLabels, sData, creditDataset.amounts, cTotal, sColors, 'stat-credit-status', creditDataset.isEmpty);

            if (window.Chart) {
                if(chart1) chart1.destroy();
                chart1 = new Chart(document.getElementById('nx-chart-status-canvas'), {
                    type: 'doughnut',
                    data: {
                        labels: sLabels,
                        datasets: [{
                            data: sData,
                            backgroundColor: sColors,
                            borderColor: '#fff',
                            borderWidth: 3,
                            hoverOffset: 12
                        }]
                    },
                    options: { 
                        cutout: '62%', 
                        responsive: true, 
                        maintainAspectRatio: false, 
                        plugins: { legend: { display: false }, tooltip: { enabled: true } },
                        animation: { animateRotate: true, duration: 700 } 
                    }
                });
            }

            // Chart 3 (Garanties par Statut)
            const garantieDataset = buildDataset(garantieStatusStats.counts, garantieStatusStats.amounts, 'Aucune garantie');
            const gsLabels = garantieDataset.labels;
            const gsData = garantieDataset.data;
            const gsColors = gsLabels.map((l, i) => {
                let lb = l.toLowerCase();
                if (garantieDataset.isEmpty) return '#d6dee8';
                if(lb.includes('accep') || lb.includes('valid') || lb.includes('actif')) return '#00B4A0';
                if(lb.includes('rejet') || lb.includes('refus')) return '#ef4444';
                if(lb.includes('attente') || lb.includes('soumis')) return '#0A2540';
                if(lb.includes('cours')) return '#B8860B';
                return colorsPalette[i % colorsPalette.length];
            });

            buildLegend(gsLabels, gsData, garantieDataset.amounts, gTotal, gsColors, 'stat-garantie-status', garantieDataset.isEmpty);

            if (window.Chart) {
                if(chart3) chart3.destroy();
                chart3 = new Chart(document.getElementById('nx-chart-garantie-status-canvas'), {
                    type: 'doughnut',
                    data: {
                        labels: gsLabels,
                        datasets: [{
                            data: gsData,
                            backgroundColor: gsColors,
                            borderColor: '#fff',
                            borderWidth: 3,
                            hoverOffset: 12
                        }]
                    },
                    options: {
                        cutout: '62%',
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { display: false }, tooltip: { enabled: true } },
                        animation: { animateRotate: true, duration: 700 }
                    }
                });
            }
        });
    }
})();
</script>
