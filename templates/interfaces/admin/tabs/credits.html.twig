<style>
/* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
   NEXORA Â· Accounts Module  (nx-acc)
â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */

:root {
  --na-bg:        #f0f4f9;
  --na-surface:   #ffffff;
  --na-border:    #e4ecf4;
  --na-txt:       #1a2b3c;
  --na-muted:     #6b85a0;
  --na-radius:    14px;
  --na-shadow:    0 2px 16px rgba(0,0,0,.07);
  --na-shadow-lg: 0 6px 32px rgba(0,0,0,.10);
  --na-teal:      #11b7aa;
  --na-teal-dk:   #0d9e93;
  --na-blue:      #2b7de9;
  --na-blue-dk:   #1f6cd6;
  --na-gold:      #e8a202;
  --na-purple:    #7c4dff;
  --na-red:       #e53935;
  --na-green:     #43a047;
}

/* â”€â”€ Shell â”€â”€ */
.nx-acc {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
  padding: 1.75rem 2rem;
  background: var(--na-bg);
  min-height: 100%;
  font-family: 'Inter', system-ui, sans-serif;
  color: var(--na-txt);
}

/* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
   HERO HEADER
â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
.nx-acc__hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1.25rem;
  background: linear-gradient(135deg, #1a2b3c 0%, #1e3448 60%, #1a3050 100%);
  border-radius: var(--na-radius);
  padding: 1.5rem 1.8rem;
  box-shadow: var(--na-shadow-lg);
  flex-wrap: wrap;
  position: relative;
  overflow: hidden;
}
.nx-acc__hero::before {
  content: '';
  position: absolute;
  width: 260px; height: 260px;
  top: -80px; right: -50px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(17,183,170,.22) 0%, transparent 70%);
  pointer-events: none;
}
.nx-acc__hero::after {
  content: '';
  position: absolute;
  width: 160px; height: 160px;
  bottom: -60px; left: 30%;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(43,125,233,.18) 0%, transparent 70%);
  pointer-events: none;
}

.nx-acc__hero-left {
  display: flex;
  align-items: center;
  gap: 1.1rem;
  position: relative;
  z-index: 1;
}

.nx-acc__hero-icon {
  width: 50px; height: 50px;
  border-radius: 13px;
  background: linear-gradient(135deg, var(--na-teal), var(--na-teal-dk));
  display: grid;
  place-items: center;
  font-size: 1.3rem;
  color: #fff;
  box-shadow: 0 4px 16px rgba(17,183,170,.4);
  flex-shrink: 0;
}

.nx-acc__hero-text h2 {
  font-size: 1.1rem;
  font-weight: 800;
  color: #fff;
  margin: 0 0 .25rem;
}
.nx-acc__hero-text p {
  font-size: .76rem;
  color: rgba(255,255,255,.5);
  margin: 0;
}

.nx-acc__hero-actions {
  display: flex;
  align-items: center;
  gap: .65rem;
  position: relative;
  z-index: 1;
  flex-wrap: wrap;
}

/* â”€â”€ Shared buttons â”€â”€ */
.na-btn {
  display: inline-flex;
  align-items: center;
  gap: .4rem;
  padding: .52rem 1.1rem;
  border-radius: 9px;
  font-size: .82rem;
  font-weight: 600;
  border: none;
  cursor: pointer;
  text-decoration: none;
  transition: all .2s ease;
  font-family: inherit;
  white-space: nowrap;
}
.na-btn--primary {
  background: linear-gradient(135deg, var(--na-teal), var(--na-teal-dk));
  color: #fff;
  box-shadow: 0 3px 10px rgba(17,183,170,.35);
}
.na-btn--primary:hover {
  box-shadow: 0 5px 18px rgba(17,183,170,.5);
  transform: translateY(-1px);
}
.na-btn--ghost {
  background: rgba(255,255,255,.1);
  color: rgba(255,255,255,.85);
  border: 1px solid rgba(255,255,255,.18);
  backdrop-filter: blur(4px);
}
.na-btn--ghost:hover {
  background: rgba(255,255,255,.18);
  color: #fff;
}
.na-btn--ghost-dark {
  background: transparent;
  color: var(--na-teal);
  border: 1px solid rgba(17,183,170,.3);
  font-size: .78rem;
}
.na-btn--ghost-dark:hover { background: rgba(17,183,170,.06); }
.na-btn--danger {
  background: rgba(229,57,53,.09);
  color: var(--na-red);
  border: 1px solid rgba(229,57,53,.22);
  font-size: .76rem;
  padding: .38rem .8rem;
}
.na-btn--danger:hover { background: rgba(229,57,53,.18); }
.na-btn--save {
  background: linear-gradient(135deg, var(--na-teal), var(--na-teal-dk));
  color: #fff;
  box-shadow: 0 3px 10px rgba(17,183,170,.3);
}
.na-btn--save:hover {
  box-shadow: 0 5px 16px rgba(17,183,170,.45);
  transform: translateY(-1px);
}
.na-btn--reset {
  background: var(--na-bg);
  color: var(--na-muted);
  border: 1px solid var(--na-border);
}
.na-btn--reset:hover { background: var(--na-border); color: var(--na-txt); }

/* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
   SUBTABS
â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
.nx-acc__tabs {
  display: flex;
  align-items: center;
  gap: .4rem;
  background: var(--na-surface);
  border: 1px solid var(--na-border);
  border-radius: var(--na-radius);
  padding: .55rem .65rem;
  box-shadow: var(--na-shadow);
  flex-wrap: wrap;
}

.nx-acc__tab {
  display: inline-flex;
  align-items: center;
  gap: .45rem;
  padding: .5rem 1.1rem;
  border-radius: 9px;
  font-size: .82rem;
  font-weight: 600;
  color: var(--na-muted);
  text-decoration: none;
  transition: all .2s ease;
  border: 1px solid transparent;
}
.nx-acc__tab i { font-size: .85rem; }
.nx-acc__tab:hover {
  background: var(--na-bg);
  color: var(--na-txt);
}
.nx-acc__tab.is-active {
  background: linear-gradient(135deg, var(--na-teal), var(--na-teal-dk));
  color: #fff;
  box-shadow: 0 3px 10px rgba(17,183,170,.3);
}

.nx-acc__tabs-spacer { flex: 1; }

.nx-acc__stats-link {
  display: inline-flex;
  align-items: center;
  gap: .4rem;
  padding: .5rem 1rem;
  border-radius: 9px;
  font-size: .78rem;
  font-weight: 600;
  color: var(--na-blue);
  text-decoration: none;
  background: rgba(43,125,233,.07);
  border: 1px solid rgba(43,125,233,.18);
  transition: all .2s;
}
.nx-acc__stats-link:hover { background: rgba(43,125,233,.14); }

/* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
   KPI ROW
â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
.nx-acc__kpis {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
}

.nx-acc__kpi {
  background: var(--na-surface);
  border: 1px solid var(--na-border);
  border-radius: var(--na-radius);
  padding: 1.1rem 1.25rem;
  box-shadow: var(--na-shadow);
  display: flex;
  align-items: center;
  gap: 1rem;
  transition: transform .2s, box-shadow .2s;
  position: relative;
  overflow: hidden;
}
.nx-acc__kpi:hover {
  transform: translateY(-2px);
  box-shadow: var(--na-shadow-lg);
}
.nx-acc__kpi::after {
  content: '';
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 3px;
  border-radius: 0 3px 3px 0;
}
.nx-acc__kpi:nth-child(1)::after { background: var(--na-teal); }
.nx-acc__kpi:nth-child(2)::after { background: var(--na-blue); }
.nx-acc__kpi:nth-child(3)::after { background: var(--na-gold); }

.nx-acc__kpi-icon {
  width: 44px; height: 44px;
  border-radius: 12px;
  display: grid;
  place-items: center;
  font-size: 1.1rem;
  flex-shrink: 0;
}
.nx-acc__kpi:nth-child(1) .nx-acc__kpi-icon {
  background: rgba(17,183,170,.1); color: var(--na-teal);
}
.nx-acc__kpi:nth-child(2) .nx-acc__kpi-icon {
  background: rgba(43,125,233,.1); color: var(--na-blue);
}
.nx-acc__kpi:nth-child(3) .nx-acc__kpi-icon {
  background: rgba(232,162,2,.1); color: var(--na-gold);
}

.nx-acc__kpi-body strong {
  display: block;
  font-size: 1.55rem;
  font-weight: 800;
  color: var(--na-txt);
  line-height: 1;
  margin-bottom: .2rem;
}
.nx-acc__kpi-body small {
  font-size: .74rem;
  color: var(--na-muted);
  font-weight: 500;
}

/* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
   CONTENT GRID
â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
.nx-acc__grid {
  display: grid;
  grid-template-columns: 340px 1fr;
  gap: 1.25rem;
  align-items: start;
}

/* â”€â”€ Panel card shared â”€â”€ */
.nx-acc__panel {
  background: var(--na-surface);
  border: 1px solid var(--na-border);
  border-radius: var(--na-radius);
  box-shadow: var(--na-shadow);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.nx-acc__panel-head {
  padding: 1.1rem 1.3rem;
  border-bottom: 1px solid var(--na-border);
  background: linear-gradient(to right, #fafcff, #f5f8fd);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: .75rem;
  flex-wrap: wrap;
}
.nx-acc__panel-head-left h3 {
  font-size: .9rem;
  font-weight: 700;
  color: var(--na-txt);
  margin: 0 0 .15rem;
}
.nx-acc__panel-head-left p {
  font-size: .73rem;
  color: var(--na-muted);
  margin: 0;
}

/* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
   FORM PANEL
â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
.nx-acc__form {
  display: flex;
  flex-direction: column;
  gap: .75rem;
  padding: 1.2rem 1.3rem;
}

.nx-acc__form label {
  display: flex;
  flex-direction: column;
  gap: .3rem;
}
.nx-acc__form label span {
  font-size: .71rem;
  font-weight: 700;
  color: var(--na-muted);
  text-transform: uppercase;
  letter-spacing: .5px;
}

.nx-acc__form input[type="text"],
.nx-acc__form input[type="number"],
.nx-acc__form input[type="date"],
.nx-acc__form select {
  height: 38px;
  padding: 0 .8rem;
  border: 1px solid var(--na-border);
  border-radius: 9px;
  font-size: .82rem;
  color: var(--na-txt);
  background: var(--na-bg);
  outline: none;
  width: 100%;
  box-sizing: border-box;
  font-family: inherit;
  transition: border-color .2s, box-shadow .2s;
}
.nx-acc__form input:focus,
.nx-acc__form select:focus {
  border-color: var(--na-teal);
  box-shadow: 0 0 0 3px rgba(17,183,170,.12);
  background: #fff;
}

.nx-acc__form-divider {
  height: 1px;
  background: var(--na-border);
  margin: .2rem 0;
}

.nx-acc__form-label-id {
  font-size: .7rem;
  color: var(--na-muted);
  background: rgba(43,125,233,.06);
  border: 1px solid rgba(43,125,233,.15);
  border-radius: 7px;
  padding: .5rem .7rem;
  display: flex;
  align-items: center;
  gap: .35rem;
  margin-bottom: .1rem;
}
.nx-acc__form-label-id i { color: var(--na-blue); }

.nx-acc__form-actions {
  display: flex;
  gap: .55rem;
  padding-top: .4rem;
  border-top: 1px solid var(--na-border);
}
.nx-acc__form-actions .na-btn { flex: 1; justify-content: center; }

/* ── Validation errors ── */
.nx-field-error {
  display: none;
  color: #dc2626 !important;
  font-size: .75rem;
  font-weight: 500;
  margin-top: .3rem;
  padding: 0;
  background: none !important;
  text-transform: none !important;
  letter-spacing: normal !important;
}
.nx-field-error.is-visible { display: block; }
.nx-acc__form label .nx-field-error {
  color: #dc2626 !important;
  text-transform: none !important;
  letter-spacing: normal !important;
  font-weight: 500 !important;
  background: transparent !important;
}
.nx-acc__form input.is-invalid,
.nx-acc__form select.is-invalid {
  border-color: #dc2626 !important;
  box-shadow: 0 0 0 2px rgba(220,38,38,.15) !important;
}
.nx-acc__form input.is-valid,
.nx-acc__form select.is-valid {
  border-color: #16a34a !important;
  box-shadow: none !important;
}

/* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
   TABLE PANEL
â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
.nx-acc__table-wrap { overflow-x: auto; }

.nx-acc__table {
  width: 100%;
  border-collapse: collapse;
