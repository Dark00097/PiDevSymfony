{% set unread_count = 0 %}
{% for item in items %}
    {% if not item.is_read|default(0) %}
        {% set unread_count = unread_count + 1 %}
    {% endif %}
{% endfor %}

<section class="panel-card nx-crud-screen">
    <header class="nx-crud-head">
        <div>
            <h2>Centre Notifications</h2>
            <p>Alertes systeme, emails et suivi des evenements admin</p>
        </div>
        <form method="post">
            <input type="hidden" name="tab" value="notifications">
            <input type="hidden" name="action" value="notifications_read">
            <button class="btn btn-secondary" type="submit">Marquer tout comme lu</button>
        </form>
    </header>

    <div class="nx-crud-kpis">
        <article class="nx-crud-kpi">
            <span class="nx-crud-kpi-icon"><i class="fa-solid fa-bell"></i></span>
            <div><strong>{{ items|length }}</strong><small>Notifications total</small></div>
        </article>
        <article class="nx-crud-kpi">
            <span class="nx-crud-kpi-icon"><i class="fa-solid fa-envelope-circle-check"></i></span>
            <div><strong>{{ unread_count }}</strong><small>Non lues</small></div>
        </article>
        <article class="nx-crud-kpi">
            <span class="nx-crud-kpi-icon"><i class="fa-solid fa-bullhorn"></i></span>
            <div><strong>{{ notifications_count }}</strong><small>Compteur topbar</small></div>
        </article>
    </div>

    <article class="nx-crud-table-card">
        <div class="nx-crud-card-head">
            <h3>Flux des notifications</h3>
            <p>Historique detaille des alertes admin et utilisateurs</p>
        </div>

        <div class="table-wrap">
            <table class="data-table nx-crud-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Type</th>
                        <th>Titre</th>
                        <th>Message</th>
                        <th>Date</th>
                        <th>Etat</th>
                    </tr>
                </thead>
                <tbody>
                {% for item in items %}
                    <tr>
                        <td>{{ item.idNotification|default('-') }}</td>
                        <td>{{ item.type|default('INFO') }}</td>
                        <td>{{ item.title }}</td>
                        <td>{{ item.message }}</td>
                        <td>{{ item.created_at }}</td>
                        <td>{{ item.is_read|default(0) ? 'Lue' : 'Non lue' }}</td>
                    </tr>
                {% else %}
                    <tr><td colspan="6">Aucune notification.</td></tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </article>
</section>
