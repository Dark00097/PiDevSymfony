          <p>GÃ©rer et superviser les donnÃ©es bancaires</p>
        {% endif %}
      </div>
    </div>
    <div class="nx-acc__hero-actions">
      {% if active_panel == 'ia' %}
        <a class="na-btn na-btn--ghost"
