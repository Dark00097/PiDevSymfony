            <span id="nx-acc-page-info" style="font-size:13px;color:var(--na-muted);font-weight:600;"></span>
            <div id="nx-acc-page-btns" style="display:flex;align-items:center;gap:6px;flex-wrap:wrap;"></div>
        </div>

        <style>
        .nx-pg-btn{height:36px;min-width:36px;padding:0 12px;border-radius:10px;border:1px solid var(--na-border);background:#fff;color:var(--na-txt);font:inherit;font-size:13px;font-weight:700;cursor:pointer;display:inline-flex;align-items:center;justify-content:center;transition:all .18s}
        .nx-pg-btn:hover{background:var(--na-teal);color:#fff;border-color:var(--na-teal)}
        .nx-pg-btn.active{background:var(--na-teal);color:#fff;border-color:var(--na-teal);box-shadow:0 4px 12px rgba(17,183,170,.25)}
        .nx-pg-btn:disabled{opacity:.4;cursor:not-allowed}
        </style>

        <script>
        (function(){
            const PER_PAGE = 10;
            const tbody = document.querySelector('#nx-account-table tbody');
            if (!tbody) return;
            const allRows = Array.from(tbody.querySelectorAll('tr[data-id]'));
            const total = allRows.length;
            if (total <= PER_PAGE) { document.getElementById('nx-acc-pagination').style.display = 'none'; return; }
            let page = 1;
            const totalPages = () => Math.ceil(total / PER_PAGE);

            function render() {
                const start = (page - 1) * PER_PAGE;
                allRows.forEach((r, i) => { r.style.display = (i >= start && i < start + PER_PAGE) ? '' : 'none'; });
                const info = document.getElementById('nx-acc-page-info');
                if (info) info.textContent = 'Affichage ' + (start + 1) + '–' + Math.min(start + PER_PAGE, total) + ' sur ' + total + ' comptes';
                const btns = document.getElementById('nx-acc-page-btns');
                if (!btns) return;
                const tp = totalPages();
                let html = '<button class="nx-pg-btn" id="nx-pg-prev" ' + (page === 1 ? 'disabled' : '') + '><i class="fa-solid fa-chevron-left"></i></button>';
                const range = [];
                if (tp <= 7) { for (let i = 1; i <= tp; i++) range.push(i); }
                else {
                    range.push(1);
                    if (page > 3) range.push('…');
                    for (let i = Math.max(2, page - 1); i <= Math.min(tp - 1, page + 1); i++) range.push(i);
                    if (page < tp - 2) range.push('…');
                    range.push(tp);
                }
                range.forEach(function(p) {
                    if (p === '…') { html += '<span style="padding:0 4px;color:var(--na-muted);">…</span>'; }
                    else { html += '<button class="nx-pg-btn' + (p === page ? ' active' : '') + '" data-p="' + p + '">' + p + '</button>'; }
                });
                html += '<button class="nx-pg-btn" id="nx-pg-next" ' + (page === tp ? 'disabled' : '') + '><i class="fa-solid fa-chevron-right"></i></button>';
                btns.innerHTML = html;
                btns.querySelectorAll('[data-p]').forEach(function(b) {
                    b.addEventListener('click', function() { page = parseInt(b.dataset.p); render(); });
                });
                const prev = btns.querySelector('#nx-pg-prev');
                const next = btns.querySelector('#nx-pg-next');
                if (prev) prev.addEventListener('click', function() { if (page > 1) { page--; render(); } });
                if (next) next.addEventListener('click', function() { if (page < tp) { page++; render(); } });
            }
            render();
        })();
        </script>

      </article>

    </div>
  {% endif %}

</section>

