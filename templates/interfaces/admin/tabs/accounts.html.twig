<script>
(() => {
  /* â”€â”€ Search â”€â”€ */
  const wire = (inputId, tableId) => {
    const input = document.getElementById(inputId);
    const table = document.getElementById(tableId);
    if (!input || !table) return;
    input.addEventListener('input', () => {
      const q = input.value.toLowerCase().trim();
      table.querySelectorAll('tbody tr').forEach(row => {
        row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
      });
    });
  };
  wire('nx-acc-account-search', 'nx-account-table');
  wire('nx-acc-vault-search',   'nx-vault-table');

  /* â”€â”€ Sort â”€â”€ */
  const wireSort = (tableId) => {
    document.querySelectorAll(`#${tableId} thead th.sortable`).forEach(th => {
      th.addEventListener('click', () => {
        const table = document.getElementById(tableId);
        const col   = +th.dataset.col;
        const asc   = !th.classList.contains('sort-asc');
        table.querySelectorAll('thead th').forEach(h => h.classList.remove('sort-asc','sort-desc'));
        th.classList.add(asc ? 'sort-asc' : 'sort-desc');
        const icon = th.querySelector('.sort-icon');
        if (icon) icon.className = 'fa-solid sort-icon ' + (asc ? 'fa-sort-up' : 'fa-sort-down');
        const rows = [...table.querySelectorAll('tbody tr')];
        rows.sort((a, b) => {
          const va = a.cells[col]?.textContent.trim() ?? '';
          const vb = b.cells[col]?.textContent.trim() ?? '';
          const na = parseFloat(va.replace(/\s/g,''));
          const nb = parseFloat(vb.replace(/\s/g,''));
          const cmp = (!isNaN(na) && !isNaN(nb)) ? na - nb : va.localeCompare(vb, 'fr');
          return asc ? cmp : -cmp;
        });
        rows.forEach(r => table.querySelector('tbody').appendChild(r));
      });
    });
  };
  wireSort('nx-account-table');
  wireSort('nx-vault-table');

  /* â”€â”€ Sort dropdown (compte table) â”€â”€ */
  let sortAsc = true;
  const sortField = document.getElementById('nx-acc-sort-field');
  const sortDirBtn = document.getElementById('nx-acc-sort-dir');

  function applyDropdownSort() {
    const col = sortField?.value;
    if (col === '' || col === null || col === undefined) return;
    const table = document.getElementById('nx-account-table');
    if (!table) return;
    const rows = [...table.querySelectorAll('tbody tr')];
    rows.sort((a, b) => {
      const va = a.cells[+col]?.textContent.trim() ?? '';
      const vb = b.cells[+col]?.textContent.trim() ?? '';
      const na = parseFloat(va.replace(/\s/g,''));
      const nb = parseFloat(vb.replace(/\s/g,''));
      const cmp = (!isNaN(na) && !isNaN(nb)) ? na - nb : va.localeCompare(vb, 'fr');
      return sortAsc ? cmp : -cmp;
    });
    rows.forEach(r => table.querySelector('tbody').appendChild(r));
    if (sortDirBtn) {
      sortDirBtn.querySelector('i').className = 'fa-solid ' + (sortAsc ? 'fa-arrow-up-a-z' : 'fa-arrow-down-z-a');
    }
  }

  sortField?.addEventListener('change', applyDropdownSort);
  sortDirBtn?.addEventListener('click', () => {
    sortAsc = !sortAsc;
    applyDropdownSort();
  });

  /* â”€â”€ Sort dropdown (vault table) â”€â”€ */
  let vaultSortAsc = true;
  const vaultSortField  = document.getElementById('nx-vault-sort-field');
  const vaultSortDirBtn = document.getElementById('nx-vault-sort-dir');

  function applyVaultSort() {
    const col = vaultSortField?.value;
    if (col === '' || col === null || col === undefined) return;
    const table = document.getElementById('nx-vault-table');
    if (!table) return;
    const rows = [...table.querySelectorAll('tbody tr')];
    rows.sort((a, b) => {
      const va = a.cells[+col]?.textContent.trim() ?? '';
      const vb = b.cells[+col]?.textContent.trim() ?? '';
      const na = parseFloat(va.replace(/\s/g,''));
      const nb = parseFloat(vb.replace(/\s/g,''));
      const cmp = (!isNaN(na) && !isNaN(nb)) ? na - nb : va.localeCompare(vb, 'fr');
      return vaultSortAsc ? cmp : -cmp;
    });
    rows.forEach(r => table.querySelector('tbody').appendChild(r));
    if (vaultSortDirBtn) {
      vaultSortDirBtn.querySelector('i').className = 'fa-solid ' + (vaultSortAsc ? 'fa-arrow-up-a-z' : 'fa-arrow-down-z-a');
    }
    // update count
    const countEl = document.getElementById('nx-vault-count');
    if (countEl) {
      const visible = rows.filter(r => r.style.display !== 'none').length;
      countEl.textContent = visible + ' coffre' + (visible !== 1 ? 's' : '');
    }
  }

  vaultSortField?.addEventListener('change', applyVaultSort);
  vaultSortDirBtn?.addEventListener('click', () => {
    vaultSortAsc = !vaultSortAsc;
    applyVaultSort();
  });

  /* â”€â”€ Vault search with count update â”€â”€ */
  document.getElementById('nx-acc-vault-search')?.addEventListener('input', function() {
    const q = this.value.toLowerCase().trim();
    const table = document.getElementById('nx-vault-table');
    if (!table) return;
    let visible = 0;
    table.querySelectorAll('tbody tr').forEach(row => {
      const show = row.textContent.toLowerCase().includes(q);
      row.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    const countEl = document.getElementById('nx-vault-count');
    if (countEl) countEl.textContent = visible + ' coffre' + (visible !== 1 ? 's' : '');
  });

  /* â”€â”€ Row click â†’ fill form + update export link â”€â”€ */
  const exportBtn   = document.getElementById('nx-export-btn');
  const exportBase  = '{{ path('admin_account_export_pdf') }}';

  document.querySelectorAll('#nx-account-table tbody tr').forEach(row => {
    row.addEventListener('click', (e) => {
      // Don't trigger if clicking a button/form inside the row
      if (e.target.closest('button, a, form')) return;
      // Highlight
      document.querySelectorAll('#nx-account-table tbody tr').forEach(r => r.classList.remove('is-selected'));
      row.classList.add('is-selected');
      // Fill form
      nxEditCompte(row);
      // Update export button to point to this account
      if (exportBtn && row.dataset.id) {
        exportBtn.href = exportBase + '?idCompte=' + row.dataset.id;
      }
    });
  });

  // Reset export link when form is reset
  document.getElementById('nx-compte-form')?.addEventListener('reset', () => {
    document.querySelectorAll('#nx-account-table tbody tr').forEach(r => r.classList.remove('is-selected'));
    if (exportBtn) exportBtn.href = exportBase;
  });
})();

/* â”€â”€ Edit: prÃ©-remplir le formulaire â”€â”€ */
function nxEditCompte(row) {
  const d = row.dataset;
  document.getElementById('f-idCompte').value        = d.id;
  document.getElementById('f-numeroCompte').value    = d.numero;
  document.getElementById('f-solde').value           = d.solde;
  document.getElementById('f-dateOuverture').value   = d.date || document.getElementById('f-dateOuverture').dataset.expectedDate || '';
  document.getElementById('f-dateOuverture').dataset.expectedDate = d.date || document.getElementById('f-dateOuverture').dataset.expectedDate || '';
  document.getElementById('f-plafondRetrait').value  = d.plafondRetrait;
  document.getElementById('f-plafondVirement').value = d.plafondVirement;
  const sel1 = document.getElementById('f-statutCompte');
  const sel2 = document.getElementById('f-typeCompte');
  const sel3 = document.getElementById('f-idUser');
  [...sel1.options].forEach(o => o.selected = o.value === d.statut);
  [...sel2.options].forEach(o => o.selected = o.value === d.type);
  if (sel3) [...sel3.options].forEach(o => o.selected = o.value === d.userId);
  document.getElementById('f-mode-label').textContent = 'Modification du compte #' + d.id;
  document.getElementById('nx-acc-form').scrollIntoView({ behavior: 'smooth', block: 'start' });
  // Update export button
  const exportBtn  = document.getElementById('nx-export-btn');
  const exportBase = '{{ path('admin_account_export_pdf') }}';
  if (exportBtn) exportBtn.href = exportBase + '?idCompte=' + d.id;
}

/* â”€â”€ Reset form â”€â”€ */
function nxResetCompteForm() {
  document.getElementById('f-idCompte').value = '';
  document.getElementById('f-idUser').value = '';
  document.getElementById('f-numeroCompte').value = '';
  document.getElementById('f-solde').value = '';
  document.getElementById('f-dateOuverture').value = document.getElementById('f-dateOuverture').dataset.expectedDate || '';
  document.getElementById('f-dateOuverture').dataset.expectedDate = document.getElementById('f-dateOuverture').dataset.expectedDate || '';
  document.getElementById('f-statutCompte').value = '';
  document.getElementById('f-plafondRetrait').value = '';
  document.getElementById('f-plafondVirement').value = '';
  document.getElementById('f-typeCompte').value = '';
  document.getElementById('f-mode-label').textContent = 'Nouveau compte';

  ['idUser','numeroCompte','solde','dateOuverture','statutCompte','plafondRetrait','plafondVirement','typeCompte'].forEach(function(field) {
    var fieldEl = document.getElementById('f-' + field);
    var errorEl = document.getElementById('err-' + field);
    if (fieldEl) {
      fieldEl.classList.remove('is-invalid');
      fieldEl.classList.remove('is-valid');
      fieldEl.style.borderColor = '';
      fieldEl.style.boxShadow = '';
    }
    if (errorEl) {
      errorEl.textContent = '';
      errorEl.classList.remove('is-visible');
      errorEl.style.display = 'none';
    }
  });

  document.querySelectorAll('#nx-account-table tbody tr').forEach(r => r.classList.remove('is-selected'));
  const exportBtn = document.getElementById('nx-export-btn');
  if (exportBtn) exportBtn.href = '{{ path('admin_account_export_pdf') }}';
}

/* â”€â”€ View: afficher la modal de dÃ©tail â”€â”€ */
function nxViewCompte(row) {
  const d = row.dataset;
  const fields = [
    ['ID Compte',         '#' + d.id],
    ['NumÃ©ro de Compte',  d.numero],
    ['Solde',             d.solde + ' DT'],
    ['Date d\'Ouverture', d.date || 'â€”'],
    ['Statut',            d.statut],
    ['Plafond Retrait',   d.plafondRetrait ? d.plafondRetrait + ' DT' : 'â€”'],
    ['Plafond Virement',  d.plafondVirement ? d.plafondVirement + ' DT' : 'â€”'],
    ['Type de Compte',    d.type],
  ];
  const body = document.getElementById('nx-detail-body');
  body.innerHTML = fields.map(([k,v]) =>
    `<div class="nx-detail-row"><span>${k}</span><span>${v}</span></div>`
  ).join('');
  document.getElementById('nx-detail-modal').hidden = false;
}

/* â”€â”€ Vault: Edit â”€â”€ */
function nxEditVault(row) {
  const d = row.dataset;
  document.getElementById('vf-idCoffre').value      = d.id;
  document.getElementById('vf-nom').value           = d.nom;
  document.getElementById('vf-objectif').value      = d.objectif;
  document.getElementById('vf-actuel').value        = d.actuel;
  document.getElementById('vf-dateCreation').value  = d.dateCreation || '';
  document.getElementById('vf-dateObjectifs').value = d.dateObjectifs || '';
  const selStatus = document.getElementById('vf-status');
  const selVerrou = document.getElementById('vf-verrou');
  const selCompte = document.getElementById('vf-idCompte');
  if (selStatus) [...selStatus.options].forEach(o => o.selected = o.value === d.status);
  if (selVerrou) [...selVerrou.options].forEach(o => o.selected = o.value === d.verrou);
  if (selCompte) [...selCompte.options].forEach(o => o.selected = o.value === d.idCompte);
  document.getElementById('vf-mode-label').textContent = 'Modification du coffre #' + d.id;
  document.getElementById('nx-acc-form').scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function nxResetVaultForm() {
  document.getElementById('vf-idCoffre').value = '';
  document.getElementById('nx-vault-form').reset();
  document.getElementById('vf-mode-label').textContent = 'Nouveau coffre';
}

/* â”€â”€ Vault: View â”€â”€ */
function nxViewVault(row) {
  if (window.nxOpenVaultDrawer) {
    window.nxOpenVaultDrawer(row);
    return;
  }

  const d = row.dataset;
  const pct = d.objectif > 0 ? ((d.actuel / d.objectif) * 100).toFixed(1) : 0;
  const fields = [
    ['ID Coffre',       '#' + d.id],
    ['Nom',             d.nom],
    ['Objectif',        parseFloat(d.objectif).toFixed(2) + ' DT'],
    ['Montant actuel',  parseFloat(d.actuel).toFixed(2) + ' DT'],
    ['Progression',     pct + '%'],
    ['Statut',          d.status],
  ];
  const body = document.getElementById('nx-detail-body');
  body.innerHTML = fields.map(([k,v]) =>
    `<div class="nx-detail-row"><span>${k}</span><span>${v}</span></div>`
  ).join('');
  document.getElementById('nx-detail-modal').hidden = false;
}
</script>


<script>
(function() {
  'use strict';

  /* ── Drawer open/close ── */
  var overlay  = document.getElementById('nx-drawer-overlay');
  var drawer   = document.getElementById('nx-account-drawer');
  var closeBtn = document.getElementById('nx-drawer-close');
  var body     = document.getElementById('nx-drawer-body');
  var iconEl   = document.getElementById('nx-dw-icon');
  var titleEl  = document.getElementById('nx-dw-title');
  var subtitleEl = document.getElementById('nx-dw-subtitle');

  if (overlay && overlay.parentElement !== document.body) {
    document.body.appendChild(overlay);
  }
  if (drawer && drawer.parentElement !== document.body) {
    document.body.appendChild(drawer);
  }

  function setDrawerState(isOpen) {
    if (drawer) {
      drawer.classList.toggle('is-open', isOpen);
    }
    if (overlay) {
      overlay.classList.toggle('is-open', isOpen);
    }
    document.documentElement.classList.toggle('nx-drawer-open', isOpen);
    document.body.classList.toggle('nx-drawer-open', isOpen);
  }

  function setDrawerHeader(iconClass, title, subtitle) {
    if (iconEl) {
      iconEl.innerHTML = '<i class="fa-solid ' + iconClass + '"></i>';
    }
    if (titleEl) {
      titleEl.textContent = title;
    }
    if (subtitleEl) {
      subtitleEl.textContent = subtitle;
    }
  }

  function formatMoney(value) {
    var num = parseFloat(value || 0);
    if (!isFinite(num)) num = 0;
    return num.toFixed(2) + ' DT';
  }

  function formatNumber(value) {
    var num = parseFloat(value || 0);
    if (!isFinite(num)) num = 0;
    return num.toFixed(1).replace(/\.0$/, '');
  }

  function closeDrawer() {
    setDrawerState(false);
  }

  if (closeBtn) closeBtn.addEventListener('click', closeDrawer);
  if (overlay)  overlay.addEventListener('click', closeDrawer);
  document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeDrawer(); });

  /* ── Load vaults JSON ── */
  var allVaults = [];
  try {
    var jsonEl = document.getElementById('nx-vaults-json');
    if (jsonEl) allVaults = JSON.parse(jsonEl.textContent || '[]');
  } catch(e) {}

  /* ── Color helpers ── */
  function statColor(st) {
    var s = (st || '').toLowerCase();
    if (s === 'actif')  return { bg: 'rgba(34,197,94,.15)',  border: 'rgba(34,197,94,.35)',  color: '#166534' };
    if (s === 'fermé' || s === 'ferme')  return { bg: 'rgba(239,68,68,.15)',  border: 'rgba(239,68,68,.35)',  color: '#991b1b' };
    if (s === 'bloqué' || s === 'bloque') return { bg: 'rgba(249,115,22,.15)', border: 'rgba(249,115,22,.35)', color: '#9a3412' };
    return { bg: 'rgba(255,255,255,.1)', border: 'rgba(255,255,255,.2)', color: '#fff' };
  }

  function progColor(pct) {
    if (pct >= 100) return '#22c55e';
    if (pct >= 50)  return '#f97316';
    return '#ef4444';
  }

  function buildVaultDrawer(row) {
    var d = row.dataset;
    var idCoffre = d.id || '—';
    var nom = d.nom || '—';
    var objectif = parseFloat(d.objectif || 0);
    var actuel = parseFloat(d.actuel || 0);
    var creation = d.dateCreation || '—';
    var objectifDate = d.dateObjectifs || '—';
    var status = d.status || '—';
    var verrouille = String(d.verrou || '0') === '1' || (objectif > 0 && actuel >= objectif);
    var numeroCompte = d.numeroCompte || '—';
    var idCompte = d.idCompte || '—';
    var progression = objectif > 0 ? Math.min((actuel / objectif) * 100, 100) : 0;
    var restant = Math.max(objectif - actuel, 0);
    var sc = statColor(status);
    var barColor = progColor(progression);
    var lockIcon = verrouille ? 'fa-lock' : 'fa-lock-open';
    var lockColor = verrouille ? '#ef4444' : '#22c55e';

    var html = '';

    html += '<div style="background:linear-gradient(135deg,#0a2540,#1e3448);border-radius:16px;padding:1.6rem 1.8rem;display:flex;align-items:flex-start;gap:1.2rem;flex-wrap:wrap;position:relative;overflow:hidden;">';
    html += '<div style="position:absolute;width:220px;height:220px;top:-70px;right:-50px;border-radius:50%;background:radial-gradient(circle,rgba(0,180,160,.18) 0%,transparent 70%);pointer-events:none;"></div>';
    html += '<div style="width:56px;height:56px;border-radius:15px;background:linear-gradient(135deg,#00B4A0,#0d9e93);display:grid;place-items:center;color:#fff;font-size:1.4rem;flex-shrink:0;box-shadow:0 6px 20px rgba(0,180,160,.4);"><i class="fa-solid fa-vault"></i></div>';
    html += '<div style="flex:1;min-width:0;">';
    html += '<h2 style="font-size:1.5rem;font-weight:900;color:#fff;margin:0 0 .3rem;letter-spacing:-.3px;">' + nom + '</h2>';
    html += '<p style="font-size:.82rem;color:rgba(255,255,255,.55);margin:0 0 .8rem;">Coffre #' + idCoffre + ' &middot; Compte li&eacute; ' + numeroCompte + '</p>';
    html += '<div style="display:flex;align-items:center;gap:.6rem;flex-wrap:wrap;">';
    html += '<span style="display:inline-flex;align-items:center;gap:.4rem;padding:.4rem .95rem;border-radius:20px;font-size:.8rem;font-weight:700;background:' + sc.bg + ';color:' + sc.color + ';border:1px solid ' + sc.border + ';">';
    html += '<i class="fa-solid fa-circle" style="font-size:.45rem"></i>' + status + '</span>';
    html += '<span style="display:inline-flex;align-items:center;gap:.4rem;padding:.4rem .95rem;border-radius:20px;font-size:.8rem;font-weight:700;background:rgba(255,255,255,.1);color:#fff;border:1px solid rgba(255,255,255,.18);">';
    html += '<i class="fa-solid ' + lockIcon + '" style="color:' + lockColor + '"></i>' + (verrouille ? 'Verrouill&eacute;' : 'Ouvert') + '</span>';
    html += '<span style="display:inline-flex;align-items:center;gap:.4rem;padding:.4rem .95rem;border-radius:20px;font-size:.8rem;font-weight:700;background:rgba(255,255,255,.1);color:#fff;border:1px solid rgba(255,255,255,.18);">';
    html += '<i class="fa-solid fa-coins" style="color:#00B4A0"></i><span style="font-size:1.05rem;font-weight:900;color:#00B4A0;">' + formatMoney(actuel) + '</span></span>';
    html += '</div></div></div>';

    html += '<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:.9rem;">';
    [
      { icon: 'fa-bullseye', color: '#2b7de9', bg: 'rgba(43,125,233,.1)', border: '#2b7de9', value: formatMoney(objectif), label: 'Objectif' },
      { icon: 'fa-chart-line', color: '#00B4A0', bg: 'rgba(0,180,160,.1)', border: '#00B4A0', value: formatNumber(progression) + '%', label: 'Progression' },
      { icon: 'fa-wallet', color: '#B8860B', bg: 'rgba(184,134,11,.1)', border: '#B8860B', value: formatMoney(restant), label: 'Montant restant' }
    ].forEach(function(k) {
      html += '<div style="background:#fff;border:1px solid #e4ecf4;border-radius:14px;padding:1.1rem 1.2rem;display:flex;align-items:center;gap:.9rem;position:relative;overflow:hidden;box-shadow:0 2px 10px rgba(0,0,0,.05);">';
      html += '<div style="position:absolute;left:0;top:0;bottom:0;width:4px;border-radius:0 4px 4px 0;background:' + k.border + '"></div>';
      html += '<div style="width:44px;height:44px;border-radius:12px;background:' + k.bg + ';display:grid;place-items:center;font-size:1.1rem;flex-shrink:0;color:' + k.color + ';">';
      html += '<i class="fa-solid ' + k.icon + '"></i></div>';
      html += '<div><strong style="display:block;font-size:1.3rem;font-weight:900;color:#1a2b3c;line-height:1;">' + k.value + '</strong>';
      html += '<small style="font-size:.75rem;color:#6b85a0;font-weight:500;margin-top:.2rem;display:block;">' + k.label + '</small></div></div>';
    });
    html += '</div>';

    html += '<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:1rem;">';

    html += '<div style="background:#fff;border:1px solid #e4ecf4;border-radius:14px;box-shadow:0 2px 10px rgba(0,0,0,.05);overflow:hidden;">';
    html += '<div style="display:flex;align-items:center;gap:.7rem;padding:1rem 1.1rem;border-bottom:1px solid #e4ecf4;background:linear-gradient(to right,#fafcff,#f5f8fd);">';
    html += '<div style="width:34px;height:34px;border-radius:10px;background:linear-gradient(135deg,#00B4A0,#0d9e93);display:grid;place-items:center;color:#fff;font-size:.85rem;"><i class="fa-solid fa-circle-info"></i></div>';
    html += '<div><h3 style="font-size:.86rem;font-weight:800;color:#1a2b3c;margin:0;">Informations du coffre</h3><p style="font-size:.72rem;color:#6b85a0;margin:.1rem 0 0;">Toutes les donn&eacute;es essentielles</p></div>';
    html += '</div>';
    html += '<div style="padding:1rem 1.1rem;display:grid;gap:.8rem;">';
    [
      ['ID Coffre', '#' + idCoffre],
      ['Nom du coffre', nom],
      ['Date de cr&eacute;ation', creation],
      ['Date objectif', objectifDate],
      ['Statut', status],
      ['Verrouillage', verrouille ? 'Oui' : 'Non']
    ].forEach(function(field) {
      html += '<div style="display:flex;justify-content:space-between;gap:1rem;padding:.75rem .85rem;background:#f8fbff;border:1px solid #e4ecf4;border-radius:10px;">';
      html += '<span style="font-size:.74rem;font-weight:700;color:#6b85a0;text-transform:uppercase;letter-spacing:.4px;">' + field[0] + '</span>';
      html += '<strong style="font-size:.82rem;color:#1a2b3c;text-align:right;">' + field[1] + '</strong>';
      html += '</div>';
    });
    html += '</div></div>';

    html += '<div style="background:#fff;border:1px solid #e4ecf4;border-radius:14px;box-shadow:0 2px 10px rgba(0,0,0,.05);overflow:hidden;">';
    html += '<div style="display:flex;align-items:center;gap:.7rem;padding:1rem 1.1rem;border-bottom:1px solid #e4ecf4;background:linear-gradient(to right,#fafcff,#f5f8fd);">';
    html += '<div style="width:34px;height:34px;border-radius:10px;background:linear-gradient(135deg,#2b7de9,#1f6cd6);display:grid;place-items:center;color:#fff;font-size:.85rem;"><i class="fa-solid fa-link"></i></div>';
    html += '<div><h3 style="font-size:.86rem;font-weight:800;color:#1a2b3c;margin:0;">Compte associ&eacute;</h3><p style="font-size:.72rem;color:#6b85a0;margin:.1rem 0 0;">Rattachement et suivi financier</p></div>';
    html += '</div>';
    html += '<div style="padding:1rem 1.1rem;display:grid;gap:.8rem;">';
    [
      ['N&deg; compte', numeroCompte],
      ['ID compte', idCompte !== '—' ? '#' + idCompte : '—'],
      ['Objectif', formatMoney(objectif)],
      ['Montant actuel', formatMoney(actuel)],
      ['Montant restant', formatMoney(restant)],
      ['Progression', formatNumber(progression) + '%']
    ].forEach(function(field) {
      html += '<div style="display:flex;justify-content:space-between;gap:1rem;padding:.75rem .85rem;background:#f8fbff;border:1px solid #e4ecf4;border-radius:10px;">';
      html += '<span style="font-size:.74rem;font-weight:700;color:#6b85a0;text-transform:uppercase;letter-spacing:.4px;">' + field[0] + '</span>';
      html += '<strong style="font-size:.82rem;color:#1a2b3c;text-align:right;">' + field[1] + '</strong>';
      html += '</div>';
    });
    html += '</div></div>';

    html += '</div>';

    html += '<div style="background:#fff;border:1px solid #e4ecf4;border-radius:14px;box-shadow:0 2px 10px rgba(0,0,0,.05);overflow:hidden;">';
    html += '<div style="display:flex;align-items:center;gap:.75rem;padding:.95rem 1.1rem;border-bottom:1px solid #e4ecf4;background:linear-gradient(to right,#fafcff,#f5f8fd);">';
    html += '<div style="width:34px;height:34px;border-radius:10px;background:linear-gradient(135deg,#B8860B,#d6a535);display:grid;place-items:center;color:#fff;font-size:.85rem;"><i class="fa-solid fa-chart-pie"></i></div>';
    html += '<div><h3 style="font-size:.86rem;font-weight:800;color:#1a2b3c;margin:0;">Suivi de progression</h3><p style="font-size:.72rem;color:#6b85a0;margin:.1rem 0 0;">Avancement du coffre vers son objectif</p></div>';
    html += '</div>';
    html += '<div style="padding:1rem 1.1rem;">';
    html += '<div style="display:flex;justify-content:space-between;align-items:center;gap:1rem;margin-bottom:.55rem;"><span style="font-size:.78rem;color:#6b85a0;font-weight:700;">Progression actuelle</span><strong style="font-size:1rem;color:#1a2b3c;">' + formatNumber(progression) + '%</strong></div>';
    html += '<div style="height:10px;background:#edf3f8;border-radius:999px;overflow:hidden;"><div style="height:100%;width:' + Math.min(progression, 100) + '%;background:' + barColor + ';border-radius:999px;"></div></div>';
    html += '<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:.75rem;margin-top:1rem;">';
    [
      ['Objectif', formatMoney(objectif)],
      ['Actuel', formatMoney(actuel)],
      ['Restant', formatMoney(restant)]
    ].forEach(function(field) {
      html += '<div style="padding:.85rem .9rem;background:#f8fbff;border:1px solid #e4ecf4;border-radius:10px;text-align:center;">';
      html += '<small style="display:block;font-size:.7rem;color:#6b85a0;font-weight:700;text-transform:uppercase;letter-spacing:.4px;margin-bottom:.2rem;">' + field[0] + '</small>';
      html += '<strong style="font-size:.82rem;color:#1a2b3c;">' + field[1] + '</strong>';
      html += '</div>';
    });
    html += '</div></div></div>';

    return html;
  }

  /* ── Build drawer HTML ── */
  function buildDrawer(row) {
    var d = row.dataset;
    var idCompte = d.id;
    var numero   = d.numero || '—';
    var solde    = parseFloat(d.solde || 0).toFixed(2);
    var date     = d.date || '—';
    var statut   = d.statut || '—';
    var retrait  = d.plafondRetrait ? parseFloat(d.plafondRetrait).toFixed(2) + ' DT' : '—';
    var virement = d.plafondVirement ? parseFloat(d.plafondVirement).toFixed(2) + ' DT' : '—';
    var type     = d.type || '—';

    // Filter vaults for this account
    var vaults = allVaults.filter(function(v) {
      return String(v.idCompte) === String(idCompte);
    });

    var totalStored = vaults.reduce(function(s, v) { return s + parseFloat(v.montantActuel || 0); }, 0);
    var actifs = vaults.filter(function(v) { return (v.status || '').toLowerCase() === 'actif'; }).length;

    var sc = statColor(statut);
    var stLow = statut.toLowerCase().replace('é','e').replace('û','u');

    // Hero
    var html = '<div style="background:linear-gradient(135deg,#0a2540,#1e3448);border-radius:16px;padding:1.6rem 1.8rem;display:flex;align-items:flex-start;gap:1.2rem;flex-wrap:wrap;position:relative;overflow:hidden;">';
    html += '<div style="position:absolute;width:220px;height:220px;top:-70px;right:-50px;border-radius:50%;background:radial-gradient(circle,rgba(0,180,160,.18) 0%,transparent 70%);pointer-events:none;"></div>';
    html += '<div style="width:56px;height:56px;border-radius:15px;background:linear-gradient(135deg,#00B4A0,#0d9e93);display:grid;place-items:center;color:#fff;font-size:1.4rem;flex-shrink:0;box-shadow:0 6px 20px rgba(0,180,160,.4);"><i class="fa-solid fa-building-columns"></i></div>';
    html += '<div style="flex:1;min-width:0;">';
    html += '<h2 style="font-size:1.5rem;font-weight:900;color:#fff;margin:0 0 .3rem;letter-spacing:-.3px;">' + numero + '</h2>';
    html += '<p style="font-size:.82rem;color:rgba(255,255,255,.55);margin:0 0 .8rem;">' + type + ' &middot; Ouvert le ' + date + '</p>';
    html += '<div style="display:flex;align-items:center;gap:.6rem;flex-wrap:wrap;">';
    html += '<span style="display:inline-flex;align-items:center;gap:.4rem;padding:.4rem .95rem;border-radius:20px;font-size:.8rem;font-weight:700;background:' + sc.bg + ';color:' + sc.color + ';border:1px solid ' + sc.border + ';">';
    html += '<i class="fa-solid fa-circle" style="font-size:.45rem"></i>' + statut + '</span>';
    html += '<span style="display:inline-flex;align-items:center;gap:.4rem;padding:.4rem .95rem;border-radius:20px;font-size:.8rem;font-weight:700;background:rgba(255,255,255,.1);color:#fff;border:1px solid rgba(255,255,255,.18);">';
    html += '<i class="fa-solid fa-coins" style="color:#00B4A0"></i><span style="font-size:1.05rem;font-weight:900;color:#00B4A0;">' + solde + ' DT</span></span>';
    html += '<span style="display:inline-flex;align-items:center;gap:.4rem;padding:.4rem .95rem;border-radius:20px;font-size:.8rem;font-weight:700;background:rgba(255,255,255,.1);color:rgba(255,255,255,.85);border:1px solid rgba(255,255,255,.18);">';
    html += '<i class="fa-solid fa-arrow-down"></i>Retrait : ' + retrait + '</span>';
    html += '<span style="display:inline-flex;align-items:center;gap:.4rem;padding:.4rem .95rem;border-radius:20px;font-size:.8rem;font-weight:700;background:rgba(255,255,255,.1);color:rgba(255,255,255,.85);border:1px solid rgba(255,255,255,.18);">';
    html += '<i class="fa-solid fa-paper-plane"></i>Virement : ' + virement + '</span>';
    html += '</div></div></div>';

    // KPIs
    html += '<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:.9rem;">';
    var kpis = [
      { icon: 'fa-vault',        color: '#00B4A0', bg: 'rgba(0,180,160,.1)',  val: vaults.length,                label: 'Coffres associés' },
      { icon: 'fa-circle-check', color: '#22c55e', bg: 'rgba(34,197,94,.1)',  val: actifs,                       label: 'Coffres actifs' },
      { icon: 'fa-coins',        color: '#B8860B', bg: 'rgba(184,134,11,.1)', val: totalStored.toFixed(2)+' DT', label: 'Montant stocké' },
    ];
    var borders = ['#00B4A0','#22c55e','#B8860B'];
    kpis.forEach(function(k, i) {
      html += '<div style="background:#fff;border:1px solid #e4ecf4;border-radius:14px;padding:1.1rem 1.2rem;display:flex;align-items:center;gap:.9rem;position:relative;overflow:hidden;box-shadow:0 2px 10px rgba(0,0,0,.05);">';
      html += '<div style="position:absolute;left:0;top:0;bottom:0;width:4px;border-radius:0 4px 4px 0;background:' + borders[i] + '"></div>';
      html += '<div style="width:44px;height:44px;border-radius:12px;background:' + k.bg + ';display:grid;place-items:center;font-size:1.1rem;flex-shrink:0;color:' + k.color + ';">';
      html += '<i class="fa-solid ' + k.icon + '"></i></div>';
      html += '<div><strong style="display:block;font-size:1.4rem;font-weight:900;color:#1a2b3c;line-height:1;">' + k.val + '</strong>';
      html += '<small style="font-size:.75rem;color:#6b85a0;font-weight:500;margin-top:.2rem;display:block;">' + k.label + '</small></div></div>';
    });
    html += '</div>';

    // Vaults panel
    html += '<div style="background:#fff;border:1px solid #e4ecf4;border-radius:14px;overflow:hidden;">';
    html += '<div style="display:flex;align-items:center;gap:.75rem;padding:.9rem 1.1rem;border-bottom:1px solid #e4ecf4;background:linear-gradient(to right,#fafcff,#f5f8fd);">';
    html += '<div style="width:32px;height:32px;border-radius:9px;background:linear-gradient(135deg,#00B4A0,#0d9e93);display:grid;place-items:center;color:#fff;font-size:.8rem;flex-shrink:0;"><i class="fa-solid fa-vault"></i></div>';
    html += '<div><h3 style="font-size:.85rem;font-weight:800;color:#1a2b3c;margin:0;">Coffres Virtuels liés</h3>';
    html += '<p style="font-size:.7rem;color:#6b85a0;margin:.1rem 0 0;">Tous les coffres associés à ce compte</p></div>';
    html += '<span style="margin-left:auto;background:#f0f4f9;border:1px solid #e4ecf4;border-radius:20px;padding:.15rem .6rem;font-size:.7rem;font-weight:700;color:#6b85a0;">' + vaults.length + ' coffre' + (vaults.length !== 1 ? 's' : '') + '</span>';
    html += '</div>';

    // Search
    html += '<div style="display:flex;align-items:center;gap:.5rem;padding:.65rem .9rem;border-bottom:1px solid #e4ecf4;">';
    html += '<i class="fa-solid fa-magnifying-glass" style="color:#6b85a0;font-size:.75rem;"></i>';
    html += '<input id="nx-dw-vault-search" type="text" placeholder="Rechercher un coffre..." style="flex:1;height:32px;padding:0 .7rem;border:1px solid #e4ecf4;border-radius:7px;font-size:.78rem;color:#1a2b3c;background:#f0f4f9;outline:none;font-family:inherit;">';
    html += '</div>';

    // Table
    html += '<div style="overflow-x:auto;">';
    html += '<table id="nx-dw-vault-table" style="width:100%;border-collapse:collapse;font-size:.82rem;">';
    html += '<thead><tr style="background:#f0f4f9;">';
    ['Nom','Objectif','Actuel','Date créa.','Date obj.','Statut','Verrou','Progression'].forEach(function(h) {
      html += '<th style="padding:.65rem 1rem;text-align:left;font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#6b85a0;border-bottom:1px solid #e4ecf4;white-space:nowrap;">' + h + '</th>';
    });
    html += '</tr></thead><tbody>';

    if (vaults.length === 0) {
      html += '<tr><td colspan="8" style="text-align:center;color:#6b85a0;font-size:.85rem;padding:2.5rem 1rem;">Aucun coffre lié à ce compte.</td></tr>';
    } else {
      vaults.forEach(function(v) {
        var pct = parseFloat(v.progression || 0);
        var barColor = progColor(pct);
        var lockIcon = pct >= 100 ? 'fa-lock' : 'fa-lock-open';
        var lockColor = pct >= 100 ? '#ef4444' : '#22c55e';
        var stVc = statColor(v.status || '');
        html += '<tr style="border-bottom:1px solid #e4ecf4;">';
        html += '<td style="padding:.75rem 1rem;font-weight:700;color:#1a2b3c;font-size:.82rem;">' + (v.nom || '—') + '</td>';
        html += '<td style="padding:.75rem 1rem;color:#1a2b3c;font-size:.82rem;">' + parseFloat(v.objectifMontant||0).toFixed(2) + ' DT</td>';
        html += '<td style="padding:.75rem 1rem;color:#1a2b3c;font-size:.82rem;">' + parseFloat(v.montantActuel||0).toFixed(2) + ' DT</td>';
        html += '<td style="padding:.75rem 1rem;color:#6b85a0;font-size:.78rem;">' + (v.dateCreation || '—') + '</td>';
        html += '<td style="padding:.75rem 1rem;color:#6b85a0;font-size:.78rem;">' + (v.dateObjectifs || '—') + '</td>';
        html += '<td style="padding:.75rem 1rem;"><span style="display:inline-block;padding:.22rem .65rem;border-radius:20px;font-size:.72rem;font-weight:700;background:' + stVc.bg + ';color:' + stVc.color + ';border:1px solid ' + stVc.border + ';">' + (v.status || '—') + '</span></td>';
        html += '<td style="padding:.75rem 1rem;text-align:center;"><i class="fa-solid ' + lockIcon + '" style="color:' + lockColor + ';font-size:1.05rem;"></i></td>';
        html += '<td style="padding:.75rem 1rem;min-width:110px;"><div style="height:7px;background:#f0f4f9;border-radius:6px;overflow:hidden;"><div style="height:100%;border-radius:6px;background:' + barColor + ';width:' + Math.min(pct,100) + '%;"></div></div>';
        html += '<span style="font-size:.72rem;color:#6b85a0;font-weight:600;margin-top:.2rem;display:block;">' + pct + '%</span></td>';
        html += '</tr>';
      });
    }
    html += '</tbody></table></div></div>';
    return html;
  }

  /* ── Open drawer ── */
  window.nxOpenDrawer = function(btn) {
    var row = btn.closest('tr');
    if (!row) return;

    var numero = row.dataset.numero || 'Compte';
    setDrawerHeader('fa-building-columns', numero, 'Informations et coffres associés');

    body.innerHTML = buildDrawer(row);

    setDrawerState(true);
    // Force scroll to top after DOM update
    requestAnimationFrame(function() {
      if (body) {
        body.scrollTop = 0;
      }
    });

    // Wire vault search inside drawer
    var searchInput = document.getElementById('nx-dw-vault-search');
    var table = document.getElementById('nx-dw-vault-table');
    if (searchInput && table) {
      searchInput.addEventListener('input', function() {
        var q = this.value.toLowerCase().trim();
        table.querySelectorAll('tbody tr').forEach(function(r) {
          r.style.display = r.textContent.toLowerCase().includes(q) ? '' : 'none';
        });
      });
    }
  };

  window.nxOpenVaultDrawer = function(row) {
    if (!row || !body) return;

    var nom = row.dataset.nom || 'Coffre';
    setDrawerHeader('fa-vault', nom, 'Toutes les informations du coffre virtuel');
    body.innerHTML = buildVaultDrawer(row);

    setDrawerState(true);
    requestAnimationFrame(function() {
      body.scrollTop = 0;
    });
  };
})();
</script>

<script>
(() => {
  const profilesEl = document.getElementById('nx-ai-profiles-json');
  const table = document.getElementById('nx-ai-client-table');
  if (!profilesEl || !table) return;

  let profiles = [];
  try {
    profiles = JSON.parse(profilesEl.textContent || '[]');
  } catch (error) {
    profiles = [];
  }
  if (!Array.isArray(profiles) || profiles.length === 0) return;

  const profilesById = {};
  profiles.forEach((profile) => {
    profilesById[String(profile.client_id)] = profile;
  });

  const nameEl = document.getElementById('nx-ai-client-name');
  const avatarEl = document.getElementById('nx-ai-client-avatar');
  const subtitleEl = document.getElementById('nx-ai-client-subtitle');
  const balanceEl = document.getElementById('nx-ai-client-balance');
  const vaultsEl = document.getElementById('nx-ai-client-vaults');
  const debitsEl = document.getElementById('nx-ai-client-debits');
  const analysisEl = document.getElementById('nx-ai-client-analysis');
  const badgeEl = document.getElementById('nx-ai-client-badge');
  const recommendationsEl = document.getElementById('nx-ai-client-recommendations');
  const clientIdInput = document.getElementById('nx-ai-client-id');

  const money = (value) => Number(value || 0).toLocaleString('fr-TN', {
    minimumFractionDigits: 2,
    maximumFractionDigits: 2,
  }) + ' DT';

  const toneClass = (tone) => 'nx-ml__badge is-' + (tone || 'info');

  function renderProfile(profile) {
    if (!profile || !nameEl) return;

    if (clientIdInput) clientIdInput.value = profile.client_id || '';
    if (avatarEl) avatarEl.textContent = profile.initials || 'CL';
    nameEl.textContent = profile.client_name || 'Client';
    if (subtitleEl) {
      subtitleEl.textContent = 'Score IA ' + (profile.risk_score || 0) + '/100 - Confiance ' + (profile.confidence || 0) + '%';
    }
    if (balanceEl) balanceEl.textContent = money(profile.total_balance || 0);
    if (vaultsEl) vaultsEl.textContent = String(profile.vault_count || 0);
    if (debitsEl) debitsEl.textContent = String(profile.debit_count || 0);
    if (analysisEl) analysisEl.textContent = profile.analysis || 'Analyse indisponible.';
    if (badgeEl) {
      badgeEl.className = toneClass(profile.badge_tone);
      badgeEl.textContent = profile.profile_label || 'Profil';
    }
    if (recommendationsEl) {
      const items = Array.isArray(profile.recommendations) && profile.recommendations.length
        ? profile.recommendations
        : ['Aucune recommandation specifique.'];
      recommendationsEl.innerHTML = items.map((item) => '<li>' + String(item)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#039;') + '</li>').join('');
    }
  }

  table.querySelectorAll('tbody tr[data-client-id]').forEach((row) => {
    row.addEventListener('click', () => {
      table.querySelectorAll('tbody tr').forEach((item) => item.classList.remove('is-active'));
      row.classList.add('is-active');
      renderProfile(profilesById[row.dataset.clientId]);
    });
  });
})();
</script>

<script>
/* ══════════════════════════════════════
   VALIDATION — Compte Bancaire
══════════════════════════════════════ */
function nxSetError(fieldId, errId, msg) {
  var field = document.getElementById(fieldId);
  var err   = document.getElementById(errId);
  if (!field || !err) return;
  err.textContent = msg;
  err.style.cssText = 'display:block;color:#dc2626;font-size:13px;font-weight:500;margin-top:4px;text-transform:none;letter-spacing:normal;background:none;';
  field.style.borderColor = '#dc2626';
  field.style.boxShadow = '0 0 0 2px rgba(220,38,38,.15)';
}
function nxClearError(fieldId, errId) {
  var field = document.getElementById(fieldId);
  var err   = document.getElementById(errId);
  if (!field || !err) return;
  err.style.display = 'none';
  err.textContent = '';
  field.style.borderColor = '#16a34a';
  field.style.boxShadow = 'none';
}

function nxValidateCompte(e) {
  var ok = true;
  var dateField = document.getElementById('f-dateOuverture');
  var expectedDate = dateField ? (dateField.dataset.expectedDate || '') : '';

  // idUser
  var idUser = document.getElementById('f-idUser')?.value;
  if (!idUser) {
    nxSetError('f-idUser','err-idUser','Veuillez selectionner un utilisateur.'); ok = false;
  } else { nxClearError('f-idUser','err-idUser'); }

  // numeroCompte
  var num = (document.getElementById('f-numeroCompte')?.value || '').trim();
  if (num === '') {
    nxSetError('f-numeroCompte','err-numeroCompte','Le numéro de compte est obligatoire.'); ok = false;
  } else if (!/^CB-\d{3,}$/.test(num)) {
    nxSetError('f-numeroCompte','err-numeroCompte','Le numéro de compte doit être au format CB-XXX (ex : CB-123).'); ok = false;
  } else { nxClearError('f-numeroCompte','err-numeroCompte'); }

  // solde
  var solde = document.getElementById('f-solde')?.value;
  if (solde === '' || solde === null || solde === undefined) {
    nxSetError('f-solde','err-solde','Le solde est obligatoire.'); ok = false;
  } else if (parseFloat(solde) < 0) {
    nxSetError('f-solde','err-solde','Le solde doit être un nombre positif ou égal à 0.'); ok = false;
  } else { nxClearError('f-solde','err-solde'); }

  // dateOuverture
  var dateVal = dateField?.value;
  if (!dateVal) {
    nxSetError('f-dateOuverture','err-dateOuverture',"La date d'ouverture est obligatoire."); ok = false;
  } else if (dateVal !== expectedDate) {
    dateField.value = expectedDate;
    nxSetError('f-dateOuverture','err-dateOuverture',"La date d'ouverture est fixée automatiquement au " + expectedDate + '.'); ok = false;
  } else {
    nxClearError('f-dateOuverture','err-dateOuverture');
  }

  // statutCompte
  var statut = document.getElementById('f-statutCompte')?.value;
  if (!statut) {
    nxSetError('f-statutCompte','err-statutCompte','Veuillez sélectionner un statut.'); ok = false;
  } else { nxClearError('f-statutCompte','err-statutCompte'); }

  // plafondRetrait
  var retrait = document.getElementById('f-plafondRetrait')?.value;
  if (retrait === '' || retrait === null || retrait === undefined) {
    nxSetError('f-plafondRetrait','err-plafondRetrait','Le plafond de retrait est obligatoire.'); ok = false;
  } else if (parseFloat(retrait) < 10 || parseFloat(retrait) > 1000) {
    nxSetError('f-plafondRetrait','err-plafondRetrait','Le plafond de retrait doit être compris entre 10 DT et 1000 DT.'); ok = false;
  } else { nxClearError('f-plafondRetrait','err-plafondRetrait'); }

  // plafondVirement
  var virement = document.getElementById('f-plafondVirement')?.value;
  if (virement === '' || virement === null || virement === undefined) {
    nxSetError('f-plafondVirement','err-plafondVirement','Le plafond de virement est obligatoire.'); ok = false;
  } else if (parseFloat(virement) < 10 || parseFloat(virement) > 1000) {
    nxSetError('f-plafondVirement','err-plafondVirement','Le plafond de virement doit être compris entre 10 DT et 1000 DT.'); ok = false;
  } else { nxClearError('f-plafondVirement','err-plafondVirement'); }

  // typeCompte
  var type = document.getElementById('f-typeCompte')?.value;
  if (!type) {
    nxSetError('f-typeCompte','err-typeCompte','Veuillez sélectionner un type de compte.'); ok = false;
  } else { nxClearError('f-typeCompte','err-typeCompte'); }

  if (!ok && e) e.preventDefault();
  return ok;
}

/* Live validation on input */
['f-idUser','f-numeroCompte','f-solde','f-dateOuverture','f-statutCompte','f-plafondRetrait','f-plafondVirement','f-typeCompte'].forEach(function(id) {
  var el = document.getElementById(id);
  if (el) el.addEventListener('input', function() { nxValidateCompte(null); });
  if (el) el.addEventListener('change', function() { nxValidateCompte(null); });
});

/* ══════════════════════════════════════
   VALIDATION — Coffre Virtuel
══════════════════════════════════════ */
function nxValidateVault(e) {
  var ok = true;
  var today = new Date(); today.setHours(0,0,0,0);

  // nom
  var nom = (document.getElementById('vf-nom')?.value || '').trim();
  if (nom.length < 3) {
    nxSetError('vf-nom','err-nom','Le nom du coffre est obligatoire et doit contenir au moins 3 caractères.'); ok = false;
  } else { nxClearError('vf-nom','err-nom'); }

  // objectifMontant
  var obj = document.getElementById('vf-objectif')?.value;
  if (obj === '' || obj === null || obj === undefined) {
    nxSetError('vf-objectif','err-objectif',"L'objectif de montant est obligatoire."); ok = false;
  } else if (parseFloat(obj) <= 0) {
    nxSetError('vf-objectif','err-objectif',"L'objectif de montant doit être supérieur à 0."); ok = false;
  } else { nxClearError('vf-objectif','err-objectif'); }

  // montantActuel
  var actuel = document.getElementById('vf-actuel')?.value;
  if (actuel === '' || actuel === null || actuel === undefined) {
    nxSetError('vf-actuel','err-actuel','Le montant actuel est obligatoire.'); ok = false;
  } else if (parseFloat(actuel) < 0) {
    nxSetError('vf-actuel','err-actuel','Le montant actuel doit être positif ou égal à 0.'); ok = false;
  } else if (obj && parseFloat(actuel) > parseFloat(obj)) {
    nxSetError('vf-actuel','err-actuel',"Le montant actuel ne doit pas dépasser l'objectif de montant."); ok = false;
  } else { nxClearError('vf-actuel','err-actuel'); }

  // dateCreation
  var dc = document.getElementById('vf-dateCreation')?.value;
  if (!dc) {
    nxSetError('vf-dateCreation','err-dateCreation','La date de création est obligatoire.'); ok = false;
  } else {
    var dCreation = new Date(dc); dCreation.setHours(0,0,0,0);
    if (dCreation > today) {
      nxSetError('vf-dateCreation','err-dateCreation','La date de création ne doit pas être supérieure à la date actuelle.'); ok = false;
    } else { nxClearError('vf-dateCreation','err-dateCreation'); }
  }

  // dateObjectifs
  var dobj = document.getElementById('vf-dateObjectifs')?.value;
  if (dobj && dc) {
    var dObjectif = new Date(dobj); dObjectif.setHours(0,0,0,0);
    var dCreation2 = new Date(dc); dCreation2.setHours(0,0,0,0);
    if (dObjectif < dCreation2) {
      nxSetError('vf-dateObjectifs','err-dateObjectifs',"La date d'objectif doit être supérieure ou égale à la date de création."); ok = false;
    } else { nxClearError('vf-dateObjectifs','err-dateObjectifs'); }
  }

  // status
  var status = document.getElementById('vf-status')?.value;
  if (!status) {
    nxSetError('vf-status','err-status','Veuillez sélectionner un statut.'); ok = false;
  } else { nxClearError('vf-status','err-status'); }

  // estVerrouille — auto-lock if 100%
  if (obj && actuel && parseFloat(obj) > 0) {
    var pct = (parseFloat(actuel) / parseFloat(obj)) * 100;
    var verrou = document.getElementById('vf-verrou');
    if (pct >= 100 && verrou && verrou.value === '0') {
      nxSetError('vf-verrou','err-verrou',"Le coffre doit être verrouillé lorsque l'objectif est atteint."); ok = false;
    } else if (verrou) { nxClearError('vf-verrou','err-verrou'); }
  }

  // idCompte
  var idCompte = document.getElementById('vf-idCompte')?.value;
  if (!idCompte || idCompte === '0') {
    nxSetError('vf-idCompte','err-idCompte','Veuillez sélectionner un compte associé.'); ok = false;
  } else { nxClearError('vf-idCompte','err-idCompte'); }

  if (!ok && e) e.preventDefault();
  return ok;
}

/* Live validation on input */
['vf-nom','vf-objectif','vf-actuel','vf-dateCreation','vf-dateObjectifs','vf-status','vf-verrou','vf-idCompte'].forEach(function(id) {
  var el = document.getElementById(id);
  if (el) el.addEventListener('input', function() { nxValidateVault(null); });
  if (el) el.addEventListener('change', function() { nxValidateVault(null); });
});
</script>
