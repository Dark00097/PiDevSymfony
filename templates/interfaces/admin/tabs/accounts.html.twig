          <i class="fa-solid fa-microchip"></i> ModÃ¨les locaux
        </a>
      {% else %}
        <a class="na-btn na-btn--ghost" id="nx-export-btn"
           href="{{ path('admin_account_export_pdf') }}" target="_blank">
          <i class="fa-solid fa-file-pdf"></i> Exporter
