}
.nx-acc__tab.is-active {
  background: linear-gradient(135deg, var(--na-teal), var(--na-teal-dk));
  color: #fff;
  box-shadow: 0 3px 10px rgba(17,183,170,.3);
}

.nx-acc__tabs-spacer { flex: 1; }

.nx-acc__stats-link {
  display: inline-flex;
  align-items: center;
  gap: .4rem;
  padding: .5rem 1rem;
  border-radius: 9px;
  font-size: .78rem;
  font-weight: 600;
  color: var(--na-blue);
  text-decoration: none;
  background: rgba(43,125,233,.07);
  border: 1px solid rgba(43,125,233,.18);
  transition: all .2s;
}
.nx-acc__stats-link:hover { background: rgba(43,125,233,.14); }

/* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
   KPI ROW
â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
.nx-acc__kpis {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
}

.nx-acc__kpi {
  background: var(--na-surface);
  border: 1px solid var(--na-border);
  border-radius: var(--na-radius);
  padding: 1.1rem 1.25rem;
  box-shadow: var(--na-shadow);
  display: flex;
  align-items: center;
  gap: 1rem;
  transition: transform .2s, box-shadow .2s;
  position: relative;
  overflow: hidden;
}
.nx-acc__kpi:hover {
  transform: translateY(-2px);
  box-shadow: var(--na-shadow-lg);
}
.nx-acc__kpi::after {
  content: '';
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 3px;
  border-radius: 0 3px 3px 0;
}
.nx-acc__kpi:nth-child(1)::after { background: var(--na-teal); }
.nx-acc__kpi:nth-child(2)::after { background: var(--na-blue); }
.nx-acc__kpi:nth-child(3)::after { background: var(--na-gold); }

.nx-acc__kpi-icon {
  width: 44px; height: 44px;
  border-radius: 12px;
  display: grid;
  place-items: center;
  font-size: 1.1rem;
  flex-shrink: 0;
}
.nx-acc__kpi:nth-child(1) .nx-acc__kpi-icon {
  background: rgba(17,183,170,.1); color: var(--na-teal);
}
.nx-acc__kpi:nth-child(2) .nx-acc__kpi-icon {
  background: rgba(43,125,233,.1); color: var(--na-blue);
}
.nx-acc__kpi:nth-child(3) .nx-acc__kpi-icon {
  background: rgba(232,162,2,.1); color: var(--na-gold);
}

.nx-acc__kpi-body strong {
  display: block;
  font-size: 1.55rem;
  font-weight: 800;
  color: var(--na-txt);
  line-height: 1;
  margin-bottom: .2rem;
}
.nx-acc__kpi-body small {
  font-size: .74rem;
  color: var(--na-muted);
  font-weight: 500;
}

/* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
   CONTENT GRID
â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
.nx-acc__grid {
  display: grid;
  grid-template-columns: 340px 1fr;
  gap: 1.25rem;
  align-items: start;
}

/* â”€â”€ Panel card shared â”€â”€ */
.nx-acc__panel {
  background: var(--na-surface);
  border: 1px solid var(--na-border);
  border-radius: var(--na-radius);
  box-shadow: var(--na-shadow);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.nx-acc__panel-head {
  padding: 1.1rem 1.3rem;
  border-bottom: 1px solid var(--na-border);
  background: linear-gradient(to right, #fafcff, #f5f8fd);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: .75rem;
  flex-wrap: wrap;
}
.nx-acc__panel-head-left h3 {
  font-size: .9rem;
  font-weight: 700;
  color: var(--na-txt);
  margin: 0 0 .15rem;
}
.nx-acc__panel-head-left p {
  font-size: .73rem;
  color: var(--na-muted);
  margin: 0;
}

/* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
   FORM PANEL
â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
.nx-acc__form {
  display: flex;
  flex-direction: column;
  gap: .75rem;
  padding: 1.2rem 1.3rem;
}

.nx-acc__form label {
  display: flex;
  flex-direction: column;
  gap: .3rem;
}
.nx-acc__form label span {
  font-size: .71rem;
  font-weight: 700;
  color: var(--na-muted);
  text-transform: uppercase;
  letter-spacing: .5px;
}

.nx-acc__form input[type="text"],
.nx-acc__form input[type="number"],
.nx-acc__form input[type="date"],
.nx-acc__form select {
  height: 38px;
  padding: 0 .8rem;
  border: 1px solid var(--na-border);
  border-radius: 9px;
  font-size: .82rem;
  color: var(--na-txt);
  background: var(--na-bg);
  outline: none;
  width: 100%;
  box-sizing: border-box;
  font-family: inherit;
  transition: border-color .2s, box-shadow .2s;
}
.nx-acc__form input:focus,
.nx-acc__form select:focus {
  border-color: var(--na-teal);
  box-shadow: 0 0 0 3px rgba(17,183,170,.12);
  background: #fff;
}

.nx-acc__form-divider {
  height: 1px;
  background: var(--na-border);
  margin: .2rem 0;
}

.nx-acc__form-label-id {
  font-size: .7rem;
  color: var(--na-muted);
  background: rgba(43,125,233,.06);
  border: 1px solid rgba(43,125,233,.15);
  border-radius: 7px;
  padding: .5rem .7rem;
  display: flex;
  align-items: center;
  gap: .35rem;
  margin-bottom: .1rem;
}
.nx-acc__form-label-id i { color: var(--na-blue); }

.nx-acc__form-actions {
  display: flex;
  gap: .55rem;
  padding-top: .4rem;
  border-top: 1px solid var(--na-border);
}
.nx-acc__form-actions .na-btn { flex: 1; justify-content: center; }

/* ── Validation errors ── */
.nx-field-error {
  display: none;
  color: #dc2626 !important;
  font-size: .75rem;
  font-weight: 500;
  margin-top: .3rem;
  padding: 0;
  background: none !important;
  text-transform: none !important;
  letter-spacing: normal !important;
}
.nx-field-error.is-visible { display: block; }
.nx-acc__form label .nx-field-error {
  color: #dc2626 !important;
  text-transform: none !important;
  letter-spacing: normal !important;
  font-weight: 500 !important;
  background: transparent !important;
}
.nx-acc__form input.is-invalid,
.nx-acc__form select.is-invalid {
  border-color: #dc2626 !important;
  box-shadow: 0 0 0 2px rgba(220,38,38,.15) !important;
}
.nx-acc__form input.is-valid,
.nx-acc__form select.is-valid {
  border-color: #16a34a !important;
  box-shadow: none !important;
}

/* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
   TABLE PANEL
