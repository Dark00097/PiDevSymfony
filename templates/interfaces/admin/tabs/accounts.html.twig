  {# â”€â”€ SUBTABS â”€â”€ #}
  <div class="nx-acc__tabs">
    <a class="nx-acc__tab {{ active_panel == 'compte' ? 'is-active' : '' }}"
       href="{{ path(route_name, { tab: 'accounts', panel: 'compte' }) }}">
      <i class="fa-solid fa-credit-card"></i> Compte Bancaire
    </a>
    <a class="nx-acc__tab {{ active_panel == 'coffre' ? 'is-active' : '' }}"
       href="{{ path(route_name, { tab: 'accounts', panel: 'coffre' }) }}">
      <i class="fa-solid fa-vault"></i> Coffre Virtuel
    </a>
    <a class="nx-acc__tab {{ active_panel == 'ia' ? 'is-active' : '' }}"
       href="{{ path(route_name, { tab: 'accounts', panel: 'ia' }) }}">
      <i class="fa-solid fa-brain"></i> Assistante IA
    </a>
    <span class="nx-acc__tabs-spacer"></span>
    <button class="nx-acc__stats-link" type="button" id="nx-stats-toggle"
            onclick="document.getElementById('nx-stats-panel').classList.toggle('is-open')">
      <i class="fa-solid fa-chart-pie"></i> Statistiques
    </button>
  </div>

  {# â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
     STATS PANEL (Chart.js)
  â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• #}
  {% set stats  = support.account_stats|default({}) %}
  {% set total  = stats.total|default(0) %}
  {% set counts = stats.counts|default({'Actif': 0, 'FermÃ©': 0, 'BloquÃ©': 0}) %}
  {% set soldes = stats.soldes|default({'Actif': 0, 'FermÃ©': 0, 'BloquÃ©': 0}) %}
  {% set colors = stats.colors|default({'Actif': '#00B4A0', 'FermÃ©': '#0A2540', 'BloquÃ©': '#B8860B'}) %}
  {% set vstats = support.vault_stats|default({}) %}

  <div class="nx-stats-panel" id="nx-stats-panel">
    <div class="nx-stats-inner">

      <div class="nx-stats-header">
        <span class="nx-stats-header-icon"><i class="fa-solid fa-chart-pie"></i></span>
        <div>
          <h3>Statistiques des Comptes &amp; Coffres</h3>
          <p>{{ total }} compte{{ total != 1 ? 's' : '' }} Â· {{ vstats.total|default(0) }} coffre{{ vstats.total|default(0) != 1 ? 's' : '' }}</p>
        </div>
        <button class="nx-stats-close" type="button"
                onclick="document.getElementById('nx-stats-panel').classList.remove('is-open')">
          <i class="fa-solid fa-xmark"></i>
        </button>
      </div>

      <div class="nx-stats-charts-row">

        {# â”€â”€ Chart 1 : Comptes par statut â”€â”€ #}
        <div class="nx-chart-card">
          <div class="nx-chart-card-head">
            <span class="nx-chart-dot" style="background:#00B4A0"></span>
            <strong>Comptes par statut</strong>
          </div>
          <div class="nx-chart-wrap">
            <canvas id="nx-chart-accounts" width="200" height="200"></canvas>
          </div>
          <div class="nx-chart-legend">
            {% for statut, count in counts %}
              {% set color = colors[statut]|default('#999') %}
              {% set pct   = total > 0 ? ((count / total) * 100)|round(1) : 0 %}
              {% set solde = soldes[statut]|default(0) %}
              <div class="nx-chart-legend-row" style="--lc:{{ color }}">
                <span class="nx-chart-legend-dot"></span>
                <span class="nx-chart-legend-label">{{ statut }}</span>
                <strong>{{ count }}</strong>
                <span class="nx-chart-legend-pct">{{ pct }}%</span>
                <span class="nx-chart-legend-val">{{ solde|number_format(2, '.', ' ') }} DT</span>
              </div>
            {% endfor %}
          </div>
        </div>

        {# â”€â”€ Chart 2 : Progression des coffres â”€â”€ #}
        <div class="nx-chart-card">
          <div class="nx-chart-card-head">
            <span class="nx-chart-dot" style="background:#6c63ff"></span>
            <strong>Progression des coffres</strong>
          </div>
          <div class="nx-chart-wrap">
            <canvas id="nx-chart-vaults" width="200" height="200"></canvas>
          </div>
          <div class="nx-chart-legend">
            <div class="nx-chart-legend-row" style="--lc:#ef4444">
              <span class="nx-chart-legend-dot"></span>
              <span class="nx-chart-legend-label">0 â€“ 49%</span>
              <strong>{{ vstats.rouge|default(0) }}</strong>
              <span class="nx-chart-legend-pct">Rouge</span>
            </div>
            <div class="nx-chart-legend-row" style="--lc:#f97316">
              <span class="nx-chart-legend-dot"></span>
              <span class="nx-chart-legend-label">50 â€“ 99%</span>
              <strong>{{ vstats.orange|default(0) }}</strong>
              <span class="nx-chart-legend-pct">Orange</span>
            </div>
