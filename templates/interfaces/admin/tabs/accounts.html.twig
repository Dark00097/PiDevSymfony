  </style>

  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <script>
  (() => {
    const accountsData = {
      labels: [{% for s, c in counts %}'{{ s }}'{{ not loop.last ? ',' : '' }}{% endfor %}],
      data:   [{% for s, c in counts %}{{ c }}{{ not loop.last ? ',' : '' }}{% endfor %}],
      colors: [{% for s, c in counts %}'{{ colors[s]|default('#999') }}'{{ not loop.last ? ',' : '' }}{% endfor %}],
    };
    const vaultsData = {
      labels: ['0â€“49% (Rouge)', '50â€“99% (Orange)', '100% (Vert)'],
      data:   [{{ vstats.rouge|default(0) }}, {{ vstats.orange|default(0) }}, {{ vstats.vert|default(0) }}],
      colors: ['#ef4444', '#f97316', '#22c55e'],
    };

    const makeChart = (id, labels, data, colors) => {
      const ctx = document.getElementById(id);
      if (!ctx) return;
      new Chart(ctx, {
        type: 'doughnut',
        data: {
          labels,
          datasets: [{
            data,
            backgroundColor: colors,
            borderColor: '#fff',
            borderWidth: 3,
            hoverOffset: 12,
          }],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          cutout: '62%',
          plugins: {
            legend: { display: false },
            tooltip: {
              callbacks: {
                label: (ctx) => ` ${ctx.label} : ${ctx.parsed} (${((ctx.parsed / ctx.dataset.data.reduce((a,b)=>a+b,0))*100).toFixed(1)}%)`,
              },
            },
          },
          animation: { animateRotate: true, duration: 700 },
        },
      });
    };

    makeChart('nx-chart-accounts', accountsData.labels, accountsData.data, accountsData.colors);
    makeChart('nx-chart-vaults',   vaultsData.labels,   vaultsData.data,   vaultsData.colors);
  })();
  </script>
