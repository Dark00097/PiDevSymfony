  background: var(--na-bg);
  outline: none;
  font-family: inherit;
  cursor: pointer;
  transition: border-color .2s;
  flex-shrink: 0;
}
.nx-acc__sort-select:focus { border-color: var(--na-teal); }

.nx-acc__sort-dir {
  width: 36px; height: 36px;
  border: 1px solid var(--na-border);
  border-radius: 8px;
  background: var(--na-bg);
  color: var(--na-muted);
  font-size: .85rem;
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  transition: all .2s;
}
.nx-acc__sort-dir:hover { background: var(--na-teal); color: #fff; border-color: var(--na-teal); }

/* â”€â”€ Action icon buttons â”€â”€ */
.nx-acc__act-group {
  display: flex;
  align-items: center;
  gap: .35rem;
}
.nx-acc__act-btn {
  width: 30px; height: 30px;
  border-radius: 8px;
  border: none;
