:root {
  --na-bg:        #f0f4f9;
  --na-surface:   #ffffff;
  --na-border:    #e4ecf4;
  --na-txt:       #1a2b3c;
  --na-muted:     #6b85a0;
  --na-radius:    14px;
  --na-shadow:    0 2px 16px rgba(0,0,0,.07);
  --na-shadow-lg: 0 6px 32px rgba(0,0,0,.10);
  --na-teal:      #11b7aa;
  --na-teal-dk:   #0d9e93;
  --na-blue:      #2b7de9;
  --na-blue-dk:   #1f6cd6;
  --na-gold:      #e8a202;
  --na-purple:    #7c4dff;
  --na-red:       #e53935;
  --na-green:     #43a047;
}

/* â”€â”€ Shell â”€â”€ */
.nx-acc {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
  padding: 1.75rem 2rem;
  background: var(--na-bg);
  min-height: 100%;
  font-family: 'Inter', system-ui, sans-serif;
  color: var(--na-txt);
}

/* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
   HERO HEADER
â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
.nx-acc__hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1.25rem;
  background: linear-gradient(135deg, #1a2b3c 0%, #1e3448 60%, #1a3050 100%);
  border-radius: var(--na-radius);
  padding: 1.5rem 1.8rem;
  box-shadow: var(--na-shadow-lg);
  flex-wrap: wrap;
  position: relative;
  overflow: hidden;
}
.nx-acc__hero::before {
  content: '';
  position: absolute;
  width: 260px; height: 260px;
  top: -80px; right: -50px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(17,183,170,.22) 0%, transparent 70%);
  pointer-events: none;
}
.nx-acc__hero::after {
  content: '';
  position: absolute;
  width: 160px; height: 160px;
  bottom: -60px; left: 30%;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(43,125,233,.18) 0%, transparent 70%);
  pointer-events: none;
}

.nx-acc__hero-left {
  display: flex;
  align-items: center;
  gap: 1.1rem;
  position: relative;
  z-index: 1;
}

.nx-acc__hero-icon {
  width: 50px; height: 50px;
  border-radius: 13px;
  background: linear-gradient(135deg, var(--na-teal), var(--na-teal-dk));
  display: grid;
  place-items: center;
  font-size: 1.3rem;
  color: #fff;
  box-shadow: 0 4px 16px rgba(17,183,170,.4);
  flex-shrink: 0;
}

.nx-acc__hero-text h2 {
  font-size: 1.1rem;
  font-weight: 800;
  color: #fff;
  margin: 0 0 .25rem;
}
.nx-acc__hero-text p {
  font-size: .76rem;
  color: rgba(255,255,255,.5);
  margin: 0;
}

.nx-acc__hero-actions {
  display: flex;
  align-items: center;
  gap: .65rem;
  position: relative;
  z-index: 1;
  flex-wrap: wrap;
}

/* â”€â”€ Shared buttons â”€â”€ */
.na-btn {
  display: inline-flex;
  align-items: center;
  gap: .4rem;
  padding: .52rem 1.1rem;
  border-radius: 9px;
  font-size: .82rem;
  font-weight: 600;
  border: none;
  cursor: pointer;
  text-decoration: none;
  transition: all .2s ease;
  font-family: inherit;
  white-space: nowrap;
}
.na-btn--primary {
  background: linear-gradient(135deg, var(--na-teal), var(--na-teal-dk));
  color: #fff;
  box-shadow: 0 3px 10px rgba(17,183,170,.35);
}
.na-btn--primary:hover {
  box-shadow: 0 5px 18px rgba(17,183,170,.5);
  transform: translateY(-1px);
}
.na-btn--ghost {
  background: rgba(255,255,255,.1);
  color: rgba(255,255,255,.85);
  border: 1px solid rgba(255,255,255,.18);
  backdrop-filter: blur(4px);
}
.na-btn--ghost:hover {
  background: rgba(255,255,255,.18);
  color: #fff;
}
.na-btn--ghost-dark {
  background: transparent;
  color: var(--na-teal);
  border: 1px solid rgba(17,183,170,.3);
  font-size: .78rem;
}
.na-btn--ghost-dark:hover { background: rgba(17,183,170,.06); }
.na-btn--danger {
  background: rgba(229,57,53,.09);
  color: var(--na-red);
  border: 1px solid rgba(229,57,53,.22);
  font-size: .76rem;
  padding: .38rem .8rem;
}
.na-btn--danger:hover { background: rgba(229,57,53,.18); }
.na-btn--save {
  background: linear-gradient(135deg, var(--na-teal), var(--na-teal-dk));
  color: #fff;
  box-shadow: 0 3px 10px rgba(17,183,170,.3);
}
.na-btn--save:hover {
  box-shadow: 0 5px 16px rgba(17,183,170,.45);
  transform: translateY(-1px);
}
.na-btn--reset {
  background: var(--na-bg);
  color: var(--na-muted);
  border: 1px solid var(--na-border);
}
.na-btn--reset:hover { background: var(--na-border); color: var(--na-txt); }

/* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
   SUBTABS
â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
.nx-acc__tabs {
  display: flex;
  align-items: center;
  gap: .4rem;
  background: var(--na-surface);
  border: 1px solid var(--na-border);
  border-radius: var(--na-radius);
  padding: .55rem .65rem;
  box-shadow: var(--na-shadow);
  flex-wrap: wrap;
}

.nx-acc__tab {
  display: inline-flex;
  align-items: center;
  gap: .45rem;
  padding: .5rem 1.1rem;
  border-radius: 9px;
  font-size: .82rem;
  font-weight: 600;
  color: var(--na-muted);
  text-decoration: none;
  transition: all .2s ease;
  border: 1px solid transparent;
}
.nx-acc__tab i { font-size: .85rem; }
.nx-acc__tab:hover {
  background: var(--na-bg);
