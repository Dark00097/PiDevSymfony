{% set active_panel   = panel|default(support.active_panel|default('partenaire')) %}
{% set partner_items  = support.partners_items|default(support.partners|default(items)) %}
{% set cashback_items = support.cashbacks|default(items) %}
{% set users          = support.users|default([]) %}
{% set partners       = support.partners|default([]) %}
{% set stats_section_id = active_panel == 'cashback' ? 'ncb-cashback-stats' : 'ncb-partner-stats' %}
{% set cashback_stat_colors = {
  'En attente': '#f59e0b',
  'Valides / credites': '#22c55e',
  'Rejetes': '#ef4444',
  'Autre': '#7c4dff'
} %}
{% set partner_stat_palette = ['#0f2d4a', '#22c1b5', '#f59e0b', '#60a5fa', '#8b5cf6', '#ef4444'] %}

{% set pending_cashback = 0 %}
{% set validated_cashback = 0 %}
{% set rejected_cashback = 0 %}
{% set total_cashback_amount = 0 %}
{% for item in cashback_items %}
  {% if item.statut|default('') in ['En attente','Pending'] %}
    {% set pending_cashback = pending_cashback + 1 %}
  {% endif %}
  {% if item.statut|default('') in ['Valide','Credite','Validé'] %}
    {% set validated_cashback = validated_cashback + 1 %}
  {% endif %}
  {% if item.statut|default('') in ['Rejete','Rejeté'] %}
    {% set rejected_cashback = rejected_cashback + 1 %}
  {% endif %}
  {% set total_cashback_amount = total_cashback_amount + (item.montant_cashback|default(0)) %}
{% endfor %}
{% set cashback_other_count = cashback_items|length - pending_cashback - validated_cashback - rejected_cashback %}
{% set cashback_status_counts = {
  'En attente': pending_cashback,
  'Valides / credites': validated_cashback,
  'Rejetes': rejected_cashback
} %}
{% if cashback_other_count > 0 %}
  {% set cashback_status_counts = cashback_status_counts|merge({'Autre': cashback_other_count}) %}
{% endif %}

{% set total_rating = 0 %}
{% set avg_rate     = 0 %}
{% set active_partners = 0 %}
{% set partner_category_counts = {} %}
{% for item in partner_items %}
  {% set total_rating = total_rating + (item.rating|default(0)) %}
  {% set avg_rate     = avg_rate     + (item.tauxCashback|default(0)) %}
  {% if item.status|default('') in ['Actif', 'Active'] %}
    {% set active_partners = active_partners + 1 %}
  {% endif %}
  {% set partner_category = item.categorie|default('Autre')|trim %}
  {% if partner_category == '' %}
    {% set partner_category = 'Autre' %}
  {% endif %}
  {% set partner_category_counts = partner_category_counts|merge({
    (partner_category): (partner_category_counts[partner_category]|default(0) + 1)
  }) %}
{% endfor %}

<style>
/* ═══════════════════════════════════════════
   NEXORA · Cashback Admin  (ncb)
═══════════════════════════════════════════ */

:root {
  --ncb-bg:        #f0f4f9;
  --ncb-surface:   #ffffff;
  --ncb-border:    #e4ecf4;
  --ncb-txt:       #1a2b3c;
  --ncb-muted:     #6b85a0;
  --ncb-radius:    14px;
  --ncb-shadow:    0 2px 16px rgba(0,0,0,.07);
  --ncb-shadow-lg: 0 6px 32px rgba(0,0,0,.10);
  --ncb-teal:      #11b7aa;
  --ncb-teal-dk:   #0d9e93;
  --ncb-blue:      #2b7de9;
  --ncb-blue-dk:   #1f6cd6;
  --ncb-green:     #22c55e;
  --ncb-green-dk:  #16a34a;
  --ncb-red:       #e53935;
  --ncb-red-dk:    #c62828;
  --ncb-gold:      #e8a202;
  --ncb-gold-dk:   #cc8f00;
  --ncb-purple:    #7c4dff;
  --ncb-purple-dk: #6a3de0;
  --ncb-orange:    #f97316;
}

/* ── Shell ── */
.ncb-shell {
  display: flex;
  flex-direction: column;
  gap: 1.4rem;
  padding: 1.75rem 2rem;
  background: var(--ncb-bg);
  min-height: 100%;
  font-family: 'Inter', system-ui, sans-serif;
  color: var(--ncb-txt);
}

/* ══════════════════════════════
   HERO
══════════════════════════════ */
.ncb-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1.25rem;
  background: linear-gradient(135deg, #1a2b3c 0%, #1e3448 55%, #17304a 100%);
  border-radius: var(--ncb-radius);
  padding: 1.4rem 1.8rem;
  box-shadow: var(--ncb-shadow-lg);
  flex-wrap: wrap;
  position: relative;
  overflow: hidden;
}
.ncb-hero::before {
  content: '';
  position: absolute;
  width: 280px; height: 280px;
  top: -90px; right: -55px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(232,162,2,.22) 0%, transparent 70%);
  pointer-events: none;
}
.ncb-hero::after {
  content: '';
  position: absolute;
  width: 180px; height: 180px;
  bottom: -60px; left: 30%;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(17,183,170,.16) 0%, transparent 70%);
  pointer-events: none;
}

.ncb-hero-left {
  display: flex;
  align-items: center;
  gap: 1rem;
  position: relative;
  z-index: 1;
}
.ncb-hero-icon {
  width: 50px; height: 50px;
  border-radius: 13px;
  background: linear-gradient(135deg, var(--ncb-gold), var(--ncb-gold-dk));
  display: grid;
  place-items: center;
  font-size: 1.3rem;
  color: #fff;
  box-shadow: 0 4px 16px rgba(232,162,2,.45);
  flex-shrink: 0;
}
.ncb-hero-text h2 {
  font-size: 1.1rem;
  font-weight: 800;
  color: #fff;
  margin: 0 0 .22rem;
}
.ncb-hero-text p {
  font-size: .75rem;
  color: rgba(255,255,255,.5);
  margin: 0;
}

.ncb-hero-actions {
  display: flex;
  align-items: center;
  gap: .55rem;
  position: relative;
  z-index: 1;
  flex-wrap: wrap;
}

/* ── Shared buttons ── */
.ncb-btn {
  display: inline-flex;
  align-items: center;
  gap: .4rem;
  padding: .5rem 1.05rem;
  border-radius: 9px;
  font-size: .81rem;
  font-weight: 600;
  border: none;
  cursor: pointer;
  text-decoration: none;
  transition: all .2s ease;
  font-family: inherit;
  white-space: nowrap;
}
.ncb-btn--primary {
  background: linear-gradient(135deg, var(--ncb-teal), var(--ncb-teal-dk));
  color: #fff;
  box-shadow: 0 3px 10px rgba(17,183,170,.35);
}
.ncb-btn--primary:hover {
  box-shadow: 0 5px 18px rgba(17,183,170,.5);
  transform: translateY(-1px);
}
.ncb-btn--gold {
  background: linear-gradient(135deg, var(--ncb-gold), var(--ncb-gold-dk));
  color: #fff;
  box-shadow: 0 3px 10px rgba(232,162,2,.35);
}
.ncb-btn--gold:hover {
  box-shadow: 0 5px 16px rgba(232,162,2,.5);
  transform: translateY(-1px);
}
.ncb-btn--ghost-hero {
  background: rgba(255,255,255,.1);
  color: rgba(255,255,255,.85);
  border: 1px solid rgba(255,255,255,.18);
  backdrop-filter: blur(4px);
}
.ncb-btn--ghost-hero:hover {
  background: rgba(255,255,255,.18);
  color: #fff;
}
.ncb-btn--ghost {
  background: var(--ncb-bg);
  color: var(--ncb-muted);
  border: 1px solid var(--ncb-border);
}
.ncb-btn--ghost:hover { background: var(--ncb-border); color: var(--ncb-txt); }
.ncb-btn--save {
  background: linear-gradient(135deg, var(--ncb-teal), var(--ncb-teal-dk));
  color: #fff;
  box-shadow: 0 3px 10px rgba(17,183,170,.28);
}
.ncb-btn--save:hover {
  box-shadow: 0 5px 16px rgba(17,183,170,.44);
  transform: translateY(-1px);
}
.ncb-btn--danger {
  background: rgba(229,57,53,.09);
  color: var(--ncb-red);
  border: 1px solid rgba(229,57,53,.22);
  font-size: .75rem;
  padding: .35rem .75rem;
}
.ncb-btn--danger:hover { background: rgba(229,57,53,.17); }
.ncb-btn--reward {
  background: rgba(232,162,2,.1);
  color: var(--ncb-gold-dk);
  border: 1px solid rgba(232,162,2,.25);
  font-size: .75rem;
  padding: .35rem .75rem;
}
.ncb-btn--reward:hover { background: rgba(232,162,2,.2); }

/* ══════════════════════════════
   SUBTABS
══════════════════════════════ */
.ncb-tabs {
  display: flex;
  align-items: center;
  gap: .4rem;
  background: var(--ncb-surface);
  border: 1px solid var(--ncb-border);
  border-radius: var(--ncb-radius);
  padding: .55rem .65rem;
  box-shadow: var(--ncb-shadow);
  flex-wrap: wrap;
}
.ncb-tab {
  display: inline-flex;
  align-items: center;
  gap: .45rem;
  padding: .48rem 1.05rem;
  border-radius: 9px;
  font-size: .81rem;
  font-weight: 600;
  color: var(--ncb-muted);
  text-decoration: none;
  transition: all .2s ease;
  border: 1px solid transparent;
}
.ncb-tab i { font-size: .82rem; }
.ncb-tab:hover { background: var(--ncb-bg); color: var(--ncb-txt); }
.ncb-tab.is-active {
  background: linear-gradient(135deg, var(--ncb-gold), var(--ncb-gold-dk));
  color: #fff;
  box-shadow: 0 3px 10px rgba(232,162,2,.35);
}
.ncb-tabs-spacer { flex: 1; }
.ncb-stats-link {
  display: inline-flex;
  align-items: center;
  gap: .4rem;
  padding: .48rem .95rem;
  border-radius: 9px;
  font-size: .77rem;
  font-weight: 600;
  color: var(--ncb-blue);
  text-decoration: none;
  background: rgba(43,125,233,.07);
  border: 1px solid rgba(43,125,233,.18);
  transition: all .2s;
}
.ncb-stats-link:hover { background: rgba(43,125,233,.14); }

.ncb-stats-panel {
  display: block;
  background: var(--ncb-surface);
  border: 1px solid rgba(0,0,0,.06);
  border-radius: 20px;
  box-shadow: var(--ncb-shadow);
  padding: 1.25rem 1.35rem;
  position: relative;
  overflow: hidden;
}

.ncb-stats-panel::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3px;
  background: linear-gradient(90deg, var(--ncb-gold), var(--ncb-orange), var(--ncb-blue));
  opacity: .95;
}

.ncb-stats-panel.is-collapsed {
  display: none;
}

.ncb-stats-panel-head h3 {
  font-size: .96rem;
  font-weight: 800;
  color: var(--ncb-txt);
  margin: 0 0 .24rem;
}

.ncb-stats-panel-head p {
  font-size: .76rem;
  color: var(--ncb-muted);
  margin: 0;
}

.ncb-analytics-layout {
  margin-top: 1rem;
  display: grid;
  grid-template-columns: 220px 1fr;
  gap: 1.1rem;
  align-items: center;
}

.ncb-donut-shell {
  width: 220px;
  height: 220px;
  border-radius: 999px;
  display: grid;
  place-items: center;
  background: #f8fafc;
  border: 1px solid var(--ncb-border);
  position: relative;
}

.ncb-donut {
  width: 180px;
  height: 180px;
  transform: rotate(-90deg);
}

.ncb-donut-track {
  fill: transparent;
  stroke: #e2e8f0;
  stroke-width: 4.5;
}

.ncb-donut-segment {
  fill: transparent;
  stroke-width: 4.5;
}

.ncb-donut-total {
  position: absolute;
  text-align: center;
}

.ncb-donut-total strong {
  display: block;
  font-size: 2rem;
  line-height: 1;
  color: var(--ncb-txt);
  font-weight: 800;
}

.ncb-donut-total span {
  font-size: .72rem;
  color: var(--ncb-muted);
  text-transform: uppercase;
  letter-spacing: .08em;
  font-weight: 700;
}

.ncb-type-list {
  display: flex;
  flex-direction: column;
  gap: .85rem;
}

.ncb-type-row {
  border: 1px solid #edf2f7;
  border-radius: 14px;
  padding: .8rem .9rem;
  background: #fbfcff;
}

.ncb-type-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: .75rem;
  margin-bottom: .45rem;
}

.ncb-type-title {
  display: inline-flex;
  align-items: center;
  gap: .55rem;
  color: var(--ncb-txt);
  font-size: .9rem;
  font-weight: 800;
}

.ncb-type-dot {
  width: 10px;
  height: 10px;
  border-radius: 999px;
  flex-shrink: 0;
}

.ncb-type-head small {
  font-size: .82rem;
  color: var(--ncb-muted);
}

.ncb-type-track {
  height: 9px;
  border-radius: 999px;
  background: #e2e8f0;
  overflow: hidden;
}

.ncb-type-fill {
  display: block;
  height: 100%;
  width: var(--fill, 0%);
  border-radius: 999px;
}

.ncb-type-empty {
  padding: 1rem;
  border: 1px dashed #cbd5e1;
  border-radius: 12px;
  color: var(--ncb-muted);
  font-size: .82rem;
  text-align: center;
  background: #f8fafc;
}

.ncb-stats-grid {
  display: none;
}

/* ══════════════════════════════
   KPI ROW
══════════════════════════════ */
.ncb-kpis {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
}
.ncb-kpi {
  background: var(--ncb-surface);
  border: 1px solid var(--ncb-border);
  border-radius: var(--ncb-radius);
  padding: 1.05rem 1.2rem;
  box-shadow: var(--ncb-shadow);
  display: flex;
  align-items: center;
  gap: .9rem;
  position: relative;
  overflow: hidden;
  transition: transform .2s, box-shadow .2s;
}
.ncb-kpi:hover {
  transform: translateY(-2px);
  box-shadow: var(--ncb-shadow-lg);
}
.ncb-kpi::before {
  content: '';
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 3px;
  border-radius: 0 3px 3px 0;
}

/* partner panel */
.ncb-kpis--partner .ncb-kpi:nth-child(1)::before { background: var(--ncb-teal); }
.ncb-kpis--partner .ncb-kpi:nth-child(2)::before { background: var(--ncb-gold); }
.ncb-kpis--partner .ncb-kpi:nth-child(3)::before { background: var(--ncb-purple); }
.ncb-kpis--partner .ncb-kpi:nth-child(1) .ncb-kpi-icon { background: rgba(17,183,170,.1);  color: var(--ncb-teal); }
.ncb-kpis--partner .ncb-kpi:nth-child(2) .ncb-kpi-icon { background: rgba(232,162,2,.1);   color: var(--ncb-gold); }
.ncb-kpis--partner .ncb-kpi:nth-child(3) .ncb-kpi-icon { background: rgba(124,77,255,.1);  color: var(--ncb-purple); }

/* cashback panel */
.ncb-kpis--cashback .ncb-kpi:nth-child(1)::before { background: var(--ncb-gold); }
.ncb-kpis--cashback .ncb-kpi:nth-child(2)::before { background: var(--ncb-orange); }
.ncb-kpis--cashback .ncb-kpi:nth-child(3)::before { background: var(--ncb-blue); }
.ncb-kpis--cashback .ncb-kpi:nth-child(1) .ncb-kpi-icon { background: rgba(232,162,2,.1);  color: var(--ncb-gold); }
.ncb-kpis--cashback .ncb-kpi:nth-child(2) .ncb-kpi-icon { background: rgba(249,115,22,.1); color: var(--ncb-orange); }
.ncb-kpis--cashback .ncb-kpi:nth-child(3) .ncb-kpi-icon { background: rgba(43,125,233,.1); color: var(--ncb-blue); }

.ncb-kpi-icon {
  width: 42px; height: 42px;
  border-radius: 11px;
  display: grid;
  place-items: center;
  font-size: 1.05rem;
  flex-shrink: 0;
}
.ncb-kpi-body strong {
  display: block;
  font-size: 1.5rem;
  font-weight: 800;
  color: var(--ncb-txt);
  line-height: 1;
  margin-bottom: .18rem;
}
.ncb-kpi-body small {
  font-size: .73rem;
  color: var(--ncb-muted);
  font-weight: 500;
}

/* ══════════════════════════════
   CONTENT GRID
══════════════════════════════ */
.ncb-grid {
  display: grid;
  grid-template-columns: 330px 1fr;
  gap: 1.25rem;
  align-items: start;
}

/* ── Panel card shared ── */
.ncb-panel {
  background: var(--ncb-surface);
  border: 1px solid var(--ncb-border);
  border-radius: var(--ncb-radius);
  box-shadow: var(--ncb-shadow);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}
.ncb-panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: .75rem;
  padding: 1.05rem 1.3rem;
  border-bottom: 1px solid var(--ncb-border);
  background: linear-gradient(to right, #fafcff, #f5f8fd);
  flex-wrap: wrap;
}
.ncb-panel-head-left h3 {
  font-size: .9rem;
  font-weight: 700;
  color: var(--ncb-txt);
  margin: 0 0 .12rem;
}
.ncb-panel-head-left p {
  font-size: .72rem;
  color: var(--ncb-muted);
  margin: 0;
}

/* ══════════════════════════════
   FORM
══════════════════════════════ */
.ncb-form {
  display: flex;
  flex-direction: column;
  gap: .7rem;
  padding: 1.15rem 1.25rem;
}
.ncb-form-hint {
  display: flex;
  align-items: center;
  gap: .35rem;
  font-size: .69rem;
  color: var(--ncb-muted);
  background: rgba(43,125,233,.06);
  border: 1px solid rgba(43,125,233,.15);
  border-radius: 7px;
  padding: .45rem .7rem;
}
.ncb-form-hint i { color: var(--ncb-blue); }
.ncb-form-sep { height: 1px; background: var(--ncb-border); margin: .1rem 0; }

.ncb-field { display: flex; flex-direction: column; gap: .28rem; }
.ncb-field label {
  font-size: .7rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .45px;
  color: var(--ncb-muted);
}
.ncb-field label em { color: var(--ncb-red); font-style: normal; }

.ncb-form input[type="text"],
.ncb-form input[type="number"],
.ncb-form input[type="date"],
.ncb-form select,
.ncb-form textarea {
  width: 100%;
  box-sizing: border-box;
  border: 1px solid var(--ncb-border);
  border-radius: 9px;
  font-size: .81rem;
  color: var(--ncb-txt);
  background: var(--ncb-bg);
  outline: none;
  font-family: inherit;
  transition: border-color .2s, box-shadow .2s;
}
.ncb-form input[type="text"],
.ncb-form input[type="number"],
.ncb-form input[type="date"],
.ncb-form select { height: 38px; padding: 0 .8rem; }
.ncb-form textarea { padding: .6rem .8rem; resize: vertical; min-height: 68px; }
.ncb-form input:focus,
.ncb-form select:focus,
.ncb-form textarea:focus {
  border-color: var(--ncb-gold);
  box-shadow: 0 0 0 3px rgba(232,162,2,.14);
  background: #fff;
}

/* rating stars row */
.ncb-rating-row {
  display: flex;
  align-items: center;
  gap: .5rem;
}
.ncb-rating-row input { flex: 1; }
.ncb-stars {
  display: flex;
  gap: 2px;
  font-size: .78rem;
  color: var(--ncb-gold);
}

.ncb-form-actions {
  display: flex;
  gap: .45rem;
  padding-top: .45rem;
  border-top: 1px solid var(--ncb-border);
}
.ncb-form-actions .ncb-btn { flex: 1; justify-content: center; }

/* ══════════════════════════════
   SEARCH BAR
══════════════════════════════ */
.ncb-search-bar {
  display: flex;
  align-items: center;
  gap: .6rem;
  padding: .75rem 1.1rem;
  border-bottom: 1px solid var(--ncb-border);
  flex-wrap: wrap;
}
.ncb-search-wrap {
  position: relative;
  flex: 1;
  min-width: 150px;
}
.ncb-search-wrap i {
  position: absolute;
  left: .7rem;
  top: 50%;
  transform: translateY(-50%);
  color: var(--ncb-muted);
  font-size: .78rem;
  pointer-events: none;
}
.ncb-search-input {
  width: 100%;
  height: 35px;
  padding: 0 .8rem 0 2rem;
  border: 1px solid var(--ncb-border);
  border-radius: 8px;
  font-size: .8rem;
  color: var(--ncb-txt);
  background: var(--ncb-bg);
  outline: none;
  box-sizing: border-box;
  font-family: inherit;
  transition: border-color .2s, box-shadow .2s;
}
.ncb-search-input:focus {
  border-color: var(--ncb-gold);
  box-shadow: 0 0 0 3px rgba(232,162,2,.12);
  background: #fff;
}
.ncb-row-count {
  font-size: .71rem;
  font-weight: 600;
  color: var(--ncb-muted);
  background: var(--ncb-bg);
  border: 1px solid var(--ncb-border);
  border-radius: 20px;
  padding: .2rem .65rem;
  white-space: nowrap;
}

/* ══════════════════════════════
   TABLE
══════════════════════════════ */
.ncb-table-wrap { overflow-x: auto; }
.ncb-table {
  width: 100%;
  border-collapse: collapse;
  font-size: .8rem;
}
.ncb-table thead th {
  padding: .6rem 1rem;
  text-align: left;
  font-size: .68rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .55px;
  color: var(--ncb-muted);
  background: var(--ncb-bg);
  border-bottom: 1px solid var(--ncb-border);
  white-space: nowrap;
}
.ncb-table thead th:first-child { border-radius: 8px 0 0 8px; }
.ncb-table thead th:last-child  { border-radius: 0 8px 8px 0; }
.ncb-table tbody td {
  padding: .72rem 1rem;
  border-bottom: 1px solid var(--ncb-border);
  vertical-align: middle;
  color: var(--ncb-txt);
}
.ncb-table tbody tr:last-child td { border-bottom: none; }
.ncb-table tbody tr:hover td      { background: rgba(232,162,2,.03); }

/* cell helpers */
.ncb-tid {
  font-family: monospace;
  font-size: .75rem;
  background: var(--ncb-bg);
  padding: .16rem .48rem;
  border-radius: 5px;
  color: var(--ncb-muted);
  font-weight: 600;
}
.ncb-name-cell {
  display: flex;
  align-items: center;
  gap: .5rem;
}
.ncb-name-dot {
  width: 30px; height: 30px;
  border-radius: 9px;
  background: linear-gradient(135deg, var(--ncb-gold), var(--ncb-orange));
  color: #fff;
  font-size: .7rem;
  font-weight: 700;
  display: grid;
  place-items: center;
  flex-shrink: 0;
}
.ncb-user-dot {
  width: 26px; height: 26px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--ncb-teal), var(--ncb-blue));
  color: #fff;
  font-size: .6rem;
  font-weight: 700;
  display: grid;
  place-items: center;
  flex-shrink: 0;
}
.ncb-cat-tag {
  display: inline-block;
  background: var(--ncb-bg);
  color: var(--ncb-muted);
  border: 1px solid var(--ncb-border);
  border-radius: 6px;
  padding: .16rem .52rem;
  font-size: .72rem;
  font-weight: 500;
}
.ncb-rate {
  font-weight: 700;
  color: var(--ncb-gold-dk);
  font-size: .82rem;
}
.ncb-amount {
  font-weight: 700;
  color: var(--ncb-txt);
}
.ncb-amount em {
  font-style: normal;
  font-size: .7rem;
  color: var(--ncb-muted);
  margin-left: .1rem;
}
.ncb-cashback-amount {
  font-weight: 800;
  color: var(--ncb-green-dk);
  display: inline-flex;
  align-items: baseline;
  gap: .15rem;
}
.ncb-cashback-amount em {
  font-style: normal;
  font-size: .7rem;
  color: rgba(22,163,74,.7);
}

/* star rating display */
.ncb-star-row {
  display: flex;
  align-items: center;
  gap: .3rem;
}
.ncb-star-row i {
  font-size: .72rem;
  color: var(--ncb-gold);
}
.ncb-star-row span {
  font-size: .75rem;
  font-weight: 700;
  color: var(--ncb-txt);
}

/* status badge */
.ncb-status {
  display: inline-block;
  padding: .18rem .58rem;
  border-radius: 20px;
  font-size: .69rem;
  font-weight: 700;
  text-transform: capitalize;
}
.ncb-status--active,
.ncb-status--actif,
.ncb-status--valide {
  background: rgba(34,197,94,.1);
  color: var(--ncb-green-dk);
  border: 1px solid rgba(34,197,94,.22);
}
.ncb-status--wait,
.ncb-status--attente,
.ncb-status--pending {
  background: rgba(232,162,2,.1);
  color: #946800;
  border: 1px solid rgba(232,162,2,.22);
}
.ncb-status--inactive,
.ncb-status--inactif {
  background: rgba(229,57,53,.1);
  color: var(--ncb-red-dk);
  border: 1px solid rgba(229,57,53,.2);
}
.ncb-status--neutral {
  background: var(--ncb-bg);
  color: var(--ncb-muted);
  border: 1px solid var(--ncb-border);
}

/* inline reward form */
.ncb-reward-form {
  display: flex;
  align-items: center;
  gap: .4rem;
  flex-wrap: wrap;
}
.ncb-reward-form input {
  height: 30px;
  padding: 0 .55rem;
  border: 1px solid var(--ncb-border);
  border-radius: 7px;
  font-size: .75rem;
  background: var(--ncb-bg);
  color: var(--ncb-txt);
  outline: none;
  font-family: inherit;
  transition: border-color .18s, box-shadow .18s;
}
.ncb-reward-form input[name="bonus_amount"] { width: 70px; }
.ncb-reward-form input[name="bonus_note"]   { width: 90px; }
.ncb-reward-form input:focus {
  border-color: var(--ncb-gold);
  box-shadow: 0 0 0 2px rgba(232,162,2,.14);
  background: #fff;
}

.ncb-actions-cell { display: flex; align-items: center; gap: .35rem; }

/* empty */
.ncb-empty {
  text-align: center;
  padding: 2.5rem 1rem;
  color: var(--ncb-muted);
  font-size: .81rem;
}
.ncb-empty i {
  display: block;
  font-size: 1.8rem;
  opacity: .22;
  margin-bottom: .5rem;
}

/* ══════════════════════════════
   RESPONSIVE
══════════════════════════════ */
@media (max-width: 1100px) {
  .ncb-grid { grid-template-columns: 1fr; }
  .ncb-analytics-layout { grid-template-columns: 1fr; }
  .ncb-donut-shell { margin: 0 auto; }
}
@media (max-width: 720px) {
  .ncb-kpis { grid-template-columns: 1fr 1fr; }
  .ncb-hero { flex-direction: column; align-items: flex-start; }
}
@media (max-width: 520px) {
  .ncb-shell { padding: 1rem; gap: 1rem; }
  .ncb-kpis  { grid-template-columns: 1fr; }
}
</style>

{# ═══════════════════════════════════════════
   MARKUP
═══════════════════════════════════════════ #}
<section class="ncb-shell">

  {# ── HERO ── #}
  <header class="ncb-hero">
    <div class="ncb-hero-left">
      <span class="ncb-hero-icon">
        <i class="fa-solid fa-coins"></i>
      </span>
      <div class="ncb-hero-text">
        <h2>Gestion Cashback</h2>
        <p>Gérer et superviser les partenaires et dossiers cashback</p>
      </div>
    </div>
    <div class="ncb-hero-actions">
      <a class="ncb-btn ncb-btn--ghost-hero"
         href="{{ path('admin_features', { section: 'statistics' }) }}">
        <i class="fa-solid fa-download"></i> Exporter
      </a>
      <a class="ncb-btn ncb-btn--gold" href="#ncb-form">
        <i class="fa-solid fa-plus"></i> Ajouter
      </a>
    </div>
  </header>

  {# ── SUBTABS ── #}
  <div class="ncb-tabs">
    <a class="ncb-tab {{ active_panel == 'partenaire' ? 'is-active' : '' }}"
       href="{{ path(route_name, { tab: 'cashback', panel: 'partenaire' }) }}">
      <i class="fa-solid fa-handshake"></i> Partenaires
    </a>
    <a class="ncb-tab {{ active_panel == 'cashback' ? 'is-active' : '' }}"
       href="{{ path(route_name, { tab: 'cashback', panel: 'cashback' }) }}">
      <i class="fa-solid fa-coins"></i> Cashback
      {% if pending_cashback > 0 %}
        <span style="
          background:var(--ncb-orange);color:#fff;
          font-size:.6rem;font-weight:800;
          padding:.1rem .4rem;border-radius:20px;margin-left:.15rem;
        ">{{ pending_cashback }}</span>
      {% endif %}
    </a>
    <span class="ncb-tabs-spacer"></span>
    <a class="ncb-stats-link"
       href="#{{ stats_section_id }}"
       id="ncb-stats-link"
       aria-expanded="false">
      <i class="fa-solid fa-chart-pie"></i> Statistiques
    </a>
  </div>

  <div class="ncb-stats-panel is-collapsed" id="{{ stats_section_id }}">
    <div class="ncb-stats-panel-head">
      {% if active_panel == 'cashback' %}
        <h3>Statistiques Cashback</h3>
        <p>Vue rapide des dossiers cashback, validations et montants générés.</p>
      {% else %}
        <h3>Statistiques Partenaires</h3>
        <p>Vue rapide du réseau partenaires, des notes et des taux proposés.</p>
      {% endif %}
    </div>
    {% if active_panel == 'cashback' %}
      <div class="ncb-analytics-layout">
        <div class="ncb-donut-shell">
          {% set cashback_donut_offset = 25 %}
          <svg viewBox="0 0 42 42" class="ncb-donut" aria-label="Repartition des statuts cashback">
            <circle class="ncb-donut-track" cx="21" cy="21" r="15.915"></circle>
            {% for label, count in cashback_status_counts %}
              {% if count > 0 %}
                {% set percent = cashback_items|length > 0 ? (count * 100 / cashback_items|length) : 0 %}
                <circle
                  class="ncb-donut-segment"
                  cx="21"
                  cy="21"
                  r="15.915"
                  stroke="{{ cashback_stat_colors[label]|default(cashback_stat_colors['Autre']) }}"
                  stroke-dasharray="{{ percent }} {{ 100 - percent }}"
                  stroke-dashoffset="{{ cashback_donut_offset }}"
                ></circle>
                {% set cashback_donut_offset = cashback_donut_offset - percent %}
              {% endif %}
            {% endfor %}
          </svg>
          <div class="ncb-donut-total">
            <strong>{{ cashback_items|length }}</strong>
            <span>Cashback</span>
          </div>
        </div>
        <div class="ncb-type-list">
          {% for label, count in cashback_status_counts %}
            {% if count > 0 %}
              {% set percent = cashback_items|length > 0 ? (count * 100 / cashback_items|length) : 0 %}
              <div class="ncb-type-row">
                <div class="ncb-type-head">
                  <div class="ncb-type-title">
                    <span class="ncb-type-dot" style="background: {{ cashback_stat_colors[label]|default(cashback_stat_colors['Autre']) }};"></span>
                    <span>{{ label }}</span>
                  </div>
                  <small>{{ count }} ({{ percent|number_format(1, '.', '') }}%)</small>
                </div>
                <div class="ncb-type-track">
                  <span class="ncb-type-fill" style="--fill: {{ percent }}%; background: {{ cashback_stat_colors[label]|default(cashback_stat_colors['Autre']) }};"></span>
                </div>
              </div>
            {% endif %}
          {% else %}
            <div class="ncb-type-empty">Aucune donnee cashback disponible.</div>
          {% endfor %}
        </div>
      </div>
    {% else %}
      <div class="ncb-analytics-layout">
        <div class="ncb-donut-shell">
          {% set partner_donut_offset = 25 %}
          <svg viewBox="0 0 42 42" class="ncb-donut" aria-label="Repartition des categories partenaires">
            <circle class="ncb-donut-track" cx="21" cy="21" r="15.915"></circle>
            {% for label, count in partner_category_counts %}
              {% if count > 0 %}
                {% set percent = partner_items|length > 0 ? (count * 100 / partner_items|length) : 0 %}
                {% set color = partner_stat_palette[loop.index0 % (partner_stat_palette|length)] %}
                <circle
                  class="ncb-donut-segment"
                  cx="21"
                  cy="21"
                  r="15.915"
                  stroke="{{ color }}"
                  stroke-dasharray="{{ percent }} {{ 100 - percent }}"
                  stroke-dashoffset="{{ partner_donut_offset }}"
                ></circle>
                {% set partner_donut_offset = partner_donut_offset - percent %}
              {% endif %}
            {% endfor %}
          </svg>
          <div class="ncb-donut-total">
            <strong>{{ partner_items|length }}</strong>
            <span>Partenaires</span>
          </div>
        </div>
        <div class="ncb-type-list">
          {% for label, count in partner_category_counts %}
            {% if count > 0 %}
              {% set percent = partner_items|length > 0 ? (count * 100 / partner_items|length) : 0 %}
              {% set color = partner_stat_palette[loop.index0 % (partner_stat_palette|length)] %}
              <div class="ncb-type-row">
                <div class="ncb-type-head">
                  <div class="ncb-type-title">
                    <span class="ncb-type-dot" style="background: {{ color }};"></span>
                    <span>{{ label }}</span>
                  </div>
                  <small>{{ count }} ({{ percent|number_format(1, '.', '') }}%)</small>
                </div>
                <div class="ncb-type-track">
                  <span class="ncb-type-fill" style="--fill: {{ percent }}%; background: {{ color }};"></span>
                </div>
              </div>
            {% endif %}
          {% else %}
            <div class="ncb-type-empty">Aucune categorie partenaire disponible.</div>
          {% endfor %}
        </div>
      </div>
    {% endif %}
    <div class="ncb-stats-grid">
      {% if active_panel == 'cashback' %}
        <article class="ncb-stat-card">
          <span class="ncb-stat-icon"><i class="fa-solid fa-coins"></i></span>
          <div class="ncb-stat-copy">
            <strong>{{ cashback_items|length }}</strong>
            <small>Dossiers cashback</small>
          </div>
        </article>
        <article class="ncb-stat-card">
          <span class="ncb-stat-icon"><i class="fa-solid fa-hourglass-half"></i></span>
          <div class="ncb-stat-copy">
            <strong>{{ pending_cashback }}</strong>
            <small>En attente / à traiter</small>
          </div>
        </article>
        <article class="ncb-stat-card">
          <span class="ncb-stat-icon"><i class="fa-solid fa-circle-check"></i></span>
          <div class="ncb-stat-copy">
            <strong>{{ validated_cashback }}</strong>
            <small>Validés ou crédités</small>
          </div>
        </article>
        <article class="ncb-stat-card">
          <span class="ncb-stat-icon"><i class="fa-solid fa-wallet"></i></span>
          <div class="ncb-stat-copy">
            <strong>{{ total_cashback_amount|number_format(2, '.', ' ') }}</strong>
            <small>Montant cashback total (DT)</small>
          </div>
        </article>
      {% else %}
        <article class="ncb-stat-card">
          <span class="ncb-stat-icon"><i class="fa-solid fa-handshake"></i></span>
          <div class="ncb-stat-copy">
            <strong>{{ partner_items|length }}</strong>
            <small>Partenaires enregistrés</small>
          </div>
        </article>
        <article class="ncb-stat-card">
          <span class="ncb-stat-icon"><i class="fa-solid fa-bolt"></i></span>
          <div class="ncb-stat-copy">
            <strong>{{ active_partners }}</strong>
            <small>Partenaires actifs</small>
          </div>
        </article>
        <article class="ncb-stat-card">
          <span class="ncb-stat-icon"><i class="fa-solid fa-star"></i></span>
          <div class="ncb-stat-copy">
            <strong>{{ partner_items|length > 0 ? (total_rating / partner_items|length)|number_format(1, '.', ' ') : '0.0' }}</strong>
            <small>Note moyenne / 5</small>
          </div>
        </article>
        <article class="ncb-stat-card">
          <span class="ncb-stat-icon"><i class="fa-solid fa-percent"></i></span>
          <div class="ncb-stat-copy">
            <strong>{{ partner_items|length > 0 ? (avg_rate / partner_items|length)|number_format(2, '.', ' ') : '0.00' }}%</strong>
            <small>Taux cashback moyen</small>
          </div>
        </article>
      {% endif %}
    </div>
  </div>

  {# ════════════════════════════
     CASHBACK PANEL
  ════════════════════════════ #}
  {% if active_panel == 'cashback' %}

    <div class="ncb-kpis ncb-kpis--cashback" id="ncb-cashback-stats">
      <div class="ncb-kpi">
        <span class="ncb-kpi-icon"><i class="fa-solid fa-coins"></i></span>
        <div class="ncb-kpi-body">
          <strong>{{ summary.cashback_total|default(0)|number_format(2, '.', ' ') }}</strong>
          <small>Cashback cumulé (DT)</small>
        </div>
      </div>
      <div class="ncb-kpi">
        <span class="ncb-kpi-icon"><i class="fa-solid fa-hourglass-half"></i></span>
        <div class="ncb-kpi-body">
          <strong>{{ pending_cashback }}</strong>
          <small>Dossiers en attente</small>
        </div>
      </div>
      <div class="ncb-kpi">
        <span class="ncb-kpi-icon"><i class="fa-solid fa-store"></i></span>
        <div class="ncb-kpi-body">
          <strong>{{ partners|length }}</strong>
          <small>Partenaires référencés</small>
        </div>
      </div>
    </div>

    <div class="ncb-grid">

      {# Form #}
      <article class="ncb-panel" id="ncb-form">
        <div class="ncb-panel-head">
          <div class="ncb-panel-head-left">
            <h3><i class="fa-solid fa-coins" style="color:var(--ncb-gold);margin-right:.4rem"></i>Dossier Cashback</h3>
            <p>Créer ou modifier une demande cashback</p>
          </div>
        </div>

        <form method="post" class="ncb-form">
          <input type="hidden" name="tab"    value="cashback">
          <input type="hidden" name="panel"  value="cashback">
          <input type="hidden" name="action" value="cashback_save">

          <div class="ncb-form-hint">
            <i class="fa-solid fa-pen-to-square"></i>
            Remplir l'ID uniquement pour modifier
          </div>

          <div class="ncb-field">
            <label>ID pour modifier</label>
            <input type="number" name="id_cashback" placeholder="Laisser vide pour créer">
          </div>

          <div class="ncb-form-sep"></div>

          <div class="ncb-field">
            <label>Utilisateur</label>
            <select name="id_user">
              {% for u in users %}
                <option value="{{ u.idUser }}">#{{ u.idUser }} · {{ u.prenom }} {{ u.nom }}</option>
              {% endfor %}
            </select>
          </div>

          <div class="ncb-field">
            <label>Partenaire lié</label>
            <select name="id_partenaire">
              <option value="">— Saisie libre —</option>
              {% for partner in partners %}
                <option value="{{ partner.idPartenaire }}">{{ partner.nom }}</option>
              {% endfor %}
            </select>
          </div>

          <div class="ncb-field">
            <label>Nom partenaire <em>*</em></label>
            <input type="text" name="partenaire_nom" required placeholder="Ou saisir manuellement…">
          </div>

          <div class="ncb-field">
            <label>Montant achat (DT) <em>*</em></label>
            <input type="number" step="0.01" name="montant_achat" required placeholder="0.00">
          </div>

          <div class="ncb-field">
            <label>Date d'achat</label>
            <input type="date" name="date_achat" value="{{ 'now'|date('Y-m-d') }}">
          </div>

          <div class="ncb-field">
            <label>Statut</label>
            <select name="statut">
              <option value="En attente" selected>En attente</option>
              <option value="Valide">Validé</option>
              <option value="Rejete">Rejeté</option>
            </select>
          </div>

          <div class="ncb-form-actions">
            <button class="ncb-btn ncb-btn--save" type="submit">
              <i class="fa-solid fa-floppy-disk"></i> Enregistrer
            </button>
            <button class="ncb-btn ncb-btn--ghost" type="reset">
              <i class="fa-solid fa-rotate-left"></i> Annuler
            </button>
          </div>
        </form>
      </article>

      {# Table #}
      <article class="ncb-panel">
        <div class="ncb-panel-head">
          <div class="ncb-panel-head-left">
            <h3>Liste Cashback</h3>
            <p>Attribuer bonus et suivre les statuts</p>
          </div>
          <span class="ncb-row-count">
            {{ cashback_items|length }} dossier{{ cashback_items|length != 1 ? 's' : '' }}
          </span>
        </div>

        <div class="ncb-search-bar">
          <div class="ncb-search-wrap">
            <i class="fa-solid fa-magnifying-glass"></i>
            <input class="ncb-search-input" type="text"
                   placeholder="Rechercher un dossier…"
                   id="ncb-cb-search">
          </div>
        </div>

        <div class="ncb-table-wrap">
          <table class="ncb-table" id="ncb-cb-table">
            <thead>
              <tr>
                <th>#ID</th>
                <th>Utilisateur</th>
                <th>Partenaire</th>
                <th>Achat</th>
                <th>Cashback</th>
                <th>Statut</th>
                <th>Récompense admin</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              {% for item in cashback_items %}
                {% set sk = item.statut|default('')|lower %}
                {% set sc = 'neutral' %}
                {% if 'valide' in sk or 'valid' in sk %}{% set sc = 'valide' %}
                {% elseif 'attente' in sk or 'pending' in sk %}{% set sc = 'attente' %}
                {% elseif 'rejete' in sk %}{% set sc = 'inactive' %}
                {% endif %}
                <tr>
                  <td><span class="ncb-tid">#{{ item.id_cashback }}</span></td>
                  <td>
                    <div class="ncb-name-cell">
                      <span class="ncb-user-dot">
                        {{ item.user_name|default('?')|first|upper }}
                      </span>
                      {{ item.user_name|default('#' ~ item.id_user) }}
                    </div>
                  </td>
                  <td>
                    <div class="ncb-name-cell">
                      <span class="ncb-name-dot">
                        {{ item.partenaire_nom|first|upper }}
                      </span>
                      {{ item.partenaire_nom }}
                    </div>
                  </td>
                  <td class="ncb-amount">
                    {{ item.montant_achat|number_format(2, '.', ' ') }}<em>DT</em>
                  </td>
                  <td>
                    <span class="ncb-cashback-amount">
                      +{{ item.montant_cashback|number_format(2, '.', ' ') }}<em>DT</em>
                    </span>
                  </td>
                  <td>
                    <span class="ncb-status ncb-status--{{ sc }}">
                      {{ item.statut }}
                    </span>
                  </td>
                  <td>
                    <form method="post" class="ncb-reward-form">
                      <input type="hidden" name="tab"         value="cashback">
                      <input type="hidden" name="panel"       value="cashback">
                      <input type="hidden" name="action"      value="cashback_reward">
                      <input type="hidden" name="id_cashback" value="{{ item.id_cashback }}">
                      <input type="number" step="0.01" name="bonus_amount" placeholder="Bonus">
                      <input type="text"              name="bonus_note"   placeholder="Note">
                      <button class="ncb-btn ncb-btn--reward" type="submit">
                        <i class="fa-solid fa-gift"></i> Accorder
                      </button>
                    </form>
                  </td>
                  <td>
                    <form method="post">
                      <input type="hidden" name="tab"         value="cashback">
                      <input type="hidden" name="panel"       value="cashback">
                      <input type="hidden" name="action"      value="cashback_delete">
                      <input type="hidden" name="id_cashback" value="{{ item.id_cashback }}">
                      <button class="ncb-btn ncb-btn--danger" type="submit">
                        <i class="fa-solid fa-trash-can"></i> Supprimer
                      </button>
                    </form>
                  </td>
                </tr>
              {% else %}
                <tr>
                  <td colspan="8" class="ncb-empty">
                    <i class="fa-solid fa-coins"></i>
                    Aucun cashback enregistré.
                  </td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </article>

    </div>

  {# ════════════════════════════
     PARTENAIRE PANEL
  ════════════════════════════ #}
  {% else %}

    <div class="ncb-kpis ncb-kpis--partner" id="ncb-partner-stats">
      <div class="ncb-kpi">
        <span class="ncb-kpi-icon"><i class="fa-solid fa-handshake"></i></span>
        <div class="ncb-kpi-body">
          <strong>{{ partner_items|length }}</strong>
          <small>Partenaires actifs</small>
        </div>
      </div>
      <div class="ncb-kpi">
        <span class="ncb-kpi-icon"><i class="fa-solid fa-star"></i></span>
        <div class="ncb-kpi-body">
          <strong>
            {{ partner_items|length > 0
              ? (total_rating / partner_items|length)|number_format(1, '.', ' ')
              : '0.0' }}
          </strong>
          <small>Note moyenne / 5</small>
        </div>
      </div>
      <div class="ncb-kpi">
        <span class="ncb-kpi-icon"><i class="fa-solid fa-percent"></i></span>
        <div class="ncb-kpi-body">
          <strong>
            {{ partner_items|length > 0
              ? (avg_rate / partner_items|length)|number_format(2, '.', ' ')
              : '0.00' }}%
          </strong>
          <small>Taux cashback moyen</small>
        </div>
      </div>
    </div>

    <div class="ncb-grid">

      {# Form #}
      <article class="ncb-panel" id="ncb-form">
        <div class="ncb-panel-head">
          <div class="ncb-panel-head-left">
            <h3><i class="fa-solid fa-handshake" style="color:var(--ncb-teal);margin-right:.4rem"></i>Partenaire</h3>
            <p>Ajouter ou modifier un partenaire</p>
          </div>
        </div>

        <form method="post" class="ncb-form">
          <input type="hidden" name="tab"    value="cashback">
          <input type="hidden" name="panel"  value="partenaire">
          <input type="hidden" name="action" value="partner_save">

          <div class="ncb-form-hint">
            <i class="fa-solid fa-pen-to-square"></i>
            Remplir l'ID uniquement pour modifier
          </div>

          <div class="ncb-field">
            <label>ID pour modifier</label>
            <input type="number" name="idPartenaire" placeholder="Laisser vide pour créer">
          </div>

          <div class="ncb-form-sep"></div>

          <div class="ncb-field">
            <label>Nom <em>*</em></label>
            <input type="text" name="nom" required placeholder="Nom du partenaire">
          </div>

          <div class="ncb-field">
            <label>Catégorie <em>*</em></label>
            <input type="text" name="categorie" required placeholder="Ex: Alimentation…">
          </div>

          <div class="ncb-field">
            <label>Description</label>
            <input type="text" name="description" placeholder="Optionnel">
          </div>

          <div class="ncb-field">
            <label>Taux cashback (%)</label>
            <input type="number" step="0.01" name="tauxCashback" placeholder="Ex: 5.00">
          </div>

          <div class="ncb-field">
            <label>Taux cashback max (%)</label>
            <input type="number" step="0.01" name="tauxCashbackMax" placeholder="Ex: 15.00">
          </div>

          <div class="ncb-field">
            <label>Plafond mensuel (DT)</label>
            <input type="number" step="0.01" name="plafondMensuel" placeholder="Ex: 500.00">
          </div>

          <div class="ncb-field">
            <label>Statut</label>
            <select name="status">
              <option value="Actif" selected>Actif</option>
              <option value="Inactif">Inactif</option>
            </select>
          </div>

          <div class="ncb-field">
            <label>Note (0 – 5)</label>
            <div class="ncb-rating-row">
              <input type="number" step="0.1" min="0" max="5" name="rating" value="4"
                     id="ncb-rating-input">
              <div class="ncb-stars" id="ncb-stars-preview">
                <i class="fa-solid fa-star"></i>
                <i class="fa-solid fa-star"></i>
                <i class="fa-solid fa-star"></i>
                <i class="fa-solid fa-star"></i>
                <i class="fa-regular fa-star"></i>
              </div>
            </div>
          </div>

          <div class="ncb-form-actions">
            <button class="ncb-btn ncb-btn--save" type="submit">
              <i class="fa-solid fa-floppy-disk"></i> Enregistrer
            </button>
            <button class="ncb-btn ncb-btn--ghost" type="reset">
              <i class="fa-solid fa-rotate-left"></i> Annuler
            </button>
          </div>
        </form>
      </article>

      {# Table #}
      <article class="ncb-panel">
        <div class="ncb-panel-head">
          <div class="ncb-panel-head-left">
            <h3>Liste des Partenaires</h3>
            <p>Fiche complète des partenaires cashback</p>
          </div>
          <span class="ncb-row-count">
            {{ partner_items|length }} partenaire{{ partner_items|length != 1 ? 's' : '' }}
          </span>
        </div>

        <div class="ncb-search-bar">
          <div class="ncb-search-wrap">
            <i class="fa-solid fa-magnifying-glass"></i>
            <input class="ncb-search-input" type="text"
                   placeholder="Rechercher un partenaire…"
                   id="ncb-pt-search">
          </div>
        </div>

        <div class="ncb-table-wrap">
          <table class="ncb-table" id="ncb-pt-table">
            <thead>
              <tr>
                <th>#ID</th>
                <th>Nom</th>
                <th>Catégorie</th>
                <th>Taux</th>
                <th>Taux max</th>
                <th>Plafond</th>
                <th>Note</th>
                <th>Statut</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              {% for item in partner_items %}
                {% set sk = item.status|default('')|lower %}
                {% set sc = 'neutral' %}
                {% if 'actif' in sk or 'active' in sk %}{% set sc = 'active' %}
                {% elseif 'inactif' in sk or 'inactive' in sk %}{% set sc = 'inactive' %}
                {% endif %}
                {% set stars = item.rating|default(0)|round(0, 'floor') %}
                <tr>
                  <td><span class="ncb-tid">#{{ item.idPartenaire }}</span></td>
                  <td>
                    <div class="ncb-name-cell">
                      <span class="ncb-name-dot">{{ item.nom|first|upper }}</span>
                      <strong style="font-size:.82rem">{{ item.nom }}</strong>
                    </div>
                  </td>
                  <td><span class="ncb-cat-tag">{{ item.categorie }}</span></td>
                  <td><span class="ncb-rate">{{ item.tauxCashback|default(0)|number_format(2, '.', ' ') }}%</span></td>
                  <td style="font-size:.78rem;color:var(--ncb-muted)">
                    {{ item.tauxCashbackMax|default(0)|number_format(2, '.', ' ') }}%
                  </td>
                  <td class="ncb-amount">
                    {{ item.plafondMensuel|default(0)|number_format(2, '.', ' ') }}<em>DT</em>
                  </td>
                  <td>
                    <div class="ncb-star-row">
                      {% for s in 1..5 %}
                        <i class="fa-{{ s <= stars ? 'solid' : 'regular' }} fa-star"></i>
                      {% endfor %}
                      <span>{{ item.rating|default(0)|number_format(1, '.', ' ') }}</span>
                    </div>
                  </td>
                  <td>
                    <span class="ncb-status ncb-status--{{ sc }}">
                      {{ item.status|default('—') }}
                    </span>
                  </td>
                  <td>
                    <form method="post">
                      <input type="hidden" name="tab"          value="cashback">
                      <input type="hidden" name="panel"        value="partenaire">
                      <input type="hidden" name="action"       value="partner_delete">
                      <input type="hidden" name="idPartenaire" value="{{ item.idPartenaire }}">
                      <button class="ncb-btn ncb-btn--danger" type="submit">
                        <i class="fa-solid fa-trash-can"></i> Supprimer
                      </button>
                    </form>
                  </td>
                </tr>
              {% else %}
                <tr>
                  <td colspan="9" class="ncb-empty">
                    <i class="fa-solid fa-handshake"></i>
                    Aucun partenaire enregistré.
                  </td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </article>

    </div>
  {% endif %}

</section>

{# ── Client interactions ── #}
<script>
(() => {
  /* live search */
  const wire = (inputId, tableId) => {
    const input = document.getElementById(inputId);
    const table = document.getElementById(tableId);
    if (!input || !table) return;
    input.addEventListener('input', () => {
      const q = input.value.toLowerCase().trim();
      table.querySelectorAll('tbody tr').forEach(row => {
        row.style.display =
          !q || row.textContent.toLowerCase().includes(q) ? '' : 'none';
      });
    });
  };
  wire('ncb-pt-search', 'ncb-pt-table');
  wire('ncb-cb-search', 'ncb-cb-table');

  const statsLink = document.querySelector('.ncb-stats-link');
  if (statsLink instanceof HTMLAnchorElement) {
    statsLink.addEventListener('click', event => {
      const hash = statsLink.getAttribute('href') || '';
      if (!hash.startsWith('#')) return;
      const target = document.querySelector(hash);
      if (!(target instanceof HTMLElement)) return;
      event.preventDefault();
      const isCollapsed = target.classList.contains('is-collapsed');
      target.classList.toggle('is-collapsed');
      statsLink.setAttribute('aria-expanded', isCollapsed ? 'true' : 'false');
      target.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  }

  /* live star preview in form */
  const ratingInput = document.getElementById('ncb-rating-input');
  const starsWrap   = document.getElementById('ncb-stars-preview');
  if (ratingInput && starsWrap) {
    const update = () => {
      const val   = parseFloat(ratingInput.value) || 0;
      const floor = Math.floor(val);
      starsWrap.querySelectorAll('i').forEach((star, idx) => {
        star.className = `fa-${ idx < floor ? 'solid' : 'regular' } fa-star`;
      });
    };
    ratingInput.addEventListener('input', update);
    update();
  }
})();
</script>
