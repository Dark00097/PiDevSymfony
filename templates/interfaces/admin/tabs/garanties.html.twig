<section class="panel-card nx-crud-screen">
    <header class="nx-crud-head">
        <div>
            <h2>Gestion Garanties</h2>
            <p>Securisation des dossiers de credit par garanties</p>
        </div>
    </header>

    <div class="nx-crud-kpis">
        <article class="nx-crud-kpi">
            <span class="nx-crud-kpi-icon"><i class="fa-solid fa-shield-halved"></i></span>
            <div><strong>{{ items|length }}</strong><small>Garanties enregistrees</small></div>
        </article>
        <article class="nx-crud-kpi">
            <span class="nx-crud-kpi-icon"><i class="fa-solid fa-file-invoice-dollar"></i></span>
            <div><strong>{{ support.credits|default([])|length }}</strong><small>Credits relies</small></div>
        </article>
        <article class="nx-crud-kpi">
            <span class="nx-crud-kpi-icon"><i class="fa-solid fa-hourglass-half"></i></span>
            <div><strong>{{ summary.credits_pending|default(0) }}</strong><small>Credits en attente</small></div>
        </article>
    </div>

    <div class="nx-crud-grid">
        <article class="nx-crud-form-card">
            <div class="nx-crud-card-head">
                <h3>Garantie credit</h3>
                <p>Ajouter ou modifier une garantie</p>
            </div>

            <form method="post" class="editor-form nx-crud-form">
                <input type="hidden" name="tab" value="garanties">
                <input type="hidden" name="action" value="garantie_save">
                <label><span>ID pour modifier</span><input type="number" name="idGarantie"></label>
                <label><span>Credit</span>
                    <select name="idCredit">
                        {% for credit in support.credits|default([]) %}
                            <option value="{{ credit.idCredit }}">#{{ credit.idCredit }} - {{ credit.typeCredit }}</option>
                        {% endfor %}
                    </select>
                </label>
                <label><span>Type</span><input type="text" name="typeGarantie" required></label>
                <label><span>Description</span><input type="text" name="description"></label>
                <label><span>Adresse</span><input type="text" name="adresseBien"></label>
                <label><span>Valeur estimee</span><input type="number" step="0.01" name="valeurEstimee"></label>
                <label><span>Nom garant</span><input type="text" name="nomGarant"></label>
                <div class="nx-crud-form-actions">
                    <button class="btn btn-primary nx-btn-save" type="submit">Enregistrer</button>
                    <button class="btn btn-secondary" type="reset">Annuler</button>
                </div>
            </form>
        </article>

        <article class="nx-crud-table-card">
            <div class="nx-crud-card-head">
                <h3>Liste des garanties</h3>
                <p>Suivi complet des garanties associees aux credits</p>
            </div>

            <div class="table-wrap">
                <table class="data-table nx-crud-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Credit</th>
                            <th>Type</th>
                            <th>Description</th>
                            <th>Valeur</th>
                            <th>Statut</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for item in items %}
                        <tr>
                            <td>{{ item.idGarantie }}</td>
                            <td>#{{ item.idCredit }}</td>
                            <td>{{ item.typeGarantie }}</td>
                            <td>{{ item.description|default('-') }}</td>
                            <td>{{ item.valeurEstimee|default(0)|number_format(2, '.', ' ') }} DT</td>
                            <td>{{ item.statut }}</td>
                            <td class="nx-cell-actions">
                                <form method="post">
                                    <input type="hidden" name="tab" value="garanties">
                                    <input type="hidden" name="action" value="garantie_delete">
                                    <input type="hidden" name="idGarantie" value="{{ item.idGarantie }}">
                                    <button class="btn btn-danger" type="submit">Supprimer</button>
                                </form>
                            </td>
                        </tr>
                    {% else %}
                        <tr><td colspan="7">Aucune garantie enregistree.</td></tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </article>
    </div>
</section>
