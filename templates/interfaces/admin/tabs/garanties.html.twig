<style>
.nx-crud-pager {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 10px;
    margin-top: 16px;
    flex-wrap: wrap;
}

.nx-crud-pager[hidden] {
    display: none !important;
}

.nx-crud-pager-btn {
    width: 40px;
    height: 40px;
    border-radius: 999px;
    border: 1px solid #d6e2ef;
    background: #fff;
    color: #6b85a0;
    font-size: 14px;
    font-weight: 800;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
}

.nx-crud-pager-btn.is-active {
    background: linear-gradient(135deg, #11b7aa, #2b7de9);
    border-color: transparent;
    color: #fff;
}

.nx-crud-pager-btn:disabled {
    opacity: .45;
    cursor: default;
}

tr.nx-page-hidden {
    display: none;
}
</style>

<section class="panel-card nx-crud-screen">
    <header class="nx-crud-head">
        <div>
            <h2>Gestion Garanties</h2>
            <p>Securisation des dossiers de credit par garanties</p>
        </div>
    </header>

    <div class="nx-crud-kpis">
        <article class="nx-crud-kpi">
            <span class="nx-crud-kpi-icon"><i class="fa-solid fa-shield-halved"></i></span>
            <div><strong>{{ items|length }}</strong><small>Garanties enregistrees</small></div>
        </article>
        <article class="nx-crud-kpi">
            <span class="nx-crud-kpi-icon"><i class="fa-solid fa-file-invoice-dollar"></i></span>
            <div><strong>{{ support.credits|default([])|length }}</strong><small>Credits relies</small></div>
        </article>
        <article class="nx-crud-kpi">
            <span class="nx-crud-kpi-icon"><i class="fa-solid fa-hourglass-half"></i></span>
            <div><strong>{{ summary.credits_pending|default(0) }}</strong><small>Credits en attente</small></div>
        </article>
    </div>

    <div class="nx-crud-grid">
        <article class="nx-crud-form-card">
            <div class="nx-crud-card-head">
                <h3>Garantie credit</h3>
                <p>Ajouter ou modifier une garantie</p>
            </div>

            <form method="post" class="editor-form nx-crud-form">
                <input type="hidden" name="tab" value="garanties">
                <input type="hidden" name="action" value="garantie_save">
                <label><span>ID pour modifier</span><input type="number" name="idGarantie"></label>
                <label><span>Credit</span>
                    <select name="idCredit">
                        {% for credit in support.credits|default([]) %}
                            <option value="{{ credit.idCredit }}">#{{ credit.idCredit }} - {{ credit.typeCredit }}</option>
                        {% endfor %}
                    </select>
                </label>
                <label><span>Type</span><input type="text" name="typeGarantie" required></label>
                <label><span>Description</span><input type="text" name="description"></label>
                <label><span>Adresse</span><input type="text" name="adresseBien"></label>
                <label><span>Valeur estimee</span><input type="number" step="0.01" name="valeurEstimee"></label>
                <label><span>Nom garant</span><input type="text" name="nomGarant"></label>
                <div class="nx-crud-form-actions">
                    <button class="btn btn-primary nx-btn-save" type="submit">Enregistrer</button>
                    <button class="btn btn-secondary" type="reset">Annuler</button>
                </div>
            </form>
        </article>

        <article class="nx-crud-table-card">
            <div class="nx-crud-card-head">
                <h3>Liste des garanties</h3>
                <p>Suivi complet des garanties associees aux credits</p>
            </div>

            <div class="table-wrap">
                <table class="data-table nx-crud-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Credit</th>
                            <th>Type</th>
                            <th>Description</th>
                            <th>Valeur</th>
                            <th>Statut</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for item in items %}
                        <tr>
                            <td>{{ item.idGarantie }}</td>
                            <td>#{{ item.idCredit }}</td>
                            <td>{{ item.typeGarantie }}</td>
                            <td>{{ item.description|default('-') }}</td>
                            <td>{{ item.valeurEstimee|default(0)|number_format(2, '.', ' ') }} DT</td>
                            <td>{{ item.statut }}</td>
                            <td class="nx-cell-actions">
                                <form method="post">
                                    <input type="hidden" name="tab" value="garanties">
                                    <input type="hidden" name="action" value="garantie_delete">
                                    <input type="hidden" name="idGarantie" value="{{ item.idGarantie }}">
                                    <button class="btn btn-danger" type="submit">Supprimer</button>
                                </form>
                            </td>
                        </tr>
                    {% else %}
                        <tr><td colspan="7">Aucune garantie enregistree.</td></tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
            <div class="nx-crud-pager" id="admin-garanties-pager" hidden></div>
        </article>
    </div>
</section>
<script>
(() => {
    const pager = document.getElementById('admin-garanties-pager');
    const rows = Array.from(document.querySelectorAll('.nx-crud-table tbody tr'))
        .filter((row) => row.querySelector('td') && row.querySelectorAll('td').length > 1);
    const pageSize = 8;
    let currentPage = 1;

    if (!(pager instanceof HTMLElement) || rows.length === 0) {
        return;
    }

    const renderPager = () => {
        const totalPages = Math.max(1, Math.ceil(rows.length / pageSize));
        currentPage = Math.min(Math.max(1, currentPage), totalPages);
        pager.innerHTML = '';
        pager.hidden = rows.length === 0;
        if (pager.hidden) return;

        const appendButton = (label, page, { icon = '', disabled = false, active = false, ariaLabel = '' } = {}) => {
            const btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'nx-crud-pager-btn';
            btn.disabled = disabled;
            btn.setAttribute('aria-label', ariaLabel || String(label));
            btn.innerHTML = icon ? `<i class="${icon}"></i>` : String(label);
            if (active) btn.classList.add('is-active');
            btn.addEventListener('click', () => {
                if (disabled || page === currentPage) return;
                currentPage = page;
                applyPagination();
            });
            pager.appendChild(btn);
        };

        appendButton('Prev', Math.max(1, currentPage - 1), { icon: 'fa-solid fa-chevron-left', disabled: currentPage === 1, ariaLabel: 'Page precedente' });
        for (let page = 1; page <= totalPages; page += 1) {
            appendButton(String(page), page, { active: page === currentPage });
        }
        appendButton('Next', Math.min(totalPages, currentPage + 1), { icon: 'fa-solid fa-chevron-right', disabled: currentPage === totalPages, ariaLabel: 'Page suivante' });
    };

    const applyPagination = () => {
        const start = (currentPage - 1) * pageSize;
        const end = start + pageSize;
        rows.forEach((row, index) => row.classList.toggle('nx-page-hidden', index < start || index >= end));
        renderPager();
    };

    applyPagination();
})();
</script>
