<section class="panel-card nx-crud-screen">
    <header class="nx-crud-head">
        <div>
            <h2>Gestion Coffres Virtuels</h2>
            <p>Pilotage des objectifs d'epargne et coffres verrouilles</p>
        </div>
    </header>

    <div class="nx-crud-kpis">
        <article class="nx-crud-kpi">
            <span class="nx-crud-kpi-icon"><i class="fa-solid fa-vault"></i></span>
            <div><strong>{{ items|length }}</strong><small>Coffres crees</small></div>
        </article>
        <article class="nx-crud-kpi">
            <span class="nx-crud-kpi-icon"><i class="fa-solid fa-user-group"></i></span>
            <div><strong>{{ support.users|default([])|length }}</strong><small>Utilisateurs relies</small></div>
        </article>
        <article class="nx-crud-kpi">
            <span class="nx-crud-kpi-icon"><i class="fa-solid fa-building-columns"></i></span>
            <div><strong>{{ support.accounts|default([])|length }}</strong><small>Comptes relies</small></div>
        </article>
    </div>

    <div class="nx-crud-grid">
        <article class="nx-crud-form-card">
            <div class="nx-crud-card-head">
                <h3>Coffre virtuel</h3>
                <p>Creer ou modifier un coffre</p>
            </div>

            <form method="post" class="editor-form nx-crud-form">
                <input type="hidden" name="tab" value="vaults">
                <input type="hidden" name="action" value="vault_save">
                <label><span>ID pour modifier</span><input type="number" name="idCoffre"></label>
                <label><span>Utilisateur</span>
                    <select name="idUser">
                        <option value="">Sans utilisateur</option>
                        {% for u in support.users|default([]) %}
                            <option value="{{ u.idUser }}">{{ u.idUser }} - {{ u.prenom }} {{ u.nom }}</option>
                        {% endfor %}
                    </select>
                </label>
                <label><span>Compte</span>
                    <select name="idCompte">
                        <option value="">Sans compte</option>
                        {% for account in support.accounts|default([]) %}
                            <option value="{{ account.idCompte }}">{{ account.idCompte }} - {{ account.numeroCompte }}</option>
                        {% endfor %}
                    </select>
                </label>
                <label><span>Nom</span><input type="text" name="nom" required></label>
                <label><span>Objectif (DT)</span><input type="number" step="0.01" name="objectifMontant" required></label>
                <label><span>Montant actuel (DT)</span><input type="number" step="0.01" name="montantActuel"></label>
                <label><span>Status</span><input type="text" name="status" value="Actif"></label>

                <div class="nx-crud-form-actions">
                    <button class="btn btn-primary nx-btn-save" type="submit">Enregistrer</button>
                    <button class="btn btn-secondary" type="reset">Annuler</button>
                </div>
            </form>
        </article>

        <article class="nx-crud-table-card">
            <div class="nx-crud-card-head">
                <h3>Liste des coffres</h3>
                <p>Suivi de l'objectif et du montant actuel</p>
            </div>

            <div class="table-wrap">
                <table class="data-table nx-crud-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Nom</th>
                            <th>Objectif</th>
                            <th>Montant actuel</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for item in items %}
                        <tr>
                            <td>{{ item.idCoffre }}</td>
                            <td>{{ item.nom }}</td>
                            <td>{{ item.objectifMontant|number_format(2, '.', ' ') }} DT</td>
                            <td>{{ item.montantActuel|number_format(2, '.', ' ') }} DT</td>
                            <td>{{ item.status|default('-') }}</td>
                            <td class="nx-cell-actions">
                                <form method="post">
                                    <input type="hidden" name="tab" value="vaults">
                                    <input type="hidden" name="action" value="vault_delete">
                                    <input type="hidden" name="idCoffre" value="{{ item.idCoffre }}">
                                    <button class="btn btn-danger" type="submit">Supprimer</button>
                                </form>
                            </td>
                        </tr>
                    {% else %}
                        <tr><td colspan="6">Aucun coffre enregistre.</td></tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </article>
    </div>
</section>
