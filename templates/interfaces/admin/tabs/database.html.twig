{% set entity_datasets = support.entity_datasets|default(items|default([])) %}
{% set entity_preview_limit = support.entity_preview_limit|default(12) %}
{% set entity_total_tables = support.entity_total_tables|default(entity_datasets|length) %}
{% set entity_total_rows = support.entity_total_rows|default(0) %}

<style>
.dbx-root {
    display: grid;
    gap: 22px;
}

.dbx-hero {
    position: relative;
    overflow: hidden;
    border-radius: 26px;
    padding: 28px;
    background:
        radial-gradient(circle at top right, rgba(59,130,246,.22), transparent 34%),
        linear-gradient(135deg, #0f172a 0%, #1d4ed8 52%, #0ea5e9 100%);
    color: #fff;
    box-shadow: 0 24px 60px rgba(37, 99, 235, .18);
}

.dbx-hero::after {
    content: '';
    position: absolute;
    inset: auto -40px -60px auto;
    width: 180px;
    height: 180px;
    border-radius: 50%;
    background: rgba(255,255,255,.08);
}

.dbx-hero-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 18px;
    flex-wrap: wrap;
}

.dbx-hero-copy h1 {
    margin: 0;
    font-size: 33px;
    font-weight: 900;
    letter-spacing: -.03em;
}

.dbx-hero-copy p {
    margin: 10px 0 0;
    max-width: 760px;
    font-size: 15px;
    color: rgba(255,255,255,.84);
}

.dbx-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 14px;
    border-radius: 999px;
    background: rgba(255,255,255,.12);
    border: 1px solid rgba(255,255,255,.18);
    font-size: 13px;
    font-weight: 700;
}

.dbx-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 14px;
    margin-top: 22px;
}

.dbx-stat {
    background: rgba(255,255,255,.1);
    border: 1px solid rgba(255,255,255,.16);
    border-radius: 20px;
    padding: 18px 20px;
}

.dbx-stat strong {
    display: block;
    font-size: 28px;
    font-weight: 900;
}

.dbx-stat span {
    display: block;
    margin-top: 6px;
    color: rgba(255,255,255,.76);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: .08em;
}

.dbx-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    padding: 18px 22px;
    border-radius: 22px;
    background: rgba(255,255,255,.86);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(148,163,184,.18);
    box-shadow: 0 14px 34px rgba(15, 23, 42, .06);
}

.dbx-search {
    position: relative;
    flex: 1 1 340px;
}

.dbx-search i {
    position: absolute;
    top: 50%;
    left: 16px;
    transform: translateY(-50%);
    color: #94a3b8;
}

.dbx-search input {
    width: 100%;
    height: 50px;
    border-radius: 16px;
    border: 1px solid #dbe7f3;
    background: #f8fbff;
    padding: 0 18px 0 44px;
    font-size: 14px;
    color: #0f172a;
}

.dbx-toolbar-note {
    color: #64748b;
    font-size: 13px;
    font-weight: 600;
}

.dbx-grid {
    display: grid;
    gap: 18px;
}

.dbx-card {
    border-radius: 24px;
    background: #fff;
    border: 1px solid rgba(148,163,184,.18);
    box-shadow: 0 18px 40px rgba(15,23,42,.06);
    overflow: hidden;
}

.dbx-card-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 18px;
    padding: 22px 24px 16px;
    border-bottom: 1px solid #edf2f7;
}

.dbx-card-title {
    display: flex;
    align-items: center;
    gap: 12px;
}

.dbx-card-icon {
    width: 44px;
    height: 44px;
    border-radius: 14px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #dbeafe, #e0f2fe);
    color: #2563eb;
}

.dbx-card-title h3 {
    margin: 0;
    font-size: 20px;
    font-weight: 800;
    color: #0f172a;
}

.dbx-card-title p {
    margin: 4px 0 0;
    font-size: 13px;
    color: #64748b;
}

.dbx-card-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
}

.dbx-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 9px 12px;
    border-radius: 999px;
    background: #eff6ff;
    color: #1d4ed8;
    font-size: 12px;
    font-weight: 800;
}

.dbx-table-wrap {
    overflow: auto;
    padding: 0 18px 18px;
}

.dbx-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    min-width: 720px;
}

.dbx-table thead th {
    position: sticky;
    top: 0;
    z-index: 1;
    background: #f8fbff;
    color: #475569;
    text-align: left;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: .08em;
    padding: 13px 14px;
    border-bottom: 1px solid #dbe7f3;
}

.dbx-table tbody td {
    padding: 13px 14px;
    border-bottom: 1px solid #edf2f7;
    font-size: 13px;
    color: #0f172a;
    vertical-align: top;
}

.dbx-table tbody tr:nth-child(even) td {
    background: #fcfdff;
}

.dbx-null {
    color: #94a3b8;
    font-style: italic;
}

.dbx-empty {
    padding: 28px 24px 30px;
    text-align: center;
    color: #64748b;
}

.dbx-empty i {
    display: block;
    margin-bottom: 10px;
    font-size: 24px;
    color: #94a3b8;
}

@media (max-width: 768px) {
    .dbx-hero { padding: 22px; }
    .dbx-hero-copy h1 { font-size: 26px; }
    .dbx-card-head { padding: 18px 18px 14px; }
    .dbx-table-wrap { padding: 0 12px 14px; }
}
</style>

<section class="dbx-root">
    <div class="dbx-hero">
        <div class="dbx-hero-top">
            <div class="dbx-hero-copy">
                <h1>Base de donnees</h1>
                <p>Affichage centralise des donnees de chaque entite Doctrine du projet, avec un apercu direct des lignes en base.</p>
            </div>
            <div class="dbx-badge">
                <i class="fa-solid fa-database"></i>
                <span>Lecture seule</span>
            </div>
        </div>

        <div class="dbx-stats">
            <div class="dbx-stat">
                <strong>{{ entity_total_tables }}</strong>
                <span>Entites detectees</span>
            </div>
            <div class="dbx-stat">
                <strong>{{ entity_total_rows }}</strong>
                <span>Lignes totales</span>
            </div>
            <div class="dbx-stat">
                <strong>{{ entity_preview_limit }}</strong>
                <span>Lignes affichees max / entite</span>
            </div>
        </div>
    </div>

    <div class="dbx-toolbar">
        <label class="dbx-search">
            <i class="fa-solid fa-magnifying-glass"></i>
            <input type="search" id="dbx-entity-search" placeholder="Rechercher une entite ou une table...">
        </label>
        <div class="dbx-toolbar-note">Chaque bloc affiche les {{ entity_preview_limit }} dernieres lignes au maximum.</div>
    </div>

    <div class="dbx-grid" id="dbx-entity-grid">
        {% for entity in entity_datasets %}
            <article class="dbx-card" data-entity-name="{{ entity.entity_name|lower }}" data-table-name="{{ entity.table_name|lower }}">
                <div class="dbx-card-head">
                    <div class="dbx-card-title">
                        <span class="dbx-card-icon"><i class="fa-solid fa-table-list"></i></span>
                        <div>
                            <h3>{{ entity.entity_name }}</h3>
                            <p>Table SQL: <strong>{{ entity.table_name }}</strong></p>
                        </div>
                    </div>

                    <div class="dbx-card-meta">
                        <span class="dbx-pill"><i class="fa-solid fa-layer-group"></i>{{ entity.total_count }} ligne{{ entity.total_count > 1 ? 's' : '' }}</span>
                        {% if entity.identifier_columns is not empty %}
                            <span class="dbx-pill"><i class="fa-solid fa-key"></i>{{ entity.identifier_columns|join(', ') }}</span>
                        {% endif %}
                    </div>
                </div>

                {% if entity.rows is not empty %}
                    <div class="dbx-table-wrap">
                        <table class="dbx-table">
                            <thead>
                                <tr>
                                    {% for column in entity.columns %}
                                        <th>{{ column }}</th>
                                    {% endfor %}
                                </tr>
                            </thead>
                            <tbody>
                                {% for row in entity.rows %}
                                    <tr>
                                        {% for column in entity.columns %}
                                            {% set value = attribute(row, column)|default(null) %}
                                            <td>
                                                {% if value is same as(null) or value is same as('') %}
                                                    <span class="dbx-null">NULL</span>
                                                {% elseif value is iterable and value is not same as(false) and value is not same as(true) %}
                                                    {{ value|json_encode(constant('JSON_UNESCAPED_UNICODE')) }}
                                                {% else %}
                                                    {{ value }}
                                                {% endif %}
                                            </td>
                                        {% endfor %}
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% else %}
                    <div class="dbx-empty">
                        <i class="fa-solid fa-inbox"></i>
                        <span>Aucune ligne trouvee pour cette entite.</span>
                    </div>
                {% endif %}
            </article>
        {% else %}
            <div class="dbx-empty">
                <i class="fa-solid fa-database"></i>
                <span>Aucune entite Doctrine disponible.</span>
            </div>
        {% endfor %}
    </div>
</section>

<script>
(() => {
  const searchInput = document.getElementById('dbx-entity-search');
  const cards = Array.from(document.querySelectorAll('#dbx-entity-grid .dbx-card'));
  if (!searchInput || cards.length === 0) return;

  const applyFilter = () => {
    const query = searchInput.value.trim().toLowerCase();
    cards.forEach((card) => {
      const haystack = `${card.dataset.entityName || ''} ${card.dataset.tableName || ''}`;
      card.hidden = query !== '' && !haystack.includes(query);
    });
  };

  searchInput.addEventListener('input', applyFilter);
})();
</script>
