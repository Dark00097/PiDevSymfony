<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>QR Code — Transaction #{{ transaction.idTransaction }}</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        *{box-sizing:border-box;margin:0;padding:0}
        body{min-height:100vh;background:linear-gradient(135deg,#0f172a 0%,#1e293b 50%,#0f2744 100%);display:flex;align-items:center;justify-content:center;font-family:'Segoe UI',system-ui,sans-serif;padding:1.5rem}

        .qr-card{background:#fff;border-radius:24px;box-shadow:0 30px 80px rgba(0,0,0,.4);width:min(420px,100%);overflow:hidden;animation:popIn .4s cubic-bezier(.34,1.56,.64,1)}
        @keyframes popIn{from{opacity:0;transform:scale(.88) translateY(20px)}to{opacity:1;transform:scale(1) translateY(0)}}

        /* Header */
        .qr-header{background:linear-gradient(135deg,#1e293b 0%,#1e3a5f 60%,#0f4c81 100%);padding:1.4rem 1.6rem;position:relative;overflow:hidden}
        .qr-header::after{content:'';position:absolute;right:-40px;top:-40px;width:160px;height:160px;border-radius:50%;background:radial-gradient(circle,rgba(255,255,255,.1) 0%,transparent 70%)}
        .qr-header__top{display:flex;align-items:center;gap:.75rem;position:relative;z-index:1}
        .qr-header__icon{width:44px;height:44px;border-radius:12px;background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.2);display:grid;place-items:center;font-size:1.1rem;color:#fff;flex-shrink:0}
        .qr-header__title{color:#fff;font-size:1rem;font-weight:700;margin-bottom:.15rem}
        .qr-header__sub{color:rgba(255,255,255,.55);font-size:.72rem}
        .qr-header__badge{margin-top:.9rem;position:relative;z-index:1;display:inline-flex;align-items:center;gap:.4rem;padding:.3rem .8rem;border-radius:999px;font-size:.72rem;font-weight:700;border:1px solid rgba(255,255,255,.2);color:#fff;background:rgba(255,255,255,.1)}

        /* QR zone */
        .qr-body{padding:1.6rem;display:flex;flex-direction:column;align-items:center;gap:1.2rem}
        .qr-frame{background:#f8fafc;border:2px solid #e2e8f0;border-radius:18px;padding:1rem;display:flex;align-items:center;justify-content:center;position:relative}
        .qr-frame svg{width:220px;height:220px;display:block}
        .qr-frame__corner{position:absolute;width:18px;height:18px;border-color:#6366f1;border-style:solid}
        .qr-frame__corner--tl{top:6px;left:6px;border-width:3px 0 0 3px;border-radius:4px 0 0 0}
        .qr-frame__corner--tr{top:6px;right:6px;border-width:3px 3px 0 0;border-radius:0 4px 0 0}
        .qr-frame__corner--bl{bottom:6px;left:6px;border-width:0 0 3px 3px;border-radius:0 0 0 4px}
        .qr-frame__corner--br{bottom:6px;right:6px;border-width:0 3px 3px 0;border-radius:0 0 4px 0}

        .qr-hint{font-size:.72rem;color:#94a3b8;text-align:center;display:flex;align-items:center;gap:.4rem}

        /* Infos */
        .qr-info{width:100%;display:grid;grid-template-columns:1fr 1fr;gap:.6rem}
        .qr-info__item{background:#f8fafc;border:1px solid #e2e8f0;border-radius:10px;padding:.65rem .8rem}
        .qr-info__item--wide{grid-column:1/-1}
        .qr-info__label{font-size:.62rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#94a3b8;margin-bottom:.2rem}
        .qr-info__value{font-size:.82rem;font-weight:700;color:#1e293b}
        .qr-info__value--amount{font-size:1rem;color:#0f766e}

        /* Badges statut/type */
        .badge{display:inline-flex;align-items:center;gap:.3rem;padding:.2rem .6rem;border-radius:999px;font-size:.68rem;font-weight:700;border:1px solid transparent}
        .badge--credit{background:rgba(22,163,74,.1);color:#15803d;border-color:rgba(22,163,74,.25)}
        .badge--debit{background:rgba(220,38,38,.1);color:#b91c1c;border-color:rgba(220,38,38,.25)}
        .badge--ok{background:rgba(22,163,74,.1);color:#15803d;border-color:rgba(22,163,74,.25)}
        .badge--wait{background:rgba(234,179,8,.1);color:#a16207;border-color:rgba(234,179,8,.25)}
        .badge--fail{background:rgba(220,38,38,.1);color:#b91c1c;border-color:rgba(220,38,38,.25)}

        /* Actions */
        .qr-actions{width:100%;display:flex;gap:.6rem;padding:0 1.6rem 1.6rem}
        .qr-btn{flex:1;display:inline-flex;align-items:center;justify-content:center;gap:.45rem;padding:.65rem 1rem;border-radius:10px;font-size:.8rem;font-weight:700;border:none;cursor:pointer;text-decoration:none;font-family:inherit;transition:all .2s}
        .qr-btn--print{background:linear-gradient(135deg,#6366f1,#4f46e5);color:#fff;box-shadow:0 3px 10px rgba(99,102,241,.35)}
        .qr-btn--print:hover{box-shadow:0 5px 16px rgba(99,102,241,.45);transform:translateY(-1px)}
        .qr-btn--back{background:#f1f5f9;color:#475569;border:1px solid #e2e8f0}
        .qr-btn--back:hover{background:#e2e8f0}

        /* Footer */
        .qr-footer{background:#f8fafc;border-top:1px solid #e2e8f0;padding:.75rem 1.6rem;text-align:center;font-size:.65rem;color:#94a3b8}

        @media print{
            body{background:#fff;padding:0}
            .qr-card{box-shadow:none;border-radius:0;width:100%}
            .qr-actions,.qr-footer{display:none}
        }
    </style>
</head>
<body>

{% set type_key   = transaction.typeTransaction|default('')|lower %}
{% set is_debit   = 'debit' in type_key %}

<div class="qr-card">

    <div class="qr-header">
        <div class="qr-header__top">
            <div class="qr-header__icon"><i class="fa-solid fa-qrcode"></i></div>
            <div>
                <div class="qr-header__title">Code QR — Transaction</div>
                <div class="qr-header__sub">Scannez pour vérifier les détails</div>
            </div>
        </div>
        <div class="qr-header__badge">
            <i class="fa-solid fa-hashtag"></i> {{ transaction.idTransaction }}
            &nbsp;·&nbsp;
            <i class="fa-regular fa-calendar"></i> {{ transaction.dateTransaction|default('-') }}
        </div>
    </div>

    <div class="qr-body">

        <div class="qr-frame">
            <span class="qr-frame__corner qr-frame__corner--tl"></span>
            <span class="qr-frame__corner qr-frame__corner--tr"></span>
            <span class="qr-frame__corner qr-frame__corner--bl"></span>
            <span class="qr-frame__corner qr-frame__corner--br"></span>
            {{ qr_svg|raw }}
        </div>

        <p class="qr-hint">
            <i class="fa-solid fa-circle-info"></i>
            Pointez votre appareil photo vers ce code pour vérifier la transaction
        </p>

        <div class="qr-info">
            <div class="qr-info__item qr-info__item--wide">
                <div class="qr-info__label">Montant</div>
                <div class="qr-info__value qr-info__value--amount">
                    {{ transaction.montant_value|default(0)|number_format(3, '.', ' ') }} DT
                </div>
            </div>
            <div class="qr-info__item">
                <div class="qr-info__label">Type</div>
                <div class="qr-info__value">
                    <span class="badge {{ is_debit ? 'badge--debit' : 'badge--credit' }}">
                        <i class="fa-solid {{ is_debit ? 'fa-arrow-down' : 'fa-arrow-up' }}"></i>
                        {{ transaction.typeTransaction|default('-') }}
                    </span>
                </div>
            </div>
            <div class="qr-info__item">
                <div class="qr-info__label">Catégorie</div>
                <div class="qr-info__value">{{ transaction.categorie|default('-') }}</div>
            </div>
            <div class="qr-info__item">
                <div class="qr-info__label">N° Compte</div>
                <div class="qr-info__value">{{ transaction.numeroCompte|default('-') }}</div>
            </div>
            {% if transaction.description|default('') is not empty %}
            <div class="qr-info__item qr-info__item--wide">
                <div class="qr-info__label">Description</div>
                <div class="qr-info__value">{{ transaction.description }}</div>
            </div>
            {% endif %}
        </div>

    </div>

    <div class="qr-actions">
        <button class="qr-btn qr-btn--print" onclick="window.print()">
            <i class="fa-solid fa-print"></i> Imprimer
        </button>
        <a class="qr-btn qr-btn--back" href="javascript:history.back()">
            <i class="fa-solid fa-arrow-left"></i> Retour
        </a>
    </div>

    <div class="qr-footer">
        Nexora Banking &nbsp;·&nbsp; Généré le {{ 'now'|date('d/m/Y à H:i') }} &nbsp;·&nbsp; Document officiel
    </div>

</div>

</body>
</html>
