<section class="summary-grid">
    <article class="summary-card"><strong>{{ security_analysis.score }}/100</strong><span>Security score</span></article>
    <article class="summary-card"><strong>{{ prediction.savings_score }}/100</strong><span>Savings score</span></article>
    <article class="summary-card"><strong>{{ prediction.total_predicted_spending|number_format(2, '.', ' ') }}</strong><span>Predicted spending</span></article>
    <article class="summary-card"><strong>{{ surplus.surplus|number_format(2, '.', ' ') }}</strong><span>Monthly surplus</span></article>
</section>

<section class="panel-grid">
    <article class="panel-card">
        <div class="panel-header">
            <h2>Account Security Analysis</h2>
            <a class="btn btn-secondary" href="{{ path('portal_feature_analysis_download') }}">Download report</a>
        </div>
        <p>{{ security_analysis.summary }}</p>
        <div class="feature-list">{% for item in security_analysis.sections %}<div><strong>{{ item.title }}</strong><p>{{ item.text }}</p></div>{% endfor %}</div>
        <form method="post"><input type="hidden" name="action" value="secure_account"><button class="btn btn-primary" type="submit">Secure my account</button></form>
    </article>
    <article class="panel-card">
        <h2>Spending Prediction</h2>
        <p>{{ prediction.summary }}</p>
        <div class="table-wrap">
            <table class="data-table"><thead><tr><th>Category</th><th>Prediction</th></tr></thead><tbody>{% for item in prediction.predictions %}<tr><td>{{ item.category }}</td><td>{{ item.predicted_amount|number_format(2, '.', ' ') }} DT</td></tr>{% else %}<tr><td colspan="2">No forecast data available.</td></tr>{% endfor %}</tbody></table>
        </div>
        <div class="feature-list">{% for tip in prediction.conseils %}<div>{{ tip }}</div>{% endfor %}</div>
    </article>
</section>

<section class="panel-grid">
    <article class="panel-card"><h2>Account Advisor</h2><p>{{ account_advice.summary }}</p><div class="feature-list">{% for item in account_advice.action_items %}<div>{{ item }}</div>{% endfor %}</div></article>
    <article class="panel-card"><h2>Cashback Advisor</h2><p>{{ cashback_advice.summary }}</p><div class="feature-list">{% for item in cashback_advice.recommended_partners %}<div><strong>{{ item.name }}</strong><p>{{ item.category }} | {{ item.rating }}/5</p><small>{{ item.reason }}</small></div>{% endfor %}</div></article>
</section>

<section class="panel-grid">
    <article class="panel-card">
        <h2>Translations</h2>
        <form method="post" class="editor-form">
            <input type="hidden" name="action" value="translate_labels">
            <label><span>Language</span><select name="translation_language"><option value="en" {{ translation.language == 'en' ? 'selected' : '' }}>English</option><option value="fr" {{ translation.language == 'fr' ? 'selected' : '' }}>Francais</option><option value="ar" {{ translation.language == 'ar' ? 'selected' : '' }}>Arabic</option></select></label>
            <button class="btn btn-secondary" type="submit">Apply translation</button>
        </form>
        <div class="table-wrap"><table class="data-table"><thead><tr><th>Key</th><th>Value</th></tr></thead><tbody>{% for key, value in translation.labels %}<tr><td>{{ key }}</td><td>{{ value }}</td></tr>{% endfor %}</tbody></table></div>
    </article>
    <article class="panel-card">
        <h2>Monthly Surplus</h2>
        <p>{{ surplus.message }}</p>
        <div class="feature-list"><div><strong>Current income</strong><p>{{ surplus.current_income|number_format(2, '.', ' ') }} DT</p></div><div><strong>Average income</strong><p>{{ surplus.average_income|number_format(2, '.', ' ') }} DT</p></div></div>
        {% if surplus.show %}<form method="post"><input type="hidden" name="action" value="ack_surplus"><input type="hidden" name="month" value="{{ surplus.month }}"><button class="btn btn-primary" type="submit">Acknowledge suggestion</button></form>{% endif %}
    </article>
</section>

<section class="panel-grid">
    <article class="panel-card">
        <h2>Voice Note to Account Fields</h2>
        <form method="post" class="editor-form">
            <input type="hidden" name="action" value="parse_account_note">
            <label class="wide"><span>Speech text</span><textarea name="speech_text" rows="5" class="form-textarea" placeholder="Create savings account CB-77 with balance 1200, withdrawal 300, transfer 500">{{ app.request.request.get('speech_text') }}</textarea></label>
            <button class="btn btn-secondary" type="button" data-speech-fill="speech_text">Use browser speech</button>
            <button class="btn btn-primary" type="submit">Parse note</button>
        </form>
        {% if view_state.parsed_account %}<div class="table-wrap"><table class="data-table"><tbody>{% for key, value in view_state.parsed_account %}<tr><th>{{ key }}</th><td>{{ value }}</td></tr>{% endfor %}</tbody></table></div>{% endif %}
    </article>
    <article class="panel-card">
        <h2>Complaint Improver</h2>
        <form method="post" class="editor-form">
            <input type="hidden" name="action" value="improve_reclamation">
            <label class="wide"><span>Raw complaint</span><textarea name="raw_reclamation" rows="5" class="form-textarea" placeholder="Describe the issue">{{ app.request.request.get('raw_reclamation') }}</textarea></label>
            <button class="btn btn-primary" type="submit">Improve complaint</button>
        </form>
        {% if view_state.improved_reclamation %}<div class="feature-list"><div><strong>Sentiment</strong><p>{{ view_state.improved_reclamation.sentiment }} | {{ view_state.improved_reclamation.severity }}</p></div><div><strong>Improved text</strong><p>{{ view_state.improved_reclamation.improved }}</p></div></div>{% endif %}
    </article>
</section>

<section class="panel-card">
    <h2>Guarantee Description Generator</h2>
    <form method="post" class="editor-form">
        <input type="hidden" name="action" value="generate_garantie_text">
        <label><span>Type garantie</span><input type="text" name="typeGarantie" value="{{ app.request.request.get('typeGarantie') }}"></label>
        <label><span>Nom garant</span><input type="text" name="nomGarant" value="{{ app.request.request.get('nomGarant') }}"></label>
        <label><span>Adresse</span><input type="text" name="adresseBien" value="{{ app.request.request.get('adresseBien') }}"></label>
        <label><span>Valeur estimee</span><input type="number" step="0.01" name="valeurEstimee" value="{{ app.request.request.get('valeurEstimee') }}"></label>
        <button class="btn btn-primary" type="submit">Generate description</button>
    </form>
    {% if view_state.generated_garantie %}<div class="notification-item">{{ view_state.generated_garantie }}</div>{% endif %}
</section>
