.cb-search-box input::placeholder { color: #aabece; }
.cb-search-clear {
  width: 20px; height: 20px; border-radius: 50%;
  background: #e2ecf8; border: none; color: #5b80a0;
  display: flex; align-items: center; justify-content: center;
  font-size: 11px; cursor: pointer;
}

.cb-sort-wrap { min-width: 140px; }
.cb-sort-select { font-size: 12px; min-height: 40px; }

/* Filter tabs */
.cb-filter-tabs {
  display: flex; align-items: center; gap: 6px;
  background: #fff; border-radius: 14px;
  padding: 10px 14px; border: 1px solid #dde8f5;
  flex-wrap: wrap;
}
.cb-filter-tab {
  display: inline-flex; align-items: center; gap: 7px;
  min-height: 34px; padding: 0 14px;
  border-radius: 9px; background: transparent;
  border: 1px solid transparent;
  font: inherit; font-size: 12px; font-weight: 700;
  color: #7294ae; cursor: pointer; transition: all .15s;
}
.cb-filter-tab:hover { background: #f0f4f8; color: #0a2540; }
.cb-filter-active {
  background: linear-gradient(120deg,#1565c0,#1e88e5);
  color: #fff;
  box-shadow: 0 4px 12px rgba(21,101,192,.2);
}
.cb-filter-active:hover { background: linear-gradient(120deg,#1565c0,#1e88e5); color: #fff; }
.cb-tab-count {
  background: rgba(255,255,255,.25); border-radius: 999px;
  padding: 1px 7px; font-size: 10px; font-weight: 800;
}
.cb-filter-tab:not(.cb-filter-active) .cb-tab-count {
  background: #e8f0fb; color: #1565c0;
}

/* ══════════════════════════════════════════════════════════════════════
   CARDS GRID
   ══════════════════════════════════════════════════════════════════════ */
.cb-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(420px, 1fr));
  gap: 14px;
}

.cb-card {
  background: #fff;
  border-radius: 18px;
  border: 1px solid #dde8f5;
  display: flex; flex-direction: column;
  gap: 12px;
  box-shadow: 0 2px 12px rgba(10,37,64,.05);
  transition: box-shadow .2s, transform .2s, border-color .2s;
  overflow: hidden;
  position: relative;
}
.cb-card:hover {
  box-shadow: 0 10px 32px rgba(10,37,64,.12);
  transform: translateY(-3px);
  border-color: #b8d4f0;
}

/* Accent strip */
.cb-card-accent {
  height: 3px; width: 100%;
}
.cb-accent-green  { background: linear-gradient(90deg,#1565c0,#00bcd4); }
.cb-accent-amber  { background: linear-gradient(90deg,#1565c0,#00bcd4); }
.cb-accent-red    { background: linear-gradient(90deg,#1565c0,#00bcd4); }

/* Card top */
.cb-card-top {
  display: flex; align-items: center;
  justify-content: space-between; gap: 8px;
  padding: 14px 16px 10px;
}

.cb-card-partner { display: flex; align-items: center; gap: 10px; }

.cb-partner-avatar {
  width: 38px; height: 38px; border-radius: 12px;
  background: linear-gradient(135deg,#00838f,#00bcd4);
  color: #fff; font-size: 15px; font-weight: 800;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}

.cb-partner-name { font-size: 14px; font-weight: 800; color: #0a2540; }
.cb-card-id { font-size: 11px; color: #9ab4cc; font-weight: 600; margin-top: 1px; }

/* Status badge */
.cb-status-badge {
  display: inline-flex; align-items: center; gap: 5px;
  padding: 5px 10px; border-radius: 999px;
  font-size: 11px; font-weight: 800; white-space: nowrap; flex-shrink: 0;
}
.cb-status-green  { background: #dcfce7; color: #166534; }
.cb-status-amber  { background: #fef9c3; color: #854d0e; }
.cb-status-red    { background: #fee2e2; color: #991b1b; }

/* Amounts */
.cb-card-amounts {
  display: flex; align-items: stretch;
  margin: 0 16px;
  background: linear-gradient(135deg,#f0f9ff,#e0f7fa);
  border-radius: 14px;
  border: 1px solid #b2ebf2;
  overflow: hidden;
}
.cb-card-amount-block {
  flex: 1; padding: 12px 14px;
  display: flex; flex-direction: column; gap: 3px;
}
.cb-card-amount-divider {
  width: 1px; background: #b2ebf2;
}
.cb-amount-label {
  font-size: 10px; color: #7294ae;
  text-transform: uppercase; letter-spacing: 0.4px; font-weight: 700;
}
.cb-amount-val {
  font-size: 18px; font-weight: 900; color: #0a2540; letter-spacing: -0.3px;
}
.cb-amount-val small { font-size: 11px; font-weight: 600; color: #7294ae; margin-left: 2px; }
.cb-cashback-block { background: rgba(0,188,212,.06); }
.cb-cashback-val { color: #00838f; }

/* Progress */
.cb-card-progress { padding: 10px 16px; }
.cb-progress-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 5px;
}
.cb-progress-label { font-size: 10px; color: #9ab4cc; font-weight: 700; text-transform: uppercase; letter-spacing: 0.4px; }
.cb-progress-pct { font-size: 11px; font-weight: 800; color: #00838f; }
.cb-progress-track { height: 6px; background: #e0f7fa; border-radius: 999px; overflow: hidden; }
.cb-progress-fill {
  height: 100%; border-radius: 999px;
  background: linear-gradient(90deg,#00838f,#00bcd4);
  transition: width .6s ease;
}

/* Rating */
.cb-card-rating {
  padding: 12px 16px 16px;
  border-top: 1px solid #f0f4f8;
  display: flex; flex-direction: column; gap: 10px;
}
.cb-rating-header {
  display: flex; align-items: center; gap: 7px;
  font-size: 11px; font-weight: 700; color: #7294ae;
}
.cb-rating-header i { color: #f59e0b; }

.cb-rating-form { display: flex; flex-direction: column; gap: 8px; }

/* Stars */
.cb-stars {
  display: flex; align-items: center; gap: 4px;
}
.cb-star-btn {
  width: 28px; height: 28px; border-radius: 8px;
  background: #f7faff; border: 1px solid #dde8f5;
  color: #c4d4e4; font-size: 13px;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; transition: all .15s;
}
.cb-star-btn:hover,
.cb-star-btn.cb-star-active {
  background: #fff8e1; border-color: #fbbf24; color: #f59e0b;
}
.cb-star-btn.cb-star-filled { color: #f59e0b; background: #fff8e1; border-color: #fde68a; }

.cb-rating-comment { min-height: 36px; font-size: 12px; }

.cb-rating-actions { display: flex; align-items: center; gap: 8px; }

.cb-rate-submit-btn {
  flex: 1;
  display: inline-flex; align-items: center; justify-content: center; gap: 7px;
  min-height: 36px; border-radius: 10px;
  background: linear-gradient(120deg,#00838f,#00bcd4);
  color: #fff; font: inherit; font-size: 12px; font-weight: 700;
  border: none; cursor: pointer; transition: opacity .15s;
}
.cb-rate-submit-btn:hover { opacity: .88; }

.cb-delete-form { display: none; }
.cb-delete-btn {
  width: 36px; height: 36px; border-radius: 10px;
  background: #fff0f0; border: 1px solid #fecaca;
  color: #dc2626; display: flex; align-items: center;
  justify-content: center; cursor: pointer; font-size: 13px;
  transition: all .15s;
}
.cb-delete-btn:hover { background: #dc2626; color: #fff; }

.cb-edit-btn {
  width: 36px; height: 36px; border-radius: 10px;
  background: #eaf2fd; border: 1px solid #c3d9f5;
  color: #1565c0; display: flex; align-items: center;
  justify-content: center; cursor: pointer; font-size: 13px;
  transition: all .15s;
}
.cb-edit-btn:hover { background: #1565c0; color: #fff; }

/* Empty state */
.cb-empty {
  grid-column: 1 / -1;
  display: flex; flex-direction: column; align-items: center; gap: 10px;
  padding: 60px 20px;
  background: #fff; border-radius: 18px;
  border: 1px dashed #c4d9ee; text-align: center;
}
.cb-empty[hidden] { display: none !important; }
.cb-empty-icon {
  width: 70px; height: 70px; border-radius: 50%;
  background: linear-gradient(135deg,#e0f7fa,#b2ebf2);
  display: flex; align-items: center; justify-content: center;
  font-size: 28px; color: #7294ae;
}
.cb-empty strong { font-size: 17px; color: #0a2540; }
.cb-empty span { font-size: 13px; color: #7294ae; max-width: 300px; }
.cb-empty-cta {
  display: inline-flex; align-items: center; gap: 8px;
  min-height: 40px; padding: 0 20px; border-radius: 12px;
  background: linear-gradient(120deg,#00838f,#00bcd4);
  color: #fff; font: inherit; font-size: 13px; font-weight: 700;
  border: none; cursor: pointer; margin-top: 6px; transition: opacity .15s;
}
.cb-empty-cta:hover { opacity: .88; }

/* ══════════════════════════════════════════════════════════════════════
   TABLE VIEW
   ══════════════════════════════════════════════════════════════════════ */
.cb-table-wrap {
  background: #fff; border-radius: 18px;
  border: 1px solid #dde8f5;
  box-shadow: 0 4px 20px rgba(10,37,64,.07);
  overflow: auto;
}

.cb-table { width: 100%; border-collapse: collapse; min-width: 900px; }

.cb-table thead tr { background: linear-gradient(135deg,#f2f8fd,#e8f4fb); }
.cb-table th {
  padding: 14px 16px; text-align: left;
  border-bottom: 2px solid #daeaf6;
}
.cb-table th span {
  font-size: 11px; font-weight: 800; color: #5b80a0;
  text-transform: uppercase; letter-spacing: 0.7px;
}

.cb-tr { border-bottom: 1px solid #edf4fb; transition: background .15s; }
.cb-tr:hover { background: #f5fbff; }
.cb-tr:last-child { border-bottom: none; }
.cb-table td { padding: 12px 16px; vertical-align: middle; }

.cb-id-pill {
  display: inline-block;
  background: linear-gradient(135deg,#00838f,#00bcd4);
  color: #fff; font-size: 11px; font-weight: 800;
  padding: 4px 10px; border-radius: 999px;
}

.cb-tbl-partner { display: flex; align-items: center; gap: 9px; }
.cb-tbl-avatar {
  width: 30px; height: 30px; border-radius: 50%;
  background: linear-gradient(135deg,#00838f,#00bcd4);
  color: #fff; font-size: 12px; font-weight: 800;
  display: flex; align-items: center; justify-content: center;
}
.cb-tbl-partner span { font-size: 13px; font-weight: 600; color: #1b3a57; }

.cb-tbl-amount { font-size: 14px; font-weight: 800; color: #0a2540; }
.cb-tbl-cashback { font-size: 14px; font-weight: 800; color: #00838f; }
.cb-tbl-cur { font-size: 11px; color: #7294ae; margin-left: 2px; }

.cb-tbl-rate-wrap { display: flex; align-items: center; gap: 8px; min-width: 100px; }
.cb-tbl-rate-bar { flex: 1; height: 5px; background: #e0f7fa; border-radius: 999px; overflow: hidden; }
.cb-tbl-rate-fill { height: 100%; border-radius: 999px; background: linear-gradient(90deg,#00838f,#00bcd4); }
.cb-tbl-rate-pct { font-size: 11px; font-weight: 800; color: #00838f; white-space: nowrap; }

.cb-tbl-rate-form { }
.cb-tbl-rate-row { display: flex; align-items: center; gap: 6px; }
.cb-tbl-rate-input { width: 60px; min-height: 32px; font-size: 12px; padding: 0 8px; }
.cb-tbl-comment-input { width: 130px; min-height: 32px; font-size: 12px; padding: 0 8px; }
.cb-tbl-rate-btn {
  width: 32px; height: 32px; border-radius: 9px;
  background: linear-gradient(120deg,#00838f,#00bcd4);
  border: none; color: #fff; font-size: 13px;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; transition: opacity .15s;
}
.cb-tbl-rate-btn:hover { opacity: .85; }

.cb-tbl-actions { display: flex; align-items: center; gap: 6px; }
.cb-tbl-edit-btn {
  width: 32px; height: 32px; border-radius: 9px;
  background: #eaf2fd; border: 1px solid #c3d9f5;
  color: #1565c0; display: flex; align-items: center;
  justify-content: center; cursor: pointer; font-size: 13px;
  transition: all .15s;
}
.cb-tbl-edit-btn:hover { background: #1565c0; color: #fff; }
.cb-tbl-del-btn {
  width: 32px; height: 32px; border-radius: 9px;
  background: #fff0f0; border: 1px solid #fecaca;
  color: #dc2626; display: flex; align-items: center;
  justify-content: center; cursor: pointer; font-size: 13px;
  transition: all .15s;
}
.cb-tbl-del-btn:hover { background: #dc2626; color: #fff; }

.cb-tbl-empty {
  display: flex; flex-direction: column; align-items: center; gap: 8px;
  padding: 48px; color: #7294ae; text-align: center;
}
.cb-tbl-empty i { font-size: 28px; color: #b8d4e8; margin-bottom: 4px; }
.cb-tbl-empty span { font-size: 13px; font-weight: 600; }

/* ══════════════════════════════════════════════════════════════════════
   ASSISTANT + QR BUNDLE
   ══════════════════════════════════════════════════════════════════════ */
.cb-smart-tools {
  display: grid;
  grid-template-columns: 1.2fr .95fr;
  gap: 18px;
  margin-top: 20px;
}
.cb-tool-card {
  background: #fff;
  border: 1px solid #dce8f5;
  border-radius: 18px;
  box-shadow: 0 10px 28px rgba(10,37,64,.08);
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}
.cb-tool-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
}
.cb-tool-head h3 {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 18px;
  font-weight: 900;
  color: #0a2540;
}
.cb-tool-head p {
  margin-top: 6px;
  font-size: 13px;
  color: #5d7288;
  line-height: 1.55;
}
.cb-tool-badge {
  border-radius: 999px;
  padding: 7px 12px;
  background: linear-gradient(120deg,#e0f2fe,#d1fae5);
  color: #0a2540;
  font-size: 11px;
  font-weight: 800;
  letter-spacing: .08em;
  text-transform: uppercase;
}
.cb-assistant-messages {
  display: flex;
  flex-direction: column;
  gap: 12px;
  min-height: 210px;
  max-height: 360px;
  overflow: auto;
  padding-right: 4px;
}
.cb-chat-bubble {
  max-width: 92%;
  border-radius: 16px;
  padding: 14px 16px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  box-shadow: 0 6px 20px rgba(10,37,64,.06);
}
.cb-chat-bubble strong {
  font-size: 12px;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: .06em;
}
.cb-chat-bubble p {
  font-size: 14px;
  line-height: 1.6;
  color: #17324d;
}
.cb-chat-bubble-bot {
  background: linear-gradient(135deg,#eef7ff,#f0fdfa);
  border: 1px solid #d6ebfb;
  align-self: flex-start;
}
.cb-chat-bubble-user {
  background: linear-gradient(135deg,#0f766e,#0891b2);
  color: #fff;
  align-self: flex-end;
}
.cb-chat-bubble-user p,
.cb-chat-bubble-user strong {
  color: #fff;
}
.cb-chat-metrics,
.cb-chat-offers {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}
.cb-chat-metrics span,
.cb-chat-offers span {
  border-radius: 999px;
  padding: 7px 10px;
  font-size: 12px;
  font-weight: 700;
}
.cb-chat-metrics span {
  background: #f0f7ff;
  color: #0a4a75;
}
.cb-chat-offers span {
  background: #fff7ed;
  color: #9a3412;
}
.cb-assistant-starters {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}
.cb-starter-btn {
  border: 1px solid #cfe3f7;
  background: #f7fbff;
  color: #0a4f73;
  border-radius: 999px;
  padding: 8px 12px;
  font: inherit;
  font-size: 12px;
  font-weight: 700;
  cursor: pointer;
  transition: transform .15s ease, box-shadow .15s ease, background .15s ease;
}
.cb-starter-btn:hover {
  background: #e9f5ff;
  box-shadow: 0 8px 20px rgba(10,37,64,.08);
  transform: translateY(-1px);
}
.cb-assistant-form {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 10px;
}
.cb-assistant-send {
  min-width: 132px;
}
.cb-bundle-grid {
  display: grid;
  grid-template-columns: 220px 1fr;
  gap: 18px;
  align-items: center;
}
.cb-bundle-preview {
  min-height: 220px;
  border-radius: 18px;
  border: 1px dashed #bfd9f1;
  background: linear-gradient(135deg,#f8fbff,#eef9ff);
  display: grid;
  place-items: center;
  padding: 18px;
}
.cb-bundle-preview img {
  width: 100%;
  max-width: 220px;
  height: auto;
}
.cb-bundle-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
  color: #4f6d86;
  text-align: center;
  font-size: 13px;
  line-height: 1.5;
}
.cb-bundle-placeholder i {
  font-size: 42px;
  color: #0ea5b7;
}
.cb-bundle-info {
  display: flex;
  flex-direction: column;
  gap: 14px;
}
.cb-bundle-kpis {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10px;
}
.cb-bundle-kpi {
  border-radius: 14px;
  background: #f6fbff;
  border: 1px solid #d9eafb;
  padding: 12px 14px;
}
.cb-bundle-kpi span {
  display: block;
  font-size: 12px;
  color: #61809a;
  margin-bottom: 6px;
}
.cb-bundle-kpi strong {
  font-size: 16px;
  font-weight: 900;
  color: #0a2540;
}
.cb-bundle-meta {
  font-size: 13px;
  line-height: 1.7;
  color: #4d657b;
}
.cb-bundle-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

/* ══════════════════════════════════════════════════════════════════════
   FOOTER STATS
   ══════════════════════════════════════════════════════════════════════ */
.cb-footer-stats {
  display: flex; align-items: center;
  justify-content: space-between; flex-wrap: wrap; gap: 10px;
  background: #fff; border-radius: 14px;
  padding: 13px 18px; border: 1px solid #dde8f5;
}
.cb-fs-item {
  display: inline-flex; align-items: center; gap: 7px;
  font-size: 12px; color: #7294ae; font-weight: 600;
}
.cb-fs-item i { color: #1565c0; }
.cb-fs-item strong { color: #0a2540; }

/* ══════════════════════════════════════════════════════════════════════
   HIDDEN UTILITY
   ══════════════════════════════════════════════════════════════════════ */
.cb-card.cb-hidden { display: none; }
.cb-form-collapsed .cb-form-body,
.cb-form-collapsed .cb-form-footer { display: none; }

/* ══════════════════════════════════════════════════════════════════════
   DARK MODE
   ══════════════════════════════════════════════════════════════════════ */
.cb-root.cb-dark {
  background: #0d1b2e;
  color: #c8ddf0;
}
.cb-root.cb-dark .cb-topbar,
.cb-root.cb-dark .cb-page-header,
.cb-root.cb-dark .cb-kpi-card,
.cb-root.cb-dark .cb-toolbar,
.cb-root.cb-dark .cb-filter-tabs,
.cb-root.cb-dark .cb-card,
.cb-root.cb-dark .cb-empty,
.cb-root.cb-dark .cb-footer-stats,
.cb-root.cb-dark .cb-form-card,
.cb-root.cb-dark .cb-table-wrap,
.cb-root.cb-dark .cb-tool-card {
  background: #122038;
  border-color: #1e3655;
}
.cb-root.cb-dark .cb-input {
  background: #0d1b2e;
  border-color: #1e3655;
  color: #c8ddf0;
}
.cb-root.cb-dark .cb-page-title,
.cb-root.cb-dark .cb-content-title,
.cb-root.cb-dark .cb-partner-name,
.cb-root.cb-dark .cb-kpi-value,
.cb-root.cb-dark .cb-amount-val,
.cb-root.cb-dark .cb-tool-head h3,
.cb-root.cb-dark .cb-bundle-kpi strong {
  color: #e4f0ff;
}
.cb-root.cb-dark .cb-tool-head p,
.cb-root.cb-dark .cb-bundle-meta,
.cb-root.cb-dark .cb-bundle-kpi span,
.cb-root.cb-dark .cb-bundle-placeholder { color: #9fb5ca; }
.cb-root.cb-dark .cb-kpi-strip { background: #0d1b2e; }
.cb-root.cb-dark .cb-search-box { background: #0d1b2e; border-color: #1e3655; }
.cb-root.cb-dark .cb-search-box input { color: #c8ddf0; }
.cb-root.cb-dark .cb-card-amounts { background: linear-gradient(135deg,#0d2035,#0d2a30); border-color: #1e3a40; }
.cb-root.cb-dark .cb-card-rating { border-color: #1e3655; }
.cb-root.cb-dark .cb-chat-bubble-bot {
  background: linear-gradient(135deg,#17314c,#0f2a3f);
  border-color: #285071;
}
.cb-root.cb-dark .cb-chat-bubble-bot p { color: #dcecff; }
.cb-root.cb-dark .cb-chat-metrics span {
  background: #16324d;
  color: #cae6ff;
}
.cb-root.cb-dark .cb-chat-offers span {
  background: #3a2414;
  color: #ffd7b2;
}
.cb-root.cb-dark .cb-starter-btn {
  background: #16324d;
  border-color: #285071;
  color: #d9edff;
}
.cb-root.cb-dark .cb-bundle-preview,
.cb-root.cb-dark .cb-bundle-kpi {
  background: #132b43;
  border-color: #254561;
}
.cb-root.cb-dark .cb-modal-close {
  background: #16324d;
  border-color: #285071;
  color: #e4f0ff;
}
.cb-root.cb-dark .cb-modal-close:hover {
  background: #1e3f60;
  border-color: #35648f;
}
.cb-root.cb-dark .cb-topbar-btn,
.cb-root.cb-dark .cb-user-chip { background: #1a2f4a; border-color: #1e3655; }
.cb-root.cb-dark .cb-tr:hover { background: #142540; }

