{% set total_cashback = 0 %}
{% set pending_count = 0 %}
{% set validated_count = 0 %}
{% set total_purchases = 0 %}
{% for item in items %}
    {% set total_cashback = total_cashback + (item.montant_cashback|default(0)) %}
    {% set total_purchases = total_purchases + (item.montant_achat|default(0)) %}
    {% set st = item.statut|default('')|lower %}
    {% if 'attente' in st %}{% set pending_count = pending_count + 1 %}{% endif %}
    {% if 'valid' in st or 'approuv' in st %}{% set validated_count = validated_count + 1 %}{% endif %}
{% endfor %}

<div class="cb-root">

    {# ── PAGE HEADER ── #}
    <header class="cb-page-header">
        <div class="cb-page-header-inner">
            <div class="cb-page-header-left">
                <div class="cb-page-icon-ring">
                    <i class="fa-solid fa-hand-holding-heart"></i>
                </div>
                <div>
                    <h1 class="cb-page-title">Mes Recompenses Cashback</h1>
                    <p class="cb-page-sub">Suivez vos achats, cumulez des cashbacks et evaluez vos partenaires</p>
                </div>
            </div>
            <div class="cb-page-header-actions">
                <button type="button" class="cb-hdr-btn cb-hdr-btn-outline" id="cb-dark-toggle" title="Mode sombre">
                    <i class="fa-solid fa-moon"></i>
                    <span>Mode sombre</span>
                </button>
                <button type="button" class="cb-hdr-btn cb-hdr-btn-outline" id="cb-view-toggle">
                    <i class="fa-solid fa-table-cells"></i>
                    <span>Vue tableau</span>
                </button>
                <button type="button" class="cb-hdr-btn cb-hdr-btn-outline" id="cb-open-assistant">
                    <i class="fa-solid fa-comments"></i>
                    <span>Assistant</span>
                </button>
                <button type="button" class="cb-hdr-btn cb-hdr-btn-outline" id="cb-open-bundle">
                    <i class="fa-solid fa-qrcode"></i>
                    <span>Bundle QR</span>
                </button>
                <button type="button" class="cb-hdr-btn cb-hdr-btn-primary" id="cb-add-btn">
                    <i class="fa-solid fa-plus"></i>
                    <span>Nouveau cashback</span>
                </button>
            </div>
        </div>
    </header>

    {# ── KPI STRIP ── #}
    <div class="cb-kpi-strip">
        <div class="cb-kpi-card">
            <div class="cb-kpi-icon cb-kpi-teal">
                <i class="fa-solid fa-coins"></i>
            </div>
            <div class="cb-kpi-body">
                <span class="cb-kpi-value">
                    {{ total_cashback|number_format(2, '.', ' ') }}<small>DT</small>
                </span>
                <span class="cb-kpi-label">Total cashback cumule</span>
            </div>
            <div class="cb-kpi-trend cb-trend-teal"></div>
        </div>
        <div class="cb-kpi-card">
            <div class="cb-kpi-icon cb-kpi-blue">
                <i class="fa-solid fa-receipt"></i>
            </div>
            <div class="cb-kpi-body">
                <span class="cb-kpi-value">
                    {{ total_purchases|number_format(2, '.', ' ') }}<small>DT</small>
                </span>
                <span class="cb-kpi-label">Volume d'achats</span>
            </div>
            <div class="cb-kpi-trend cb-trend-blue"></div>
        </div>
        <div class="cb-kpi-card">
            <div class="cb-kpi-icon cb-kpi-amber">
                <i class="fa-solid fa-clock"></i>
            </div>
            <div class="cb-kpi-body">
                <span class="cb-kpi-value">{{ pending_count }}</span>
                <span class="cb-kpi-label">En attente</span>
            </div>
            <div class="cb-kpi-trend cb-trend-amber"></div>
        </div>
        <div class="cb-kpi-card">
            <div class="cb-kpi-icon cb-kpi-green">
                <i class="fa-solid fa-circle-check"></i>
            </div>
            <div class="cb-kpi-body">
                <span class="cb-kpi-value">{{ validated_count }}</span>
                <span class="cb-kpi-label">Valides</span>
            </div>
            <div class="cb-kpi-trend cb-trend-green"></div>
        </div>
        <div class="cb-kpi-card">
            <div class="cb-kpi-icon cb-kpi-purple">
                <i class="fa-solid fa-store"></i>
            </div>
            <div class="cb-kpi-body">
                <span class="cb-kpi-value">{{ items|length }}</span>
                <span class="cb-kpi-label">Total transactions</span>
            </div>
            <div class="cb-kpi-trend cb-trend-purple"></div>
        </div>
    </div>

    {# ── MAIN SPLIT LAYOUT ── #}
    <div class="cb-split">

        {# ─── LEFT: FORM ─── #}
        <aside class="cb-form-col" id="cb-form-col">
            <div class="cb-form-card" id="cb-form-card">

                <div class="cb-form-card-header">
                    <div class="cb-fch-top">
                        <div class="cb-fch-icon">
                            <i class="fa-solid fa-file-pen"></i>
                        </div>
                        <div>
                            <h2 class="cb-fch-title">Enregistrer un cashback</h2>
                            <p class="cb-fch-sub">Creer ou modifier une transaction</p>
                        </div>
                        <button class="cb-collapse-btn" id="cb-collapse-form" type="button" title="Reduire">
                            <i class="fa-solid fa-chevron-left"></i>
                        </button>
                    </div>
                </div>

                <form method="post" class="cb-form" id="cashback-form" novalidate>
                    <input type="hidden" name="tab" value="cashback">
                    <input type="hidden" name="action" value="cashback_save">

                    <div class="cb-form-body">

                        {# Section: Identite #}
                        <div class="cb-form-section">
                            <div class="cb-section-label">
                                <i class="fa-solid fa-circle-info"></i>
                                <span>Informations de base</span>
                                <div class="cb-section-line"></div>
                            </div>

                            <div class="cb-field-group">
                                <div class="cb-field">
                                    <label class="cb-label">
                                        <i class="fa-solid fa-hashtag"></i>
                                        ID (modification)
                                    </label>
                                    <input class="cb-input" type="number" name="id_cashback" id="cb-id-field" placeholder="Laisser vide pour creer">
                                </div>
                            </div>

                            <div class="cb-field-group cb-field-group-2">
                                <div class="cb-field">
                                    <label class="cb-label">
                                        <i class="fa-solid fa-store"></i>
                                        Partenaire existant
                                    </label>
                                    <div class="cb-select-wrap">
                                        <select class="cb-input cb-select" name="id_partenaire">
                                            <option value="">Partenaire libre</option>
                                            {% for partner in support.partners|default([]) %}
                                                <option value="{{ partner.idPartenaire }}">{{ partner.nom }}</option>
                                            {% endfor %}
                                        </select>
                                        <i class="fa-solid fa-chevron-down cb-select-icon"></i>
                                    </div>
                                </div>
                                <div class="cb-field">
                                    <label class="cb-label">
                                        <i class="fa-solid fa-pen"></i>
                                        Nom partenaire <span class="cb-req">*</span>
                                    </label>
                                    <input class="cb-input" type="text" name="partenaire_nom" id="cb-partenaire-nom" placeholder="Ex: Carrefour, Amazon…">
                                    <span id="cb-err-partenaire" class="cb-val-msg"></span>
                                </div>
                            </div>
                        </div>

                        {# Section: Transaction #}
                        <div class="cb-form-section">
                            <div class="cb-section-label">
                                <i class="fa-solid fa-money-bill-transfer"></i>
                                <span>Details de la transaction</span>
                                <div class="cb-section-line"></div>
                            </div>

                            <div class="cb-field-group cb-field-group-2">
                                <div class="cb-field">
                                    <label class="cb-label">
                                        <i class="fa-solid fa-cart-shopping"></i>
                                        Montant achat (TND) <span class="cb-req">*</span>
                                    </label>
                                    <div class="cb-input-pfx-wrap">
                                        <span class="cb-input-pfx">TND</span>
                                        <input class="cb-input cb-input-pfx-field" type="number" step="0.01" name="montant_achat" id="cb-montant-achat" placeholder="0.00">
                                    </div>
                                    <span id="cb-err-montant" class="cb-val-msg"></span>
                                </div>
                                <div class="cb-field">
                                    <label class="cb-label">
                                        <i class="fa-solid fa-calendar-day"></i>
                                        Date d'achat
                                    </label>
                                    <input class="cb-input" type="date" name="date_achat" value="{{ 'now'|date('Y-m-d') }}">
                                </div>
                            </div>

                            <div class="cb-field-group">
                                <div class="cb-field">
                                    <label class="cb-label">
                                        <i class="fa-solid fa-list-check"></i>
                                        Statut
                                    </label>
                                    <div class="cb-select-wrap">
                                        <select class="cb-input cb-select" name="statut">
                                            <option value="En attente" selected>En attente</option>
                                            <option value="Valide">Valide</option>
                                            <option value="Refuse">Refuse</option>
                                            <option value="Expire">Expire</option>
                                        </select>
                                        <i class="fa-solid fa-chevron-down cb-select-icon"></i>
                                    </div>
                                </div>
                            </div>
                        </div>

                        {# Live cashback estimator #}
                        <div class="cb-estimator" id="cb-estimator">
                            <div class="cb-estimator-header">
                                <i class="fa-solid fa-calculator"></i>
                                <span>Estimateur de cashback</span>
                            </div>
                            <div class="cb-estimator-rates">
                                <span class="cb-estimator-hint">Le taux est calcule automatiquement selon le montant et le partenaire choisi.</span>
                            </div>
                            <div class="cb-estimator-meta">
                                <span class="cb-est-label">Taux applique</span>
                                <span class="cb-est-rate" id="cb-est-rate">0.00%</span>
                            </div>
                            <div class="cb-estimator-result">
                                <span class="cb-est-label">Cashback estime</span>
                                <span class="cb-est-value" id="cb-est-value">0.00 DT</span>
                            </div>
                        </div>

                    </div>{# /form-body #}

                    <div class="cb-form-footer">
                        <button class="cb-reset-btn" type="reset">
                            <i class="fa-solid fa-xmark"></i>
                            Annuler
                        </button>
                        <button class="cb-submit-btn" type="submit">
                            <i class="fa-solid fa-floppy-disk"></i>
                            Enregistrer
                        </button>
                    </div>
                </form>
            </div>
        </aside>

        {# ─── RIGHT: CONTENT ─── #}
        <main class="cb-content-col">

            {# Toolbar #}
            <div class="cb-toolbar">
                <div class="cb-toolbar-left">
                    <h2 class="cb-content-title">
                        <i class="fa-solid fa-hand-holding-heart"></i>
                        Transactions
                    </h2>
                    <span class="cb-count-badge">{{ items|length }}</span>
                </div>
                <div class="cb-toolbar-right">
                    <div class="cb-search-box">
                        <i class="fa-solid fa-magnifying-glass"></i>
                        <input type="text" id="cb-search-input" placeholder="Rechercher partenaire, statut…">
                        <button class="cb-search-clear" id="cb-search-clear" type="button" hidden>
                            <i class="fa-solid fa-xmark"></i>
                        </button>
                    </div>
                    <div class="cb-select-wrap cb-sort-wrap">
                        <select class="cb-input cb-select cb-sort-select" id="cb-sort-select">
                            <option value="id_desc">Plus recent</option>
                            <option value="id_asc">Plus ancien</option>
                            <option value="amount_desc">Montant ↓</option>
                            <option value="amount_asc">Montant ↑</option>
                            <option value="cashback_desc">Cashback ↓</option>
                        </select>
                        <i class="fa-solid fa-chevron-down cb-select-icon"></i>
                    </div>
                </div>
            </div>

            {# Status filter tabs #}
            <div class="cb-filter-tabs">
                <button class="cb-filter-tab cb-filter-active" data-filter="all" type="button">
                    Tous <span class="cb-tab-count">{{ items|length }}</span>
                </button>
                <button class="cb-filter-tab" data-filter="attente" type="button">
                    En attente <span class="cb-tab-count">{{ pending_count }}</span>
                </button>
                <button class="cb-filter-tab" data-filter="valid" type="button">
                    Valides <span class="cb-tab-count">{{ validated_count }}</span>
                </button>
            </div>

            {# Cards grid — default view #}
            <div class="cb-grid" id="cb-grid">
                {% for item in items %}
                    {% set st_key = item.statut|default('En attente')|lower %}
                    {% set st_color = 'attente' in st_key ? 'amber' : ('valid' in st_key or 'approuv' in st_key ? 'green' : 'red') %}
                    {% set st_icon  = 'attente' in st_key ? 'clock' : ('valid' in st_key or 'approuv' in st_key ? 'circle-check' : 'circle-xmark') %}
                    <div class="cb-card"
                         data-cb-id="{{ item.id_cashback }}"
                         data-cb-partner="{{ item.partenaire_nom|default('')|lower|e('html_attr') }}"
                         data-cb-status="{{ item.statut|default('')|lower|e('html_attr') }}"
                         data-cb-amount="{{ item.montant_achat|default(0) }}"
                         data-cb-cashback="{{ item.montant_cashback|default(0) }}"
                         data-cb-search="{{ (item.partenaire_nom ~ ' ' ~ item.statut ~ ' ' ~ item.montant_achat)|lower|e('html_attr') }}"
                    >
                        {# top accent #}
                        <div class="cb-card-accent cb-accent-{{ st_color }}"></div>

                        <div class="cb-card-top">
                            <div class="cb-card-partner">
                                <div class="cb-partner-avatar">
                                    {{ item.partenaire_nom|default('?')|first|upper }}
                                </div>
                                <div>
                                    <div class="cb-partner-name">{{ item.partenaire_nom|default('—') }}</div>
                                    <div class="cb-card-id">#{{ item.id_cashback }}</div>
                                </div>
                            </div>
                            <span class="cb-status-badge cb-status-{{ st_color }}">
                                <i class="fa-solid fa-{{ st_icon }}"></i>
                                {{ item.statut|default('En attente') }}
                            </span>
                        </div>

                        <div class="cb-card-amounts">
                            <div class="cb-card-amount-block">
                                <span class="cb-amount-label">Montant achat</span>
                                <span class="cb-amount-val">{{ item.montant_achat|default(0)|number_format(2, '.', ' ') }} <small>DT</small></span>
                            </div>
                            <div class="cb-card-amount-divider"></div>
                            <div class="cb-card-amount-block cb-cashback-block">
                                <span class="cb-amount-label">Cashback recu</span>
                                <span class="cb-amount-val cb-cashback-val">
                                    +{{ item.montant_cashback|default(0)|number_format(2, '.', ' ') }} <small>DT</small>
                                </span>
                            </div>
                        </div>

                        {# Cashback progress bar #}
                        {% set cb_rate = item.montant_achat|default(0) > 0 ? ((item.montant_cashback|default(0) / item.montant_achat|default(1)) * 100)|round(1, 'common') : 0 %}
                        <div class="cb-card-progress">
                            <div class="cb-progress-header">
                                <span class="cb-progress-label">Taux retour</span>
                                <span class="cb-progress-pct">{{ cb_rate }}%</span>
                            </div>
                            <div class="cb-progress-track">
                                <div class="cb-progress-fill" style="width: {{ cb_rate > 100 ? 100 : (cb_rate < 0 ? 0 : cb_rate) }}%"></div>
                            </div>
                        </div>

                        {# Rating form #}
                        <div class="cb-card-rating">
                            <div class="cb-rating-header">
                                <i class="fa-solid fa-star"></i>
                                <span>Evaluer ce partenaire</span>
                            </div>
                            <form method="post" class="cb-rating-form">
                                <input type="hidden" name="tab" value="cashback">
                                <input type="hidden" name="action" value="cashback_rating">
                                <input type="hidden" name="id_cashback" value="{{ item.id_cashback }}">

                                <div class="cb-stars" data-rating-group>
                                    {% for star in 1..5 %}
                                        <button class="cb-star-btn" type="button" data-star="{{ star }}">
                                            <i class="fa-regular fa-star"></i>
                                        </button>
                                    {% endfor %}
                                    <input type="hidden" name="user_rating" class="cb-rating-input" value="">
                                </div>

                                <input class="cb-input cb-rating-comment" type="text" name="user_rating_comment" placeholder="Laisser un commentaire…">

                                <div class="cb-rating-actions">
                                    <button class="cb-rate-submit-btn" type="submit">
                                        <i class="fa-solid fa-paper-plane"></i>
                                        Envoyer
                                    </button>
                                    <button class="cb-delete-btn"
                                            type="submit"
                                            form="cb-delete-{{ item.id_cashback }}"
                                            onclick="return confirm('Supprimer ce cashback ?');">
                                        <i class="fa-solid fa-trash-can"></i>
                                    </button>
                                    <button class="cb-edit-btn" type="button"
                                            data-cb-edit="{{ item.id_cashback }}"
                                            data-partner-id="{{ item.id_partenaire|default('') }}"
                                            data-partner-nom="{{ item.partenaire_nom|default('')|e('html_attr') }}"
                                            data-montant="{{ item.montant_achat|default(0) }}"
                                            data-statut="{{ item.statut|default('En attente')|e('html_attr') }}">
                                        <i class="fa-solid fa-pen-to-square"></i>
                                    </button>
                                </div>
                            </form>
                            <form method="post" id="cb-delete-{{ item.id_cashback }}" class="cb-delete-form">
                                <input type="hidden" name="tab" value="cashback">
                                <input type="hidden" name="action" value="cashback_delete">
                                <input type="hidden" name="id_cashback" value="{{ item.id_cashback }}">
                            </form>
                        </div>

                    </div>
                {% else %}
                    <div class="cb-empty" id="cb-empty-main">
                        <div class="cb-empty-icon">
                            <i class="fa-solid fa-hand-holding-heart"></i>
                        </div>
                        <strong>Aucun cashback enregistre</strong>
                        <span>Utilisez le formulaire pour enregistrer votre premiere transaction cashback.</span>
                        <button class="cb-empty-cta" type="button" id="cb-empty-add">
                            <i class="fa-solid fa-plus"></i> Ajouter un cashback
                        </button>
                    </div>
                {% endfor %}

                <div class="cb-empty" id="cb-no-results" hidden>
                    <div class="cb-empty-icon">
                        <i class="fa-solid fa-magnifying-glass"></i>
                    </div>
                    <strong>Aucun resultat</strong>
                    <span>Essayez un autre mot-cle ou modifiez les filtres.</span>
                </div>
            </div>

            {# TABLE VIEW (hidden by default, toggled) #}
            <div class="cb-table-wrap" id="cb-table-view" hidden>
                <table class="cb-table">
                    <thead>
                        <tr>
                            <th><span>ID</span></th>
                            <th><span>Partenaire</span></th>
                            <th><span>Montant achat</span></th>
                            <th><span>Cashback</span></th>
                            <th><span>Taux</span></th>
                            <th><span>Statut</span></th>
                            <th><span>Evaluer</span></th>
                            <th><span>Actions</span></th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for item in items %}
                            {% set st_key   = item.statut|default('En attente')|lower %}
                            {% set st_color = 'attente' in st_key ? 'amber' : ('valid' in st_key ? 'green' : 'red') %}
                            {% set cb_rate  = item.montant_achat|default(0) > 0 ? ((item.montant_cashback|default(0) / item.montant_achat|default(1)) * 100)|round(1, 'common') : 0 %}
                            <tr class="cb-tr">
                                <td>
                                    <span class="cb-id-pill">#{{ item.id_cashback }}</span>
                                </td>
                                <td>
                                    <div class="cb-tbl-partner">
                                        <div class="cb-tbl-avatar">{{ item.partenaire_nom|default('?')|first|upper }}</div>
                                        <span>{{ item.partenaire_nom|default('—') }}</span>
                                    </div>
                                </td>
                                <td>
                                    <span class="cb-tbl-amount">{{ item.montant_achat|default(0)|number_format(2, '.', ' ') }}</span>
                                    <small class="cb-tbl-cur">DT</small>
                                </td>
                                <td>
                                    <span class="cb-tbl-cashback">+{{ item.montant_cashback|default(0)|number_format(2, '.', ' ') }}</span>
                                    <small class="cb-tbl-cur">DT</small>
                                </td>
                                <td>
                                    <div class="cb-tbl-rate-wrap">
                                        <div class="cb-tbl-rate-bar">
                                               <div class="cb-tbl-rate-fill" style="width:{{ cb_rate > 100 ? 100 : (cb_rate < 0 ? 0 : cb_rate) }}%"></div>
                                        </div>
                                        <span class="cb-tbl-rate-pct">{{ cb_rate }}%</span>
                                    </div>
                                </td>
                                <td>
                                    <span class="cb-status-badge cb-status-{{ st_color }}">
                                        {{ item.statut|default('—') }}
                                    </span>
                                </td>
                                <td>
                                    <form method="post" class="cb-tbl-rate-form">
                                        <input type="hidden" name="tab" value="cashback">
                                        <input type="hidden" name="action" value="cashback_rating">
                                        <input type="hidden" name="id_cashback" value="{{ item.id_cashback }}">
                                        <div class="cb-tbl-rate-row">
                                            <input class="cb-input cb-tbl-rate-input" type="number" step="0.1" max="5" name="user_rating" placeholder="0-5">
                                            <input class="cb-input cb-tbl-comment-input" type="text" name="user_rating_comment" placeholder="Commentaire…">
                                            <button class="cb-tbl-rate-btn" type="submit">
                                                <i class="fa-solid fa-star"></i>
                                            </button>
                                        </div>
                                    </form>
                                </td>
                                <td>
                                    <div class="cb-tbl-actions">
                                        <button class="cb-tbl-edit-btn" type="button"
                                                data-cb-edit="{{ item.id_cashback }}"
                                                data-partner-id="{{ item.id_partenaire|default('') }}"
                                                data-partner-nom="{{ item.partenaire_nom|default('')|e('html_attr') }}"
                                                data-montant="{{ item.montant_achat|default(0) }}"
                                                data-statut="{{ item.statut|default('En attente')|e('html_attr') }}">
                                            <i class="fa-solid fa-pen-to-square"></i>
                                        </button>
                                        <form method="post" onsubmit="return confirm('Supprimer ?');">
                                            <input type="hidden" name="tab" value="cashback">
                                            <input type="hidden" name="action" value="cashback_delete">
                                            <input type="hidden" name="id_cashback" value="{{ item.id_cashback }}">
                                            <button class="cb-tbl-del-btn" type="submit">
                                                <i class="fa-solid fa-trash-can"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="8">
                                    <div class="cb-tbl-empty">
                                        <i class="fa-solid fa-hand-holding-heart"></i>
                                        <span>Aucun cashback enregistre</span>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            {# Footer stats #}
            <div class="cb-footer-stats">
                <div class="cb-fs-item">
                    <i class="fa-solid fa-layer-group"></i>
                    <span>Total: <strong>{{ items|length }}</strong></span>
                </div>
                <div class="cb-fs-item">
                    <i class="fa-solid fa-coins"></i>
