  .cb-modal { padding: 12px; }
  .cb-modal-dialog,
  .cb-modal-dialog-wide { width: min(100%, calc(100vw - 12px)); }
  .cb-toolbar { flex-direction: column; align-items: stretch; }
  .cb-toolbar-right { flex-wrap: wrap; }
  .cb-search-box input { width: 100%; }
  .cb-field-group-2 { grid-template-columns: 1fr; }
  .cb-grid { grid-template-columns: 1fr; }
  .cb-assistant-form { grid-template-columns: 1fr; }
  .cb-bundle-kpis { grid-template-columns: 1fr; }
  .cb-page-header-inner { flex-direction: column; align-items: flex-start; }
  .cb-footer-stats { flex-direction: column; align-items: flex-start; }
}
</style>

<script>
(() => {
  'use strict';

  const ready = (fn) => document.readyState === 'loading'
    ? document.addEventListener('DOMContentLoaded', fn)
    : fn();

  ready(() => {
    const root = document.querySelector('.cb-root');
    if (!root) return;

    const $  = (sel, ctx = root) => ctx.querySelector(sel);
    const $$ = (sel, ctx = root) => Array.from(ctx.querySelectorAll(sel));
    const $doc = (sel) => document.querySelector(sel);
    const $$doc = (sel) => Array.from(document.querySelectorAll(sel));

    /* ── MODALS ── */
    const assistantOpenBtn = $('#cb-open-assistant');
    const bundleOpenBtn = $('#cb-open-bundle');
    const assistantModal = document.getElementById('cb-assistant-modal');
    const bundleModal = document.getElementById('cb-bundle-modal');
    const allModals = [assistantModal, bundleModal].filter(Boolean);
    let activeModal = null;

    const lockBody = (locked) => {
      document.body.style.overflow = locked ? 'hidden' : '';
    };

    const openModal = (modal) => {
      if (!modal) return;
      allModals.forEach((item) => { item.hidden = true; });
      modal.hidden = false;
      activeModal = modal;
      lockBody(true);
    };

    const closeModal = (modal = activeModal) => {
      if (!modal) return;
      modal.hidden = true;
      if (activeModal === modal) {
        activeModal = null;
      }
      if (!allModals.some((item) => item && !item.hidden)) {
        lockBody(false);
      }
    };

    assistantOpenBtn?.addEventListener('click', () => openModal(assistantModal));
    bundleOpenBtn?.addEventListener('click', () => openModal(bundleModal));

    document.addEventListener('click', (event) => {
      const trigger = event.target.closest('[data-cb-close-modal]');
      if (!trigger) return;
      closeModal(trigger.closest('.cb-modal'));
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && activeModal) {
        closeModal(activeModal);
      }
    });

    /* ── DARK MODE ── */
    const darkBtn  = $('#cb-dark-toggle');
    const DARK_KEY = 'nexora-cashback-dark';

    const applyDark = (on) => {
      root.classList.toggle('cb-dark', on);
      if (darkBtn) {
        darkBtn.querySelector('i').className = on ? 'fa-solid fa-sun' : 'fa-solid fa-moon';
      }
    };

    applyDark(localStorage.getItem(DARK_KEY) === '1');
    darkBtn?.addEventListener('click', () => {
      const next = !root.classList.contains('cb-dark');
      applyDark(next);
      localStorage.setItem(DARK_KEY, next ? '1' : '0');
    });

    /* ── FORM COLLAPSE ── */
    const collapseBtn = $('#cb-collapse-form');
    const formCard    = $('#cb-form-card');

    collapseBtn?.addEventListener('click', () => {
      formCard?.classList.toggle('cb-form-collapsed');
      const i = collapseBtn.querySelector('i');
      if (i) {
        i.className = formCard?.classList.contains('cb-form-collapsed')
          ? 'fa-solid fa-chevron-right'
          : 'fa-solid fa-chevron-left';
      }
    });

    /* ── ADD NEW BUTTON ── */
    const addBtn      = $('#cb-add-btn');
    const emptyAddBtn = $('#cb-empty-add');
    const cashbackForm = $('#cashback-form');

    const resetAndFocus = () => {
      closeModal();
      cashbackForm?.reset();
      const idFld = $('#cb-id-field');
      if (idFld) idFld.value = '';
      updateEstimator();
      document.getElementById('cb-form-card')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    };

    addBtn?.addEventListener('click', resetAndFocus);
    emptyAddBtn?.addEventListener('click', resetAndFocus);

    /* ── EDIT FILL ── */
    const fillForm = (btn) => {
      if (!cashbackForm) return;
      const set = (name, val) => {
        const f = cashbackForm.querySelector(`[name="${name}"]`);
        if (f) f.value = val ?? '';
      };
      set('id_cashback',    btn.dataset.cbEdit);
      set('id_partenaire',  btn.dataset.partnerId);
      set('partenaire_nom', btn.dataset.partnerNom);
      set('montant_achat',  btn.dataset.montant);
      set('statut',         btn.dataset.statut);
      updateEstimator();
      document.getElementById('cb-form-card')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    };

    $$('[data-cb-edit]').forEach((btn) => {
      btn.addEventListener('click', () => fillForm(btn));
    });

    /* ── CASHBACK ESTIMATOR ── */
    const montantAchatField = $('#cb-montant-achat');
    const partnerIdField    = document.querySelector('select[name="id_partenaire"]');
    const partnerNameField  = $('#cb-partenaire-nom');
    const estValue          = $('#cb-est-value');
    const estRate           = $('#cb-est-rate');
    let estimatorRequestId  = 0;

    const updateEstimator = async () => {
      const amount = parseFloat(montantAchatField?.value) || 0;
      const partnerId = partnerIdField?.value || '';
      const partnerName = (partnerNameField?.value || '').trim();

      if (estValue) estValue.textContent = '0.00 DT';
      if (estRate) estRate.textContent = '0.00%';

      if (amount <= 0 || (!partnerId && !partnerName)) {
        return;
      }

      const requestId = ++estimatorRequestId;

      try {
        const response = await fetch('{{ path('app_portal_cashback_calculate') }}', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
            'X-Requested-With': 'XMLHttpRequest'
          },
          body: new URLSearchParams({
            montant_achat: String(amount),
            id_partenaire: partnerId,
            partenaire_nom: partnerName
          })
        });

        const data = await response.json();
        if (requestId !== estimatorRequestId) {
          return;
        }

        if (partnerNameField && !partnerName && data.partner_name) {
          partnerNameField.value = data.partner_name;
        }

        if (estRate && data.taux !== undefined) {
          estRate.textContent = `${data.taux}%`;
        }

        if (estValue && data.montant_cashback !== undefined) {
          estValue.textContent = `${data.montant_cashback} DT`;
        }
      } catch (error) {
        console.error('Cashback calculation failed:', error);
      }
    };

    partnerIdField?.addEventListener('change', () => {
      const selectedOption = partnerIdField.options[partnerIdField.selectedIndex];
      if (partnerNameField && selectedOption && selectedOption.value) {
        partnerNameField.value = selectedOption.textContent.trim();
      }
      updateEstimator();
    });

    partnerNameField?.addEventListener('input', updateEstimator);
    montantAchatField?.addEventListener('input', updateEstimator);
    montantAchatField?.addEventListener('change', updateEstimator);

    updateEstimator();

    /* ── STAR RATING ── */
    $$('[data-rating-group]').forEach((group) => {
      const stars = $$('.cb-star-btn', group);
      const hidden = group.querySelector('.cb-rating-input');

      stars.forEach((star, idx) => {
        star.addEventListener('mouseenter', () => {
          stars.forEach((s, i) => {
            s.querySelector('i').className = i <= idx
              ? 'fa-solid fa-star'
              : 'fa-regular fa-star';
          });
        });

        star.addEventListener('mouseleave', () => {
          const selected = parseInt(hidden?.value || '0', 10);
          stars.forEach((s, i) => {
            s.querySelector('i').className = i < selected
              ? 'fa-solid fa-star'
              : 'fa-regular fa-star';
            s.classList.toggle('cb-star-filled', i < selected);
          });
        });

        star.addEventListener('click', () => {
          const val = idx + 1;
          if (hidden) hidden.value = val;
          stars.forEach((s, i) => {
            s.querySelector('i').className = i < val
              ? 'fa-solid fa-star'
              : 'fa-regular fa-star';
            s.classList.toggle('cb-star-filled', i < val);
          });
        });
      });
    });

    /* ── VIEW TOGGLE (Cards ↔ Table) ── */
    const viewToggleBtn = $('#cb-view-toggle');
    const gridView      = $('#cb-grid');
    const tableView     = $('#cb-table-view');
    let   isTableView   = false;

    viewToggleBtn?.addEventListener('click', () => {
      isTableView = !isTableView;
      if (gridView)  gridView.hidden  = isTableView;
      if (tableView) tableView.hidden = !isTableView;
      const i = viewToggleBtn.querySelector('i');
      const s = viewToggleBtn.querySelector('span');
      if (i) i.className = isTableView ? 'fa-solid fa-table-cells-large' : 'fa-solid fa-table-cells';
      if (s) s.textContent = isTableView ? 'Vue cartes' : 'Vue tableau';
    });

    /* ── SEARCH, SORT & FILTER ── */
    const searchInput = $('#cb-search-input');
    const searchClear = $('#cb-search-clear');
    const sortSelect  = $('#cb-sort-select');
    const filterTabs  = $$('.cb-filter-tab');
    const allCards    = $$('[data-cb-id]');
    const noResults   = $('#cb-no-results');

    let activeFilter = 'all';

    const applyState = () => {
      const kw   = (searchInput?.value ?? '').trim().toLowerCase();
      const sort = sortSelect?.value ?? 'id_desc';

      if (searchClear) searchClear.hidden = kw === '';

      const parseNum = (v) => { const n = Number(v); return isFinite(n) ? n : 0; };

      const visible = allCards.filter((card) => {
        const text  = card.dataset.cbSearch ?? '';
        const st    = card.dataset.cbStatus ?? '';
        const matchKw = kw === '' || text.includes(kw);
        const matchFilter = activeFilter === 'all' || st.includes(activeFilter);
        const show = matchKw && matchFilter;
        card.classList.toggle('cb-hidden', !show);
        return show;
      });

      visible.sort((a, b) => {
        const idA = parseNum(a.dataset.cbId);
        const idB = parseNum(b.dataset.cbId);
        const amA = parseNum(a.dataset.cbAmount);
        const amB = parseNum(b.dataset.cbAmount);
        const cbA = parseNum(a.dataset.cbCashback);
        const cbB = parseNum(b.dataset.cbCashback);

        switch (sort) {
          case 'id_asc':       return idA - idB;
          case 'amount_desc':  return amB - amA;
          case 'amount_asc':   return amA - amB;
          case 'cashback_desc':return cbB - cbA;
          default:             return idB - idA;
        }
      });

      const grid = $('#cb-grid');
      if (grid) visible.forEach((c) => grid.appendChild(c));

      if (noResults) noResults.hidden = visible.length > 0;
    };

    searchInput?.addEventListener('input', applyState);
    searchClear?.addEventListener('click', () => {
      if (searchInput) searchInput.value = '';
      applyState();
    });
    sortSelect?.addEventListener('change', applyState);

    filterTabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        activeFilter = tab.dataset.filter ?? 'all';
        filterTabs.forEach((t) => t.classList.remove('cb-filter-active'));
        tab.classList.add('cb-filter-active');
        applyState();
      });
    });

    /* ── CASHBACK ASSISTANT ── */
    const assistantMessages = $doc('#cb-assistant-messages');
    const assistantForm = $doc('#cb-assistant-form');
    const assistantInput = $doc('#cb-assistant-input');
    const starterButtons = $$doc('[data-cb-starter]');

    const renderSuggestionButton = (label) => {
      const button = document.createElement('button');
      button.type = 'button';
      button.className = 'cb-starter-btn';
      button.textContent = label;
      button.addEventListener('click', () => sendAssistantMessage(label));
      return button;
    };

    const appendBubble = (role, content) => {
      if (!assistantMessages) return;

      const bubble = document.createElement('article');
      bubble.className = `cb-chat-bubble ${role === 'user' ? 'cb-chat-bubble-user' : 'cb-chat-bubble-bot'}`;

      const label = document.createElement('strong');
      label.textContent = role === 'user' ? 'Vous' : (content.title || 'Assistant');
      bubble.appendChild(label);

      if (content.text) {
        const text = document.createElement('p');
        text.textContent = content.text;
        bubble.appendChild(text);
      }

      if (Array.isArray(content.metrics) && content.metrics.length > 0) {
        const metrics = document.createElement('div');
        metrics.className = 'cb-chat-metrics';
        content.metrics.forEach((item) => {
          const chip = document.createElement('span');
          chip.textContent = `${item.label}: ${item.value}`;
          metrics.appendChild(chip);
        });
        bubble.appendChild(metrics);
      }

      if (Array.isArray(content.offers) && content.offers.length > 0) {
        const offers = document.createElement('div');
        offers.className = 'cb-chat-offers';
        content.offers.forEach((item) => {
          const card = document.createElement('span');
          const reason = item.reason ? ` | ${item.reason}` : '';
          const city = item.city ? ` | ${item.city}` : '';
          card.textContent = `${item.name}${city} | ${item.cashback_max} max | ${item.rating}/5${reason}`;
          offers.appendChild(card);
        });
        bubble.appendChild(offers);
      }

      if (role !== 'user' && Array.isArray(content.suggestions) && content.suggestions.length > 0) {
        const suggestions = document.createElement('div');
        suggestions.className = 'cb-assistant-starters';
        content.suggestions.forEach((item) => {
          if (typeof item === 'string' && item.trim() !== '') {
            suggestions.appendChild(renderSuggestionButton(item.trim()));
          }
        });
        if (suggestions.childNodes.length > 0) {
          bubble.appendChild(suggestions);
        }
      }

      assistantMessages.appendChild(bubble);
      assistantMessages.scrollTop = assistantMessages.scrollHeight;
    };

    const sendAssistantMessage = async (message) => {
      const trimmed = (message || '').trim();
      if (!trimmed) return;

      appendBubble('user', { text: trimmed });
      if (assistantInput) assistantInput.value = '';

      try {
        const response = await fetch('{{ path('app_portal_cashback_assistant') }}', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
            'X-Requested-With': 'XMLHttpRequest'
          },
          body: new URLSearchParams({ message: trimmed })
        });

        const data = await response.json();
        if (!data.ok || !data.reply) {
          throw new Error(data.debug ? `${data.message || 'Assistant indisponible.'} (${data.debug})` : (data.message || 'Assistant indisponible.'));
        }

        appendBubble('bot', {
          title: data.reply.title || 'Assistant',
          text: data.reply.answer || 'Aucune reponse disponible.',
          metrics: Array.isArray(data.reply.metrics) ? data.reply.metrics : [],
          offers: Array.isArray(data.reply.offers) ? data.reply.offers : [],
          suggestions: Array.isArray(data.reply.suggestions) ? data.reply.suggestions : []
        });
      } catch (error) {
        appendBubble('bot', {
          title: 'Assistant',
          text: error && error.message ? error.message : 'Une erreur est survenue pendant la reponse du chatbot.'
        });
      }
    };

    assistantForm?.addEventListener('submit', (event) => {
      event.preventDefault();
      sendAssistantMessage(assistantInput?.value || '');
    });

    starterButtons.forEach((button) => {
      button.addEventListener('click', () => sendAssistantMessage(button.dataset.cbStarter || ''));
    });

    /* ── QR BUNDLE ── */
    const bundleImage = $doc('#cb-bundle-qr-image');
    const bundlePlaceholder = $doc('#cb-bundle-placeholder');
    const bundleMeta = $doc('#cb-bundle-meta');
    const bundleKpis = $doc('#cb-bundle-kpis');
    const bundleRefresh = $doc('#cb-bundle-refresh');
    const bundleDownload = $doc('#cb-bundle-download');

    const renderBundle = (payload) => {
      if (!payload || !payload.ok) return;

      if (bundleImage && payload.qr_image_data_url) {
        bundleImage.src = payload.qr_image_data_url;
        bundleImage.hidden = false;
      }
      if (bundlePlaceholder) bundlePlaceholder.hidden = true;
      if (bundleDownload && payload.download_url) bundleDownload.href = payload.download_url;

      const summary = payload.summary || {};
      if (bundleKpis) {
        bundleKpis.innerHTML = '';
        [
          ['Cashback total', `${Number(summary.total_cashback || 0).toFixed(2)} DT`],
          ['Valide / credite', `${Number(summary.approved_cashback || 0).toFixed(2)} DT`],
          ['Dossiers', String(summary.count || 0)],
          ['En attente', String(summary.pending_count || 0)]
        ].forEach(([label, value]) => {
          const card = document.createElement('div');
          card.className = 'cb-bundle-kpi';
          const labelNode = document.createElement('span');
          labelNode.textContent = label;
          const valueNode = document.createElement('strong');
          valueNode.textContent = value;
          card.appendChild(labelNode);
          card.appendChild(valueNode);
          bundleKpis.appendChild(card);
        });
      }

      if (bundleMeta) {
        const bestPartner = summary.best_partner ? `Partenaire fort: ${summary.best_partner}.` : 'Aucun partenaire dominant pour le moment.';
        bundleMeta.innerHTML = '';
        const paragraph = document.createElement('p');
        paragraph.textContent = `Hash bundle: ${payload.hash || '-'} | Genere le ${payload.generated_at || '-'} | ${bestPartner}`;
        bundleMeta.appendChild(paragraph);
      }
    };

    const loadBundle = async () => {
      try {
        if (bundlePlaceholder) {
          bundlePlaceholder.hidden = false;
          bundlePlaceholder.querySelector('span').textContent = 'Generation du QR cashback...';
        }

        const response = await fetch('{{ path('app_portal_cashback_bundle') }}', {
          headers: { 'X-Requested-With': 'XMLHttpRequest' }
        });
        const data = await response.json();
        if (!data.ok) {
          throw new Error(data.debug ? `${data.message || 'Impossible de generer le bundle cashback.'} (${data.debug})` : (data.message || 'Impossible de generer le bundle cashback.'));
        }
        renderBundle(data);
      } catch (error) {
        if (bundlePlaceholder) {
          bundlePlaceholder.hidden = false;
          bundlePlaceholder.querySelector('span').textContent = error && error.message ? error.message : 'Erreur pendant la generation du QR.';
        }
        if (bundleImage) bundleImage.hidden = true;
      }
    };

    bundleRefresh?.addEventListener('click', loadBundle);
    loadBundle();

    applyState();
  });
})();
</script>

<style>
.cb-val-msg{font-size:12px;font-weight:600;margin-top:4px;display:block;min-height:16px}
.cb-val-msg.ok{color:#16a34a}
.cb-val-msg.err{color:#dc2626}
#cashback-form .cb-input.cb-v-invalid{border-color:#dc2626!important;box-shadow:0 0 0 3px rgba(220,38,38,.12)!important;background:#fff5f5!important}
#cashback-form .cb-input.cb-v-valid{border-color:#16a34a!important;box-shadow:0 0 0 3px rgba(22,163,74,.1)!important;background:#f0fdf4!important}
</style>
<script>
(function(){
function g(id){return document.getElementById(id);}
function setOk(inputId,spanId){
  var el=g(inputId),s=g(spanId);
  if(el){el.classList.remove('cb-v-invalid');el.classList.add('cb-v-valid');}
  if(s){s.className='cb-val-msg ok';s.textContent='✓ Valide';}
  return true;
}
function setErr(inputId,spanId,msg){
  var el=g(inputId),s=g(spanId);
  if(el){el.classList.remove('cb-v-valid');el.classList.add('cb-v-invalid');}
  if(s){s.className='cb-val-msg err';s.textContent='⚠ '+msg;}
  return false;
}
function clr(inputId,spanId){
  var el=g(inputId),s=g(spanId);
  if(el){el.classList.remove('cb-v-valid','cb-v-invalid');}
  if(s){s.className='cb-val-msg';s.textContent='';}
  return true;
}

function vPartenaire(){
  var el=g('cb-partenaire-nom');
  if(!el)return true;
  var v=el.value.trim();
  if(!v)return setErr('cb-partenaire-nom','cb-err-partenaire','Le nom du partenaire est obligatoire.');
  if(v.length<2)return setErr('cb-partenaire-nom','cb-err-partenaire','Min. 2 caractères.');
  return setOk('cb-partenaire-nom','cb-err-partenaire');
}
function vMontant(){
  var el=g('cb-montant-achat');
  if(!el)return true;
  if(!el.value)return setErr('cb-montant-achat','cb-err-montant','Le montant d\'achat est obligatoire.');
  var v=parseFloat(el.value);
  if(isNaN(v)||v<=0)return setErr('cb-montant-achat','cb-err-montant','Doit être un nombre positif.');
  return setOk('cb-montant-achat','cb-err-montant');
}

/* Live */
var pEl=g('cb-partenaire-nom');
if(pEl){['input','blur'].forEach(function(e){pEl.addEventListener(e,vPartenaire);});}
var mEl=g('cb-montant-achat');
if(mEl){['input','blur'].forEach(function(e){mEl.addEventListener(e,vMontant);});}

/* Submit */
var form=g('cashback-form');
if(form){
  form.addEventListener('submit',function(e){
    var ok=vPartenaire()&vMontant();
    if(!ok)e.preventDefault();
  });
}
})();
</script>
