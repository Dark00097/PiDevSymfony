{% set partners = support.partners|default(support.partenaires|default([])) %}
{% set stats = support.stats|default({}) %}

<div class="cb-root">
    <section class="cb-page-header">
        <div>
            <h1>Recompenses</h1>
            <p>Cashback et offres exclusives</p>
        </div>
    </section>

    <section class="cb-summary-cards">
        <div class="cb-summary-card">
            <strong>{{ stats.total_rewards|default(0)|number_format(2, '.', ' ') }} DT</strong>
            <span>Solde disponible</span>
        </div>
        <div class="cb-summary-card">
            <strong>{{ stats.month_total|default(0)|number_format(2, '.', ' ') }} DT</strong>
            <span>Ce mois-ci</span>
        </div>
        <div class="cb-summary-card">
            <strong>{{ stats.week_total|default(0)|number_format(2, '.', ' ') }} DT</strong>
            <span>Cette semaine</span>
        </div>
        <div class="cb-summary-card">
            <strong>{{ stats.pending_count|default(0) }}</strong>
            <span>En attente</span>
        </div>
    </section>

    <div class="cb-layout">
        <aside class="cb-sidebar">
            <div class="cb-box cb-box-highlight">
                <div class="cb-box-title">
                    <span>+</span>
                    <div>
                        <strong>Ajouter une nouvelle entree</strong>
                        <p>Saisir votre cashback</p>
                    </div>
                </div>

                <form method="post" action="{{ path('portal_dashboard') }}" class="cb-form" id="cashbackForm">
                    <input type="hidden" name="tab" value="cashback">
                    <input type="hidden" name="action" value="cashback_save">
                    <input type="hidden" name="id_user" value="{{ current_user.idUser }}">
                    <input type="hidden" name="statut" value="En attente">

                    <label>Selectionner un partenaire</label>
                    <select name="partenaire_nom" id="partnerSelect" required>
                        <option value="">-- Selectionnez --</option>
                        {% for partner in partners %}
                            <option value="{{ partner.nom }}">{{ partner.nom }}{% if partner.categorie is not empty %} • {{ partner.categorie }}{% endif %}</option>
                        {% endfor %}
                    </select>

                    <div class="cb-two-columns">
                        <div>
                            <label>Montant achat</label>
                            <div class="cb-input-with-prefix">
                                <span>DT</span>
                                <input type="number" name="montant_achat" id="montantInput" step="0.01" min="0" placeholder="0.00" required>
                            </div>
                        </div>
                        <div>
                            <label>Date achat</label>
                            <input type="date" name="date_achat" value="{{ 'now'|date('Y-m-d') }}" required>
                        </div>
                    </div>

                    <div class="cb-two-columns">
                        <div>
                            <label>Taux applique</label>
                            <input type="text" id="tauxDisplay" value="0.00" readonly>
                            <input type="hidden" name="taux_applique" id="tauxHidden" value="0.00">
                        </div>
                        <div>
                            <label>Montant cashback</label>
                            <input type="text" id="cashbackDisplay" value="0.00" readonly>
                            <input type="hidden" name="montant_cashback" id="cashbackHidden" value="0.00">
                        </div>
                    </div>

                    <label>Reference transaction (optionnel)</label>
                    <input type="text" name="transaction_ref" placeholder="Saisir reçu ou numero de transaction">

                    <div class="cb-estimate-box">
                        <div>
                            <strong>Cashback estime</strong>
                            <span>Base sur votre achat</span>
                        </div>
                        <strong class="cb-estimate-value" id="estimateValue">+0.00 DT</strong>
                        <p>Sera credite sous 3-5 jours</p>
                    </div>

                    <button type="submit" class="cb-button cb-button-primary">Saisir cashback</button>
                </form>

                <script>
                    const partnerSelect = document.getElementById('partnerSelect');
                    const montantInput = document.getElementById('montantInput');
                    const tauxDisplay = document.getElementById('tauxDisplay');
                    const cashbackDisplay = document.getElementById('cashbackDisplay');
                    const tauxHidden = document.getElementById('tauxHidden');
                    const cashbackHidden = document.getElementById('cashbackHidden');
                    const estimateValue = document.getElementById('estimateValue');

                    async function calculateCashback() {
                        const montant = parseFloat(montantInput.value) || 0;
                        const partner = partnerSelect.value;

                        if (montant <= 0 || !partner) {
                            tauxDisplay.value = '0.00';
                            cashbackDisplay.value = '0.00';
                            tauxHidden.value = '0.00';
                            cashbackHidden.value = '0.00';
                            estimateValue.textContent = '+0.00 DT';
                            return;
                        }

                        try {
                            const response = await fetch('{{ path('app_portal_cashback_calculate') }}', {
                                method: 'POST',
                                headers: {
                                    'Content-Type': 'application/x-www-form-urlencoded',
                                    'X-Requested-With': 'XMLHttpRequest'
                                },
                                body: new URLSearchParams({
                                    'montant_achat': montant,
                                    'partenaire_nom': partner
                                })
                            });

                            const data = await response.json();
                            
                            if (data.taux !== undefined) {
                                tauxDisplay.value = data.taux;
                                tauxHidden.value = data.taux;
                            }
                            
                            if (data.montant_cashback !== undefined) {
                                cashbackDisplay.value = data.montant_cashback;
                                cashbackHidden.value = data.montant_cashback;
                                estimateValue.textContent = '+' + data.montant_cashback + ' DT';
                            }
                        } catch (error) {
                            console.error('Error calculating cashback:', error);
                        }
                    }

                    partnerSelect.addEventListener('change', calculateCashback);
                    montantInput.addEventListener('input', calculateCashback);
                    montantInput.addEventListener('change', calculateCashback);
                </script>
            </div>

            <div class="cb-box">
                <h2>Commercants partenaires</h2>
                <div class="cb-partner-grid">
                    {% for partner in partners %}
                        <article class="cb-partner-card">
                            <strong>{{ partner.nom|default('N/A') }}</strong>
                            <span>Taux cashback Jusqu'a {{ partner.taux_cashback|default(0) }}%</span>
                            <div class="cb-partner-meta">
                                <span>Rating</span>
                                <strong>{{ partner.rating|default(0)|number_format(1, '.', '') }}★</strong>
                            </div>
                        </article>
                    {% else %}
                        <p>Aucun partenaire disponible.</p>
                    {% endfor %}
                </div>
            </div>
        </aside>

        <main class="cb-content">
            {% set bestPartner = '' %}
            {% set bestEarnings = 0 %}
            {% for partnerName, amount in support.partner_earnings|default({}) %}
                {% if amount > bestEarnings %}
                    {% set bestEarnings = amount %}
                    {% set bestPartner = partnerName %}
                {% endif %}
            {% endfor %}

            <div class="cb-box cb-ai-card">
                <div class="cb-box-header">
                    <h2>Analyse cashback</h2>
                    <span>En direct</span>
                </div>
                <div class="cb-ai-body">
                    <p>Vos récompenses se mettent à jour dès que vous saisissez un nouveau cashback.</p>
                    <ul class="cb-insight-list">
                        <li><strong>{{ items|length|default(0) }}</strong> cashback enregistrés</li>
                        <li><strong>{{ partners|length|default(0) }}</strong> partenaires actifs</li>
                        <li><strong>{{ bestEarnings|number_format(2, '.', ' ') }} DT</strong> gagnés avec {{ bestPartner ? bestPartner|title : 'aucun partenaire' }}</li>
                    </ul>
                    <button type="button" class="cb-button cb-button-secondary" onclick="window.location.reload()">Rafraîchir</button>
                </div>
                <div class="cb-ai-footer">
                    <span>Dernière mise à jour : {{ 'now'|date('d/m/Y H:i') }}</span>
                </div>
            </div>

            <div class="cb-box">
                <div class="cb-box-header">
                    <h2>Vos recompenses</h2>
                    <select class="cb-filter-select" id="filterStatus">
                        <option value="">Toute periode</option>
                        <option value="Valide">Creditees</option>
                        <option value="En attente">En attente</option>
                        <option value="Expire">Expirees</option>
                    </select>
                </div>

                {% if items|length > 0 %}
                    <div class="cb-rewards-list">
                        {% for item in items %}
                            <article class="cb-reward-item" data-status="{{ item.statut|default('') }}">
                                <div class="cb-reward-header">
                                    <div class="cb-reward-partner">
                                        <strong class="cb-partner-name">{{ item.partenaire_nom|default('N/A') }}</strong>
                                        <span class="cb-status-badge cb-status-{{ item.statut|lower|replace({' ': '-'}) }}">
                                            {{ item.statut|default('-') }}
                                        </span>
                                    </div>
                                    <div class="cb-reward-actions">
                                        {% if item.statut == 'En attente' %}
                                            <button type="button" class="cb-action-btn cb-btn-rate" data-id="{{ item.id_cashback }}" title="Evaluer">Noter</button>
                                        {% elseif item.statut == 'Valide' %}
                                            <button type="button" class="cb-action-btn cb-btn-modify" data-id="{{ item.id_cashback }}" data-partner="{{ item.partenaire_nom }}" data-amount="{{ item.montant_achat }}" data-date="{{ item.date_achat }}" data-ref="{{ item.transaction_ref }}" title="Modifier">Modifier ...</button>
                                        {% endif %}
                                        <button type="button" class="cb-action-btn cb-btn-delete" data-id="{{ item.id_cashback }}" title="Supprimer">Vider</button>
                                        {% if item.bonus_decision %}
                                            <button type="button" class="cb-action-btn cb-btn-bonus" data-id="{{ item.id_cashback }}" title="Bonus" disabled>{{ item.bonus_decision }}</button>
                                        {% endif %}
                                    </div>
                                </div>

                                <div class="cb-reward-details">
                                    <div class="cb-detail-row">
                                        <span class="cb-detail-label">Achat :</span>
                                        <strong>$ {{ item.montant_achat|default(0)|number_format(2, '.', '') }}</strong>
                                        
                                        <span class="cb-detail-label">Date :</span>
                                        <span>{{ item.date_achat|default('-') }}</span>
                                        
                                        <span class="cb-detail-label">Ref :</span>
                                        <span class="cb-transaction-ref">
                                            {% set ref = item.transaction_ref|default('-') %}
                                            {% if ref|length > 30 %}
                                                {{ ref|slice(0, 27) }}...
                                            {% else %}
                                                {{ ref }}
                                            {% endif %}
                                        </span>
                                    </div>

                                    <div class="cb-detail-row">
                                        <span class="cb-detail-label">Note :</span>
                                        <span class="cb-rating-display">
                                            {% if item.user_rating %}
                                                {% set stars = item.user_rating > 5 ? 5 : item.user_rating %}
                                                {% for i in 1..5 %}
                                                    {% if i <= stars %}★{% else %}☆{% endif %}
                                                {% endfor %}
                                                ({{ item.user_rating|number_format(1, '.', '') }}/5)
                                            {% else %}
                                                ☆☆☆☆☆
                                            {% endif %}
                                        </span>

                                        <span class="cb-detail-label">Bonus :</span>
                                        <span class="cb-bonus-display">
                                            {% if item.bonus_decision == 'Approved' %}
                                                <span class="cb-bonus-approved">Approv...</span>
                                            {% elseif item.bonus_decision == 'Rejected' %}
                                                <span class="cb-bonus-rejected">Rejete</span>
                                            {% else %}
                                                <span class="cb-bonus-pending">Pending</span>
                                            {% endif %}
                                        </span>

                                        <span class="cb-detail-label">Taux :</span>
                                        <strong class="cb-rate-display">{{ item.taux_applique|default(0)|number_format(2, '.', '') }}%</strong>
                                    </div>

                                    <div class="cb-detail-row">
                                        <span class="cb-detail-label">Cashback :</span>
                                        <strong class="cb-cashback-amount">{{ item.montant_cashback|default(0)|number_format(2, '.', '') }} DT</strong>
                                    </div>

                                    {% if item.bonus_note %}
                                        <div class="cb-bonus-note">
                                            <small>📝 {{ item.bonus_note }}</small>
                                        </div>
                                    {% endif %}
                                </div>
                            </article>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="cb-empty-state">
                        <p>Aucune transaction cashback trouvee.</p>
                    </div>
                {% endif %}
            </div>

            <!-- Modify Modal -->
            <div id="modifyModal" class="cb-modal" style="display: none;">
                <div class="cb-modal-content">
                    <div class="cb-modal-header">
                        <h3>Modifier cette transaction</h3>
                        <button type="button" class="cb-modal-close" onclick="closeModifyModal()">&times;</button>
                    </div>
                    <form id="modifyForm" method="post" action="{{ path('portal_dashboard') }}" class="cb-form cb-modify-form">
                    </form>
                </div>
            </div>

            <!-- Rating Modal -->
            <div id="ratingModal" class="cb-modal" style="display: none;">
                <div class="cb-modal-content">
                    <div class="cb-modal-header">
                        <h3>Evaluer cette transaction</h3>
                        <button type="button" class="cb-modal-close" onclick="closeRatingModal()">&times;</button>
                    </div>
                    <form id="ratingForm" method="post" action="{{ path('portal_dashboard') }}">
                        <input type="hidden" name="tab" value="cashback">
                        <input type="hidden" name="action" value="cashback_rating">
                        <input type="hidden" name="id_cashback" value="">

                        <div class="cb-form-group">
                            <label>Votre evaluation</label>
                            <div class="cb-star-rating">
                                {% for i in 1..5 %}
                                    <input type="radio" name="user_rating" value="{{ i }}" id="star{{ i }}" style="display: none;">
                                    <label for="star{{ i }}" class="cb-star" data-value="{{ i }}">★</label>
                                {% endfor %}
                            </div>
                        </div>

                        <div class="cb-form-group">
                            <label>Commentaire (optionnel)</label>
                            <textarea name="user_rating_comment" placeholder="Partagez votre experience..." rows="3"></textarea>
                        </div>

                        <div class="cb-modal-footer">
                            <button type="button" class="cb-button cb-button-secondary" onclick="closeRatingModal()">Annuler</button>
                            <button type="submit" class="cb-button cb-button-primary">Soumettre evaluation</button>
                        </div>
                    </form>
                </div>
            </div>

            <script>
                let currentRatingId = null;

                // Rating handlers
                document.querySelectorAll('.cb-btn-rate').forEach(btn => {
                    btn.addEventListener('click', function() {
                        currentRatingId = this.getAttribute('data-id');
                        document.querySelector('input[name="id_cashback"]').value = currentRatingId;
                        document.getElementById('ratingModal').style.display = 'flex';
                    });
                });

                // Star rating interaction
                document.querySelectorAll('.cb-star').forEach(star => {
                    star.addEventListener('click', function() {
                        const value = this.getAttribute('data-value');
                        document.querySelector(`input[value="${value}"]`).checked = true;
                        
                        // Update star display
                        document.querySelectorAll('.cb-star').forEach(s => {
                            s.classList.remove('cb-star-active');
                        });
                        for (let i = 1; i <= value; i++) {
                            document.querySelector(`label[for="star${i}"]`).classList.add('cb-star-active');
                        }
                    });
                });

                function closeRatingModal() {
                    document.getElementById('ratingModal').style.display = 'none';
                    currentRatingId = null;
                    document.querySelector('input[name="id_cashback"]').value = '';
                    // Reset form
                    document.getElementById('ratingForm').reset();
                    document.querySelectorAll('.cb-star').forEach(s => s.classList.remove('cb-star-active'));
                }

                // Filter by status
                document.getElementById('filterStatus').addEventListener('change', function() {
                    const filterValue = this.value;
                    document.querySelectorAll('.cb-reward-item').forEach(item => {
                        if (!filterValue || item.getAttribute('data-status') === filterValue) {
                            item.style.display = 'block';
                        } else {
                            item.style.display = 'none';
                        }
                    });
                });

                // Close modal when clicking outside
                document.getElementById('ratingModal').addEventListener('click', function(e) {
                    if (e.target === this) {
                        closeRatingModal();
                    }
                });

                // Delete handler
                document.querySelectorAll('.cb-btn-delete').forEach(btn => {
                    btn.addEventListener('click', function() {
                        const id = this.getAttribute('data-id');
                        if (confirm('Êtes-vous sûr de vouloir supprimer cette entree cashback ?')) {
                            const form = document.createElement('form');
                            form.method = 'POST';
                            form.action = '{{ path('portal_dashboard') }}';
                            form.innerHTML = `
                                <input type="hidden" name="tab" value="cashback">
                                <input type="hidden" name="action" value="cashback_delete">
                                <input type="hidden" name="id_cashback" value="${id}">
                            `;
                            document.body.appendChild(form);
                            form.submit();
                        }
                    });
                });

                // Modify handler
                document.querySelectorAll('.cb-btn-modify').forEach(btn => {
                    btn.addEventListener('click', function() {
                        const id = this.getAttribute('data-id');
                        document.getElementById('modifyForm').innerHTML = `
                            <input type="hidden" name="tab" value="cashback">
                            <input type="hidden" name="action" value="cashback_save">
                            <input type="hidden" name="id_cashback" value="${id}">
                            <input type="hidden" name="id_user" value="{{ current_user.idUser }}">
                            <input type="hidden" name="statut" value="${this.getAttribute('data-status') || 'Valide'}">
                            
                            <label>Selectionner un partenaire</label>
                            <select name="partenaire_nom" required>
                                <option value="">-- Selectionnez --</option>
                                {% for partner in partners %}
                                    <option value="{{ partner.nom|e('html_attr') }}">{{ partner.nom }}</option>
                                {% endfor %}
                            </select>
                            
                            <div class="cb-two-columns">
                                <div>
                                    <label>Montant achat</label>
                                    <input type="number" name="montant_achat" step="0.01" min="0" required>
                                </div>
                                <div>
                                    <label>Date achat</label>
                                    <input type="date" name="date_achat" required>
                                </div>
                            </div>
                            
                            <label>Reference transaction</label>
                            <input type="text" name="transaction_ref" placeholder="Saisir reçu ou numero">
                            
                            <div class="cb-modal-footer">
                                <button type="button" class="cb-button cb-button-secondary" onclick="closeModifyModal()">Annuler</button>
                                <button type="submit" class="cb-button cb-button-primary">Enregistrer modifications</button>
                            </div>
                        `;
                        
                        // Set pre-filled values
                        const partner = this.getAttribute('data-partner');
                        const amount = this.getAttribute('data-amount');
                        const date = this.getAttribute('data-date');
                        const ref = this.getAttribute('data-ref');
                        
                        document.querySelector('select[name="partenaire_nom"]').value = partner;
                        document.querySelector('input[name="montant_achat"]').value = amount;
                        document.querySelector('input[name="date_achat"]').value = date;
                        document.querySelector('input[name="transaction_ref"]').value = ref || '';
                        
                        document.getElementById('modifyModal').style.display = 'flex';
                    });
                });

                function closeModifyModal() {
                    document.getElementById('modifyModal').style.display = 'none';
                    document.getElementById('modifyForm').innerHTML = '';
                }

                // Close modify modal when clicking outside
                const modifyModal = document.getElementById('modifyModal');
                if (modifyModal) {
                    modifyModal.addEventListener('click', function(e) {
                        if (e.target === this) {
                            closeModifyModal();
                        }
                    });
                }
            </script>
        </main>
    </div>
</div>
