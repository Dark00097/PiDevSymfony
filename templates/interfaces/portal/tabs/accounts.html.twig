        </div>

        <div class="acc-kpi-tile acc-kpi-tile--acc">
            <div class="acc-kpi-tile-left">
                <div class="acc-kpi-badge-icon">
                    <i class="fa-solid fa-university"></i>
                </div>
                <div>
                    <span class="acc-kpi-label">COMPTES ACTIFS</span>
                    <span class="acc-kpi-sub">Comptes enregistres</span>
                </div>
            </div>
            <div class="acc-kpi-tile-right">
                <strong class="acc-kpi-num">{{ items|length }}</strong>
                <span class="acc-kpi-currency">cptes</span>
            </div>
            <div class="acc-kpi-bar">
                <span style="width:{{ items|length > 0 ? '80%' : '0%' }}"></span>
            </div>
