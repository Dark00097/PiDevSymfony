{% set total_balance = 0 %}
{% for account in items %}
    {% set total_balance = total_balance + (account.solde|default(0)) %}
{% endfor %}
{% set vaults = support.vaults|default([]) %}
{% set activity_logs = support.activity|default([]) %}
{% set wheel = support.wheel|default({
    can_spin: false,
    total_points: 0,
    bonus_ready: false,
    last_points: 0,
    last_spin_date: '',
    eligibility: {
        condition_solde: false,
        condition_budget: false,
        condition_epargne: false,
        message: 'Verification en cours.',
        suggestion: 'Aucune donnee disponible.'
    }
}) %}
{% set wheel_progress = wheel.total_points > 100 ? 100 : wheel.total_points %}
{% set health_label = items|length > 0 ? 'Excellent' : 'A surveiller' %}

<style>
/* ═══════════════════════════════════════════════
   ACC SHELL — ROOT LAYOUT (mirrors tnx-shell)
═══════════════════════════════════════════════ */
.acc-shell {
    display: flex;
    flex-direction: column;
    gap: 20px;
}

/* ═══════════════════════════════════════════════
   BANNER
═══════════════════════════════════════════════ */
.acc-banner {
    background: linear-gradient(92deg, #0a2540 0%, #1565c0 52%, #00bcd4 100%);
    border-radius: 20px;
    padding: 20px 26px;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 24px;
    color: #fff;
    box-shadow: 0 18px 40px rgba(10,37,64,.22);
}

.acc-banner-brand {
    display: flex;
    align-items: center;
    gap: 14px;
}

.acc-banner-icon {
    width: 52px;
    height: 52px;
    border-radius: 15px;
    background: rgba(255,255,255,.15);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
    flex-shrink: 0;
}

.acc-banner-text h1 {
    margin: 0;
    font-size: clamp(18px,1.8vw,26px);
    line-height: 1.1;
    color: #fff;
}

.acc-banner-text p {
    margin: 4px 0 0;
    font-size: 12px;
    color: rgba(255,255,255,.72);
}

.acc-banner-center {
    display: flex;
    align-items: center;
    justify-content: center;
}

.acc-banner-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 24px;
}

.acc-banner-stat-num {
    font-size: clamp(22px,2vw,32px);
    font-weight: 800;
    line-height: 1;
}

.acc-banner-stat-lbl {
    font-size: 11px;
    color: rgba(255,255,255,.65);
    margin-top: 4px;
    text-transform: uppercase;
    font-weight: 600;
    letter-spacing: .04em;
}

.acc-banner-divider {
    width: 1px;
    height: 36px;
    background: rgba(255,255,255,.25);
}

.acc-banner-nav {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: flex-end;
}

.acc-nav-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 0 14px;
    height: 36px;
    border-radius: 999px;
    border: 1px solid rgba(255,255,255,.28);
    background: rgba(255,255,255,.12);
    color: #fff;
    text-decoration: none;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: background .18s;
    font-family: inherit;
}

.acc-nav-pill:hover { background: rgba(255,255,255,.22); }

.acc-nav-pill--wheel {
    background: linear-gradient(120deg,#7c3aed,#4f46e5);
    border-color: transparent;
    box-shadow: 0 6px 16px rgba(79,70,229,.35);
}

.acc-nav-pill--wheel:hover { background: linear-gradient(120deg,#6d28d9,#4338ca); }

.acc-nav-pill--cta {
    background: #fff;
    color: #0a2540;
    border-color: #fff;
}

.acc-nav-pill--cta:hover { background: #e0f7fa; }

/* ═══════════════════════════════════════════════
   KPI STRIP
═══════════════════════════════════════════════ */
.acc-kpi-strip {
    display: grid;
    grid-template-columns: repeat(4,1fr);
    gap: 14px;
}

.acc-kpi-tile {
    background: #fff;
    border-radius: 16px;
    border: 1px solid #dce8f3;
    padding: 16px 18px 12px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    box-shadow: 0 6px 20px rgba(23,54,84,.07);
    position: relative;
    overflow: hidden;
    transition: box-shadow .2s, transform .2s;
}

.acc-kpi-tile:hover { box-shadow: 0 10px 28px rgba(10,37,64,.12); transform: translateY(-2px); }

.acc-kpi-tile::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    border-radius: 16px 16px 0 0;
}

.acc-kpi-tile--bal::before  { background: linear-gradient(90deg,#00bcd4,#00838f); }
.acc-kpi-tile--acc::before  { background: linear-gradient(90deg,#1565c0,#1e88e5); }
.acc-kpi-tile--vlt::before  { background: linear-gradient(90deg,#7c3aed,#a78bfa); }
.acc-kpi-tile--hlth::before { background: linear-gradient(90deg,#f59e0b,#fbbf24); }

.acc-kpi-tile-left {
    display: flex;
    align-items: center;
    gap: 10px;
}

.acc-kpi-badge-icon {
    width: 38px;
    height: 38px;
    border-radius: 11px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 15px;
    flex-shrink: 0;
}

.acc-kpi-tile--bal  .acc-kpi-badge-icon { background: #e0f7fa; color: #00838f; }
.acc-kpi-tile--acc  .acc-kpi-badge-icon { background: #dbeafe; color: #1565c0; }
.acc-kpi-tile--vlt  .acc-kpi-badge-icon { background: #ede9fe; color: #7c3aed; }
.acc-kpi-tile--hlth .acc-kpi-badge-icon { background: #fef3c7; color: #d97706; }

.acc-kpi-label {
    display: block;
    font-size: 10px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: .06em;
    color: #5d7d97;
}

.acc-kpi-sub {
    display: block;
    font-size: 11px;
    color: #94aec2;
    margin-top: 2px;
}

.acc-kpi-tile-right {
    display: flex;
    align-items: baseline;
    gap: 4px;
}

.acc-kpi-num {
    font-size: clamp(20px,1.8vw,28px);
    font-weight: 900;
    line-height: 1;
    color: #0a2540;
}

.acc-kpi-currency {
    font-size: 13px;
    font-weight: 700;
    color: #94aec2;
}

.acc-kpi-bar {
    height: 5px;
    background: #eef3f9;
    border-radius: 999px;
    overflow: hidden;
}

.acc-kpi-bar span {
    display: block;
    height: 100%;
    border-radius: inherit;
    transition: width .6s ease;
}

.acc-kpi-tile--bal  .acc-kpi-bar span { background: linear-gradient(90deg,#00bcd4,#00838f); }
.acc-kpi-tile--acc  .acc-kpi-bar span { background: linear-gradient(90deg,#1565c0,#1e88e5); }
.acc-kpi-tile--vlt  .acc-kpi-bar span { background: linear-gradient(90deg,#7c3aed,#a78bfa); }
.acc-kpi-tile--hlth .acc-kpi-bar span { background: linear-gradient(90deg,#f59e0b,#fbbf24); }

/* ═══════════════════════════════════════════════
   BODY: TABS + CONTENT
═══════════════════════════════════════════════ */
.acc-body {
    display: flex;
    flex-direction: column;
    gap: 16px;
}

/* Tab bar */
.acc-tabbar {
    display: flex;
    align-items: center;
    gap: 6px;
    background: #fff;
    border-radius: 14px;
    padding: 8px 10px;
    border: 1px solid #dce8f3;
    box-shadow: 0 4px 14px rgba(10,37,64,.05);
    flex-wrap: wrap;
}

.acc-tab-btn {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 8px 16px;
    border-radius: 10px;
    border: none;
    background: transparent;
    color: #5d7d97;
    font: inherit;
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
    transition: all .18s;
}

.acc-tab-btn i { font-size: 13px; }

.acc-tab-btn em {
    font-style: normal;
    font-size: 10px;
    font-weight: 800;
    background: #eef3f9;
    color: #7294ae;
    border-radius: 999px;
    padding: 1px 7px;
}

.acc-tab-btn:hover { background: #f5f9ff; color: #1565c0; }

.acc-tab-btn.active {
    background: linear-gradient(120deg,#0a2540,#1565c0);
    color: #fff;
    box-shadow: 0 4px 14px rgba(21,101,192,.25);
}

.acc-tab-btn.active em { background: rgba(255,255,255,.2); color: #fff; }

.acc-tabbar-sep { flex: 1; }

.acc-tabbar-action {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    height: 34px;
    padding: 0 14px;
    border-radius: 10px;
    border: none;
    font: inherit;
    font-size: 12px;
    font-weight: 700;
    cursor: pointer;
    transition: all .18s;
    text-decoration: none;
}

.acc-tabbar-action--wheel {
    background: linear-gradient(120deg,#7c3aed,#4f46e5);
    color: #fff;
    box-shadow: 0 4px 12px rgba(79,70,229,.3);
}

.acc-tabbar-action--wheel:hover { opacity: .9; }

/* Tab panels */
.acc-tab-panel { display: none; flex-direction: column; gap: 16px; }
.acc-tab-panel.active { display: flex; }

/* ═══════════════════════════════════════════════
   SHARED PANEL CARD
═══════════════════════════════════════════════ */
.acc-panel {
    background: #fff;
    border-radius: 18px;
    border: 1px solid #dce8f3;
    box-shadow: 0 6px 20px rgba(10,37,64,.06);
    overflow: hidden;
    display: flex;
    flex-direction: column;
}

.acc-panel-head {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 16px 18px;
    border-bottom: 1px solid #f0f5fb;
    background: linear-gradient(135deg,#f7faff,#f0f5fb);
}

.acc-panel-head-icon {
    width: 36px;
    height: 36px;
    border-radius: 11px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    color: #fff;
    flex-shrink: 0;
}

.acc-panel-head-text strong {
    display: block;
    font-size: 14px;
    font-weight: 800;
    color: #0a2540;
}

.acc-panel-head-text p {
    font-size: 11px;
    color: #7294ae;
    margin-top: 2px;
}

.acc-panel-head-action {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    height: 30px;
    padding: 0 12px;
    border-radius: 8px;
    border: 1px solid #c3d9f5;
    background: #eaf2fd;
    color: #1565c0;
    font: inherit;
    font-size: 11px;
    font-weight: 700;
    cursor: pointer;
    transition: all .15s;
    text-decoration: none;
    white-space: nowrap;
}

.acc-panel-head-action:hover { background: #1565c0; color: #fff; border-color: transparent; }

.acc-panel-count {
    margin-left: auto;
    padding: 3px 10px;
    border-radius: 999px;
    background: linear-gradient(120deg,#1565c0,#00bcd4);
    color: #fff;
    font-size: 10px;
    font-weight: 800;
}

/* ═══════════════════════════════════════════════
   OVERVIEW GRID
═══════════════════════════════════════════════ */
.acc-overview-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
}

.acc-panel-wide { grid-column: 1 / -1; }

/* Account rows */
.acc-account-rows { display: flex; flex-direction: column; }

.acc-account-row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 18px;
    border-bottom: 1px solid #f5f8fc;
    transition: background .15s;
    cursor: default;
}

.acc-account-row:last-child { border-bottom: none; }
.acc-account-row:hover { background: #f7faff; }
.acc-account-row.selectable { cursor: pointer; }
.acc-account-row.selectable:hover { background: #eaf2fd; }

.acc-avatar {
    width: 38px;
    height: 38px;
    border-radius: 12px;
    background: linear-gradient(135deg,#1565c0,#00bcd4);
    color: #fff;
    font-size: 12px;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
}

.acc-avatar.sm { width: 30px; height: 30px; border-radius: 9px; font-size: 10px; }

.acc-account-row-info { flex: 1; min-width: 0; }
.acc-account-row-info strong { display: block; font-size: 13px; font-weight: 700; color: #0a2540; }
.acc-account-row-info small  { display: block; font-size: 11px; color: #7294ae; margin-top: 1px; }

.acc-balance { font-size: 14px; font-weight: 800; color: #0a2540; white-space: nowrap; }

/* Points panel */
.acc-points-body {
    padding: 18px;
    display: flex;
    flex-direction: column;
    gap: 14px;
}

.acc-big-score { display: flex; align-items: flex-end; gap: 6px; }

.acc-big-score span {
    font-size: 42px;
    font-weight: 900;
    color: #0a2540;
    line-height: 1;
    letter-spacing: -1px;
}

.acc-big-score small {
    font-size: 13px;
    font-weight: 600;
    color: #7294ae;
    margin-bottom: 6px;
}

.acc-progress-track {
    height: 8px;
    background: #e8f0f8;
    border-radius: 999px;
    overflow: hidden;
}

.acc-progress-fill {
    height: 100%;
    border-radius: 999px;
    background: linear-gradient(90deg,#1565c0,#00bcd4);
    transition: width .6s ease;
}

.acc-cond-mini {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 12px;
    border-radius: 10px;
    font-size: 12px;
    font-weight: 600;
}

.acc-cond-mini i { font-size: 12px; flex-shrink: 0; }
.acc-cond-mini span { flex: 1; }
.acc-cond-mini b { font-size: 12px; font-weight: 800; }

.acc-cond-mini.ok { background: #dcfce7; color: #166534; border: 1px solid #bbf7d0; }
.acc-cond-mini.ko { background: #fee2e2; color: #991b1b; border: 1px solid #fecaca; }

.acc-spin-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    min-height: 42px;
    border-radius: 12px;
    background: linear-gradient(120deg,#1565c0,#00bcd4);
    color: #fff;
    font: inherit;
    font-size: 13px;
    font-weight: 700;
    border: none;
    cursor: pointer;
    box-shadow: 0 4px 14px rgba(21,101,192,.25);
    transition: all .18s;
}

.acc-spin-cta:hover { opacity: .9; }
.acc-spin-cta.disabled { background: #e2eaf4; color: #7294ae; box-shadow: none; cursor: not-allowed; }

/* Vault strip */
.acc-vault-strip {
    display: grid;
    grid-template-columns: repeat(auto-fill,minmax(190px,1fr));
    gap: 12px;
    padding: 16px;
}

.acc-vault-chip {
    background: linear-gradient(135deg,#f0f9ff,#e0f7fa);
    border: 1px solid #b2ebf2;
    border-radius: 14px;
    padding: 14px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    transition: box-shadow .2s, transform .2s;
}

.acc-vault-chip:hover { box-shadow: 0 6px 18px rgba(0,188,212,.15); transform: translateY(-2px); }

.acc-vault-chip-head { display: flex; align-items: center; gap: 8px; }
.acc-vault-chip-head i { color: #00838f; font-size: 14px; }
.acc-vault-chip-head strong { font-size: 13px; font-weight: 800; color: #0a2540; }

.acc-vault-chip-prog {
    height: 5px;
    background: rgba(0,188,212,.15);
    border-radius: 999px;
    overflow: hidden;
}

.acc-vault-chip-prog span {
    display: block;
    height: 100%;
    border-radius: 999px;
    background: linear-gradient(90deg,#00838f,#00bcd4);
    transition: width .6s ease;
}

.acc-vault-chip p { font-size: 11px; font-weight: 700; color: #00838f; }
.acc-vault-chip small { font-size: 11px; color: #7294ae; }

/* ═══════════════════════════════════════════════
   ACCOUNTS TAB — TOOLBAR + TABLE
═══════════════════════════════════════════════ */
.acc-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    background: #fff;
    border-radius: 14px;
    padding: 12px 16px;
    border: 1px solid #dce8f3;
    flex-wrap: wrap;
}

.acc-search-box {
    display: flex;
    align-items: center;
    gap: 8px;
    background: #f7faff;
    border: 1.5px solid #cddff0;
    border-radius: 10px;
    padding: 0 12px;
    min-height: 38px;
    transition: border-color .18s;
}

.acc-search-box:focus-within { border-color: #1e88e5; box-shadow: 0 0 0 3px rgba(30,136,229,.1); }
.acc-search-box i { color: #8aafc8; font-size: 12px; }

.acc-search-box input {
    border: none; outline: none; background: transparent;
    font: inherit; font-size: 13px; color: #0a2540; width: 200px;
}

.acc-search-box input::placeholder { color: #aabece; }

.acc-filter-chips {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
}

.acc-chip {
    padding: 5px 13px;
    border-radius: 999px;
    background: #f0f4f8;
    border: 1px solid #dce8f3;
    font: inherit;
    font-size: 12px;
    font-weight: 700;
    color: #7294ae;
    cursor: pointer;
    transition: all .15s;
}

.acc-chip:hover { background: #eaf2fd; color: #1565c0; }

.acc-chip.active {
    background: linear-gradient(120deg,#1565c0,#1e88e5);
    color: #fff;
    border-color: transparent;
    box-shadow: 0 3px 10px rgba(21,101,192,.2);
}

.acc-table-wrap {
    background: #fff;
    border-radius: 18px;
    border: 1px solid #dce8f3;
    box-shadow: 0 4px 16px rgba(10,37,64,.06);
    overflow: auto;
}

.acc-table {
    width: 100%;
    border-collapse: collapse;
    min-width: 860px;
}

.acc-table thead tr { background: linear-gradient(135deg,#f2f8fd,#e8f4fb); }

.acc-table th {
    padding: 13px 16px;
    text-align: left;
    border-bottom: 2px solid #daeaf6;
    font-size: 11px;
    font-weight: 800;
    color: #5b80a0;
    text-transform: uppercase;
    letter-spacing: .7px;
    white-space: nowrap;
}

.acc-tr { border-bottom: 1px solid #edf4fb; transition: background .15s; }
.acc-tr:hover { background: #f5fbff; }
.acc-tr:last-child { border-bottom: none; }

.acc-table td {
    padding: 13px 16px;
    vertical-align: middle;
    font-size: 13px;
    color: #1b3a57;
}

.acc-td-account { display: flex; align-items: center; gap: 9px; }
.acc-td-account span { font-size: 13px; font-weight: 600; color: #0a2540; }

.acc-type-badge {
    display: inline-block;
    background: rgba(21,101,192,.1);
    color: #1565c0;
    border-radius: 7px;
    padding: 3px 9px;
    font-size: 11px;
    font-weight: 700;
}

.acc-balance-cell { font-size: 14px; font-weight: 800; color: #0a2540; }

.acc-status-dot {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 4px 10px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 700;
}

.acc-status-dot::before {
    content: '';
    width: 6px; height: 6px;
    border-radius: 50%;
    background: currentColor;
    flex-shrink: 0;
}

.acc-status-dot.actif  { background: #dcfce7; color: #16a34a; }
.acc-status-dot.bloque { background: #fef3c7; color: #d97706; }
.acc-status-dot.ferme  { background: #fee2e2; color: #dc2626; }

/* Row actions */
.acc-action-group { display: flex; align-items: center; gap: 5px; }

.acc-act-btn {
    width: 32px; height: 32px;
    border-radius: 9px;
    border: none;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    font-size: 12px;
    transition: all .15s;
    text-decoration: none;
}

.acc-act-btn:hover { transform: scale(1.1); }
.acc-act-btn.view  { background: #eaf2fd; color: #1565c0; }
.acc-act-btn.view:hover  { background: #1565c0; color: #fff; }
.acc-act-btn.edit  { background: #f0fdf4; color: #16a34a; border: 1px solid #bbf7d0; }
.acc-act-btn.edit:hover  { background: #16a34a; color: #fff; border-color: transparent; }
.acc-act-btn.del   { background: #fff0f0; color: #dc2626; border: 1px solid #fecaca; }
.acc-act-btn.del:hover   { background: #dc2626; color: #fff; border-color: transparent; }

/* ═══════════════════════════════════════════════
   VAULTS + EDIT — TWO COL
═══════════════════════════════════════════════ */
.acc-two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    align-items: start;
}

/* Form */
.acc-form {
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding: 18px;
}

.acc-form-section-label {
    font-size: 11px;
    font-weight: 800;
    color: #1565c0;
    text-transform: uppercase;
    letter-spacing: .7px;
    display: flex;
    align-items: center;
    gap: 8px;
}

.acc-form-section-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg,#c3d9f5,transparent);
}

.acc-form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
.acc-field { display: flex; flex-direction: column; gap: 5px; }
.acc-field-full { grid-column: 1 / -1; }

.acc-field label {
    font-size: 11px;
    font-weight: 700;
    color: #4e7490;
    display: flex;
    align-items: center;
    gap: 5px;
}

.acc-field label i { color: #1565c0; font-size: 10px; }

.acc-input {
    width: 100%;
    min-height: 40px;
    border-radius: 11px;
    border: 1.5px solid #ccddef;
    background: #f7faff;
    padding: 0 12px;
    font: inherit;
    font-size: 13px;
    color: #0a2540;
    outline: none;
    appearance: none;
    transition: border-color .18s, box-shadow .18s;
}

.acc-input:focus {
    border-color: #1e88e5;
    background: #fff;
    box-shadow: 0 0 0 3px rgba(30,136,229,.12);
}

.acc-input::placeholder { color: #aabece; font-size: 12px; }

.acc-select-wrap { position: relative; }
.acc-select-wrap .acc-input { padding-right: 30px; cursor: pointer; }

.acc-select-wrap::after {
    content: '\f078';
    font-family: 'Font Awesome 6 Free';
    font-weight: 900;
    position: absolute;
    right: 11px; top: 50%;
    transform: translateY(-50%);
    color: #8aafc8;
    font-size: 10px;
    pointer-events: none;
}

.acc-checkbox-label {
    display: flex;
    align-items: center;
    gap: 9px;
    font-size: 12px;
    font-weight: 600;
    color: #4e7490;
    cursor: pointer;
    padding: 10px 14px;
    background: #f7faff;
    border: 1.5px solid #ccddef;
    border-radius: 11px;
}

.acc-checkbox-label input[type="checkbox"] {
    width: 16px; height: 16px;
    accent-color: #1565c0;
    flex-shrink: 0;
}

.acc-form-actions {
    display: flex;
    gap: 10px;
    padding-top: 6px;
    border-top: 1px solid #edf4fb;
}

.acc-submit-btn {
    flex: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    min-height: 42px;
    border-radius: 12px;
    background: linear-gradient(120deg,#1565c0,#00bcd4);
    color: #fff;
    font: inherit;
    font-size: 14px;
    font-weight: 800;
    border: none;
    cursor: pointer;
    box-shadow: 0 4px 14px rgba(21,101,192,.25);
    transition: all .18s;
}

.acc-submit-btn:hover { opacity: .9; }

.acc-reset-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 7px;
    min-height: 42px;
    padding: 0 16px;
    border-radius: 12px;
    background: transparent;
    border: 1.5px solid #cddff0;
    color: #5b80a0;
    font: inherit;
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
    transition: all .15s;
}

.acc-reset-btn:hover { background: #f0f4f8; }

/* Voice bar */
.acc-voice-bar {
    display: flex;
    align-items: center;
    gap: 12px;
    background: linear-gradient(135deg,#fffbeb,#fef3c7);
    border: 1px solid #fde68a;
    border-radius: 12px;
    padding: 10px 14px;
    margin: 0 18px;
}

.acc-voice-bar > span {
    width: 34px; height: 34px;
    border-radius: 10px;
    background: linear-gradient(135deg,#d97706,#f59e0b);
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-size: 14px; flex-shrink: 0;
}

.acc-voice-bar strong { display: block; font-size: 12px; font-weight: 800; color: #92400e; }
.acc-voice-bar small  { display: block; font-size: 11px; color: #b45309; margin-top: 1px; }
.acc-voice-bar b { margin-left: auto; font-size: 12px; color: #d97706; font-weight: 800; letter-spacing: 2px; }

/* Vault list cards */
.acc-vault-cards { display: flex; flex-direction: column; }

.acc-vault-card {
    padding: 14px 18px;
    border-bottom: 1px solid #f0f4f8;
    display: flex;
    flex-direction: column;
    gap: 8px;
    transition: background .15s;
}

.acc-vault-card:last-child { border-bottom: none; }
.acc-vault-card:hover { background: #f7faff; }

.acc-vault-card-top { display: flex; align-items: center; gap: 10px; }

.acc-vault-icon {
    width: 34px; height: 34px;
    border-radius: 10px;
    background: linear-gradient(135deg,#00838f,#00bcd4);
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-size: 13px; flex-shrink: 0;
}

.acc-vault-card-top > div { flex: 1; }
.acc-vault-card-top strong { display: block; font-size: 13px; font-weight: 800; color: #0a2540; }
.acc-vault-card-top small  { display: block; font-size: 11px; color: #7294ae; margin-top: 1px; }
.acc-vault-pct { font-size: 13px; font-weight: 900; color: #00838f; }

.acc-vault-prog {
    height: 5px;
    background: #e0f7fa;
    border-radius: 999px;
    overflow: hidden;
}

.acc-vault-prog span {
    display: block; height: 100%;
    border-radius: 999px;
    background: linear-gradient(90deg,#00838f,#00bcd4);
    transition: width .6s ease;
}

.acc-vault-card-foot {
    display: flex; align-items: center; justify-content: space-between;
    font-size: 11px; font-weight: 700; color: #7294ae;
}

/* ═══════════════════════════════════════════════
   EMPTY STATE
═══════════════════════════════════════════════ */
.acc-empty {
    display: flex; flex-direction: column;
    align-items: center; gap: 8px;
    padding: 40px 20px;
    text-align: center; color: #7294ae;
}

.acc-empty-icon {
    width: 60px; height: 60px;
    border-radius: 18px;
    background: linear-gradient(135deg,#e0f7f4,#d1fae5);
    display: flex; align-items: center; justify-content: center;
    font-size: 24px; color: #00bcd4;
    box-shadow: 0 8px 20px rgba(0,188,212,.14);
    margin-bottom: 4px;
}

.acc-empty strong { font-size: 14px; color: #0a2540; }
.acc-empty span   { font-size: 12px; max-width: 240px; }

/* ═══════════════════════════════════════════════
   MODAL OVERLAY
═══════════════════════════════════════════════ */
.acc-modal-wrap {
    position: fixed; inset: 0; z-index: 500;
    display: flex; align-items: center; justify-content: center; padding: 20px;
}

.acc-modal-wrap[hidden] { display: none !important; }

.acc-modal-backdrop {
    position: absolute; inset: 0;
    background: rgba(10,37,64,.5);
    backdrop-filter: blur(6px);
    border: none; cursor: pointer;
}

.acc-modal {
    position: relative; z-index: 1;
    background: #fff;
    border-radius: 24px;
    border: 1px solid #dce8f3;
    box-shadow: 0 24px 60px rgba(10,37,64,.22);
    width: 100%; max-width: 860px; max-height: 88vh;
    display: flex; flex-direction: column; overflow: hidden;
}

.acc-modal[hidden] { display: none !important; }

.acc-modal-head {
    display: flex; align-items: center; justify-content: space-between;
    gap: 16px; padding: 18px 22px;
    background: linear-gradient(135deg,#0a2540,#1565c0);
    flex-shrink: 0;
}

.acc-modal-head-left { display: flex; align-items: center; gap: 14px; }

.acc-modal-head-icon {
    width: 42px; height: 42px; border-radius: 14px;
    background: rgba(255,255,255,.15);
    border: 1px solid rgba(255,255,255,.25);
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-size: 17px; flex-shrink: 0;
}

.acc-modal-head h3 { font-size: 16px; font-weight: 800; color: #fff; line-height: 1.2; }
.acc-modal-head p  { font-size: 12px; color: rgba(255,255,255,.65); margin-top: 2px; }

.acc-modal-head-right { display: flex; align-items: center; gap: 10px; }

.acc-modal-badge {
    padding: 5px 12px; border-radius: 999px;
    font-size: 11px; font-weight: 800;
}

.acc-modal-badge.ok   { background: #dcfce7; color: #166534; }
.acc-modal-badge.warn { background: #fef3c7; color: #92400e; }

.acc-modal-close {
    display: inline-flex; align-items: center; gap: 6px;
    min-height: 34px; padding: 0 14px; border-radius: 10px;
    background: rgba(255,255,255,.12);
    border: 1px solid rgba(255,255,255,.2);
    color: rgba(255,255,255,.85);
    font: inherit; font-size: 12px; font-weight: 700;
    cursor: pointer; transition: background .15s;
}

.acc-modal-close:hover { background: rgba(255,255,255,.22); }

.acc-modal-body {
    flex: 1; overflow-y: auto; padding: 20px 22px;
    display: flex; flex-direction: column; gap: 16px;
}

/* Wheel modal */
.acc-wheel-layout {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 20px;
}

.acc-wheel-left {
    display: flex; flex-direction: column; align-items: center; gap: 14px;
}

.acc-wheel-ring-outer {
    width: 160px; height: 160px; border-radius: 50%;
    background: linear-gradient(135deg,#0a2540,#1565c0,#00bcd4);
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 12px 32px rgba(21,101,192,.35);
    animation: acc-wheel-pulse 6s linear infinite;
}

@keyframes acc-wheel-pulse {
    0%,100% { box-shadow: 0 12px 32px rgba(21,101,192,.35); }
    50%      { box-shadow: 0 16px 40px rgba(0,188,212,.45); }
}

.acc-wheel-ring-inner {
    width: 130px; height: 130px; border-radius: 50%;
    background: #fff;
    display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 4px;
}

.acc-wheel-ring-inner i     { font-size: 28px; color: #1565c0; }
.acc-wheel-ring-inner span  { font-size: 12px; font-weight: 800; color: #0a2540; }
.acc-wheel-status           { font-size: 12px; color: #7294ae; text-align: center; line-height: 1.5; }

.acc-wheel-spin-btn {
    width: 100%; min-height: 42px; border-radius: 12px;
    background: linear-gradient(120deg,#1565c0,#00bcd4);
    color: #fff; font: inherit; font-size: 14px; font-weight: 800;
    border: none; cursor: pointer;
    box-shadow: 0 6px 18px rgba(21,101,192,.28);
    transition: all .18s;
}

.acc-wheel-spin-btn:hover { opacity: .9; }

.acc-wheel-spin-btn:disabled {
    background: #e2eaf4; color: #7294ae;
    box-shadow: none; cursor: not-allowed;
}

.acc-wheel-result-note {
    background: linear-gradient(135deg,#f0fdf4,#dcfce7);
    border: 1px solid #bbf7d0; border-radius: 12px;
    padding: 12px 14px; text-align: center; width: 100%;
}

.acc-wheel-result-note strong { font-size: 12px; font-weight: 800; color: #166534; }
.acc-wheel-result-note p { font-size: 13px; color: #16a34a; margin-top: 4px; font-weight: 700; }

.acc-wheel-bonus {
    background: linear-gradient(135deg,#fef3c7,#fde68a);
    border: 1px solid #f59e0b; border-radius: 14px;
    padding: 14px; width: 100%;
    display: flex; flex-direction: column; gap: 10px;
}

.acc-wheel-bonus strong { font-size: 13px; font-weight: 900; color: #92400e; }
.acc-wheel-bonus p      { font-size: 12px; color: #78350f; }

.acc-wheel-bonus select {
    width: 100%; min-height: 38px; border-radius: 10px;
    border: 1.5px solid #fbbf24; background: #fff;
    padding: 0 10px; font: inherit; font-size: 12px; outline: none;
}

.acc-wheel-bonus-btn {
    width: 100%; min-height: 38px; border-radius: 10px;
    background: linear-gradient(120deg,#d97706,#f59e0b);
    color: #fff; font: inherit; font-size: 13px; font-weight: 700;
    border: none; cursor: pointer;
}

.acc-wheel-right  { display: flex; flex-direction: column; gap: 14px; }

.acc-wheel-section { display: flex; flex-direction: column; gap: 8px; }

.acc-wheel-section-title {
    display: flex; align-items: center; gap: 8px;
    font-size: 12px; font-weight: 800; color: #1565c0;
    text-transform: uppercase; letter-spacing: .7px;
    padding-bottom: 8px; border-bottom: 1px solid #e8f0fb;
}

.acc-wheel-condition {
    display: flex; align-items: center; gap: 12px;
    padding: 10px 14px; border-radius: 12px; transition: all .15s;
}

.acc-wheel-condition > span {
    width: 32px; height: 32px; border-radius: 9px;
    display: flex; align-items: center; justify-content: center;
    font-size: 13px; flex-shrink: 0;
}

.acc-wheel-condition > div { flex: 1; }
.acc-wheel-condition strong { display: block; font-size: 12px; font-weight: 700; }
.acc-wheel-condition small  { display: block; font-size: 11px; margin-top: 1px; opacity: .75; }
.acc-wheel-condition > b    { font-size: 12px; font-weight: 900; }

.acc-wheel-condition.ok { background: #f0fdf4; border: 1px solid #bbf7d0; color: #166534; }
.acc-wheel-condition.ok > span { background: #dcfce7; }
.acc-wheel-condition.ko { background: #fff5f5; border: 1px solid #fecaca; color: #991b1b; }
.acc-wheel-condition.ko > span { background: #fee2e2; }

.acc-wheel-pts-head {
    display: flex; align-items: center; justify-content: space-between;
    font-size: 12px; font-weight: 700; color: #0a2540;
}

.acc-wheel-pts-head span { color: #1565c0; font-weight: 800; }

.acc-wheel-refusal {
    background: #fff5f5; border: 1px solid #fecaca;
    border-radius: 12px; padding: 14px;
}

.acc-wheel-refusal h4 {
    display: flex; align-items: center; gap: 7px;
    font-size: 13px; font-weight: 800; color: #991b1b; margin-bottom: 6px;
}

.acc-wheel-refusal p { font-size: 12px; color: #7f1d1d; line-height: 1.5; }

.acc-wheel-rules {
    background: #f7faff; border: 1px solid #dce8f3;
    border-radius: 12px; padding: 14px;
    display: flex; flex-direction: column; gap: 5px;
}

.acc-wheel-rules h4 {
    display: flex; align-items: center; gap: 7px;
    font-size: 12px; font-weight: 800; color: #1565c0; margin-bottom: 4px;
}

.acc-wheel-rules p          { font-size: 12px; color: #5b80a0; line-height: 1.5; }
.acc-wheel-rules p.highlight { color: #d97706; font-weight: 700; }

/* History modal */
.acc-history-search {
    display: flex; align-items: center; gap: 8px;
    background: #f7faff; border: 1.5px solid #cddff0;
    border-radius: 11px; padding: 0 12px;
    min-height: 40px; flex-shrink: 0; transition: border-color .18s;
}

.acc-history-search:focus-within { border-color: #1e88e5; box-shadow: 0 0 0 3px rgba(30,136,229,.1); }
.acc-history-search i { color: #8aafc8; font-size: 13px; }

.acc-history-search input {
    border: none; outline: none; background: transparent;
    font: inherit; font-size: 13px; color: #0a2540; flex: 1;
}

.acc-history-list {
    display: flex; flex-direction: column; gap: 8px;
    overflow-y: auto; max-height: 420px;
}

.acc-history-row {
    display: flex; align-items: flex-start; gap: 12px;
    padding: 13px 14px;
    background: #f7faff; border: 1px solid #dce8f3; border-radius: 13px;
    transition: border-color .15s;
}

.acc-history-row:hover { border-color: #a8c8f0; background: #f0f8ff; }

.acc-history-icon {
    width: 34px; height: 34px; border-radius: 10px;
    background: linear-gradient(135deg,#1565c0,#00bcd4);
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-size: 13px; flex-shrink: 0;
}

.acc-history-main { flex: 1; }
.acc-history-main strong { display: block; font-size: 13px; font-weight: 800; color: #0a2540; }
.acc-history-main p { font-size: 12px; color: #5b80a0; margin-top: 3px; line-height: 1.4; }
.acc-history-main small { display: block; font-size: 11px; color: #7294ae; margin-top: 4px; font-weight: 600; }

.acc-history-row time {
    font-size: 11px; font-weight: 700; color: #7294ae;
    white-space: nowrap; flex-shrink: 0;
}

.acc-history-empty { text-align: center; padding: 32px; font-size: 13px; color: #7294ae; }

/* Language modal */
.acc-lang-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 14px; }

.acc-lang-card {
    display: flex; flex-direction: column; align-items: flex-start; gap: 8px;
    padding: 20px; border-radius: 16px;
    border: 1px solid #dce8f3; background: #f7faff;
    text-decoration: none; transition: all .18s;
}

.acc-lang-card:hover {
    background: linear-gradient(135deg,#1565c0,#00bcd4);
    border-color: transparent;
    box-shadow: 0 8px 24px rgba(21,101,192,.25);
    transform: translateY(-2px);
}

.acc-lang-card:hover i,
.acc-lang-card:hover strong,
.acc-lang-card:hover span { color: #fff; }

.acc-lang-card i      { font-size: 24px; color: #1565c0; transition: color .18s; }
.acc-lang-card strong { font-size: 14px; font-weight: 800; color: #0a2540; transition: color .18s; }
.acc-lang-card span   { font-size: 12px; color: #7294ae; line-height: 1.4; transition: color .18s; }

/* ═══════════════════════════════════════════════
   RESPONSIVE
═══════════════════════════════════════════════ */
@media (max-width: 1400px) {
    .acc-kpi-strip { grid-template-columns: repeat(2,1fr); }
}

@media (max-width: 1200px) {
    .acc-banner { grid-template-columns: 1fr; gap: 16px; }
    .acc-overview-grid { grid-template-columns: 1fr; }
    .acc-two-col { grid-template-columns: 1fr; }
    .acc-wheel-layout { grid-template-columns: 1fr; }
    .acc-lang-grid { grid-template-columns: 1fr 1fr; }
}

@media (max-width: 760px) {
    .acc-kpi-strip { grid-template-columns: 1fr 1fr; }
    .acc-tabbar { gap: 4px; }
    .acc-tab-btn { padding: 7px 10px; font-size: 12px; }
    .acc-form-row { grid-template-columns: 1fr; }
    .acc-lang-grid { grid-template-columns: 1fr; }
}
</style>

