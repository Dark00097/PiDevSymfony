        <div class="acc-kpi-tile acc-kpi-tile--vlt">
            <div class="acc-kpi-tile-left">
                <div class="acc-kpi-badge-icon">
                    <i class="fa-solid fa-piggy-bank"></i>
                </div>
                <div>
                    <span class="acc-kpi-label">COFFRES VIRTUELS</span>
                    <span class="acc-kpi-sub">Objectifs d'epargne</span>
                </div>
            </div>
            <div class="acc-kpi-tile-right">
                <strong class="acc-kpi-num">{{ vaults|length }}</strong>
                <span class="acc-kpi-currency">coffres</span>
            </div>
            <div class="acc-kpi-bar">
                <span style="width:{{ vaults|length > 0 ? '65%' : '0%' }}"></span>
            </div>
        </div>

        <div class="acc-kpi-tile acc-kpi-tile--hlth">
            <div class="acc-kpi-tile-left">
                <div class="acc-kpi-badge-icon">
                    <i class="fa-solid fa-shield-halved"></i>
                </div>
                <div>
                    <span class="acc-kpi-label">SANTE FINANCIERE</span>
                    <span class="acc-kpi-sub">Score NEXORA</span>
                </div>
            </div>
            <div class="acc-kpi-tile-right">
                <strong class="acc-kpi-num">{{ wheel_progress }}</strong>
                <span class="acc-kpi-currency">pts</span>
            </div>
            <div class="acc-kpi-bar">
                <span style="width:{{ wheel_progress }}%"></span>
            </div>
        </div>

    </div>

    {# ── BODY ── #}
    <div class="acc-body">

        {# Tab bar #}
        <div class="acc-tabbar">
            <button class="acc-tab-btn active" data-acc-tab="overview" type="button">
                <i class="fa-solid fa-chart-pie"></i> Vue d'ensemble
            </button>
            <button class="acc-tab-btn" data-acc-tab="accounts" type="button">
                <i class="fa-solid fa-university"></i> Mes comptes
                <em>{{ items|length }}</em>
            </button>
            <button class="acc-tab-btn" data-acc-tab="vaults" type="button">
                <i class="fa-solid fa-piggy-bank"></i> Coffres
                <em>{{ vaults|length }}</em>
            </button>
            <button class="acc-tab-btn" data-acc-tab="edit" type="button">
                <i class="fa-solid fa-pen-to-square"></i> Modifier
            </button>

            <div class="acc-tabbar-sep"></div>

            <button class="acc-tabbar-action acc-tabbar-action--wheel"
                    type="button" data-acc-modal="wheel">
                <i class="fa-solid fa-dharmachakra"></i> Tourner la Roue
            </button>
        </div>

        {# ══ TAB: OVERVIEW ══ #}
        <section class="acc-tab-panel active" id="acc-tab-overview">

            <div class="acc-overview-grid">

                {# Accounts preview #}
                <div class="acc-panel">
                    <div class="acc-panel-head">
                        <div class="acc-panel-head-icon"
                             style="background:linear-gradient(135deg,#1565c0,#1e88e5);">
                            <i class="fa-solid fa-university"></i>
                        </div>
                        <div class="acc-panel-head-text">
                            <strong>Apercu des comptes</strong>
                            <p>{{ items|length }} compte(s) lie(s)</p>
                        </div>
                        <button class="acc-panel-head-action"
                                data-acc-tab-link="accounts" type="button">
                            Voir tout →
                        </button>
                    </div>
                    <div class="acc-account-rows">
                        {% for account in items %}
                            <div class="acc-account-row">
                                <span class="acc-avatar">
                                    {{ account.numeroCompte|slice(0,2)|upper }}
                                </span>
                                <div class="acc-account-row-info">
                                    <strong>{{ account.numeroCompte }}</strong>
                                    <small>
                                        {{ account.typeCompte|default('Courant') }}
                                        · {{ account.statutCompte|default('Actif') }}
                                    </small>
                                </div>
                                <span class="acc-balance">
                                    {{ account.solde|number_format(2,'.', ' ') }} DT
                                </span>
                            </div>
                        {% else %}
                            <div class="acc-empty">
                                <div class="acc-empty-icon">
                                    <i class="fa-solid fa-inbox"></i>
                                </div>
                                <strong>Aucun compte</strong>
                                <span>Ajoutez votre premier compte bancaire.</span>
                            </div>
                        {% endfor %}
                    </div>
                </div>

                {# Points / Wheel panel #}
                <div class="acc-panel">
                    <div class="acc-panel-head">
                        <div class="acc-panel-head-icon"
                             style="background:linear-gradient(135deg,#f59e0b,#fbbf24);">
                            <i class="fa-solid fa-star"></i>
                        </div>
                        <div class="acc-panel-head-text">
                            <strong>Points NEXORA</strong>
                            <p>Programme de fidelite</p>
                        </div>
                        <button class="acc-panel-head-action"
                                type="button" data-acc-modal="wheel">
                            Ouvrir →
                        </button>
                    </div>
                    <div class="acc-points-body">
                        <div class="acc-big-score">
                            <span>{{ wheel.total_points|default(0) }}</span>
                            <small>/ 100 pts</small>
                        </div>
                        <div class="acc-progress-track">
                            <div class="acc-progress-fill" style="width:{{ wheel_progress }}%"></div>
                        </div>
                        <p style="font-size:12px;color:#7294ae;line-height:1.5;">
                            {{ wheel.eligibility.suggestion|default('Continuez pour debloquer plus de recompenses.') }}
                        </p>
                        <div style="display:flex;flex-direction:column;gap:6px;">
                            <div class="acc-cond-mini {{ wheel.eligibility.condition_solde ? 'ok' : 'ko' }}">
                                <i class="fa-solid fa-wallet"></i>
                                <span>Solde positif</span>
                                <b>{{ wheel.eligibility.condition_solde ? '✓' : '✗' }}</b>
                            </div>
                            <div class="acc-cond-mini {{ wheel.eligibility.condition_budget ? 'ok' : 'ko' }}">
                                <i class="fa-solid fa-chart-pie"></i>
                                <span>Budget respecte</span>
                                <b>{{ wheel.eligibility.condition_budget ? '✓' : '✗' }}</b>
                            </div>
                            <div class="acc-cond-mini {{ wheel.eligibility.condition_epargne ? 'ok' : 'ko' }}">
                                <i class="fa-solid fa-piggy-bank"></i>
                                <span>Epargne active</span>
                                <b>{{ wheel.eligibility.condition_epargne ? '✓' : '✗' }}</b>
                            </div>
                        </div>
                        <button class="acc-spin-cta {{ not wheel.can_spin ? 'disabled' : '' }}"
                                type="button" data-acc-modal="wheel">
                            <i class="fa-solid fa-dharmachakra"></i>
                            {{ wheel.can_spin ? 'Lancer la roue maintenant' : 'Conditions non remplies' }}
                        </button>
                    </div>
                </div>

                {# Vaults preview — full width #}
                <div class="acc-panel acc-panel-wide">
                    <div class="acc-panel-head">
                        <div class="acc-panel-head-icon"
                             style="background:linear-gradient(135deg,#7c3aed,#a78bfa);">
                            <i class="fa-solid fa-piggy-bank"></i>
                        </div>
                        <div class="acc-panel-head-text">
                            <strong>Coffres virtuels</strong>
                            <p>{{ vaults|length }} coffre(s) d'epargne</p>
                        </div>
                        <button class="acc-panel-head-action"
                                data-acc-tab-link="vaults" type="button">
                            Voir tout →
                        </button>
                    </div>
                    {% if vaults is not empty %}
                        <div class="acc-vault-strip">
                            {% for vault in vaults %}
                                {% set pct = vault.objectifMontant > 0
                                    ? ((vault.montantActuel / vault.objectifMontant) * 100)|round
                                    : 0 %}
                                <div class="acc-vault-chip">
                                    <div class="acc-vault-chip-head">
                                        <i class="fa-solid fa-lock"></i>
                                        <strong>{{ vault.nom }}</strong>
                                    </div>
                                    <small>{{ vault.numeroCompte|default('Sans compte') }}</small>
                                    <div class="acc-vault-chip-prog">
                                        <span style="width:{{ pct }}%"></span>
                                    </div>
                                    <p>
                                        {{ vault.montantActuel|number_format(2,'.', ' ') }}
                                        / {{ vault.objectifMontant|number_format(2,'.', ' ') }} DT
                                        — {{ pct }}%
                                    </p>
                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <div class="acc-empty">
                            <div class="acc-empty-icon">
                                <i class="fa-solid fa-piggy-bank"></i>
                            </div>
                            <strong>Aucun coffre cree</strong>
                            <span>Cliquez sur "Nouveau coffre" pour commencer.</span>
                        </div>
                    {% endif %}
                </div>

            </div>
        </section>

        {# ══ TAB: ACCOUNTS ══ #}
        <section class="acc-tab-panel" id="acc-tab-accounts">

            <div class="acc-toolbar">
                <div class="acc-search-box">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input type="text" id="acc-accounts-search" placeholder="Rechercher un compte…">
                </div>
                <div class="acc-filter-chips">
                    <button class="acc-chip active" data-acc-filter="all"           type="button">Tous</button>
                    <button class="acc-chip"         data-acc-filter="courant"       type="button">Courant</button>
                    <button class="acc-chip"         data-acc-filter="epargne"       type="button">Epargne</button>
                    <button class="acc-chip"         data-acc-filter="professionnel" type="button">Professionnel</button>
                </div>
            </div>

            <div class="acc-table-wrap">
                <table class="acc-table">
                    <thead>
                        <tr>
                            <th>Numero</th>
                            <th>Type</th>
                            <th>Solde</th>
                            <th>Statut</th>
                            <th>Ouverture</th>
                            <th>Plafonds</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for account in items %}
                            <tr class="acc-tr"
                                data-acc-account-type="{{ account.typeCompte|default('Courant')|lower }}">
                                <td>
                                    <div class="acc-td-account">
                                        <span class="acc-avatar sm">
                                            {{ account.numeroCompte|slice(0,2)|upper }}
                                        </span>
                                        <span>{{ account.numeroCompte }}</span>
                                    </div>
                                </td>
                                <td>
                                    <span class="acc-type-badge">
                                        {{ account.typeCompte|default('Courant') }}
                                    </span>
                                </td>
                                <td>
                                    <strong class="acc-balance-cell">
                                        {{ account.solde|number_format(2,'.', ' ') }} DT
                                    </strong>
                                </td>
                                <td>
                                    <span class="acc-status-dot {{ account.statutCompte|default('Actif')|lower }}">
                                        {{ account.statutCompte|default('Actif') }}
                                    </span>
                                </td>
                                <td>{{ account.dateOuverture|default('—') }}</td>
                                <td>
                                    <div style="font-size:11px;color:#7294ae;line-height:1.6;">
                                        <span>Ret: <b style="color:#0a2540;">{{ account.plafondRetrait|default('—') }}</b> DT</span><br>
                                        <span>Vir: <b style="color:#0a2540;">{{ account.plafondVirement|default('—') }}</b> DT</span>
                                    </div>
                                </td>
                                <td>
                                    <div class="acc-action-group">
                                        <a href="{{ path(route_name, { tab: 'vaults' }) }}"
                                           class="acc-act-btn view" title="Voir coffres">
                                            <i class="fa-solid fa-eye"></i>
                                        </a>
                                        <button class="acc-act-btn edit" type="button"
                                                data-acc-edit="{{ account.idCompte }}"
                                                data-acc-tab-link="edit"
                                                title="Modifier">
                                            <i class="fa-solid fa-pen"></i>
                                        </button>
                                        <form method="post" style="display:contents;"
                                              onsubmit="return confirm('Supprimer ce compte ?');">
                                            <input type="hidden" name="tab"      value="accounts">
                                            <input type="hidden" name="action"   value="account_delete">
                                            <input type="hidden" name="idCompte" value="{{ account.idCompte }}">
                                            <button class="acc-act-btn del" type="submit" title="Supprimer">
                                                <i class="fa-solid fa-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="7">
                                    <div class="acc-empty">
                                        <div class="acc-empty-icon">
                                            <i class="fa-solid fa-inbox"></i>
                                        </div>
                                        <strong>Aucun compte enregistre</strong>
                                        <span>Passez sur l'onglet "Modifier" pour en ajouter un.</span>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </section>

        {# ══ TAB: VAULTS ══ #}
        <section class="acc-tab-panel" id="acc-tab-vaults">
            <div class="acc-two-col">

                {# Vault form #}
                <div class="acc-panel">
                    <div class="acc-panel-head">
                        <div class="acc-panel-head-icon"
                             style="background:linear-gradient(135deg,#7c3aed,#a78bfa);">
                            <i class="fa-solid fa-plus"></i>
                        </div>
                        <div class="acc-panel-head-text">
                            <strong>Creer un coffre virtuel</strong>
                            <p>Definissez un objectif d'epargne</p>
                        </div>
                    </div>

                    <form method="post" class="acc-form">
                        <input type="hidden" name="tab"          value="accounts">
                        <input type="hidden" name="action"       value="vault_save">
                        <input type="hidden" name="dateCreation" value="{{ 'now'|date('Y-m-d') }}">

                        <div class="acc-form-section-label">
                            <i class="fa-solid fa-link"></i>
                            <span>Association</span>
                            <div class="acc-form-section-line"></div>
                        </div>

                        <div class="acc-form-row">
                            <div class="acc-field">
                                <label>
                                    <i class="fa-solid fa-building-columns"></i>
                                    Compte bancaire <span style="color:#e53935">*</span>
                                </label>
                                <div class="acc-select-wrap">
                                    <select class="acc-input" name="idCompte" required>
                                        <option value="">Choisir un compte</option>
                                        {% for account in items %}
                                            <option value="{{ account.idCompte }}">
                                                {{ account.numeroCompte }}
                                                ({{ account.solde|number_format(2,'.', ' ') }} DT)
                                            </option>
                                        {% endfor %}
                                    </select>
                                </div>
                            </div>
                            <div class="acc-field">
                                <label>
                                    <i class="fa-solid fa-tag"></i>
                                    Nom du coffre <span style="color:#e53935">*</span>
                                </label>
                                <input class="acc-input" type="text" name="nom"
                                       placeholder="Ex: Fonds vacances" required>
                            </div>
                        </div>

                        <div class="acc-form-section-label">
                            <i class="fa-solid fa-bullseye"></i>
                            <span>Objectif financier</span>
                            <div class="acc-form-section-line"></div>
                        </div>

                        <div class="acc-form-row">
                            <div class="acc-field">
                                <label>
                                    <i class="fa-solid fa-flag-checkered"></i> Montant cible (TND)
                                </label>
                                <input class="acc-input" type="number" step="0.01"
                                       name="objectifMontant" placeholder="0.00" required>
                            </div>
                            <div class="acc-field">
                                <label>
                                    <i class="fa-solid fa-coins"></i> Depot initial (TND)
                                </label>
                                <input class="acc-input" type="number" step="0.01"
                                       name="montantActuel" value="0" placeholder="0.00" required>
                            </div>
                        </div>

                        <div class="acc-form-row">
                            <div class="acc-field">
                                <label><i class="fa-solid fa-calendar-day"></i> Date cible</label>
                                <input class="acc-input" type="date" name="dateObjectifs">
                            </div>
                            <div class="acc-field">
                                <label><i class="fa-solid fa-list-check"></i> Statut</label>
                                <div class="acc-select-wrap">
                                    <select class="acc-input" name="status">
                                        {% for v in ['Actif','Bloque','Ferme'] %}
                                            <option value="{{ v }}">{{ v }}</option>
                                        {% endfor %}
                                    </select>
                                </div>
                            </div>
                        </div>

                        <label class="acc-checkbox-label">
                            <input type="hidden" name="estVerrouille" value="0">
                            <input type="checkbox" name="estVerrouille" value="1" checked>
                            <span>Verrouiller le coffre jusqu'a la date cible</span>
                        </label>

                        <div class="acc-form-actions">
                            <button class="acc-submit-btn" type="submit">
                                <i class="fa-solid fa-lock"></i> Creer le coffre
                            </button>
                        </div>
                    </form>
                </div>

                {# Vault list #}
                <div class="acc-panel">
                    <div class="acc-panel-head">
                        <div class="acc-panel-head-icon"
                             style="background:linear-gradient(135deg,#00838f,#00bcd4);">
                            <i class="fa-solid fa-piggy-bank"></i>
                        </div>
                        <div class="acc-panel-head-text">
                            <strong>Coffres existants</strong>
                            <p>Suivez votre progression</p>
                        </div>
                        <span class="acc-panel-count">{{ vaults|length }}</span>
                    </div>
                    {% if vaults is not empty %}
                        <div class="acc-vault-cards">
                            {% for vault in vaults %}
                                {% set pct = vault.objectifMontant > 0
                                    ? ((vault.montantActuel / vault.objectifMontant) * 100)|round
                                    : 0 %}
                                <div class="acc-vault-card">
                                    <div class="acc-vault-card-top">
                                        <span class="acc-vault-icon">
                                            <i class="fa-solid fa-piggy-bank"></i>
                                        </span>
                                        <div>
                                            <strong>{{ vault.nom }}</strong>
                                            <small>{{ vault.numeroCompte|default('Sans compte') }}</small>
                                        </div>
                                        <span class="acc-vault-pct">{{ pct }}%</span>
                                    </div>
                                    <div class="acc-vault-prog">
                                        <span style="width:{{ pct }}%"></span>
                                    </div>
                                    <div class="acc-vault-card-foot">
                                        <span>{{ vault.montantActuel|number_format(2,'.', ' ') }} DT</span>
                                        <span>/ {{ vault.objectifMontant|number_format(2,'.', ' ') }} DT</span>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <div class="acc-empty">
                            <div class="acc-empty-icon">
                                <i class="fa-solid fa-inbox"></i>
                            </div>
                            <strong>Aucun coffre cree</strong>
                            <span>Utilisez le formulaire pour creer votre premier coffre.</span>
                        </div>
                    {% endif %}
                </div>

            </div>
        </section>

        {# ══ TAB: EDIT ══ #}
        <section class="acc-tab-panel" id="acc-tab-edit">
            <div class="acc-two-col">

                {# Edit form #}
                <div class="acc-panel">
                    <div class="acc-panel-head">
                        <div class="acc-panel-head-icon"
                             style="background:linear-gradient(135deg,#1565c0,#1e88e5);">
                            <i class="fa-solid fa-pen-to-square"></i>
                        </div>
                        <div class="acc-panel-head-text">
                            <strong>Details du compte</strong>
                            <p>Creer ou mettre a jour un compte</p>
                        </div>
                    </div>

                    <div class="acc-voice-bar">
                        <span><i class="fa-solid fa-microphone"></i></span>
                        <div>
                            <strong>Saisie vocale intelligente</strong>
                            <small>Cliquez et dictez vos informations</small>
                        </div>
                        <b>...</b>
                    </div>

                    <form method="post" class="acc-form">
                        <input type="hidden" name="tab"    value="accounts">
                        <input type="hidden" name="action" value="account_save">

                        <div class="acc-form-section-label">
                            <i class="fa-solid fa-hashtag"></i>
                            <span>Identification</span>
                            <div class="acc-form-section-line"></div>
                        </div>

                        <div class="acc-form-row">
                            <div class="acc-field">
                                <label><i class="fa-solid fa-hashtag"></i> ID (modification)</label>
                                <input class="acc-input" type="number" name="idCompte" id="acc-edit-id"
                                       placeholder="Laisser vide pour creer">
                            </div>
                            <div class="acc-field">
                                <label>
                                    <i class="fa-solid fa-id-card"></i>
                                    Numero de compte <span style="color:#e53935">*</span>
                                </label>
                                <input class="acc-input" type="text" name="numeroCompte"
                                       placeholder="Ex: FR7612345" required>
                            </div>
                        </div>

                        <div class="acc-form-section-label">
                            <i class="fa-solid fa-sliders"></i>
                            <span>Parametres</span>
                            <div class="acc-form-section-line"></div>
                        </div>

                        <div class="acc-form-row">
                            <div class="acc-field">
                                <label><i class="fa-solid fa-coins"></i> Solde (TND)</label>
                                <input class="acc-input" type="number" step="0.01"
                                       name="solde" placeholder="0.00" required>
                            </div>
                            <div class="acc-field">
                                <label><i class="fa-solid fa-calendar-day"></i> Date d'ouverture</label>
                                <input class="acc-input" type="date" name="dateOuverture"
                                       value="{{ 'now'|date('Y-m-d') }}">
                            </div>
                        </div>

                        <div class="acc-form-row">
                            <div class="acc-field">
                                <label><i class="fa-solid fa-circle-dot"></i> Statut</label>
                                <div class="acc-select-wrap">
                                    <select class="acc-input" name="statutCompte">
                                        {% for v in ['Actif','Bloque','Ferme'] %}
                                            <option value="{{ v }}">{{ v }}</option>
                                        {% endfor %}
                                    </select>
                                </div>
                            </div>
                            <div class="acc-field">
                                <label><i class="fa-solid fa-tag"></i> Type de compte</label>
                                <div class="acc-select-wrap">
                                    <select class="acc-input" name="typeCompte">
                                        {% for v in ['Courant','Epargne','Professionnel'] %}
                                            <option value="{{ v }}">{{ v }}</option>
                                        {% endfor %}
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="acc-form-section-label">
                            <i class="fa-solid fa-shield-halved"></i>
                            <span>Plafonds de securite</span>
                            <div class="acc-form-section-line"></div>
                        </div>

                        <div class="acc-form-row">
                            <div class="acc-field">
                                <label>
                                    <i class="fa-solid fa-money-bill-wave"></i> Plafond retrait (TND)
                                </label>
                                <input class="acc-input" type="number" step="0.01"
                                       name="plafondRetrait" placeholder="0.00">
                            </div>
                            <div class="acc-field">
                                <label>
                                    <i class="fa-solid fa-paper-plane"></i> Plafond virement (TND)
                                </label>
                                <input class="acc-input" type="number" step="0.01"
                                       name="plafondVirement" placeholder="0.00">
                            </div>
                        </div>

                        <div class="acc-form-actions">
                            <button class="acc-submit-btn" type="submit">
                                <i class="fa-solid fa-floppy-disk"></i> Enregistrer
                            </button>
                            <button class="acc-reset-btn" type="reset">
                                <i class="fa-solid fa-rotate-left"></i> Vider
                            </button>
                        </div>
                    </form>
                </div>

                {# Quick-select accounts #}
                <div class="acc-panel">
                    <div class="acc-panel-head">
                        <div class="acc-panel-head-icon"
                             style="background:linear-gradient(135deg,#00838f,#00bcd4);">
                            <i class="fa-solid fa-circle-info"></i>
                        </div>
                        <div class="acc-panel-head-text">
                            <strong>Comptes disponibles</strong>
                            <p>Cliquez pour charger dans le formulaire</p>
                        </div>
                    </div>
                    <div class="acc-account-rows">
                        {% for account in items %}
                            <div class="acc-account-row selectable"
                                 data-acc-edit="{{ account.idCompte }}"
                                 data-acc-numero="{{ account.numeroCompte }}"
                                 data-acc-solde="{{ account.solde }}"
                                 data-acc-type="{{ account.typeCompte|default('Courant') }}"
                                 data-acc-statut="{{ account.statutCompte|default('Actif') }}"
                                 data-acc-ouverture="{{ account.dateOuverture|default('') }}"
                                 data-acc-retrait="{{ account.plafondRetrait|default('') }}"
                                 data-acc-virement="{{ account.plafondVirement|default('') }}">
                                <span class="acc-avatar">
                                    {{ account.numeroCompte|slice(0,2)|upper }}
                                </span>
                                <div class="acc-account-row-info">
                                    <strong>{{ account.numeroCompte }}</strong>
                                    <small>
                                        {{ account.typeCompte|default('Courant') }}
                                        · {{ account.statutCompte|default('Actif') }}
                                    </small>
                                </div>
                                <span class="acc-balance">
                                    {{ account.solde|number_format(2,'.', ' ') }} DT
                                </span>
                            </div>
                        {% else %}
                            <div class="acc-empty">
                                <div class="acc-empty-icon">
                                    <i class="fa-solid fa-inbox"></i>
                                </div>
                                <strong>Aucun compte</strong>
                                <span>Creez-en un via le formulaire.</span>
                            </div>
                        {% endfor %}
                    </div>
                </div>

            </div>
        </section>

    </div>{# end acc-body #}

</section>{# end acc-shell #}

{# ══════════════════════════════════════════════
   MODALS
══════════════════════════════════════════════ #}
<div class="acc-modal-wrap" id="acc-modal-wrap" hidden>
    <button class="acc-modal-backdrop" type="button" data-acc-close aria-label="Fermer"></button>

    {# WHEEL MODAL #}
    <div class="acc-modal" data-acc-panel="wheel" hidden>
        <div class="acc-modal-head">
            <div class="acc-modal-head-left">
                <div class="acc-modal-head-icon">
                    <i class="fa-solid fa-dharmachakra"></i>
                </div>
                <div>
                    <h3>Wheel of Fortune</h3>
                    <p>NEXORA BANK — Analyse comportement financier mensuel</p>
                </div>
            </div>
            <div class="acc-modal-head-right">
                <span class="acc-modal-badge {{ wheel.can_spin ? 'ok' : 'warn' }}">
                    {{ wheel.can_spin ? 'Eligible' : 'Verification' }}
                </span>
                <button class="acc-modal-close" type="button" data-acc-close>
                    <i class="fa-solid fa-xmark"></i> Fermer
                </button>
            </div>
        </div>
        <div class="acc-modal-body">
            <div class="acc-wheel-layout">
                <div class="acc-wheel-left">
                    <div class="acc-wheel-ring-outer">
                        <div class="acc-wheel-ring-inner">
                            <i class="fa-solid fa-star"></i>
                            <span>Roue</span>
                        </div>
                    </div>
                    <p class="acc-wheel-status">
                        {{ wheel.eligibility.message|default('Verification en cours.') }}
                    </p>
                    <form method="post" style="width:100%;">
                        <input type="hidden" name="tab"    value="accounts">
                        <input type="hidden" name="panel"  value="wheel">
                        <input type="hidden" name="action" value="wheel_spin">
                        <button class="acc-wheel-spin-btn" type="submit"
                                {{ not wheel.can_spin ? 'disabled' : '' }}>
                            <i class="fa-solid fa-dharmachakra"></i>
                            {{ wheel.can_spin ? 'Lancer la roue' : 'Conditions non remplies' }}
                        </button>
                    </form>
                    {% if wheel.last_points|default(0) > 0 %}
                        <div class="acc-wheel-result-note">
                            <strong>Dernier tirage</strong>
                            <p>+{{ wheel.last_points }} points · {{ wheel.last_spin_date|default('—') }}</p>
                        </div>
                    {% endif %}
                    {% if wheel.bonus_ready and items is not empty %}
                        <div class="acc-wheel-bonus">
                            <strong>🎉 100 POINTS ATTEINTS !</strong>
                            <p>Choisissez le compte qui recevra +50 DT.</p>
                            <form method="post">
                                <input type="hidden" name="tab"    value="accounts">
                                <input type="hidden" name="panel"  value="wheel">
                                <input type="hidden" name="action" value="wheel_bonus">
                                <select name="idCompte" required>
                                    {% for account in items %}
                                        <option value="{{ account.idCompte }}">
                                            {{ account.numeroCompte }}
                                            — {{ account.solde|number_format(2,'.', ' ') }} DT
                                        </option>
                                    {% endfor %}
                                </select>
                                <button class="acc-wheel-bonus-btn" type="submit" style="margin-top:8px;">
                                    Crediter +50 DT
                                </button>
                            </form>
                        </div>
                    {% endif %}
                </div>

                <div class="acc-wheel-right">
                    <div class="acc-wheel-section">
                        <div class="acc-wheel-section-title">
                            <i class="fa-solid fa-clipboard-check"></i> Conditions d'eligibilite
                        </div>
                        <div class="acc-wheel-condition {{ wheel.eligibility.condition_solde ? 'ok' : 'ko' }}">
                            <span><i class="fa-solid fa-wallet"></i></span>
                            <div>
                                <strong>Solde toujours positif</strong>
                                <small>Aucun solde negatif ce mois</small>
                            </div>
                            <b>{{ wheel.eligibility.condition_solde ? 'OK' : 'KO' }}</b>
                        </div>
                        <div class="acc-wheel-condition {{ wheel.eligibility.condition_budget ? 'ok' : 'ko' }}">
                            <span><i class="fa-solid fa-chart-pie"></i></span>
                            <div>
                                <strong>Budget mensuel respecte</strong>
                                <small>Depenses ≤ 80% des credits mensuels</small>
                            </div>
                            <b>{{ wheel.eligibility.condition_budget ? 'OK' : 'KO' }}</b>
                        </div>
                        <div class="acc-wheel-condition {{ wheel.eligibility.condition_epargne ? 'ok' : 'ko' }}">
                            <span><i class="fa-solid fa-piggy-bank"></i></span>
                            <div>
                                <strong>Epargne mensuelle active</strong>
                                <small>Au moins 1 operation epargne / coffre</small>
                            </div>
                            <b>{{ wheel.eligibility.condition_epargne ? 'OK' : 'KO' }}</b>
                        </div>
                    </div>

                    <div class="acc-wheel-section">
                        <div class="acc-wheel-section-title">
                            <i class="fa-solid fa-star"></i> Tes points NEXORA
                        </div>
                        <div class="acc-wheel-pts-head">
                            <span>{{ wheel.total_points|default(0) }} / 100 pts</span>
                            <span>{{ wheel_progress }}%</span>
                        </div>
                        <div class="acc-progress-track" style="margin-top:6px;">
                            <div class="acc-progress-fill" style="width:{{ wheel_progress }}%"></div>
                        </div>
                        <p style="font-size:12px;color:#7294ae;margin-top:6px;line-height:1.5;">
                            {{ wheel.eligibility.suggestion|default('Continue pour debloquer plus de recompenses.') }}
                        </p>
                    </div>

                    {% if not wheel.can_spin %}
                        <div class="acc-wheel-refusal">
                            <h4><i class="fa-solid fa-lock"></i> Acces refuse</h4>
                            <p>{{ wheel.eligibility.suggestion|default('Conditions non remplies.') }}</p>
                        </div>
                    {% endif %}

                    <div class="acc-wheel-rules">
                        <h4><i class="fa-solid fa-circle-info"></i> Regles du jeu</h4>
                        <p>— 1 tour par mois. Points cumules mois apres mois.</p>
                        <p>— 25 pts → Cashback. 50 pts → Reduction frais bancaires.</p>
                        <p class="highlight">— 100 pts → +50 DT credites automatiquement.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# HISTORY MODAL #}
    <div class="acc-modal" data-acc-panel="history" hidden>
        <div class="acc-modal-head">
            <div class="acc-modal-head-left">
                <div class="acc-modal-head-icon">
                    <i class="fa-solid fa-clock-rotate-left"></i>
                </div>
                <div>
                    <h3>Historique des actions</h3>
                    <p>Suivi des operations recentes du compte</p>
                </div>
            </div>
            <div class="acc-modal-head-right">
                <span style="font-size:12px;font-weight:700;color:rgba(255,255,255,.7);"
                      id="acc-history-count">{{ activity_logs|length }} action(s)</span>
                <button class="acc-modal-close" type="button" data-acc-close>
                    <i class="fa-solid fa-xmark"></i> Fermer
                </button>
            </div>
        </div>
        <div class="acc-modal-body">
            <div class="acc-history-search">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input id="acc-history-search" type="search"
                       placeholder="Rechercher par action, source ou date…">
            </div>
            <div class="acc-history-list" id="acc-history-list">
                {% for log in activity_logs %}
                    {% set action_text  = log.action_type|default('ACTION')|replace({'_': ' '})|title %}
                    {% set source_text  = log.action_source|default('Portal') %}
                    {% set details_text = log.details|default('') %}
                    {% set date_text    = log.created_at|default('—') %}
                    <article class="acc-history-row"
                             data-acc-history
                             data-acc-history-text="{{ (action_text~' '~source_text~' '~details_text~' '~date_text)|lower|e('html_attr') }}">
                        <div class="acc-history-icon">
                            <i class="fa-solid fa-clock-rotate-left"></i>
                        </div>
                        <div class="acc-history-main">
                            <strong>{{ action_text }}</strong>
                            <p>{{ details_text != '' ? details_text : 'Operation enregistree.' }}</p>
                            <small>{{ source_text }}</small>
                        </div>
                        <time>{{ date_text }}</time>
                    </article>
                {% else %}
                    <p class="acc-history-empty" id="acc-history-empty-base">
                        Aucune action enregistree.
                    </p>
                {% endfor %}
                <p class="acc-history-empty" id="acc-history-no-results" hidden>
                    Aucun resultat pour cette recherche.
                </p>
            </div>
        </div>
    </div>

    {# LANGUAGE MODAL #}
    <div class="acc-modal" style="max-width:640px;" data-acc-panel="language" hidden>
        <div class="acc-modal-head">
            <div class="acc-modal-head-left">
                <div class="acc-modal-head-icon">
                    <i class="fa-solid fa-globe"></i>
                </div>
                <div>
                    <h3>Langue et outils</h3>
                    <p>Acces rapide aux modules complementaires</p>
                </div>
            </div>
            <button class="acc-modal-close" type="button" data-acc-close>
                <i class="fa-solid fa-xmark"></i> Fermer
            </button>
        </div>
        <div class="acc-modal-body">
            <div class="acc-lang-grid">
                <a class="acc-lang-card" href="{{ path('portal_features', { section: 'insights' }) }}">
                    <i class="fa-solid fa-lightbulb"></i>
                    <strong>Insights IA</strong>
                    <span>Recommandations personnalisees et traduction intelligente</span>
                </a>
                <a class="acc-lang-card" href="{{ path('portal_features', { section: 'games' }) }}">
                    <i class="fa-solid fa-dragon"></i>
                    <strong>Module Jeux</strong>
                    <span>Roue + dragon + bonus et recompenses gamifiees</span>
                </a>
                <a class="acc-lang-card" href="{{ path('portal_features', { section: 'payments' }) }}">
                    <i class="fa-solid fa-credit-card"></i>
                    <strong>Paiements</strong>
                    <span>OTP, Stripe et historique des transactions</span>
                </a>
            </div>
        </div>
    </div>
</div>

<script>
(function () {
    'use strict';

    const $ = (sel, ctx = document) => ctx.querySelector(sel);
    const $$ = (sel, ctx = document) => Array.from(ctx.querySelectorAll(sel));

    /* ── TAB SYSTEM ── */
    const navBtns = $$('[data-acc-tab]');
    const panels  = $$('.acc-tab-panel');

    function activateTab(name) {
        navBtns.forEach(b => b.classList.toggle('active', b.dataset.accTab === name));
        panels.forEach(p => p.classList.toggle('active', p.id === 'acc-tab-' + name));
    }

    navBtns.forEach(btn => btn.addEventListener('click', () => activateTab(btn.dataset.accTab)));

    $$('[data-acc-tab-link]').forEach(el => {
        el.addEventListener('click', e => {
            e.preventDefault();
            activateTab(el.dataset.accTabLink);
        });
    });

    /* ── MODAL SYSTEM ── */
    const modalWrap   = $('#acc-modal-wrap');
    const modalPanels = $$('[data-acc-panel]', modalWrap || document);
    const ALLOWED     = ['wheel', 'history', 'language'];

    function hideAllModals() { modalPanels.forEach(p => p.hidden = true); }

    function syncURL(panel) {
        const url = new URL(location.href);
        panel ? url.searchParams.set('panel', panel) : url.searchParams.delete('panel');
        history.replaceState({}, '', url.pathname + (url.search || ''));
    }

    function openModal(name) {
        const pName = ALLOWED.includes(name) ? name : 'wheel';
        const panel = modalWrap?.querySelector(`[data-acc-panel="${pName}"]`);
        if (!panel || !modalWrap) return;
        hideAllModals();
        panel.hidden = false;
        modalWrap.hidden = false;
        document.body.style.overflow = 'hidden';
        syncURL(pName);
        if (pName === 'history') filterHistory();
    }

    function closeModal() {
        if (!modalWrap) return;
        modalWrap.hidden = true;
        document.body.style.overflow = '';
        hideAllModals();
        syncURL('');
    }

    $$('[data-acc-modal]').forEach(btn => btn.addEventListener('click', () => openModal(btn.dataset.accModal)));
    $$('[data-acc-close]').forEach(btn => btn.addEventListener('click', closeModal));
    document.addEventListener('keydown', e => {
        if (e.key === 'Escape' && modalWrap && !modalWrap.hidden) closeModal();
    });

    const urlPanel = new URLSearchParams(location.search).get('panel');
    if (urlPanel && ALLOWED.includes(urlPanel)) openModal(urlPanel);

    /* ── HISTORY SEARCH ── */
    const historyRows      = $$('[data-acc-history]');
    const historyCountEl   = $('#acc-history-count');
    const historyNoResults = $('#acc-history-no-results');
    const histSearchInput  = $('#acc-history-search');

    function filterHistory() {
        const kw = (histSearchInput?.value ?? '').trim().toLowerCase();
        let visible = 0;
        historyRows.forEach(row => {
            const show = kw === '' || (row.dataset.accHistoryText ?? '').includes(kw);
            row.hidden = !show;
            if (show) visible++;
        });
        if (historyCountEl) historyCountEl.textContent = `${visible} action(s)`;
        if (historyNoResults) historyNoResults.hidden = visible > 0 || kw === '';
    }

    histSearchInput?.addEventListener('input', filterHistory);

    /* ── ACCOUNTS FILTER + SEARCH ── */
    const chips     = $$('[data-acc-filter]');
    const accRows   = $$('[data-acc-account-type]');
    const accSearch = $('#acc-accounts-search');

    chips.forEach(chip => {
        chip.addEventListener('click', () => {
            chips.forEach(c => c.classList.remove('active'));
            chip.classList.add('active');
            const filter = chip.dataset.accFilter;
            accRows.forEach(row => {
                row.hidden = filter !== 'all' && row.dataset.accAccountType !== filter;
            });
        });
    });

    accSearch?.addEventListener('input', () => {
        const kw = accSearch.value.trim().toLowerCase();
        accRows.forEach(row => {
            row.hidden = kw !== '' && !row.textContent.toLowerCase().includes(kw);
        });
    });

    /* ── EDIT FORM FILL ── */
    const editIdInput = $('#acc-edit-id');

    function fillEditForm(el) {
        const form = editIdInput?.closest('form');
        if (!form) return;
        const set = (name, val) => {
            const f = form.querySelector(`[name="${name}"]`);
            if (f) f.value = val ?? '';
        };
        set('idCompte',        el.dataset.accEdit);
        set('numeroCompte',    el.dataset.accNumero);
        set('solde',           el.dataset.accSolde);
        set('typeCompte',      el.dataset.accType);
        set('statutCompte',    el.dataset.accStatut);
        set('dateOuverture',   el.dataset.accOuverture);
        set('plafondRetrait',  el.dataset.accRetrait);
        set('plafondVirement', el.dataset.accVirement);
    }

    $$('[data-acc-edit]').forEach(el => {
        el.addEventListener('click', () => {
            fillEditForm(el);
            if (el.dataset.accTabLink) activateTab('edit');
        });
    });

})();
</script>