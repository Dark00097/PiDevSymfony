{# ── Overlay principal SFSO ── #}
<div class="sfso-overlay" id="sfso-overlay" hidden role="dialog" aria-modal="true" aria-labelledby="sfso-title">
    <button class="sfso-backdrop" type="button" id="sfso-backdrop" aria-label="Fermer"></button>
    <div class="sfso-modal" id="sfso-modal-main">
        {# Contenu injecté dynamiquement par JS #}
    </div>
</div>

<div class="acc-modal-wrap" id="acc-history-modal" hidden>
    <button class="acc-modal-backdrop" type="button" data-acc-history-close aria-label="Fermer"></button>
    <div class="acc-modal">
        <div class="acc-modal-head">
            <div>
                <h4 id="acc-history-title">Historique des opérations</h4>
                <p id="acc-history-subtitle">Toutes les actions enregistrées automatiquement</p>
            </div>
            <button class="acc-modal-close" type="button" data-acc-history-close>
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>
        <div class="acc-modal-body" id="acc-history-body">
            {% for row in account_history %}
                <article class="acc-history-row"
                         data-history-row
                         data-history-text="{{ (row.action|default('') ~ ' ' ~ row.detail|default('') ~ ' ' ~ row.idCompte|default('') ~ ' ' ~ row.idCoffre|default('') ~ ' ' ~ row.timestamp|default(''))|lower|e('html_attr') }}">
                    <div class="acc-history-icon"><i class="fa-solid fa-clock-rotate-left"></i></div>
                    <div class="acc-history-main">
                        <strong>{{ row.action|default('Action') }}</strong>
                        <p>{{ row.detail|default('Aucun détail disponible.') }}</p>
                        <time>{{ row.timestamp|default('-') }}</time>
                    </div>
                </article>
            {% else %}
                <div class="acc-empty" style="min-height:180px;">
                    <i class="fa-solid fa-clock-rotate-left"></i>
                    <strong>Aucun historique disponible</strong>
                    <span>Les ajouts, modifications et suppressions apparaîtront ici.</span>
                </div>
            {% endfor %}
            <div class="acc-empty" id="acc-history-empty" hidden>
                <i class="fa-solid fa-clock-rotate-left"></i>
                <strong>Aucun historique trouvé</strong>
                <span>Effectuez une action sur les comptes ou les coffres pour alimenter cet historique.</span>
            </div>
        </div>
    </div>
</div>

<script>
(function () {
    const $ = (s, c = document) => c.querySelector(s);
    const $$ = (s, c = document) => Array.from(c.querySelectorAll(s));

    const historyModal    = $('#acc-history-modal');
    const openHistoryBtn  = $('#acc-open-history');
    const historyTitle    = $('#acc-history-title');
    const historySubtitle = $('#acc-history-subtitle');
    const historyRows     = $$('[data-history-row]');
    const historyEmpty    = $('#acc-history-empty');

    function normalize(v) {
        return (v||'').toString().toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'');
    }

    function openHistory(accountId, accountNumber) {
        if (!historyModal) return;
        if (!accountId) {
            historyRows.forEach(r => { r.hidden = false; });
            if (historyTitle)    historyTitle.textContent    = 'Historique des opérations';
            if (historySubtitle) historySubtitle.textContent = 'Toutes les actions enregistrées automatiquement';
            if (historyEmpty)    historyEmpty.hidden = historyRows.length === 0;
        } else {
            const idNeedle  = normalize('#' + accountId);
            const numNeedle = normalize(accountNumber);
            let visible = 0;
            historyRows.forEach(row => {
                const hay   = normalize(row.dataset.historyText);
                const match = hay.includes(idNeedle) || hay.includes(numNeedle);
                row.hidden  = !match;
                if (match) visible++;
            });
            if (historyTitle)    historyTitle.textContent    = 'Historique - ' + accountNumber;
            if (historySubtitle) historySubtitle.textContent = 'Actions recentes liees au compte #' + accountId;
            if (historyEmpty)    historyEmpty.hidden = visible !== 0;
        }
        historyModal.hidden = false;
        document.body.style.overflow = 'hidden';
    }

    function closeHistory() {
        if (!historyModal) return;
        historyModal.hidden = true;
        document.body.style.overflow = '';
    }

    $$('[data-acc-history-open]').forEach(btn =>
        btn.addEventListener('click', () => openHistory(btn.dataset.accountId||'', btn.dataset.accountNumber||'Compte'))
    );
    openHistoryBtn?.addEventListener('click', () => openHistory('', ''));
    $$('[data-acc-history-close]').forEach(btn => btn.addEventListener('click', closeHistory));
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeHistory(); });

    $$('[data-account-select]').forEach(card => {
        card.addEventListener('click', e => {
            if (e.target.closest('a, button, form, input, select, textarea, label')) return;
            const url = card.dataset.accountUrl;
            if (url) window.location.href = url;
        });
    });
})();
</script>

<script>
(function() {
    var today = new Date(); today.setHours(0,0,0,0);
    var accountLimitMin = 10;
    var accountLimitMax = 1000;

    function setValid(el, msgEl) {
        el.classList.remove('acc-invalid'); el.classList.add('acc-valid');
        if (msgEl) { msgEl.className = 'acc-field-ok'; msgEl.textContent = 'Valide'; }
    }
    function setError(el, msgEl, msg) {
        el.classList.remove('acc-valid'); el.classList.add('acc-invalid');
        if (msgEl) { msgEl.className = 'acc-field-error'; msgEl.textContent = msg; }
    }
    function clearState(el, msgEl) {
        el.classList.remove('acc-valid','acc-invalid');
        if (msgEl) { msgEl.className = ''; msgEl.textContent = ''; }
    }
    function getOrCreateMsg(el) {
        var next = el.nextElementSibling;
        if (next && (next.classList.contains('acc-field-error') || next.classList.contains('acc-field-ok'))) return next;
        var span = document.createElement('span');
        el.parentNode.insertBefore(span, el.nextSibling);
        return span;
    }

    var formInput = document.querySelector('input[name="action"][value="account_save"]');
    if (!formInput) return;
    var form = formInput.closest('form');
    var accountMode = form.dataset.accountMode || ((form.querySelector('input[name="idCompte"]')?.value || '').trim() !== '' ? 'edit' : 'create');
    var isEditMode = accountMode === 'edit';

    function validateField(el) {
        var name = el.name, val = el.value.trim(), msg = getOrCreateMsg(el);
        if (name === 'numeroCompte') {
            if (!val) return setError(el, msg, 'Le numéro de compte est obligatoire.');
            if (!/^CB-\d{3,}$/.test(val)) return setError(el, msg, 'Format requis : CB-XXX (ex: CB-123).');
            return setValid(el, msg);
        }
        if (name === 'typeCompte')   { return val ? setValid(el, msg) : setError(el, msg, 'Veuillez sélectionner un type.'); }
        if (name === 'statutCompte') { return val ? setValid(el, msg) : setError(el, msg, 'Veuillez sélectionner un statut.'); }
        if (name === 'solde') {
            if (!val) return setError(el, msg, 'Le solde est obligatoire.');
            if (parseFloat(val) < 0) return setError(el, msg, 'Le solde doit être ≥ 0.');
            return setValid(el, msg);
        }
        if (name === 'dateOuverture') {
            if (!val) return clearState(el, msg);
            var now = new Date();
            var todayStr = now.getFullYear() + '-'
                + String(now.getMonth() + 1).padStart(2, '0') + '-'
                + String(now.getDate()).padStart(2, '0');
            var originalDate = (el.dataset.originalValue || '').trim();
            if (isEditMode) {
                if (originalDate && val !== originalDate) return setError(el, msg, "La date d'ouverture ne peut pas être modifiée.");
                return setValid(el, msg);
            }
            if (val > todayStr) return setError(el, msg, "La date d'ouverture ne peut pas être dans le futur.");
            return setValid(el, msg);
        }
        if (name === 'plafondRetrait' || name === 'plafondVirement') {
            if (!val) return clearState(el, msg);
            var numericValue = parseFloat(val);
            if (isNaN(numericValue)) return setError(el, msg, 'Montant invalide.');
            var originalRawValue = (el.dataset.originalValue || '').trim();
            var originalNumericValue = originalRawValue === '' ? null : parseFloat(originalRawValue);
            if (isEditMode && originalNumericValue !== null && !isNaN(originalNumericValue) && numericValue === originalNumericValue) {
                return setValid(el, msg);
            }
            if (numericValue < accountLimitMin || numericValue > accountLimitMax) return setError(el, msg, 'Doit être entre 10 DT et 1000 DT.');
            return setValid(el, msg);
        }
    }

    (function() {
        var dateEl = form.querySelector('[name="dateOuverture"]');
        if (!dateEl) return;
        var now = new Date();
        var localToday = now.getFullYear() + '-'
            + String(now.getMonth() + 1).padStart(2, '0') + '-'
            + String(now.getDate()).padStart(2, '0');
        dateEl.max = localToday;
        if (!isEditMode && !dateEl.value) {
            dateEl.value = localToday;
        }
    })();

    var fields = ['numeroCompte','typeCompte','statutCompte','solde','dateOuverture','plafondRetrait','plafondVirement'];
    fields.forEach(function(name) {
        var el = form.querySelector('[name="'+name+'"]');
        if (!el) return;
        ['input','change','blur'].forEach(function(ev) { el.addEventListener(ev, function() { validateField(el); }); });
    });
    form.addEventListener('submit', function(e) {
        console.log('[Form Debug] Submission started');
        var ok = true;
        fields.forEach(function(name) {
            var el = form.querySelector('[name="'+name+'"]');
            if (!el) return;
            validateField(el);
            if (el.classList.contains('acc-invalid')) {
                console.warn('[Form Debug] Field invalid:', name);
                ok = false;
            }
        });
        if (!ok) {
            console.error('[Form Debug] Submission blocked due to validation errors');
            e.preventDefault();
            showToast('Veuillez corriger les champs en rouge avant d\'enregistrer.', 4000);
        } else {
            console.log('[Form Debug] Submission valid, sending to server...');
        }
    });
})();
</script>

<script>
(function() {
    var today = new Date(); today.setHours(0,0,0,0);
    function setValid(el,m){el.classList.remove('acc-invalid');el.classList.add('acc-valid');if(m){m.className='acc-field-ok';m.textContent='Valide';}}
    function setError(el,m,msg){el.classList.remove('acc-valid');el.classList.add('acc-invalid');if(m){m.className='acc-field-error';m.textContent=msg;}}
    function clearState(el,m){el.classList.remove('acc-valid','acc-invalid');if(m){m.className='';m.textContent='';}}
    function getOrCreateMsg(el){var next=el.nextElementSibling;if(next&&(next.classList.contains('acc-field-error')||next.classList.contains('acc-field-ok')))return next;var s=document.createElement('span');el.parentNode.insertBefore(s,el.nextSibling);return s;}
    function validate(el,form){
        var name=el.name,val=el.value.trim(),m=getOrCreateMsg(el);
        if(name==='nom'){return val.length<3?setError(el,m,'Le nom doit contenir au moins 3 caractères.'):setValid(el,m);}
        if(name==='objectifMontant'){if(!val)return setError(el,m,"L'objectif est obligatoire.");return parseFloat(val)<=0?setError(el,m,"L'objectif doit être > 0."):setValid(el,m);}
        if(name==='montantActuel'){if(!val)return clearState(el,m);if(parseFloat(val)<0)return setError(el,m,'Le montant actuel doit être ≥ 0.');var o=form.querySelector('[name="objectifMontant"]');if(o&&o.value&&parseFloat(val)>parseFloat(o.value))return setError(el,m,"Ne doit pas dépasser l'objectif.");return setValid(el,m);}
        if(name==='dateCreation'){if(!val)return clearState(el,m);var d=new Date(val);d.setHours(0,0,0,0);return d>today?setError(el,m,"La date de création ne doit pas dépasser aujourd'hui."):setValid(el,m);}
        if(name==='dateObjectifs'){if(!val)return clearState(el,m);var dc=form.querySelector('[name="dateCreation"]');if(dc&&dc.value){var a=new Date(dc.value),b=new Date(val);a.setHours(0,0,0,0);b.setHours(0,0,0,0);if(b<a)return setError(el,m,'Doit être ≥ à la date de création.');}return setValid(el,m);}
        if(name==='status'){return val?setValid(el,m):setError(el,m,'Veuillez sélectionner un statut.');}
        if(name==='idCompte'){return(!val||val==='0')?setError(el,m,'Veuillez sélectionner un compte.'):setValid(el,m);}
        if(name==='estVerrouille'){var o2=form.querySelector('[name="objectifMontant"]'),a2=form.querySelector('[name="montantActuel"]');if(o2&&a2&&o2.value&&a2.value){var pct=(parseFloat(a2.value)/parseFloat(o2.value))*100;if(pct>=100&&val==='0')return setError(el,m,"Le coffre doit être verrouillé à 100%.");}return setValid(el,m);}
    }
    var inp=document.querySelector('input[name="action"][value="vault_save"]');
    if(!inp)return;
    var form=inp.closest('form');
    ['nom','objectifMontant','montantActuel','dateCreation','dateObjectifs','status','idCompte','estVerrouille'].forEach(function(name){
        var el=form.querySelector('[name="'+name+'"]');if(!el)return;
        ['input','change','blur'].forEach(function(ev){el.addEventListener(ev,function(){validate(el,form);});});
    });
    form.addEventListener('submit',function(e){
        var ok=true;
        ['nom','objectifMontant','montantActuel','dateCreation','dateObjectifs','status','idCompte','estVerrouille'].forEach(function(name){
            var el=form.querySelector('[name="'+name+'"]');if(!el)return;
            validate(el,form);if(el.classList.contains('acc-invalid'))ok=false;
        });
        if(!ok)e.preventDefault();
    });
})();
</script>

<script>
(function () {
    const TRANSLATE_URL = '/api/translate';

    const SELECTORS = [
        '.acc-hero-title',
        '.acc-hero-sub',
        '.acc-hero-metric span',
        '.acc-stat-label',
        '.acc-stat-sub',
        '.acc-board-title h3',
        '.acc-board-title p',
        '.acc-panel-head h2',
        '.acc-panel-head p',
        '.acc-form-block-head span',
        '.acc-field label',
        '.acc-btn-save',
        '.acc-btn-cancel',
        '.acc-card-balance-label',
        '.acc-card-meta span',
        '.acc-card-edit',
        '#acc-open-history span',
        '.acc-empty strong',
        '.acc-empty span',
    ];

    let textNodes  = null;
    let currentLang = 'fr';

    function collectTextNodes() {
        if (textNodes) return;
        textNodes = [];
        const seen = new WeakSet();
        SELECTORS.forEach(sel => {
            document.querySelectorAll(sel).forEach(el => {
                el.childNodes.forEach(child => {
                    if (child.nodeType !== 3) return;
                    const text = child.textContent.trim();
                    if (text.length < 2 || seen.has(child)) return;
                    seen.add(child);
                    textNodes.push({ node: child, original: child.textContent });
                });
            });
        });
    }

    async function applyTranslation(lang) {
        if (lang === 'fr') {
            if (textNodes) textNodes.forEach(({ node, original }) => { node.textContent = original; });
            document.querySelector('.acc-page').style.direction = 'ltr';
            return;
        }

        collectTextNodes();
        const texts = textNodes.map(n => n.node.textContent.trim());
        const CHUNK = 40;
        let translated = [];

        for (let i = 0; i < texts.length; i += CHUNK) {
            const chunk = texts.slice(i, i + CHUNK);
            const res = await fetch(TRANSLATE_URL, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ texts: chunk, lang })
            });
            if (!res.ok) throw new Error('HTTP ' + res.status + ': ' + await res.text());
            const data = await res.json();
            if (data.error) throw new Error(data.error);
            translated = translated.concat(data.translations || chunk);
        }

        textNodes.forEach(({ node }, idx) => {
            if (translated[idx] !== undefined && translated[idx] !== '') {
                node.textContent = translated[idx];
            }
        });

        document.querySelector('.acc-page').style.direction = lang === 'ar' ? 'rtl' : 'ltr';
    }

    const langSelect  = document.getElementById('acc-lang-select');
    const langSpinner = document.getElementById('acc-lang-spinner');

    langSelect?.addEventListener('change', async function () {
        const lang = this.value;
        if (!lang || lang === currentLang) return;
        currentLang = lang;
        langSpinner.hidden = false;
        this.disabled = true;
        try {
            await applyTranslation(lang);
        } catch (e) {
            console.error('[Translate]', e);
        } finally {
            langSpinner.hidden = true;
            this.disabled = false;
        }
    });
})();
</script>

<script>
(function () {
    const btn  = document.getElementById('acc-voice-btn');
    const icon = document.getElementById('acc-voice-icon');
    if (!btn || !icon) return;

    const STT_PARSE_URL = '/api/voice-stt-parse';

    function normalize(str) {
        return (str || '').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').trim();
    }

    function showToast(msg, duration) {
        document.querySelectorAll('.acc-voice-toast').forEach(t => t.remove());
        const t = document.createElement('div');
        t.className = 'acc-voice-toast';
        t.innerHTML = '<i class="fa-solid fa-microphone-lines"></i> ' + msg;
        document.body.appendChild(t);
        if (duration > 0) setTimeout(() => t.remove(), duration);
        return t;
    }

    function sanitizeRecognizedValue(key, value) {
        let raw = String(value || '').trim();
        if (!raw) return '';

        if (key === 'numeroCompte') {
            // Force le format CB-XXX
            let digits = raw.replace(/\D/g, '');
            if (digits.length >= 2) return 'CB-' + digits;
            // Si pas de chiffres mais contient du texte, on garde tel quel (formaté)
            return raw.toUpperCase().replace(/\s+/g, '');
        }

        if (key === 'solde' || key === 'plafondRetrait' || key === 'plafondVirement') {
            // Nettoyage complet : garde uniquement chiffres et un seul point
            let cleaned = raw.replace(/[^\d.,]/g, '').replace(',', '.');
            let parts = cleaned.split('.');
            if (parts.length > 2) cleaned = parts[0] + '.' + parts.slice(1).join('');
            
            let num = parseFloat(cleaned);
            if (isNaN(num)) return '';
            
            // Retourne une chaîne formatée avec un point décimal
            return num.toFixed(2);
        }

        if (key === 'typeCompte') {
            const low = normalize(raw);
            if (low.includes('courant')) return 'Courant';
            if (low.includes('pro')) return 'Professionnel';
            if (low.includes('epargne')) return 'Épargne';
        }

        if (key === 'statutCompte') {
            const low = normalize(raw);
            if (low.includes('actif')) return 'Actif';
            if (low.includes('ferme')) return 'Fermé';
            if (low.includes('bloque')) return 'Bloqué';
        }

        return raw;
    }

    function fillForm(fields) {
        console.log('[Voice Debug] Fields received:', fields);
        const formInput = document.querySelector('input[name="action"][value="account_save"]');
        if (!formInput) { showToast('Formulaire introuvable.', 3000); return; }
        const form = formInput.closest('form');

        // Sécurité : s'assurer que idUser est présent
        const idUserInp = form.querySelector('input[name="idUser"]');
        if (idUserInp && !idUserInp.value) {
            console.warn('[Voice Debug] idUser was empty, trying to recover...');
            idUserInp.value = "{{ current_user.idUser|default('') }}";
        }

        const map = {
            numeroCompte:    'input[name="numeroCompte"]',
            typeCompte:      'select[name="typeCompte"]',
            statutCompte:    'select[name="statutCompte"]',
            solde:           'input[name="solde"]',
            dateOuverture:   'input[name="dateOuverture"]',
            plafondRetrait:  'input[name="plafondRetrait"]',
            plafondVirement: 'input[name="plafondVirement"]',
        };

        let filled = 0;

        Object.entries(fields).forEach(([key, value]) => {
            if (!value || !map[key]) return;
            
            // On ne laisse pas la voix modifier certains champs critiques si on est en mode création
            if (key === 'statutCompte' || key === 'dateOuverture') return;

            const el = form.querySelector(map[key]);
            if (!el) return;
            
            const sanitizedValue = sanitizeRecognizedValue(key, value);
            console.log(`[Voice Debug] Field ${key}: original="${value}", sanitized="${sanitizedValue}"`);
            
            if (!sanitizedValue) return;

            if (el.tagName === 'SELECT') {
                const needle  = normalize(String(sanitizedValue));
                let matched   = false;

                for (const opt of el.options) {
                    if (!opt.value) continue;
                    if (normalize(opt.value) === needle) { el.value = opt.value; matched = true; break; }
                }
                if (!matched) {
                    for (const opt of el.options) {
                        if (!opt.value) continue;
                        const nv = normalize(opt.value);
                        if (nv.includes(needle) || needle.includes(nv)) { el.value = opt.value; matched = true; break; }
                    }
                }
                if (!matched) {
                    for (const opt of el.options) {
                        if (!opt.value) continue;
                        const nt = normalize(opt.text);
                        if (nt.includes(needle) || needle.includes(nt)) { el.value = opt.value; matched = true; break; }
                    }
                }
                if (matched) {
                    filled++;
                    el.dispatchEvent(new Event('change', { bubbles: true }));
                }

            } else {
                el.value = String(sanitizedValue);
                // Trigger events to notify validation scripts
                el.dispatchEvent(new Event('input',  { bubbles: true }));
                el.dispatchEvent(new Event('change', { bubbles: true }));
                el.dispatchEvent(new Event('blur',   { bubbles: true }));
                filled++;
            }
        });

        showToast(
            filled > 0
                ? '✓ ' + filled + ' champ(s) rempli(s) avec succès'
                : 'Aucun champ reconnu — parlez plus clairement.',
            3500
        );

        if (filled > 0) {
            document.getElementById('acc-form-anchor')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
    }

    function startRecorder() {
        return new Promise(async (resolve, reject) => {
            try {
                const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
                const audioCtx = new (window.AudioContext || window.webkitAudioContext)({ sampleRate: 16000 });
                const source = audioCtx.createMediaStreamSource(stream);
                
                // On utilise AudioWorklet si possible, sinon ScriptProcessor
                const processor = audioCtx.createScriptProcessor(4096, 1, 1);
                const chunks = [];
                const startedAt = Date.now();
                let lastSoundAt = startedAt;
                let hasSpeech = false;
                
                processor.onaudioprocess = (e) => {
                    const input = e.inputBuffer.getChannelData(0);
                    chunks.push(new Float32Array(input));
                    let peak = 0;
                    for (let i = 0; i < input.length; i++) {
                        const v = Math.abs(input[i]);
                        if (v > peak) peak = v;
                    }
                    if (peak > 0.02) {
                        lastSoundAt = Date.now();
                        hasSpeech = true;
                    }
                };
                
                source.connect(processor);
                processor.connect(audioCtx.destination);

                resolve({
                    stop: async () => {
                        processor.disconnect();
                        source.disconnect();
                        stream.getTracks().forEach(t => t.stop());
                        const wavBlob = floatToWav(chunks, 16000);
                        audioCtx.close();
                        return wavBlob;
                    },
                    getStartedAt: () => startedAt,
                    getLastSoundAt: () => lastSoundAt,
                    hasSpeech: () => hasSpeech,
                });
            } catch (e) {
                reject(e);
            }
        });
    }

    function floatToWav(buffers, sampleRate) {
        let length = 0;
        for (const b of buffers) length += b.length;
        const pcm = new Int16Array(length);
        let offset = 0;
        for (const b of buffers) {
            for (let i = 0; i < b.length; i++) {
                let s = Math.max(-1, Math.min(1, b[i]));
                pcm[offset++] = s < 0 ? s * 0x8000 : s * 0x7FFF;
            }
        }
        const wavBuffer = new ArrayBuffer(44 + pcm.length * 2);
        const view = new DataView(wavBuffer);
        writeString(view, 0, 'RIFF');
        view.setUint32(4, 36 + pcm.length * 2, true);
        writeString(view, 8, 'WAVE');
        writeString(view, 12, 'fmt ');
        view.setUint32(16, 16, true);
        view.setUint16(20, 1, true); // PCM
        view.setUint16(22, 1, true); // Mono
        view.setUint32(24, sampleRate, true);
        view.setUint32(28, sampleRate * 2, true);
        view.setUint16(32, 2, true); // Block align
        view.setUint16(34, 16, true); // Bits per sample
        writeString(view, 36, 'data');
        view.setUint32(40, pcm.length * 2, true);
        let idx = 44;
        for (let i = 0; i < pcm.length; i++, idx += 2) {
            view.setInt16(idx, pcm[i], true);
        }
        return new Blob([view], { type: 'audio/wav' });
    }

    function writeString(view, offset, str) {
        for (let i = 0; i < str.length; i++) view.setUint8(offset + i, str.charCodeAt(i));
    }

    async function sendWav(blob) {
        const form = new FormData();
        form.append('audio', blob, 'recording.wav');
        const langSelect = document.getElementById('acc-lang-select');
        const lang = langSelect ? (langSelect.value || 'fr') : 'fr';
        form.append('lang', lang);
        const res = await fetch(STT_PARSE_URL, { method: 'POST', body: form });
        const data = await res.json().catch(() => ({}));
        if (!res.ok || data.error) throw new Error(data.error || ('HTTP ' + res.status));
        return data;
    }

    let recording = null;
    let toastEl   = null;
    let stopTimer = null;
    let monitorTimer = null;
    let isStopping = false;

    function clearVoiceTimers() {
        if (stopTimer) {
            clearTimeout(stopTimer);
            stopTimer = null;
        }
        if (monitorTimer) {
            clearInterval(monitorTimer);
            monitorTimer = null;
        }
    }

    async function stopRecordingAndProcess() {
        if (!recording || isStopping) return;
        isStopping = true;
        const activeRecording = recording;
        recording = null;
        try {
            btn.classList.remove('is-listening');
            btn.classList.add('is-processing');
            icon.className = 'fa-solid fa-circle-notch fa-spin';
            toastEl?.remove(); toastEl = null;
            toastEl = showToast('Transcription et analyse en cours…', 0);
            
            const blob = await activeRecording.stop();
            const hadSpeech = typeof activeRecording.hasSpeech === 'function' ? activeRecording.hasSpeech() : true;

            if (!hadSpeech) {
                throw new Error('Aucune voix detectee. Parlez plus pres du micro.');
            }

            const data = await sendWav(blob);
            toastEl?.remove(); toastEl = null;

            const transcript = (data.transcript || '').trim();
            const fields = data.fields || {};

            if (transcript) {
                showToast('Texte reconnu : "' + transcript + '"', 5000);
            }

            if (Object.keys(fields).length > 0) {
                fillForm(fields);
            } else {
                showToast('Désolé, je n\'ai pas pu extraire d\'informations. Essayez de citer : type, solde, numéro...', 5000);
            }
        } catch (e) {
            toastEl?.remove(); toastEl = null;
            showToast('Erreur : ' + (e.message || 'Le service est indisponible'), 5000);
            console.error('[Voice]', e);
        } finally {
            clearVoiceTimers();
            btn.classList.remove('is-processing');
            icon.className = 'fa-solid fa-microphone-lines';
            isStopping = false;
        }
    }

    btn.addEventListener('click', async () => {
        if (!recording) {
            try {
                recording = await startRecorder();
                btn.classList.add('is-listening');
                icon.className = 'fa-solid fa-stop';
                toastEl = showToast('Parlez librement… arrêt auto après votre silence ou dans 20 secondes', 0);

                stopTimer = setTimeout(() => {
                    stopRecordingAndProcess();
                }, 20000);

                monitorTimer = setInterval(() => {
                    if (!recording) return;
                    const startedAt = typeof recording.getStartedAt === 'function' ? recording.getStartedAt() : Date.now();
                    const lastSoundAt = typeof recording.getLastSoundAt === 'function' ? recording.getLastSoundAt() : startedAt;
                    const now = Date.now();
                    const recordMs = now - startedAt;
                    const silenceMs = now - lastSoundAt;

                    if (recording.hasSpeech && recording.hasSpeech() && recordMs >= 3000 && silenceMs >= 1800) {
                        stopRecordingAndProcess();
                    }
                }, 300);
            } catch (e) {
                showToast('Accès au micro refusé ou indisponible.', 4000);
            }
        } else {
            await stopRecordingAndProcess();
        }
    });
})();
</script>

