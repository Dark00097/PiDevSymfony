{# ══════════════════════════════════════════════════════════════════════════════
   SMART FINANCIAL STRATEGY OPTIMIZER — JavaScript
══════════════════════════════════════════════════════════════════════════════ #}
<script>
(function () {
    'use strict';

    // ── Références DOM ──────────────────────────────────────────────────────
    const overlay   = document.getElementById('sfso-overlay');
    const backdrop  = document.getElementById('sfso-backdrop');
    const modalMain = document.getElementById('sfso-modal-main');

    if (!overlay || !modalMain) return;

    // ── État ────────────────────────────────────────────────────────────────
    let currentCoffreId   = null;
    let currentCoffreNom  = '';
    let currentUserId     = null;
    let selectedStrategy  = null;
    let analysisData      = null;

    // ── Couleurs par type ───────────────────────────────────────────────────
    const TYPE_COLORS = {
        DOUCE:     { text: '#16a34a', bg: '#dcfce7', bar: '#22c55e' },
        MODEREE:   { text: '#2563eb', bg: '#dbeafe', bar: '#3b82f6' },
        AGRESSIVE: { text: '#d97706', bg: '#fef3c7', bar: '#f97316' },
    };

    // Labels affichés (avec accents)
    const TYPE_LABELS = {
        DOUCE:     'DOUCE',
        MODEREE:   'MODÉRÉE',
        AGRESSIVE: 'AGRESSIVE',
    };

    // Risques affichés (avec accents)
    const RISQUE_LABELS = {
        'Tres faible': 'Très faible',
        'Faible':      'Faible',
        'Modere':      'Modéré',
        'Eleve':       'Élevé',
    };

    // ── Ouvrir le modal ─────────────────────────────────────────────────────
    function openModal(coffreId, coffreNom, userId) {
        currentCoffreId  = coffreId;
        currentCoffreNom = coffreNom;
        currentUserId    = userId;
        selectedStrategy = null;
        analysisData     = null;

        overlay.hidden = false;
        document.body.style.overflow = 'hidden';
        renderLoading();
        fetchAnalysis(coffreId, userId);
    }

    function closeModal() {
        overlay.hidden = true;
        document.body.style.overflow = '';
        modalMain.innerHTML = '';
        selectedStrategy = null;
        analysisData     = null;
    }

    // ── Rendu : chargement ──────────────────────────────────────────────────
    function renderLoading() {
        modalMain.innerHTML = `
            <div class="sfso-header">
                <div class="sfso-header-left">
                    <div class="sfso-header-icon"><i class="fa-solid fa-brain"></i></div>
                    <div>
                        <h3 id="sfso-title">Smart Financial Strategy Optimizer</h3>
                        <p>Coffre : ${escHtml(currentCoffreNom)} · Analyse Random Forest ML</p>
                    </div>
                </div>
                <button class="sfso-close" type="button" id="sfso-close-btn" aria-label="Fermer">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
            <div class="sfso-loading">
                <i class="fa-solid fa-circle-notch"></i>
                <strong style="display:block;font-size:15px;color:#102a43;margin-bottom:6px;">Analyse en cours…</strong>
                <span style="font-size:13px;">Le modèle Random Forest analyse votre profil financier</span>
            </div>`;
        document.getElementById('sfso-close-btn')?.addEventListener('click', closeModal);
    }

    // ── Appel API ───────────────────────────────────────────────────────────
    async function fetchAnalysis(coffreId, userId) {
        try {
            const url = `/api/smart-strategy/analyze/${coffreId}?user_id=${userId}`;
            const res = await fetch(url, {
                headers: { 'X-User-Id': String(userId) },
            });
            const data = await res.json();
            if (!res.ok || data.error) throw new Error(data.error || 'Erreur serveur');
            analysisData = data;
            renderStrategies(data);
        } catch (err) {
            renderError(err.message);
        }
    }

    // ── Rendu : stratégies ──────────────────────────────────────────────────
    function renderStrategies(data) {
        const strategies = data.strategies || [];
        const safetySeuil = data.safety_seuil || 50;

        const cardsHtml = strategies.map(s => {
            const colors  = TYPE_COLORS[s.type] || TYPE_COLORS.MODEREE;
            const isRec   = s.recommended;
            const typeLabel = TYPE_LABELS[s.type] || s.type;
            const risqueLabel = RISQUE_LABELS[s.risque] || s.risque;
            return `
            <div class="sfso-card${isRec ? ' recommended-card' : ''}"
                 data-type="${escHtml(s.type)}"
                 role="radio" aria-checked="false" tabindex="0"
                 onclick="sfsoSelectCard(this)"
                 onkeydown="if(event.key==='Enter'||event.key===' ')sfsoSelectCard(this)">
                ${isRec ? '<span class="sfso-recommended-badge">Recommandée</span>' : ''}
                <div class="sfso-card-type" style="color:${colors.text}">${typeLabel}</div>
                <div class="sfso-card-amount" style="color:${colors.text}">${formatNum(s.montant)} DT</div>
                <div class="sfso-card-unit">par mois</div>
                <div class="sfso-card-detail">
                    <div><span>Durée</span><strong>${s.duree} mois</strong></div>
                    <div><span>Succès</span><strong style="color:${colors.text}">${s.taux_succes}%</strong></div>
                    <div><span>Risque</span><strong style="color:${colors.text}">${escHtml(risqueLabel)}</strong></div>
                </div>
                <div class="sfso-card-bar" style="background:${colors.bg}">
                    <div style="height:100%;border-radius:4px;background:${colors.bar};width:${Math.min(s.taux_succes,100)}%;"></div>
                </div>
            </div>`;
        }).join('');

        modalMain.innerHTML = `
            <div class="sfso-header">
                <div class="sfso-header-left">
                    <div class="sfso-header-icon"><i class="fa-solid fa-brain"></i></div>
                    <div>
                        <h3 id="sfso-title">Stratégies recommandées par l'IA</h3>
                        <p>Coffre : ${escHtml(currentCoffreNom)} · Analyse Random Forest ML</p>
                    </div>
                </div>
                <button class="sfso-close" type="button" id="sfso-close-btn" aria-label="Fermer">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
            <div class="sfso-body">
                <div class="sfso-metrics">
                    <div class="sfso-metric">
                        <strong>${formatNum(data.solde_compte)} DT</strong>
                        <span>Solde compte</span>
                    </div>
                    <div class="sfso-metric">
                        <strong>${formatNum(data.capacite_mensuelle)} DT</strong>
                        <span>Capacité mensuelle</span>
                    </div>
                    <div class="sfso-metric">
                        <strong>${data.ratio_epargne}%</strong>
                        <span>Ratio épargne</span>
                    </div>
                </div>
                <div class="sfso-strategies" id="sfso-strategies-grid">
                    ${cardsHtml}
                </div>
                <div class="sfso-safety">
                    <i class="fa-solid fa-circle-info"></i>
                    <span>Safety Check actif — le transfert sera suspendu si le solde descend sous <strong>${formatNum(safetySeuil)} DT</strong>.</span>
                </div>
            </div>
            <div class="sfso-footer">
                <button class="sfso-btn sfso-btn-cancel" type="button" id="sfso-cancel-btn">Annuler</button>
                <button class="sfso-btn sfso-btn-apply" type="button" id="sfso-apply-btn" disabled>
                    <i class="fa-solid fa-check"></i> Appliquer cette stratégie
                </button>
            </div>`;

        document.getElementById('sfso-close-btn')?.addEventListener('click', closeModal);
        document.getElementById('sfso-cancel-btn')?.addEventListener('click', closeModal);
        document.getElementById('sfso-apply-btn')?.addEventListener('click', onApplyClick);
    }

    // ── Sélection d'une carte ───────────────────────────────────────────────
    window.sfsoSelectCard = function(el) {
        document.querySelectorAll('.sfso-card').forEach(c => {
            c.classList.remove('selected');
            c.setAttribute('aria-checked', 'false');
        });
        el.classList.add('selected');
        el.setAttribute('aria-checked', 'true');

        const type = el.dataset.type;
        selectedStrategy = (analysisData?.strategies || []).find(s => s.type === type) || null;

        const applyBtn = document.getElementById('sfso-apply-btn');
        if (applyBtn) applyBtn.disabled = !selectedStrategy;
    };

    // ── Clic "Appliquer" → modal de confirmation ────────────────────────────
    function onApplyClick() {
        if (!selectedStrategy || !analysisData) return;
        renderConfirm(selectedStrategy, analysisData.safety_seuil);
    }

    // ── Rendu : confirmation ────────────────────────────────────────────────
    function renderConfirm(strategy, safetySeuil) {
        const colors      = TYPE_COLORS[strategy.type] || TYPE_COLORS.MODEREE;
        const typeLabel   = TYPE_LABELS[strategy.type] || strategy.type;
        const labelCap    = typeLabel.charAt(0) + typeLabel.slice(1).toLowerCase();

        modalMain.innerHTML = `
            <div class="sfso-confirm-modal">
                <div class="sfso-confirm-icon"><i class="fa-solid fa-circle-exclamation"></i></div>
                <h4>Activer cette stratégie ?</h4>
                <p>Un transfert automatique sera exécuté chaque mois vers ce coffre. Vous pourrez désactiver la stratégie à tout moment.</p>
                <div class="sfso-confirm-details">
                    <div><span>Stratégie</span><strong style="color:${colors.text}">${escHtml(labelCap)}</strong></div>
                    <div><span>Montant mensuel</span><strong style="color:${colors.text}">${formatNum(strategy.montant)} DT</strong></div>
                    <div><span>Durée estimée</span><strong>${strategy.duree} mois</strong></div>
                    <div><span>Safety Check</span><strong style="color:#16a34a">Activé (seuil ${formatNum(safetySeuil)} DT)</strong></div>
                </div>
                <div class="sfso-confirm-actions">
                    <button class="sfso-btn sfso-btn-cancel" type="button" id="sfso-back-btn">Annuler</button>
                    <button class="sfso-btn sfso-btn-apply" type="button" id="sfso-confirm-btn">
                        <i class="fa-solid fa-check"></i> Confirmer
                    </button>
                </div>
            </div>`;

        document.getElementById('sfso-back-btn')?.addEventListener('click', () => {
            renderStrategies(analysisData);
            // Restaurer la sélection
            setTimeout(() => {
                const card = document.querySelector(`.sfso-card[data-type="${strategy.type}"]`);
                if (card) sfsoSelectCard(card);
            }, 50);
        });
        document.getElementById('sfso-confirm-btn')?.addEventListener('click', onConfirmClick);
    }

    // ── Clic "Confirmer" → appel API activation ─────────────────────────────
    async function onConfirmClick() {
        if (!selectedStrategy || !analysisData) return;

        const confirmBtn = document.getElementById('sfso-confirm-btn');
        if (confirmBtn) {
            confirmBtn.disabled = true;
            confirmBtn.innerHTML = '<i class="fa-solid fa-circle-notch fa-spin"></i> Activation…';
        }

        try {
            const payload = {
                idCoffre:      currentCoffreId,
                typeStrategie: selectedStrategy.type,
                montantMensuel: selectedStrategy.montant,
                dureeEstimee:  selectedStrategy.duree,
                tauxSucces:    selectedStrategy.taux_succes,
                niveauRisque:  selectedStrategy.risque,
                safetySeuil:   analysisData.safety_seuil,
            };

            const res = await fetch('/api/smart-strategy/activate', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-User-Id': String(currentUserId),
                },
                body: JSON.stringify(payload),
            });

            const data = await res.json();
            if (!res.ok || data.error) throw new Error(data.error || 'Erreur serveur');

            renderSuccess(data, selectedStrategy);
        } catch (err) {
            renderError(err.message);
        }
    }

    // ── Rendu : succès ──────────────────────────────────────────────────────
    function renderSuccess(data, strategy) {
        const colors    = TYPE_COLORS[strategy.type] || TYPE_COLORS.MODEREE;
        const typeLabel = TYPE_LABELS[strategy.type] || strategy.type;
        const labelCap  = typeLabel.charAt(0) + typeLabel.slice(1).toLowerCase();

        modalMain.innerHTML = `
            <div class="sfso-success-modal">
                <div class="sfso-success-icon"><i class="fa-solid fa-check"></i></div>
                <h4>Stratégie activée avec succès</h4>
                <p>La stratégie <strong style="color:${colors.text}">${escHtml(labelCap)}</strong>
                   (${formatNum(strategy.montant)} DT/mois) est maintenant active.
                   Le prochain transfert aura lieu le <strong>${escHtml(data.dateProchaineExecution || '—')}</strong>
                   après vérification du Safety Check.</p>
                <button class="sfso-btn sfso-btn-apply" type="button" id="sfso-done-btn" style="width:100%;justify-content:center;">
                    Parfait
                </button>
            </div>`;

        document.getElementById('sfso-done-btn')?.addEventListener('click', () => {
            closeModal();
            // Optionnel : recharger la page pour afficher la stratégie active
            // window.location.reload();
        });
    }

    // ── Rendu : erreur ──────────────────────────────────────────────────────
    function renderError(message) {
        modalMain.innerHTML = `
            <div class="sfso-confirm-modal">
                <div class="sfso-confirm-icon" style="background:#fee2e2;color:#dc2626;">
                    <i class="fa-solid fa-triangle-exclamation"></i>
                </div>
                <h4 style="color:#dc2626;">Erreur</h4>
                <p>${escHtml(message)}</p>
                <button class="sfso-btn sfso-btn-cancel" type="button" id="sfso-err-close" style="width:100%;justify-content:center;">Fermer</button>
            </div>`;
        document.getElementById('sfso-err-close')?.addEventListener('click', closeModal);
    }

    // ── Helpers ─────────────────────────────────────────────────────────────
    function escHtml(str) {
        return String(str ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }
    function formatNum(n) {
        return Number(n).toLocaleString('fr-FR', { minimumFractionDigits: 0, maximumFractionDigits: 2 });
    }

    // ── Fermeture backdrop ──────────────────────────────────────────────────
    backdrop?.addEventListener('click', closeModal);
    document.addEventListener('keydown', e => {
        if (e.key === 'Escape' && !overlay.hidden) closeModal();
    });

    // ── Délégation : boutons trigger ────────────────────────────────────────
    document.addEventListener('click', function(e) {
        const btn = e.target.closest('.sfso-trigger-btn');
        if (!btn) return;
        const coffreId  = parseInt(btn.dataset.coffreId, 10);
        const coffreNom = btn.dataset.coffreNom || '';
        const userId    = parseInt(btn.dataset.userId, 10) || 0;
        openModal(coffreId, coffreNom, userId);
    });

})();
</script>
