    <div class="cr-restruct-overlay" id="cr-restruct-overlay" hidden></div>
    <section class="cr-restruct-modal" id="cr-restruct-modal" hidden role="dialog" aria-modal="true" aria-labelledby="cr-restruct-title">
        <header class="cr-restruct-header">
            <div>
                <h3 id="cr-restruct-title">Propositions de Restructuration</h3>
                <p id="cr-restruct-subtitle">Analyse intelligente des options pour alleger votre charge financiere.</p>
            </div>
            <button class="cr-restruct-close" id="cr-restruct-close" type="button" aria-label="Fermer">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </header>
        <div class="cr-restruct-body">
            <div class="cr-restruct-alert" id="cr-restruct-alert" hidden>
                <strong id="cr-restruct-alert-title">Difficultes financieres detectees</strong>
                <div class="cr-restruct-alert-grid">
                    <div class="cr-restruct-alert-item">
                        <span id="cr-restruct-debt-label">Taux d endettement</span>
                        <strong id="cr-restruct-debt-value">--</strong>
                    </div>
                    <div class="cr-restruct-alert-item">
                        <span id="cr-restruct-monthly-label">Mensualite actuelle</span>
                        <strong id="cr-restruct-monthly-value">--</strong>
                    </div>
                    <div class="cr-restruct-alert-item">
                        <span id="cr-restruct-type-label">Type de credit</span>
                        <strong id="cr-restruct-type-value">--</strong>
                    </div>
                </div>
            </div>

            <div class="cr-restruct-empty" id="cr-restruct-empty" hidden>
