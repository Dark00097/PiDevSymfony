                                    <i class="fa-solid fa-chevron-down cr-select-icon"></i>
                                </div>
                                <span id="cr-garantie-err-typeGarantie" class="cr-val-msg{{ garantie_errors.typeGarantie is defined ? ' is-error' : '' }}">{{ garantie_errors.typeGarantie|default('') }}</span>
                            </div>
                            <div class="cr-field">
                                <label class="cr-field-label">
                                    <i class="fa-solid fa-coins"></i> Valeur estimee (TND) <span class="cr-req">*</span>
                                </label>
                                <div class="cr-input-pfx-wrap">
                                    <span class="cr-input-pfx">TND</span>
                                    <input class="cr-input cr-input-pfx-field{{ garantie_errors.valeurEstimee is defined ? ' cr-input--error' : '' }}" type="number" step="0.01" name="valeurEstimee" id="cr-garantie-estimated" placeholder="0.00" value="{{ garantie_old.valeurEstimee|default('') }}">
                                </div>
                                <span id="cr-garantie-err-valeurEstimee" class="cr-val-msg{{ garantie_errors.valeurEstimee is defined ? ' is-error' : '' }}">{{ garantie_errors.valeurEstimee|default('') }}</span>
                            </div>
                        </div>

                        <div class="cr-field-group cr-field-group-2">
                            <div class="cr-field">
                                <label class="cr-field-label">
                                    <i class="fa-solid fa-percent"></i> Valeur retenue (TND)
                                </label>
                                <div class="cr-input-pfx-wrap">
                                    <span class="cr-input-pfx cr-input-pfx-auto">AUTO</span>
                                    <input class="cr-input cr-input-pfx-field cr-auto-field{{ garantie_errors.valeurRetenue is defined ? ' cr-input--error' : '' }}" type="text" inputmode="decimal" name="valeurRetenue" id="cr-garantie-retained" placeholder="Auto selon type" value="{{ garantie_old.valeurRetenue|default('') }}" readonly>
                                </div>
                                <span id="cr-garantie-err-valeurRetenue" class="cr-val-msg{{ garantie_errors.valeurRetenue is defined ? ' is-error' : '' }}">{{ garantie_errors.valeurRetenue|default('') }}</span>
                                <small id="cr-garantie-retained-hint" class="cr-field-hint"></small>
                            </div>
                            <div class="cr-field">
                                <label class="cr-field-label">
                                    <i class="fa-solid fa-calendar-day"></i> Date d'evaluation <span class="cr-req">*</span>
                                </label>
                                <input class="cr-input{{ garantie_errors.dateEvaluation is defined ? ' cr-input--error' : '' }}" type="date" name="dateEvaluation" id="cr-garantie-date" value="{{ garantie_old.dateEvaluation|default(current_date) }}">
                                <span id="cr-garantie-err-dateEvaluation" class="cr-val-msg{{ garantie_errors.dateEvaluation is defined ? ' is-error' : '' }}">{{ garantie_errors.dateEvaluation|default('') }}</span>
                            </div>
                        </div>

                        <div class="cr-field-group">
                            <div class="cr-field">
                                <label class="cr-field-label">
                                    <i class="fa-solid fa-user-tie"></i> Nom garant <span class="cr-req">*</span>
                                </label>
                                <input class="cr-input{{ garantie_errors.nomGarant is defined ? ' cr-input--error' : '' }}" type="text" name="nomGarant" id="cr-garantie-guarantor" placeholder="Nom du garant" value="{{ garantie_old.nomGarant|default('') }}">
                                <span id="cr-garantie-err-nomGarant" class="cr-val-msg{{ garantie_errors.nomGarant is defined ? ' is-error' : '' }}">{{ garantie_errors.nomGarant|default('') }}</span>
                            </div>
                        </div>

                        <div class="cr-field-group cr-field-group-2">
                            <div class="cr-field">
                                <label class="cr-field-label">
                                    <i class="fa-solid fa-location-dot"></i> Adresse du bien <span class="cr-req">*</span>
                                </label>
                                <input class="cr-input{{ garantie_errors.adresseBien is defined ? ' cr-input--error' : '' }}" type="text" name="adresseBien" id="cr-garantie-address" placeholder="Adresse du bien" value="{{ garantie_old.adresseBien|default('') }}">
                                <span id="cr-garantie-err-adresseBien" class="cr-val-msg{{ garantie_errors.adresseBien is defined ? ' is-error' : '' }}">{{ garantie_errors.adresseBien|default('') }}</span>
                            </div>
                            <div class="cr-field">
                                <label class="cr-field-label">
                                    <i class="fa-solid fa-map"></i> Adresse OpenStreetMap
                                </label>
                                <input class="cr-input{{ garantie_errors.adresseComplete is defined ? ' cr-input--error' : '' }}" type="text" name="adresseComplete" id="cr-garantie-address-complete" placeholder="Rechercher une adresse..." value="{{ garantie_old.adresseComplete|default(garantie_old.adresseBien|default('')) }}" autocomplete="off">
                                <div id="cr-garantie-address-suggestions" style="display:grid; gap:6px; margin-top:8px;" hidden></div>
                                <span id="cr-garantie-err-adresseComplete" class="cr-val-msg{{ garantie_errors.adresseComplete is defined ? ' is-error' : '' }}">{{ garantie_errors.adresseComplete|default('') }}</span>
