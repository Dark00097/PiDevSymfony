        nomGarant: String(getGarantieField('nomGarant')?.value ?? '').trim(),
        adresseBien: String(getGarantieField('adresseBien')?.value ?? '').trim(),
      };

      if (payload.typeGarantie === '' || payload.valeurEstimee <= 0 || payload.nomGarant === '' || payload.adresseBien === '') {
        validateGarantieField('typeGarantie');
        validateGarantieField('valeurEstimee');
        validateGarantieField('nomGarant');
        validateGarantieField('adresseBien');
        setGarantieAiStatus(t('aiMissingData'), 'is-warn', true);
        return;
      }

      const originalLabel = garantieGenerateAiLabel?.textContent || t('generateAi');
      garantieGenerateAiBtn.disabled = true;
      if (garantieGenerateAiLabel) {
        garantieGenerateAiLabel.textContent = t('generatingAi');
      }
      setGarantieAiStatus(t('generatingAi'), 'is-warn', true);

      try {
        const response = await fetch(garantieDescriptionGenerateEndpoint, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest',
          },
          body: JSON.stringify(payload),
        });

        const result = await response.json().catch(() => null);
        if (!response.ok || !result || result.ok !== true || typeof result.description !== 'string' || result.description.trim() === '') {
          throw new Error((result && typeof result.message === 'string' && result.message.trim() !== '') ? result.message : t('aiError'));
        }

        if (garantieDescriptionField instanceof HTMLInputElement || garantieDescriptionField instanceof HTMLTextAreaElement) {
          garantieDescriptionField.value = result.description.trim();
        }
        validateGarantieField('description');
        setGarantieAiStatus(`${t('aiGenerated')} (${String(result.provider ?? 'Fallback')})`, 'is-ok', true);
      } catch (error) {
        setGarantieAiStatus(error instanceof Error ? error.message : t('aiError'), 'is-risk', true);
      } finally {
        garantieGenerateAiBtn.disabled = false;
        if (garantieGenerateAiLabel) {
          garantieGenerateAiLabel.textContent = originalLabel;
        }
      }
    });

    garantieGenerateDocAiBtn?.addEventListener('click', async () => {
      const payload = {
