/* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
   FORM COLUMN
   â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
.cr-form-col {
  position: sticky;
  top: 76px;
}

.cr-form-card {
  background: #fff;
  border-radius: 20px;
  border: 1px solid #dde8f5;
  box-shadow: 0 4px 24px rgba(10,37,64,.07);
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

/* â”€â”€ Form Card Header â”€â”€ */
.cr-form-card-header {
  background: linear-gradient(135deg, #0a2540 0%, #1565c0 100%);
  padding: 22px 22px 0;
}

.cr-form-card-header-top {
  display: flex;
  align-items: flex-start;
  gap: 14px;
  padding-bottom: 18px;
}

.cr-fch-icon {
  width: 44px;
  height: 44px;
  border-radius: 14px;
  background: rgba(255,255,255,.15);
  border: 1px solid rgba(255,255,255,.25);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 17px;
  flex-shrink: 0;
}

.cr-fch-title {
  font-size: 17px;
  font-weight: 800;
  color: #fff;
  line-height: 1.2;
}

.cr-fch-sub {
  font-size: 12px;
  color: rgba(255,255,255,.68);
  margin-top: 3px;
}

.cr-form-collapse-btn {
  margin-left: auto;
  width: 32px;
  height: 32px;
  border-radius: 9px;
  background: rgba(255,255,255,.1);
  border: 1px solid rgba(255,255,255,.2);
  color: rgba(255,255,255,.8);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  font-size: 12px;
  flex-shrink: 0;
  transition: background .15s;
}

.cr-form-collapse-btn:hover { background: rgba(255,255,255,.2); }

/* â”€â”€ Steps indicator â”€â”€ */
.cr-form-steps {
  display: flex;
  align-items: center;
  padding: 0 4px 0;
}

.cr-step {
  display: flex;
  align-items: center;
  gap: 7px;
  padding: 10px 0;
  cursor: default;
  opacity: 0.5;
  transition: opacity .2s;
}

.cr-step.cr-step-active { opacity: 1; }

.cr-step-dot {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  border: 2px solid rgba(255,255,255,.4);
  color: rgba(255,255,255,.7);
  font-size: 11px;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all .2s;
}

.cr-step.cr-step-active .cr-step-dot {
  background: #fff;
  color: #1565c0;
  border-color: #fff;
}

.cr-step.cr-step-done .cr-step-dot {
  background: #00bcd4;
  color: #fff;
  border-color: #00bcd4;
}

.cr-step span {
  font-size: 11px;
  font-weight: 700;
  color: rgba(255,255,255,.75);
  white-space: nowrap;
}

.cr-step.cr-step-active span { color: #fff; }

.cr-step-line {
  flex: 1;
  height: 1px;
  background: rgba(255,255,255,.2);
  margin: 0 8px;
}

/* â”€â”€ Form body â”€â”€ */
.cr-form {
  display: flex;
  flex-direction: column;
}

.cr-form-step-body {
  padding: 20px 20px 4px;
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.cr-form-step-body[hidden] {
  display: none !important;
}

.cr-field-group {
  display: grid;
  gap: 12px;
}

.cr-field-group-2 { grid-template-columns: 1fr 1fr; }
.cr-field-group-3 { grid-template-columns: repeat(3, 1fr); }

.cr-field {
  display: flex;
  flex-direction: column;
  gap: 5px;
}

.cr-field-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  flex-wrap: wrap;
}

.cr-field-label {
  font-size: 11px;
  font-weight: 700;
  color: #4e7490;
  display: flex;
  align-items: center;
  gap: 5px;
}

.cr-field-label i { color: #1565c0; font-size: 10px; }

.cr-req { color: #e53935; }

.cr-input {
  width: 100%;
  min-height: 40px;
  border-radius: 11px;
  border: 1.5px solid #ccddef;
  background: #f7faff;
  padding: 0 12px;
  font: inherit;
  font-size: 13px;
  color: #0a2540;
  outline: none;
  appearance: none;
  transition: border-color .18s, box-shadow .18s;
}

.cr-input-textarea {
  min-height: 108px;
  padding: 10px 12px;
  resize: vertical;
}

.cr-input:focus {
  border-color: #1e88e5;
  background: #fff;
  box-shadow: 0 0 0 3px rgba(30,136,229,.12);
}

.cr-input::placeholder { color: #aabece; font-size: 12px; }

.cr-input--error {
  border-color: #ef5350 !important;
  background: #fff8f7;
  box-shadow: 0 0 0 3px rgba(239, 83, 80, 0.12);
}

.cr-val-msg {
  min-height: 16px;
  font-size: 12px;
  font-weight: 700;
  color: transparent;
}

.cr-field-hint {
  min-height: 14px;
  font-size: 11px;
  color: #6b7f92;
}

.cr-ai-generate-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  min-height: 34px;
  padding: 0 12px;
  border-radius: 999px;
  border: 1px solid #c9dcf3;
  background: linear-gradient(120deg, #eef5ff, #e0f2fe);
  color: #1565c0;
  font: inherit;
  font-size: 12px;
  font-weight: 800;
  cursor: pointer;
  transition: all .15s;
}

.cr-ai-generate-btn:hover {
  background: linear-gradient(120deg, #1565c0, #1e88e5);
  color: #fff;
  border-color: transparent;
}

.cr-ai-generate-btn:disabled {
  opacity: .7;
  cursor: wait;
}

.cr-ai-inline-status {
  min-height: 16px;
  font-size: 11px;
  font-weight: 700;
  color: #5b80a0;
}

.cr-ai-inline-status.is-ok { color: #15803d; }
.cr-ai-inline-status.is-warn { color: #b45309; }
.cr-ai-inline-status.is-risk { color: #b91c1c; }

.cr-val-msg.is-error {
  color: #d93025;
}

.cr-select { cursor: pointer; padding-right: 30px; }

.cr-select-wrap { position: relative; }

.cr-select-icon {
  position: absolute;
  right: 11px;
  top: 50%;
  transform: translateY(-50%);
  color: #8aafc8;
  font-size: 10px;
  pointer-events: none;
}

/* Prefixed input */
.cr-input-pfx-wrap { position: relative; }

.cr-input-pfx {
  position: absolute;
  left: 0;
  top: 0;
  height: 100%;
  padding: 0 10px;
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #1565c0, #1e88e5);
  color: #fff;
  font-size: 10px;
  font-weight: 800;
  border-radius: 11px 0 0 11px;
  letter-spacing: 0.3px;
  z-index: 1;
  white-space: nowrap;
}

.cr-input-pfx-auto {
  background: linear-gradient(135deg, #00838f, #00bcd4);
}

.cr-input-pfx-field { padding-left: 52px; }

/* Auto fields styling */
.cr-auto-field { background: #f0fbfd; color: #006064; font-weight: 700; }

/* â”€â”€ Calculator preview â”€â”€ */
.cr-calc-preview {
  background: linear-gradient(135deg, #f0f9ff, #e0f7fa);
  border: 1px solid #b2ebf2;
  border-radius: 14px;
  padding: 14px 16px;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.cr-calc-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.cr-calc-row span {
  font-size: 12px;
  color: #006064;
  font-weight: 600;
}

.cr-calc-row strong {
  font-size: 13px;
  font-weight: 800;
  color: #00838f;
}

/* â”€â”€ Analyze block â”€â”€ */
.cr-analyze-block {
  background: linear-gradient(135deg, #fffbeb, #fef3c7);
  border: 1px solid #fde68a;
  border-radius: 14px;
  padding: 14px 16px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.cr-analyze-header {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 12px;
  font-weight: 700;
  color: #92400e;
}

.cr-analyze-header i { color: #d97706; }

.cr-analyze-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  min-height: 38px;
  padding: 0 16px;
  border-radius: 10px;
  background: linear-gradient(120deg, #d97706, #f59e0b);
  color: #fff;
  font: inherit;
  font-size: 12px;
  font-weight: 700;
  border: none;
  cursor: pointer;
  transition: opacity .15s, transform .15s;
  width: fit-content;
}

.cr-analyze-btn:hover { opacity: .9; transform: scale(.98); }

.cr-analysis-output {
  font-size: 12px;
  font-weight: 600;
  padding: 8px 12px;
  border-radius: 8px;
  line-height: 1.5;
  white-space: pre-line;
}

.cr-analysis-output.is-ok   { background: #d1fae5; color: #065f46; }
.cr-analysis-output.is-warn { background: #fef3c7; color: #92400e; }
.cr-analysis-output.is-risk { background: #fee2e2; color: #991b1b; }

.cr-ai-modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(10, 37, 64, 0.45);
  backdrop-filter: blur(2px);
  z-index: 520;
}

.cr-ai-modal {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: min(690px, calc(100vw - 28px));
  max-height: calc(100vh - 30px);
  overflow: auto;
  background: #fff;
  border: 1px solid #d8e6f4;
  border-radius: 16px;
  box-shadow: 0 26px 60px rgba(10, 37, 64, 0.28);
  z-index: 530;
  display: flex;
  flex-direction: column;
}

.cr-ai-modal[hidden],
.cr-ai-modal-overlay[hidden] {
  display: none !important;
}

.cr-ai-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 18px;
  border-bottom: 1px solid #e7eff8;
  background: #f9fcff;
}

.cr-ai-modal-header h3 {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 30px;
  font-weight: 900;
  color: #0a2540;
  margin: 0;
}

.cr-ai-modal-header h3 i { color: #1565c0; }

.cr-ai-modal-close {
  width: 34px;
  height: 34px;
  border-radius: 10px;
  border: 1px solid #d8e6f4;
  background: #fff;
  color: #5b80a0;
  font-size: 14px;
  cursor: pointer;
}

.cr-ai-modal-close:hover { background: #eff6ff; color: #1565c0; }

.cr-ai-modal-body {
  padding: 18px;
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.cr-ai-status {
  font-size: 18px;
  font-weight: 900;
  color: #0a2540;
}

.cr-ai-status.is-ok   { color: #15803d; }
.cr-ai-status.is-warn { color: #b45309; }
.cr-ai-status.is-risk { color: #b91c1c; }

.cr-ai-score-row {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 15px;
  color: #0a2540;
}

.cr-ai-score-row strong { font-size: 19px; font-weight: 900; }

.cr-ai-progress {
  width: 100%;
  height: 16px;
  border-radius: 999px;
  background: #e3f2ea;
  overflow: hidden;
}

.cr-ai-progress-fill {
  display: block;
  height: 100%;
  width: 0%;
  background: linear-gradient(90deg, #16a34a, #22c55e);
  transition: width .35s ease;
}

.cr-ai-progress-fill.is-warn {
  background: linear-gradient(90deg, #d97706, #f59e0b);
}

.cr-ai-progress-fill.is-risk {
  background: linear-gradient(90deg, #dc2626, #ef4444);
}

.cr-ai-metrics {
  border: 1px solid #e3edf8;
  border-radius: 12px;
  background: #f8fbff;
  padding: 12px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}

.cr-ai-metric {
  border-radius: 10px;
  background: #fff;
  border: 1px solid #e6eef8;
  padding: 10px;
  display: grid;
  grid-template-columns: 1fr auto auto;
  align-items: center;
  column-gap: 10px;
}

.cr-ai-metric-label {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 13px;
  font-weight: 700;
  color: #274d70;
}

.cr-ai-metric-label i { color: #1565c0; }

.cr-ai-metric strong {
  font-size: 14px;
  font-weight: 800;
  color: #0a2540;
}

.cr-ai-metric-mark {
  min-width: 32px;
  text-align: right;
  font-size: 13px;
  font-weight: 900;
  color: #7294ae;
}

.cr-ai-metric-mark.is-ok { color: #15803d; }
.cr-ai-metric-mark.is-warn { color: #b45309; }
.cr-ai-metric-mark.is-risk { color: #b91c1c; }

.cr-ai-reco {
  border: 1px solid #e6eef8;
  border-radius: 12px;
  background: #ffffff;
  padding: 12px;
}

.cr-ai-reco h4 {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  font-size: 16px;
  font-weight: 900;
  color: #0a2540;
  margin: 0 0 8px;
}

.cr-ai-reco h4 i { color: #0d9488; }

.cr-ai-reco p {
  margin: 0;
  font-size: 16px;
  line-height: 1.55;
  color: #244665;
  white-space: pre-line;
}

.cr-ai-modal-footer {
  padding: 0 18px 16px;
  display: flex;
  justify-content: flex-end;
}

.cr-ai-ok-btn {
  min-height: 40px;
  min-width: 120px;
  padding: 0 18px;
  border-radius: 11px;
  border: none;
  background: linear-gradient(120deg, #0284c7, #0891b2);
  color: #fff;
  font-size: 25px;
  font-weight: 800;
  cursor: pointer;
}

.cr-ai-ok-btn:hover { opacity: .92; }

@media (max-width: 760px) {
  .cr-ai-modal-header h3 { font-size: 19px; }
  .cr-ai-score-row { font-size: 13px; }
  .cr-ai-score-row strong { font-size: 16px; }
  .cr-ai-metrics { grid-template-columns: 1fr; }
  .cr-ai-reco h4 { font-size: 14px; }
  .cr-ai-reco p { font-size: 13px; }
  .cr-ai-ok-btn { min-width: 96px; font-size: 13px; }
}

/* â”€â”€ Step navigation â”€â”€ */
.cr-step-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 0 18px;
  border-top: 1px solid #edf4fb;
  margin-top: 6px;
}

.cr-step-nav-final { flex-direction: column; gap: 10px; align-items: stretch; }

.cr-step-btn {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  min-height: 38px;
  padding: 0 16px;
  border-radius: 10px;
  font: inherit;
  font-size: 13px;
  font-weight: 700;
  cursor: pointer;
  border: none;
  transition: all .15s;
}

.cr-step-next {
  background: linear-gradient(120deg, #1565c0, #1e88e5);
  color: #fff;
}

.cr-step-back {
  background: #f0f4f8;
  color: #5b80a0;
  border: 1px solid #dde8f5;
}

.cr-step-back:hover { background: #e2ecf8; }
.cr-step-next:hover { opacity: .9; }

.cr-final-actions {
  display: flex;
  gap: 10px;
}

.cr-submit-btn {
  flex: 1;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  min-height: 44px;
  padding: 0 20px;
  border-radius: 12px;
  background: linear-gradient(120deg, #1565c0, #00bcd4);
  color: #fff;
  font: inherit;
  font-size: 14px;
  font-weight: 800;
  border: none;
  cursor: pointer;
  box-shadow: 0 6px 20px rgba(21,101,192,.28);
  transition: all .18s;
}

.cr-submit-btn:hover { opacity: .92; box-shadow: 0 8px 24px rgba(21,101,192,.38); }

.cr-submit-btn-sm { min-height: 38px; font-size: 13px; }

.cr-form-reset-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 7px;
  min-height: 44px;
  padding: 0 16px;
  border-radius: 12px;
  background: transparent;
  border: 1.5px solid #cddff0;
  color: #5b80a0;
  font: inherit;
  font-size: 13px;
  font-weight: 700;
  cursor: pointer;
  transition: all .15s;
}

.cr-form-reset-btn:hover { background: #f0f4f8; }

/* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
   TABLE COLUMN
   â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
.cr-table-col {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.cr-list-shell {
  display: flex;
  flex-direction: column;
  gap: 18px;
  background: #fff;
  border: 1px solid #dde8f5;
  border-radius: 24px;
  padding: 18px;
  box-shadow: 0 8px 24px rgba(10,37,64,.06);
}

/* â”€â”€ Toolbar â”€â”€ */
.cr-table-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  background: transparent;
  border-radius: 0;
  padding: 0;
  border: none;
  box-shadow: none;
  flex-wrap: wrap;
}

.cr-table-toolbar-left {
  display: flex;
  align-items: center;
  gap: 10px;
}

.cr-table-title {
  font-size: 17px;
  font-weight: 800;
  color: #0a2540;
  display: flex;
  align-items: center;
  gap: 9px;
}

.cr-table-title i { color: #1565c0; }

.cr-table-count-badge {
  padding: 3px 10px;
  border-radius: 999px;
  background: linear-gradient(120deg, #1565c0, #1e88e5);
  color: #fff;
  font-size: 11px;
  font-weight: 800;
}

.cr-table-toolbar-right {
  display: flex;
  align-items: center;
  gap: 10px;
}

.cr-search-box {
  display: flex;
  align-items: center;
  gap: 8px;
  background: #f7faff;
  border: 1.5px solid #cddff0;
  border-radius: 11px;
  padding: 0 12px;
  min-height: 40px;
  transition: border-color .18s;
}

.cr-search-box:focus-within {
  border-color: #1e88e5;
  box-shadow: 0 0 0 3px rgba(30,136,229,.10);
}

.cr-search-box i { color: #8aafc8; font-size: 12px; }

.cr-search-box input {
  border: none;
  outline: none;
  background: transparent;
  font: inherit;
  font-size: 13px;
  color: #0a2540;
  width: 190px;
}

.cr-search-box input::placeholder { color: #aabece; }

.cr-search-clear {
  width: 20px;
  height: 20px;
  border-radius: 50%;
  background: #e2ecf8;
  border: none;
  color: #5b80a0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 11px;
  cursor: pointer;
}

.cr-sort-wrap { min-width: 140px; }

.cr-sort-select { font-size: 12px; min-height: 40px; }

.cr-garanties-btn {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  min-height: 40px;
  padding: 0 14px;
  border-radius: 11px;
  background: linear-gradient(120deg, #0a2540, #1565c0);
  color: #fff;
  font: inherit;
  font-size: 12px;
  font-weight: 700;
  border: none;
  cursor: pointer;
  white-space: nowrap;
  transition: opacity .15s;
}

.cr-garanties-btn:hover { opacity: .88; }

.cr-garanties-btn.is-active-alt {
  background: linear-gradient(120deg, #eef5ff, #dbeafe);
  color: #1565c0;
  border: 1px solid #bfdbfe;
}

#cr-credits-view,
#cr-garanties-view {
  display: flex;
  flex-direction: column;
  gap: 18px;
}

#cr-credits-view[hidden],
#cr-garanties-view[hidden] {
  display: none !important;
}

/* â”€â”€ Filter tabs â”€â”€ */
.cr-filter-tabs {
  display: flex;
  align-items: center;
  gap: 6px;
  background: transparent;
  border-radius: 0;
  padding: 0 0 14px;
  border: none;
  border-bottom: 1px solid #dde8f5;
  flex-wrap: wrap;
}

.cr-filter-tab {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  min-height: 34px;
  padding: 0 14px;
  border-radius: 9px;
  background: transparent;
  border: 1px solid transparent;
  font: inherit;
  font-size: 12px;
  font-weight: 700;
  color: #7294ae;
  cursor: pointer;
  transition: all .15s;
}

.cr-filter-tab:hover { background: #f0f4f8; color: #0a2540; }

.cr-filter-tab-active {
  background: linear-gradient(120deg, #1565c0, #1e88e5);
  color: #fff;
  box-shadow: 0 4px 12px rgba(21,101,192,.2);
}

.cr-filter-tab-active:hover { background: linear-gradient(120deg, #1565c0, #1e88e5); color: #fff; }

.cr-tab-count {
  background: rgba(255,255,255,.25);
  border-radius: 999px;
  padding: 1px 7px;
  font-size: 10px;
  font-weight: 800;
}

.cr-filter-tab:not(.cr-filter-tab-active) .cr-tab-count {
  background: #e8f0fb;
  color: #1565c0;
}

/* â”€â”€ Credits card grid â”€â”€ */
.cr-credits-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 14px;
}

.cr-list-pager {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 10px;
  margin-top: 18px;
  flex-wrap: wrap;
}

.cr-list-pager[hidden] {
  display: none !important;
}

.cr-list-pager-btn {
  width: 40px;
  height: 40px;
  border-radius: 999px;
  border: 1px solid #cfe0f2;
  background: #fff;
  color: #58789a;
  font-size: 14px;
  font-weight: 800;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: transform .18s ease, box-shadow .18s ease, background .18s ease, color .18s ease, border-color .18s ease;
}

.cr-list-pager-btn:hover:not(:disabled) {
  transform: translateY(-1px);
  box-shadow: 0 10px 24px rgba(21, 101, 192, 0.12);
  border-color: #8dc7f3;
}

.cr-list-pager-btn.is-active {
  border-color: transparent;
  background: linear-gradient(135deg, #16a34a, #14b8a6);
  color: #fff;
  box-shadow: 0 12px 28px rgba(20, 184, 166, 0.22);
}

.cr-list-pager-btn:disabled {
  opacity: .45;
  cursor: default;
  box-shadow: none;
}

/* â”€â”€ Single credit card â”€â”€ */
.cr-credit-card {
  background: #fff;
  border-radius: 18px;
  border: 1px solid #dde8f5;
  padding: 18px;
  display: flex;
  flex-direction: column;
  gap: 14px;
  box-shadow: 0 2px 12px rgba(10,37,64,.05);
  transition: box-shadow .2s, transform .2s, border-color .2s;
  position: relative;
  overflow: hidden;
}

.cr-credit-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: linear-gradient(90deg, #1565c0, #00bcd4);
}

.cr-credit-card:hover {
  box-shadow: 0 10px 32px rgba(10,37,64,.12);
  transform: translateY(-3px);
  border-color: #b8d4f0;
}

.cr-credit-card.is-restructured {
  border-color: #c4b5fd;
  box-shadow: 0 16px 38px rgba(124, 58, 237, .14);
}

.cr-credit-card.is-restructured::before {
  background: linear-gradient(90deg, #7c3aed, #22c55e);
}

.cr-cc-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 8px;
}

.cr-cc-id { display: flex; flex-direction: column; gap: 3px; }

.cr-cc-applied-badge {
  display: inline-flex;
  align-items: center;
  width: fit-content;
  margin-top: 4px;
  padding: 4px 10px;
  border-radius: 999px;
  background: linear-gradient(120deg, #ede9fe, #dcfce7);
  color: #5b21b6;
  font-size: 10px;
  font-weight: 800;
  letter-spacing: .03em;
  text-transform: uppercase;
}

.cr-cc-id-label {
  font-size: 11px;
  font-weight: 800;
  color: #7294ae;
  letter-spacing: 0.3px;
}

.cr-cc-type {
  font-size: 15px;
  font-weight: 800;
  color: #0a2540;
}

/* Status badge on card */
.cr-cc-status {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  padding: 5px 11px;
  border-radius: 999px;
  font-size: 11px;
  font-weight: 800;
  white-space: nowrap;
  flex-shrink: 0;
}

.cr-status-green  { background: #dcfce7; color: #166534; }
.cr-status-red    { background: #fee2e2; color: #991b1b; }
.cr-status-amber  { background: #fef9c3; color: #854d0e; }

.cr-cc-amount-row {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 10px;
}

.cr-cc-amount {
  font-size: 26px;
  font-weight: 900;
  color: #0a2540;
  letter-spacing: -0.5px;
  line-height: 1;
}

.cr-cc-amount small {
  font-size: 12px;
  font-weight: 600;
  color: #7294ae;
  margin-left: 3px;
}

.cr-cc-monthly {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 2px;
}

.cr-cc-monthly-label {
  font-size: 10px;
  color: #aabece;
  text-transform: uppercase;
  letter-spacing: 0.4px;
  font-weight: 700;
}

.cr-cc-monthly-val {
  font-size: 13px;
  font-weight: 800;
  color: #1565c0;
}

.cr-cc-meta {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 10px 0;
  border-top: 1px solid #f0f4f8;
  border-bottom: 1px solid #f0f4f8;
}

.cr-cc-meta-item {
  display: flex;
  align-items: center;
  gap: 5px;
  font-size: 12px;
  color: #5b80a0;
  font-weight: 600;
}

.cr-cc-meta-item i { color: #1e88e5; font-size: 11px; }

.cr-cc-risk-row {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.cr-cc-risk-label {
  font-size: 10px;
  color: #aabece;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.4px;
}

.cr-cc-risk-bar-wrap {
  display: flex;
  align-items: center;
  gap: 10px;
}

.cr-cc-risk-bar {
  flex: 1;
  height: 6px;
  background: #e8f0f8;
  border-radius: 999px;
  overflow: hidden;
}

.cr-cc-risk-fill {
  height: 100%;
  border-radius: 999px;
  transition: width .6s ease;
}

.cr-risk-low    .cr-cc-risk-fill,
.cr-cc-risk-fill.cr-risk-low    { background: linear-gradient(90deg, #22c55e, #4ade80); }
.cr-risk-medium .cr-cc-risk-fill,
.cr-cc-risk-fill.cr-risk-medium { background: linear-gradient(90deg, #f59e0b, #fbbf24); }
.cr-risk-high   .cr-cc-risk-fill,
.cr-cc-risk-fill.cr-risk-high   { background: linear-gradient(90deg, #ef4444, #f87171); }

.cr-cc-risk-val {
  font-size: 11px;
  font-weight: 800;
  white-space: nowrap;
}

.cr-risk-low    { color: #166534; }
.cr-risk-medium { color: #854d0e; }
.cr-risk-high   { color: #991b1b; }

.cr-cc-actions {
  display: flex;
  align-items: center;
  gap: 8px;
}

.cr-cc-restruct-btn {
  margin-top: 10px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  width: 100%;
  min-height: 42px;
  border-radius: 12px;
  border: 1px solid #c7d8f6;
  background: linear-gradient(120deg, #f5f9ff, #e8f0fd);
  color: #244e7a;
  font: inherit;
  font-size: 13px;
  font-weight: 800;
  cursor: pointer;
  transition: all .18s ease;
}

.cr-cc-restruct-btn:hover {
  transform: translateY(-1px);
  border-color: transparent;
  background: linear-gradient(120deg, #4f46e5, #7c3aed);
  color: #fff;
  box-shadow: 0 10px 20px rgba(99, 102, 241, .18);
}

.cr-cc-restruct-btn.is-applied {
  border-color: transparent;
  background: linear-gradient(120deg, #7c3aed, #8b5cf6);
  color: #fff;
  box-shadow: 0 10px 24px rgba(124, 58, 237, .2);
}

.cr-cc-pdf-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 42px;
  height: 42px;
  padding: 0;
  border-radius: 10px;
  background: linear-gradient(120deg, #ecfeff, #cffafe);
  color: #0f766e;
  font: inherit;
  font-size: 12px;
  font-weight: 700;
  border: 1px solid #99f6e4;
  text-decoration: none;
  transition: all .15s;
}

.cr-cc-pdf-btn:hover {
  background: linear-gradient(120deg, #0f766e, #14b8a6);
  color: #fff;
  border-color: transparent;
}

.cr-cc-edit-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 42px;
  height: 42px;
  border-radius: 10px;
  background: linear-gradient(120deg, #e8f0fd, #dbeafe);
  color: #1565c0;
  font: inherit;
  font-size: 12px;
  font-weight: 700;
  border: 1px solid #c3d9f5;
  cursor: pointer;
  transition: all .15s;
}

.cr-cc-garanties-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 42px;
  height: 42px;
  border-radius: 10px;
  background: linear-gradient(120deg, #eff6ff, #dbeafe);
  color: #1d4ed8;
  font: inherit;
  font-size: 12px;
  font-weight: 700;
  border: 1px solid #bfdbfe;
  cursor: pointer;
  transition: all .15s;
}

.cr-cc-pay-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  min-width: 108px;
  height: 42px;
  padding: 0 16px;
  border-radius: 12px;
  background: linear-gradient(135deg, #12325d, #1565c0);
  color: #fff;
  font: inherit;
  font-size: 13px;
  font-weight: 800;
  border: none;
  cursor: pointer;
  transition: all .15s;
}

.cr-cc-pay-btn:hover {
  transform: translateY(-1px);
  box-shadow: 0 10px 20px rgba(21, 101, 192, .2);
}

.cr-cc-pay-label {
  line-height: 1;
}

.cr-cc-garanties-btn:hover {
  background: linear-gradient(120deg, #1d4ed8, #2563eb);
  color: #fff;
  border-color: transparent;
}

.cr-cc-pdf-btn i,
.cr-cc-garanties-btn i,
.cr-cc-edit-btn i,
.cr-cc-pay-btn i {
  font-size: 15px;
}

.cr-cc-edit-btn:hover {
  background: linear-gradient(120deg, #1565c0, #1e88e5);
  color: #fff;
  border-color: transparent;
}

.cr-cc-delete-form { display: flex; }

.cr-cc-delete-btn {
  width: 36px;
  height: 36px;
  border-radius: 10px;
  background: #fff0f0;
  border: 1px solid #fecaca;
  color: #dc2626;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  font-size: 13px;
  transition: all .15s;
}

.cr-cc-delete-btn:hover { background: #dc2626; color: #fff; }

/* â”€â”€ Empty state â”€â”€ */
.cr-empty-state {
  grid-column: 1 / -1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
  padding: 60px 20px;
  background: #fff;
  border-radius: 18px;
  border: 1px dashed #c4d9ee;
  text-align: center;
}

.cr-empty-icon {
  width: 70px;
  height: 70px;
  border-radius: 50%;
  background: linear-gradient(135deg, #eaf2fd, #dbeafe);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
  color: #7294ae;
}

.cr-empty-state strong { font-size: 17px; color: #0a2540; }
.cr-empty-state span { font-size: 13px; color: #7294ae; max-width: 300px; }

.cr-empty-cta {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  min-height: 40px;
  padding: 0 20px;
  border-radius: 12px;
  background: linear-gradient(120deg, #1565c0, #1e88e5);
  color: #fff;
  font: inherit;
  font-size: 13px;
  font-weight: 700;
  border: none;
  cursor: pointer;
  margin-top: 6px;
  transition: opacity .15s;
}

.cr-empty-cta:hover { opacity: .88; }

/* â”€â”€ Table footer â”€â”€ */
.cr-table-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 10px;
  background: #fff;
  border-radius: 14px;
  padding: 13px 18px;
  border: 1px solid #dde8f5;
}

.cr-tf-stat {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  font-size: 12px;
  color: #7294ae;
  font-weight: 600;
}

.cr-tf-stat i { color: #1565c0; }
.cr-tf-stat strong { color: #0a2540; }

.cr-tf-refresh {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  font-size: 12px;
  font-weight: 700;
  color: #1565c0;
  text-decoration: none;
  padding: 6px 14px;
  border-radius: 9px;
  background: #eaf2fd;
  border: 1px solid #c3d9f5;
  transition: all .15s;
}

.cr-tf-refresh:hover { background: #1565c0; color: #fff; }

/* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
   GARANTIES DRAWER
   â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
.cr-drawer-overlay {
  position: fixed;
  inset: 0;
  background: rgba(10,37,64,.4);
  backdrop-filter: blur(4px);
  z-index: 200;
}

.cr-drawer {
  position: fixed;
  top: 0;
  right: 0;
  width: min(680px, 100vw);
  height: 100vh;
  background: #fff;
  border-left: 1px solid #dde8f5;
  box-shadow: -8px 0 40px rgba(10,37,64,.15);
  z-index: 201;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* hidden attribute must win against class display rules */
.cr-drawer-overlay[hidden],
.cr-drawer[hidden] {
  display: none !important;
}

.cr-drawer-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  padding: 20px 24px;
  background: linear-gradient(135deg, #0a2540, #1565c0);
}

.cr-drawer-header-left {
  display: flex;
  align-items: center;
  gap: 14px;
}

.cr-drawer-icon {
  width: 44px;
  height: 44px;
  border-radius: 14px;
  background: rgba(255,255,255,.15);
  border: 1px solid rgba(255,255,255,.25);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 18px;
  flex-shrink: 0;
}

.cr-drawer-header h3 {
  font-size: 16px;
  font-weight: 800;
  color: #fff;
}

.cr-drawer-header p {
  font-size: 12px;
  color: rgba(255,255,255,.68);
  margin-top: 3px;
}

.cr-drawer-close {
  width: 36px;
  height: 36px;
  border-radius: 10px;
  background: rgba(255,255,255,.12);
  border: 1px solid rgba(255,255,255,.2);
  color: rgba(255,255,255,.85);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  font-size: 14px;
  transition: background .15s;
}

.cr-drawer-close:hover { background: rgba(255,255,255,.22); }

.cr-drawer-body {
  flex: 1;
  overflow-y: auto;
  padding: 20px 24px;
  display: flex;
  flex-direction: column;
  gap: 24px;
}

.cr-drawer-section {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.cr-drawer-section-title {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 12px;
  font-weight: 800;
  color: #1565c0;
  text-transform: uppercase;
  letter-spacing: 0.7px;
  padding-bottom: 10px;
  border-bottom: 1.5px solid #e8f0fb;
}

.cr-drawer-badge {
  margin-left: auto;
  padding: 2px 9px;
  border-radius: 999px;
  background: linear-gradient(120deg, #1565c0, #00bcd4);
  color: #fff;
  font-size: 10px;
  font-weight: 800;
}

.cr-drawer-form { gap: 12px; }

.cr-drawer-form-note {
  font-size: 11.5px;
  color: #5d7f9a;
  background: #eef5ff;
  border: 1px solid #d5e6fb;
  border-radius: 10px;
  padding: 8px 10px;
}

.cr-form-actions { display: flex; justify-content: flex-end; gap: 8px; }

.cr-drawer-actions { padding-top: 6px; border-top: 1px solid #edf4fb; }

/* Garantie list rows */
.cr-garanties-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.cr-garanties-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 14px;
  margin-top: 10px;
}

.cr-garanties-list-main {
  margin-top: 10px;
}

.cr-garantie-card {
  background: #fff;
  border-radius: 18px;
  border: 1px solid #dde8f5;
  padding: 18px;
  display: flex;
  flex-direction: column;
  gap: 14px;
  box-shadow: 0 2px 12px rgba(10,37,64,.05);
  transition: box-shadow .2s, transform .2s, border-color .2s;
  position: relative;
  overflow: hidden;
}

.cr-garantie-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: linear-gradient(90deg, #1565c0, #00bcd4);
}

.cr-garantie-card:hover {
  box-shadow: 0 10px 32px rgba(10,37,64,.12);
  transform: translateY(-3px);
  border-color: #b8d4f0;
}

.cr-garantie-row:hover { border-color: #a8c8f0; }

.cr-garantie-row-left {
  display: flex;
  align-items: center;
  gap: 12px;
}

.cr-garantie-icon {
  width: 36px;
  height: 36px;
  border-radius: 10px;
  background: linear-gradient(135deg, #1565c0, #00bcd4);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  flex-shrink: 0;
}

.cr-garantie-info {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.cr-garantie-info strong {
  font-size: 13px;
  font-weight: 800;
  color: #0a2540;
}

.cr-garantie-info span {
  font-size: 11px;
  color: #7294ae;
}

.cr-garantie-status {
  display: inline-block;
  padding: 2px 8px;
  border-radius: 999px;
  font-size: 10px;
  font-weight: 800;
  width: fit-content;
}

.cr-gstatus-green  { background: #dcfce7; color: #166534; }
.cr-gstatus-red    { background: #fee2e2; color: #991b1b; }
.cr-gstatus-amber  { background: #fef9c3; color: #854d0e; }

.cr-garantie-actions {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  flex-shrink: 0;
}

.cr-garantie-edit-btn,
.cr-garantie-del-btn {
  width: 36px;
  height: 36px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  font-size: 12px;
  transition: all .15s;
}

.cr-garantie-edit-btn {
  background: linear-gradient(120deg, #e8f0fd, #dbeafe);
  border: 1px solid #c3d9f5;
  color: #1565c0;
}

.cr-garantie-edit-btn:hover {
  background: linear-gradient(120deg, #1565c0, #1e88e5);
  color: #fff;
}

.cr-garantie-del-form { margin: 0; }

.cr-garantie-del-btn {
  background: #fff0f0;
  border: 1px solid #fecaca;
  color: #dc2626;
}

.cr-garantie-del-btn:hover { background: #dc2626; color: #fff; }

.cr-garanties-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  padding: 32px 20px;
  background: #f7faff;
  border: 1px dashed #c4d9ee;
  border-radius: 14px;
  text-align: center;
  color: #7294ae;
  font-size: 13px;
  font-weight: 600;
}

.cr-garanties-empty i { font-size: 24px; color: #b8d4e8; }

