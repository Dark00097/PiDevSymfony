            }
            if (hasMatchingAnalysis && garantieDocumentAnalysisState.verdict === 'suspect') {
              return setFieldError(garantieDocumentField, messageEl, garantieDocumentAnalysisState.message || 'Document suspect detecte.');
            }
            return setFieldOk(garantieDocumentField, messageEl);
          }
          if (existingPath === '') {
            return setFieldError(garantieDocumentField, messageEl, 'Le document justificatif est obligatoire.');
          }
          return setFieldOk(garantieDocumentField, messageEl);
        }
        case 'description':
          if (value === '') {
            return setFieldError(field, messageEl, 'Ce champ est obligatoire.');
          }
          if (value.length < 10) {
            return setFieldError(field, messageEl, 'La description doit contenir au moins 10 caracteres.');
          }
          return setFieldOk(field, messageEl);
        default:
          return true;
      }
    };
    const validateGarantieFormValues = () => garantieFieldNames.map((name) => validateGarantieField(name)).every((res) => res);

    const resetGarantieFormState = (withFormReset = true) => {
      if (withFormReset && garantieForm instanceof HTMLFormElement) {
        garantieForm.reset();
      }
      if (garantieIdField instanceof HTMLInputElement) {
        garantieIdField.value = '';
      }
      if (garantieCreditIdField instanceof HTMLInputElement) {
        garantieCreditIdField.value = '';
      }
      if (garantieDateField instanceof HTMLInputElement && garantieDateField.value === '') {
        garantieDateField.value = '{{ current_date }}';
      }
      if (garantieDocumentField instanceof HTMLInputElement) {
        garantieDocumentField.value = '';
      }
      garantieDocumentAnalysisState.fileKey = '';
      garantieDocumentAnalysisState.status = 'idle';
      garantieDocumentAnalysisState.verdict = 'pending';
      garantieDocumentAnalysisState.message = '';
      garantieDocumentAnalysisState.blurScore = 0;
      garantieDocumentAnalysisState.width = 0;
      garantieDocumentAnalysisState.height = 0;
      setGarantieAnalyzeStatus('pending');
      if (garantieAddressCompleteField instanceof HTMLInputElement) {
        garantieAddressCompleteField.value = '';
      }
      if (garantieAddressField instanceof HTMLInputElement) {
        garantieAddressField.value = '';
      }
      if (garantieDocumentPublicIdField instanceof HTMLInputElement) garantieDocumentPublicIdField.value = '';
      if (garantieDocumentMimeField instanceof HTMLInputElement) garantieDocumentMimeField.value = '';
      if (garantieDocumentUploadedAtField instanceof HTMLInputElement) garantieDocumentUploadedAtField.value = '';
      syncGarantieDocumentMeta('', '', {
        status: 'en_attente',
        feedback: 'Le justificatif est en attente de verification.',
      });
      clearGarantieAddressDetails();
      hideGarantieSuggestions();
      garantieFieldNames.forEach((name) => {
        clearFieldValidation(getGarantieField(name), getGarantieMessage(name));
      });
      setGarantieAiStatus('', '', false);
      syncRetainedFromEstimated();
    };

    garantieEstimatedField?.addEventListener('input', () => {
      normalizeDecimalInputValue(garantieEstimatedField);
      syncRetainedFromEstimated();
      validateGarantieField('valeurEstimee');
      validateGarantieField('valeurRetenue');
    });
    garantieEstimatedField?.addEventListener('change', () => {
      normalizeDecimalInputValue(garantieEstimatedField);
      syncRetainedFromEstimated();
      validateGarantieField('valeurEstimee');
      validateGarantieField('valeurRetenue');
    });
    garantieEstimatedField?.addEventListener('blur', () => {
      normalizeDecimalInputValue(garantieEstimatedField);
      syncRetainedFromEstimated();
      validateGarantieField('valeurEstimee');
      validateGarantieField('valeurRetenue');
    });
    getGarantieField('typeGarantie')?.addEventListener('change', () => {
      syncRetainedFromEstimated();
      validateGarantieField('typeGarantie');
      validateGarantieField('valeurRetenue');
    });

    garantieDocumentField?.addEventListener('change', async () => {
      const file = garantieDocumentField instanceof HTMLInputElement ? garantieDocumentField.files?.[0] ?? null : null;
      garantieDocumentAnalysisState.fileKey = file ? garantieDocFileKey(file) : '';
      garantieDocumentAnalysisState.status = file ? 'pending' : 'idle';
      garantieDocumentAnalysisState.verdict = 'pending';
      garantieDocumentAnalysisState.message = '';
      syncGarantieDocumentMeta(
        garantieExistingDocumentField instanceof HTMLInputElement ? garantieExistingDocumentField.value : '',
        file ? `Fichier selectionne: ${file.name}` : '',
        {
          status: 'en_attente',
          feedback: file ? 'Document charge. Verification en attente.' : '',
          mimeType: file?.type || '',
        }
      );
      updateGarantieDocumentPreview('', file);
      if (file) {
        try {
          const formData = new FormData();
          formData.append('document', file);
          if (garantieIdField instanceof HTMLInputElement && garantieIdField.value.trim() !== '') {
            formData.append('idGarantie', garantieIdField.value.trim());
          }
          const uploadResponse = await fetch(garantieDocumentUploadEndpoint, {
            method: 'POST',
            headers: {
              'X-Requested-With': 'XMLHttpRequest',
            },
            body: formData,
          });
          const uploadResult = await uploadResponse.json().catch(() => null);
          if (uploadResponse.ok && uploadResult && uploadResult.ok === true && typeof uploadResult.url === 'string' && uploadResult.url.trim() !== '') {
            syncGarantieDocumentMeta(uploadResult.url.trim(), `Upload Cloudinary OK: ${file.name}`, {
              status: 'en_attente',
              feedback: 'Document televerse sur Cloudinary. Verification en attente.',
              publicId: String(uploadResult.public_id ?? ''),
              mimeType: String(uploadResult.mime_type ?? file.type ?? ''),
              uploadedAt: String(uploadResult.uploaded_at ?? ''),
            });
          } else if (uploadResult && typeof uploadResult.message === 'string' && uploadResult.message.trim() !== '') {
            setFieldError(garantieDocumentField, getGarantieMessage('documentJustificatif'), uploadResult.message.trim());
          }
        } catch (_uploadError) {
          setFieldError(garantieDocumentField, getGarantieMessage('documentJustificatif'), 'Upload Cloudinary impossible. Verifiez la configuration puis reessayez.');
          if (garantieDocumentLabel) {
            garantieDocumentLabel.textContent = 'Echec upload Cloudinary';
          }
        }
        await runGarantieDocumentAnalysis({ showOkMessage: false });
      }
      validateGarantieField('documentJustificatif');
    });
    garantieDocumentPickerBtn?.addEventListener('click', () => {
      if (garantieDocumentField instanceof HTMLInputElement) {
        garantieDocumentField.click();
      }
    });
    garantieDocumentPickerBtn?.addEventListener('touchstart', () => {
      if (garantieDocumentField instanceof HTMLInputElement) {
        garantieDocumentField.click();
      }
    }, { passive: true });
    garantieDocumentPickerBtn?.addEventListener('keydown', (event) => {
      if (!(event instanceof KeyboardEvent)) return;
      if (event.key !== 'Enter' && event.key !== ' ') return;
      event.preventDefault();
      if (garantieDocumentField instanceof HTMLInputElement) {
        garantieDocumentField.click();
      }
    });
    garantieDocumentAnalyzeBtn?.addEventListener('click', async () => {
      const result = await runGarantieDocumentAnalysis({ showOkMessage: true });
      if (!result.ok) {
        return;
      }
      validateGarantieField('documentJustificatif');
    });
    garantieAddressCompleteField?.addEventListener('input', () => {
      window.clearTimeout(garantieAddressSearchTimer);
      if (garantieLatitudeField instanceof HTMLInputElement) {
        garantieLatitudeField.value = '';
      }
      if (garantieLongitudeField instanceof HTMLInputElement) {
        garantieLongitudeField.value = '';
      }
      syncGarantieAddressAliases();
      setGarantieAddressStatus('En attente');
      validateGarantieField('adresseComplete');

      const query = String(garantieAddressCompleteField.value ?? '').trim();
      if (query.length < 4) {
        hideGarantieSuggestions();
        updateGarantieMapFrame('', '');
        return;
      }

      garantieAddressSearchTimer = window.setTimeout(async () => {
        try {
          const items = await searchGarantieAddresses(query);
          renderGarantieSuggestions(items);
          if (Array.isArray(items) && items.length === 1) {
            fillGarantieAddressDetails(items[0], { overwriteAddress: true });
          }
        } catch (_error) {
          hideGarantieSuggestions();
        }
      }, 350);
    });
    garantieAddressCompleteField?.addEventListener('blur', async () => {
      const query = String(garantieAddressCompleteField.value ?? '').trim();
      if (query.length < 4) {
        return;
      }
      try {
        const items = await searchGarantieAddresses(query);
        if (Array.isArray(items) && items.length > 0) {
          fillGarantieAddressDetails(items[0], { overwriteAddress: true });
          return;
        }
      } catch (_error) {
        // keep manual address when OpenStreet query is unavailable
      }
      fillAddressFromTextFallback(query);
      syncGarantieAddressAliases();
      validateGarantieField('adresseComplete');
      validateGarantieField('adresseBien');
    });
    garantieFieldNames.forEach((name) => {
      const field = getGarantieField(name);
      if (!field || name === 'documentJustificatif') {
        return;
      }

      field.addEventListener('input', () => validateGarantieField(name));
      field.addEventListener('change', () => validateGarantieField(name));
      field.addEventListener('blur', () => validateGarantieField(name));
    });

    garantieForm?.addEventListener('reset', () => {
      window.requestAnimationFrame(() => {
        resetGarantieFormState(false);
      });
    });

    const focusFirstGarantieError = () => {
      for (const name of garantieFieldNames) {
        const field = getGarantieField(name);
        if (!(field instanceof HTMLElement)) {
          continue;
        }
        if (field.classList.contains('cr-input--error')) {
          field.focus({ preventScroll: true });
          field.scrollIntoView({ behavior: 'smooth', block: 'center' });
          return;
        }
      }
    };

    const ensureGarantieAddressDetailsBeforeSubmit = async () => {
      const hasCity = garantieCityField instanceof HTMLInputElement && garantieCityField.value.trim() !== '';
      const hasCountry = garantieCountryField instanceof HTMLInputElement && garantieCountryField.value.trim() !== '';
      if (hasCity && hasCountry) {
        return;
      }
      const query = garantieAddressCompleteField instanceof HTMLInputElement ? garantieAddressCompleteField.value.trim() : '';
      if (query.length < 4) {
        return;
      }
      try {
        const items = await searchGarantieAddresses(query);
        if (Array.isArray(items) && items.length > 0) {
          fillGarantieAddressDetails(items[0], { overwriteAddress: true });
        }
      } catch (_error) {
      }
    };

    garantieForm?.addEventListener('submit', async (event) => {
      normalizeDecimalInputValue(garantieEstimatedField);
      normalizeDecimalInputValue(garantieRetainedField);
      fillAddressFromTextFallback(garantieAddressCompleteField instanceof HTMLInputElement ? garantieAddressCompleteField.value : '');
      syncGarantieAddressAliases();
      syncRetainedFromEstimated();
      await ensureGarantieAddressDetailsBeforeSubmit();
      if (!validateGarantieFormValues()) {
        if (garantieSubmitFeedback instanceof HTMLElement) {
          garantieSubmitFeedback.textContent = 'Veuillez corriger les champs obligatoires avant enregistrement.';
          garantieSubmitFeedback.classList.add('is-error');
        }
        focusFirstGarantieError();
        event.preventDefault();
        return;
      }
      if (garantieSubmitFeedback instanceof HTMLElement) {
        garantieSubmitFeedback.textContent = 'Enregistrement en cours...';
        garantieSubmitFeedback.classList.remove('is-error');
      }
    });

    garantieGenerateAiBtn?.addEventListener('click', async () => {
      syncGarantieAddressAliases();
      const payload = {
        typeGarantie: String(getGarantieField('typeGarantie')?.value ?? '').trim(),
        valeurEstimee: parseNum(getGarantieField('valeurEstimee')?.value ?? ''),
        valeurRetenue: parseNum(getGarantieField('valeurRetenue')?.value ?? ''),
        dateEvaluation: String(getGarantieField('dateEvaluation')?.value ?? '').trim(),
        nomGarant: String(getGarantieField('nomGarant')?.value ?? '').trim(),
        adresseBien: String(getGarantieField('adresseBien')?.value ?? '').trim(),
      };

      if (payload.typeGarantie === '' || payload.valeurEstimee <= 0 || payload.nomGarant === '' || payload.adresseBien === '') {
        validateGarantieField('typeGarantie');
        validateGarantieField('valeurEstimee');
        validateGarantieField('nomGarant');
        validateGarantieField('adresseBien');
        setGarantieAiStatus(t('aiMissingData'), 'is-warn', true);
        return;
      }

      const originalLabel = garantieGenerateAiLabel?.textContent || t('generateAi');
      garantieGenerateAiBtn.disabled = true;
      if (garantieGenerateAiLabel) {
        garantieGenerateAiLabel.textContent = t('generatingAi');
      }
      setGarantieAiStatus(t('generatingAi'), 'is-warn', true);

      try {
        const response = await fetch(garantieDescriptionGenerateEndpoint, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest',
          },
          body: JSON.stringify(payload),
        });

        const result = await response.json().catch(() => null);
        if (!response.ok || !result || result.ok !== true || typeof result.description !== 'string' || result.description.trim() === '') {
          throw new Error((result && typeof result.message === 'string' && result.message.trim() !== '') ? result.message : t('aiError'));
        }

        if (garantieDescriptionField instanceof HTMLInputElement || garantieDescriptionField instanceof HTMLTextAreaElement) {
          garantieDescriptionField.value = result.description.trim();
        }
        validateGarantieField('description');
        setGarantieAiStatus(`${t('aiGenerated')} (${String(result.provider ?? 'Fallback')})`, 'is-ok', true);
      } catch (error) {
        const payloadType = String(getGarantieField('typeGarantie')?.value ?? '').trim() || 'garantie';
        const payloadAddress = String(getGarantieField('adresseBien')?.value ?? '').trim() || 'adresse non precisee';
        const payloadGuarantor = String(getGarantieField('nomGarant')?.value ?? '').trim() || 'garant non precise';
        const payloadEstimated = parseNum(getGarantieField('valeurEstimee')?.value ?? '');
        const payloadRetained = parseNum(getGarantieField('valeurRetenue')?.value ?? '');
        const fallbackText = `Garantie ${payloadType} situee a ${payloadAddress}. Valeur estimee: ${fmtNum(payloadEstimated, 2)} DT, valeur retenue: ${fmtNum(payloadRetained, 2)} DT. Garant: ${payloadGuarantor}. Dossier a verifier selon les pieces justificatives et la conformite de l'adresse.`;
        if (garantieDescriptionField instanceof HTMLInputElement || garantieDescriptionField instanceof HTMLTextAreaElement) {
          garantieDescriptionField.value = fallbackText;
          validateGarantieField('description');
        }
        setGarantieAiStatus('OpenRouter indisponible. Description de secours generee.', 'is-warn', true);
      } finally {
        garantieGenerateAiBtn.disabled = false;
        if (garantieGenerateAiLabel) {
          garantieGenerateAiLabel.textContent = originalLabel;
        }
      }
    });

    const fillGarantieForm = (row) => {
      if (!(row instanceof HTMLElement)) {
        return;
      }

      $$('[data-main-garantie-row]').forEach((card) => {
        card.classList.toggle('is-selected', card === row);
      });

      setGarantieField('idGarantie', row.dataset.garantieId ?? '');
      const garantieTypeRaw = row.dataset.garantieTypeValue ?? row.dataset.garantieType ?? '';
      setGarantieField('typeGarantie', resolveGarantieTypeValue(garantieTypeRaw));
      setGarantieField('description', row.dataset.garantieDescription ?? '');
      setGarantieField('adresseBien', row.dataset.garantieAddress ?? '');
      setGarantieField('idCredit', row.dataset.garantieCreditId ?? '');
      setGarantieField('adresseComplete', row.dataset.garantieAddressComplete ?? '');
      syncGarantieAddressAliases();
      setGarantieField('ville', row.dataset.garantieCity ?? '');
      setGarantieField('codePostal', row.dataset.garantiePostal ?? '');
      setGarantieField('pays', row.dataset.garantieCountry ?? '');
      setGarantieField('latitude', row.dataset.garantieLatitude ?? '');
      setGarantieField('longitude', row.dataset.garantieLongitude ?? '');
      setGarantieField('statutVerificationAdresse', row.dataset.garantieAddressStatus ?? 'En attente');
      setGarantieField('valeurEstimee', row.dataset.garantieEstimated ?? '');
      setGarantieField('valeurRetenue', row.dataset.garantieRetained ?? '');
      setGarantieField('dateEvaluation', normalizeIsoDate(row.dataset.garantieDate ?? ''));
      setGarantieField('nomGarant', row.dataset.garantieGuarantor ?? '');
      if (garantieDocumentField instanceof HTMLInputElement) {
        garantieDocumentField.value = '';
      }
      garantieDocumentAnalysisState.fileKey = '';
      garantieDocumentAnalysisState.status = 'idle';
      garantieDocumentAnalysisState.verdict = 'pending';
      garantieDocumentAnalysisState.message = '';
      garantieDocumentAnalysisState.blurScore = 0;
      garantieDocumentAnalysisState.width = 0;
      garantieDocumentAnalysisState.height = 0;
      setGarantieAnalyzeStatus('pending');
      syncGarantieDocumentMeta(row.dataset.garantieDocumentUrl ?? row.dataset.garantieDocument ?? '', '', {
        status: row.dataset.garantieDocumentStatus ?? 'en_attente',
        feedback: row.dataset.garantieDocumentFeedback ?? '',
        publicId: row.dataset.garantieDocumentPublicId ?? '',
        mimeType: row.dataset.garantieDocumentMime ?? '',
        uploadedAt: row.dataset.garantieDocumentUploadedAt ?? '',
      });
      setGarantieAddressStatus(row.dataset.garantieAddressStatus ?? 'En attente');
      updateGarantieMapFrame(row.dataset.garantieLatitude ?? '', row.dataset.garantieLongitude ?? '');
      hideGarantieSuggestions();

      syncRetainedFromEstimated();
      validateGarantieFormValues();

      closeDrawer();
      document.getElementById('garantie-form-card')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      garantieForm?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    };

    const isInteractiveGarantieTarget = (target) => {
      if (!(target instanceof Element)) {
        return false;
      }
      return Boolean(target.closest('button, a, form, input, select, textarea, label, [role="button"]'));
    };

    $$('[data-garantie-edit]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const row = btn.closest('[data-garantie-row]');
        fillGarantieForm(row);
      });
    });

    $$('[data-main-garantie-row]').forEach((row) => {
      if (!(row instanceof HTMLElement)) {
        return;
      }
      row.tabIndex = 0;
      row.setAttribute('role', 'button');
      row.setAttribute('aria-label', 'Charger cette garantie dans le formulaire');
      row.addEventListener('click', (event) => {
        if (isInteractiveGarantieTarget(event.target)) {
          return;
        }
        fillGarantieForm(row);
      });
      row.addEventListener('keydown', (event) => {
        if (event.key !== 'Enter' && event.key !== ' ') {
          return;
        }
        event.preventDefault();
        fillGarantieForm(row);
      });
    });

    syncGarantieDocumentMeta(garantieExistingDocumentField instanceof HTMLInputElement ? garantieExistingDocumentField.value : '', '', {
      status: garantieDocumentStatusField instanceof HTMLInputElement ? garantieDocumentStatusField.value : 'en_attente',
      feedback: garantieDocumentFeedback instanceof HTMLElement ? garantieDocumentFeedback.textContent : '',
      publicId: garantieDocumentPublicIdField instanceof HTMLInputElement ? garantieDocumentPublicIdField.value : '',
      mimeType: garantieDocumentMimeField instanceof HTMLInputElement ? garantieDocumentMimeField.value : '',
      uploadedAt: garantieDocumentUploadedAtField instanceof HTMLInputElement ? garantieDocumentUploadedAtField.value : '',
    });
    setGarantieAnalyzeStatus('pending');
    setGarantieAddressStatus(garantieAddressStatusField instanceof HTMLInputElement ? garantieAddressStatusField.value : 'En attente');
    renderStaticOpenStreetFallback(
      garantieLatitudeField instanceof HTMLInputElement ? garantieLatitudeField.value : '',
      garantieLongitudeField instanceof HTMLInputElement ? garantieLongitudeField.value : ''
    );
    waitLeafletReady((isReady) => {
      const lat = garantieLatitudeField instanceof HTMLInputElement ? garantieLatitudeField.value : '';
      const lng = garantieLongitudeField instanceof HTMLInputElement ? garantieLongitudeField.value : '';
      if (isReady) {
        updateGarantieMapFrame(lat, lng);
        return;
      }
      renderStaticOpenStreetFallback(lat, lng);
    });
    syncRetainedFromEstimated();
    openBtns.forEach((btn) => btn?.addEventListener('click', () => {
      resetGarantieFormState();
      openDrawer();
      garantieForm?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }));
    document.addEventListener('click', (event) => {
      const addCreditTrigger = event.target instanceof Element ? event.target.closest('#cr-add-credit-btn') : null;
      if (!(addCreditTrigger instanceof HTMLAnchorElement)) {
        return;
      }
      event.preventDefault();
      const href = addCreditTrigger.getAttribute('href');
      if (href && href.trim() !== '') {
        window.location.assign(href);
      }
    });
    closeBtn?.addEventListener('click', closeDrawer);
    overlay?.addEventListener('click', closeDrawer);
    document.addEventListener('click', (event) => {
      if (!(garantieAddressSuggestions instanceof HTMLElement) || garantieAddressSuggestions.hidden) {
        return;
      }
      if (garantieAddressSuggestions.contains(event.target) || garantieAddressCompleteField?.contains(event.target)) {
        return;
      }
      hideGarantieSuggestions();
    });

    /* open if redirected back with panel=credit */
    if (new URLSearchParams(location.search).get('panel') === 'credit') {
      openDrawer();
    }

