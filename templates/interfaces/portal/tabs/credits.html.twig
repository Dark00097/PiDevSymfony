{% set current_date = 'now'|date('Y-m-d') %}
{% set garanties = support.garanties|default([]) %}
{% set credit_garanties = support.all_garanties|default(garanties) %}
{% set pending_total = 0 %}
{% set accepted_total = 0 %}
{% set refused_total = 0 %}
{% set encours_total = 0 %}
{% set average_risk = 0 %}
{% set risk_sum = 0 %}
{% set total_amount = 0 %}
{% set total_monthly = 0 %}
{% set current_month = 'now'|date('Y-m') %}
{% set credits_month = 0 %}
{% set max_credit_id = 0 %}
{% set credit_feedback = support.credit_form_feedback|default({}) %}
{% if credit_feedback is empty %}
    {% set credit_feedback = {'errors': support.form_errors_credit|default({}), 'input': support.form_data_credit|default({})} %}
{% endif %}
{% set credit_old = credit_feedback.input|default({}) %}
{% set credit_errors = credit_feedback.errors|default({}) %}
{% set garantie_feedback = support.garantie_form_feedback|default({}) %}
{% if garantie_feedback is empty %}
    {% set garantie_feedback = {'errors': support.form_errors_garantie|default({}), 'input': support.form_data_garantie|default({})} %}
{% endif %}
{% set garantie_old = garantie_feedback.input|default({}) %}
{% set garantie_errors = garantie_feedback.errors|default({}) %}
{% set payment_accounts = support.payment_accounts|default(support.accounts|default([])) %}
{% set payment_otp_sent = support.payment_otp_sent|default(false) %}
{% set payment_otp_verified = support.payment_otp_verified|default(false) %}
{% set payment_phone = support.payment_phone|default(current_user.telephone|default('')) %}
{% set payment_channel = support.payment_channel|default('sms') %}
{% set payment_open_credit_id = support.payment_open_credit_id|default(0) %}
{% set payment_config = support.payment_config|default({}) %}
{% set restructuration_scenarios = support.restructuration_scenarios|default({}) %}
{% set restructuration_first_eligible_credit_id = support.restructuration_first_eligible_credit_id|default(0) %}
{% set restructuration_first_critical_credit_id = support.restructuration_first_critical_credit_id|default(0) %}
{% set payment_current_step = payment_otp_verified ? 3 : (payment_otp_sent ? 2 : 1) %}
{% set current_language = 'fr' %}
{% set credit_error_step = 1 %}
{% if credit_errors.montantDemande is defined or credit_errors.autofinancement is defined or credit_errors.duree is defined or credit_errors.tauxInteret is defined or credit_errors.mensualite is defined or credit_errors.montantAccorde is defined %}
    {% set credit_error_step = 2 %}
{% elseif credit_errors.salaire is defined or credit_errors.typeContrat is defined or credit_errors.ancienneteAnnees is defined %}
    {% set credit_error_step = 3 %}
{% endif %}
{% for item in items %}
    {% set status_key = item.statut|default('')|lower %}
    {% if 'attente' in status_key %}
        {% set pending_total = pending_total + 1 %}
    {% endif %}
    {% if 'accepte' in status_key or 'approved' in status_key %}
        {% set accepted_total = accepted_total + 1 %}
    {% endif %}
    {% if 'cours' in status_key %}
        {% set encours_total = encours_total + 1 %}
    {% endif %}
    {% if 'refuse' in status_key or 'rejet' in status_key %}
        {% set refused_total = refused_total + 1 %}
    {% endif %}
    {% set risk_sum = risk_sum + (item.risk_score|default(0)) %}
    {% set total_amount = total_amount + (item.montantDemande|default(0)) %}
    {% set total_monthly = total_monthly + (item.mensualite|default(0)) %}
    {% if item.idCredit|default(0) > max_credit_id %}
        {% set max_credit_id = item.idCredit %}
    {% endif %}
    {% if item.dateDemande is not empty and item.dateDemande|date('Y-m') == current_month %}
        {% set credits_month = credits_month + 1 %}
    {% endif %}
{% endfor %}
{% set next_credit_id = max_credit_id + 1 %}
{% if items|length > 0 %}
    {% set average_risk = (risk_sum / items|length)|round(1, 'common') %}
{% endif %}

<div class="cr-root"
     data-payment-open-credit="{{ payment_open_credit_id }}"
     data-payment-otp-sent="{{ payment_otp_sent ? '1' : '0' }}"
     data-payment-otp-verified="{{ payment_otp_verified ? '1' : '0' }}"
     data-payment-current-step="{{ payment_current_step }}"
     data-restruct-first-eligible-credit="{{ restructuration_first_eligible_credit_id }}"
     data-restruct-first-critical-credit="{{ restructuration_first_critical_credit_id }}">

    <section class="cr-hero">
        <div class="cr-hero-main">
            <div class="cr-hero-brand">
                <div class="cr-hero-icon">
                    <i class="fa-solid fa-hand-holding-dollar"></i>
                </div>
                <div class="cr-hero-copy">
                    <h1>Gestion des credits</h1>
                    <p>Demandez des prets, gerez vos credits et suivez les remboursements</p>
                </div>
            </div>

            <div class="cr-hero-center">
                <div class="cr-hero-stat">
                    <span class="cr-hero-stat-num">{{ items|length }}</span>
                    <span class="cr-hero-stat-lbl">Total dossiers</span>
                </div>
                <div class="cr-hero-divider"></div>
                <div class="cr-hero-stat">
                    <span class="cr-hero-stat-num">{{ credits_month }}</span>
                    <span class="cr-hero-stat-lbl">Ce mois</span>
                </div>
                <div class="cr-hero-divider"></div>
                <div class="cr-hero-stat">
                    <span class="cr-hero-stat-num">{{ pending_total }}</span>
                    <span class="cr-hero-stat-lbl">En attente</span>
                </div>
            </div>

            <div class="cr-hero-nav">
                <button type="button" class="cr-nav-pill" data-tool-open="history">
                    <i class="fa-solid fa-clock-rotate-left"></i><span>Historique</span>
                </button>
                <button type="button" class="cr-nav-pill" id="cr-open-assistant-btn" data-tool-open="assistant">
                    <i class="fa-solid fa-robot"></i><span>Assistant IA</span>
                </button>
                <button type="button" class="cr-nav-pill cr-nav-pill--cta" id="cr-add-credit-btn">
                    <i class="fa-solid fa-plus"></i><span>Nouveau credit</span>
                </button>
        </div>

        <div class="cr-hero-toolbar">
            <div class="cr-hero-toolbar-right">
                <label class="cr-lang-select" for="cr-language">
                    <span class="cr-visually-hidden" id="cr-language-label">Choisir la langue</span>
                    <i class="fa-solid fa-globe" aria-hidden="true"></i>
                    <span class="cr-lang-value" id="cr-language-value" aria-hidden="true">Francais</span>
                    <select id="cr-language" name="language" aria-labelledby="cr-language-label">
                        <option value="fr" {{ current_language == 'fr' ? 'selected' : '' }}>Francais</option>
                        <option value="en" {{ current_language == 'en' ? 'selected' : '' }}>English</option>
                        <option value="ar" {{ current_language == 'ar' ? 'selected' : '' }}>العربية</option>
                    </select>
                    <i class="fa-solid fa-chevron-down cr-lang-chevron" aria-hidden="true"></i>
                </label>
                <button class="cr-topbar-btn" id="cr-dark-toggle" type="button">
                    <i class="fa-solid fa-moon"></i>
                </button>
                <a class="cr-topbar-btn" href="{{ path(route_name, { tab: 'credits' }) }}" title="Actualiser">
                    <i class="fa-solid fa-rotate"></i>
                </a>
                <div class="cr-user-chip">
                    <div class="cr-user-avatar">
                        {{ current_user.prenom|first|upper }}{{ current_user.nom|first|upper }}
                    </div>
                    <div class="cr-user-info">
                        <strong>{{ current_user.prenom }} {{ current_user.nom }}</strong>
                        <small>#{{ current_user.idUser }}</small>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div class="cr-kpi-strip">
        <div class="cr-kpi-card cr-kpi-card--amount">
            <div class="cr-kpi-head">
                <div class="cr-kpi-icon cr-kpi-icon-teal">
                    <i class="fa-solid fa-coins"></i>
                </div>
                <div class="cr-kpi-copy">
                    <span class="cr-kpi-label">Montant demande</span>
                    <span class="cr-kpi-sub">Volume global</span>
                </div>
            </div>
            <div class="cr-kpi-metric">
                <strong class="cr-kpi-value">{{ total_amount|number_format(2, '.', ' ') }}</strong>
                <span class="cr-kpi-unit">DT</span>
            </div>
            <div class="cr-kpi-bar"><span style="width:100%"></span></div>
        </div>
        <div class="cr-kpi-card cr-kpi-card--monthly">
            <div class="cr-kpi-head">
                <div class="cr-kpi-icon cr-kpi-icon-blue">
                    <i class="fa-solid fa-calendar-check"></i>
                </div>
                <div class="cr-kpi-copy">
                    <span class="cr-kpi-label">Mensualites</span>
                    <span class="cr-kpi-sub">Charge cumulee</span>
                </div>
            </div>
            <div class="cr-kpi-metric">
                <strong class="cr-kpi-value">{{ total_monthly|number_format(2, '.', ' ') }}</strong>
                <span class="cr-kpi-unit">DT</span>
            </div>
            <div class="cr-kpi-bar"><span style="width:{{ total_amount > 0 ? ((total_monthly / total_amount) * 100)|round : 0 }}%"></span></div>
        </div>
        <div class="cr-kpi-card cr-kpi-card--active">
            <div class="cr-kpi-head">
                <div class="cr-kpi-icon cr-kpi-icon-green">
                    <i class="fa-solid fa-circle-check"></i>
                </div>
                <div class="cr-kpi-copy">
                    <span class="cr-kpi-label">Acceptes / Actifs</span>
                    <span class="cr-kpi-sub">Dossiers valides</span>
                </div>
            </div>
            <div class="cr-kpi-metric">
                <strong class="cr-kpi-value">{{ accepted_total }}</strong>
                <span class="cr-kpi-unit">credits</span>
            </div>
            <div class="cr-kpi-bar"><span style="width:{{ items|length > 0 ? ((accepted_total / items|length) * 100)|round : 0 }}%"></span></div>
        </div>
        <div class="cr-kpi-card cr-kpi-card--risk">
            <div class="cr-kpi-head">
                <div class="cr-kpi-icon cr-kpi-icon-red">
                    <i class="fa-solid fa-triangle-exclamation"></i>
                </div>
                <div class="cr-kpi-copy">
                    <span class="cr-kpi-label">Risque moyen</span>
                    <span class="cr-kpi-sub">Evaluation portefeuille</span>
                </div>
            </div>
            <div class="cr-kpi-metric">
                <strong class="cr-kpi-value">{{ average_risk }}</strong>
                <span class="cr-kpi-unit">/100</span>
            </div>
            <div class="cr-kpi-bar"><span class="is-danger" style="width:{{ average_risk > 100 ? 100 : average_risk }}%"></span></div>
        </div>
    </div>
    {#  MAIN SPLIT LAYOUT #}
    <div class="cr-tools-overlay" id="cr-tools-overlay" hidden></div>
    <section class="cr-tools-modal" id="cr-tools-modal" hidden role="dialog" aria-modal="true" aria-labelledby="cr-tools-title">
        <header class="cr-tools-header">
            <div>
                <h3 id="cr-tools-title">Historique des credits</h3>
                <p id="cr-tools-subtitle">Consultez rapidement l historique complet de vos credits.</p>
            </div>
            <button class="cr-tools-close" id="cr-tools-close" type="button" aria-label="Fermer">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </header>

        <div class="cr-tools-body">
            <section class="cr-tool-panel is-active" data-tool-panel="history">
                {% if items|length > 0 %}
                    <div class="cr-tool-table-wrap">
                        <table class="cr-tool-table">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Type</th>
                                    <th>Montant</th>
                                    <th>Mensualite</th>
                                    <th>Statut</th>
                                    <th>Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for item in items %}
                                    <tr>
                                        <td>#{{ item.idCredit }}</td>
                                        <td>{{ item.typeCredit|default('-') }}</td>
                                        <td>{{ item.montantDemande|default(0)|number_format(2, '.', ' ') }} DT</td>
                                        <td>{{ item.mensualite|default(0)|number_format(2, '.', ' ') }} DT</td>
                                        <td>{{ item.statut|default('-') }}</td>
                                        <td>{{ item.dateDemande|default('-') }}</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% else %}
                    <div class="cr-tool-empty">Aucun historique credit disponible.</div>
                {% endif %}
            </section>

            <section class="cr-tool-panel" data-tool-panel="assistant">
                <div class="cr-assistant-shell">
                    <aside class="cr-assistant-side">
                        <span class="cr-assistant-side-badge" id="cr-assistant-side-badge">Chat bancaire intelligent</span>
                        <h4 id="cr-assistant-side-title">Ce que l assistant peut faire</h4>
                        <p id="cr-assistant-side-subtitle">Posez une question libre ou utilisez un raccourci pour simuler un credit, calculer un score, analyser des garanties, proposer une decision et recevoir des recommandations.</p>

                        <div class="cr-assistant-quick" id="cr-assistant-quick">
                            <button type="button" class="cr-assistant-quick-btn" data-assistant-intent="simulate" data-assistant-prompt="Simule un credit a partir de mon dossier en cours.">
                                <i class="fa-solid fa-chart-line"></i>
                                <span id="cr-assistant-q-simulate">Simuler un credit</span>
                            </button>
                            <button type="button" class="cr-assistant-quick-btn" data-assistant-intent="score" data-assistant-prompt="Calcule mon score de credit.">
                                <i class="fa-solid fa-gauge-high"></i>
                                <span id="cr-assistant-q-score">Calculer un score</span>
                            </button>
                            <button type="button" class="cr-assistant-quick-btn" data-assistant-intent="garantie" data-assistant-prompt="Analyse mes garanties disponibles.">
                                <i class="fa-solid fa-shield-halved"></i>
                                <span id="cr-assistant-q-garanties">Analyser les garanties</span>
                            </button>
                            <button type="button" class="cr-assistant-quick-btn" data-assistant-intent="decision" data-assistant-prompt="Donne une decision automatique sur mon dossier.">
                                <i class="fa-solid fa-scale-balanced"></i>
                                <span id="cr-assistant-q-decision">Decision automatique</span>
                            </button>
                            <button type="button" class="cr-assistant-quick-btn" data-assistant-intent="recommend" data-assistant-prompt="Donne moi des recommandations personnalisees.">
                                <i class="fa-solid fa-lightbulb"></i>
                                <span id="cr-assistant-q-recommend">Recommandations</span>
                            </button>
                        </div>

                        <div class="cr-assistant-targets">
                            <label class="cr-assistant-target-field" for="cr-assistant-credit-select">
                                <span id="cr-assistant-credit-label">Credit cible</span>
                                <select id="cr-assistant-credit-select">
                                    <option value="" data-assistant-credit-auto>Contexte automatique</option>
                                    {% for item in items %}
                                        <option
                                            value="{{ item.idCredit }}"
                                            data-credit-option
                                            data-credit-id="{{ item.idCredit }}"
                                            data-credit-garantie-id="{{ item.idGarantie|default('') }}"
                                            data-credit-type="{{ item.typeCredit|default('Credit')|e('html_attr') }}"
                                            data-credit-amount="{{ item.montantDemande|default(0) }}"
                                        >
                                            #{{ item.idCredit }} - {{ item.typeCredit|default('Credit') }} - {{ item.montantDemande|default(0)|number_format(0, '.', ' ') }} DT
                                        </option>
                                    {% endfor %}
                                </select>
                            </label>

                            <label class="cr-assistant-target-field" for="cr-assistant-garantie-select">
                                <span id="cr-assistant-garantie-label">Garantie cible</span>
                                <select id="cr-assistant-garantie-select">
                                    <option value="" data-assistant-garantie-auto>Aucune garantie imposee</option>
                                    {% for garantie in garanties %}
                                        <option
                                            value="{{ garantie.idGarantie }}"
                                            data-garantie-option
                                            data-garantie-id="{{ garantie.idGarantie }}"
                                            data-garantie-credit-id="{{ garantie.idCredit|default('') }}"
                                            data-garantie-type="{{ garantie.typeGarantie|default('Garantie')|e('html_attr') }}"
                                            data-garantie-retained="{{ garantie.valeurRetenue|default(0) }}"
                                        >
                                            #{{ garantie.idGarantie }} - {{ garantie.typeGarantie|default('Garantie') }} - {{ garantie.valeurRetenue|default(0)|number_format(0, '.', ' ') }} DT
                                        </option>
                                    {% endfor %}
                                </select>
                            </label>
                        </div>

                        <div class="cr-assistant-context">
                            <div class="cr-assistant-context-item">
                                <span>Credits</span>
                                <strong>{{ items|length }}</strong>
                            </div>
                            <div class="cr-assistant-context-item">
                                <span>Garanties</span>
                                <strong>{{ garanties|length }}</strong>
                            </div>
                            <div class="cr-assistant-context-item">
                                <span>Risque moyen</span>
                                <strong>{{ average_risk }}/100</strong>
                            </div>
                        </div>
                    </aside>

                    <div class="cr-assistant-main">
                        <div class="cr-assistant-thread" id="cr-assistant-thread" aria-live="polite"></div>

                        <form class="cr-assistant-form" id="cr-assistant-form">
                            <label class="cr-assistant-input-wrap" for="cr-assistant-input">
                                <textarea id="cr-assistant-input" rows="3" placeholder="Exemple : simule un credit auto de 30 000 DT sur 48 mois."></textarea>
                            </label>
                            <div class="cr-assistant-form-row">
                                <span class="cr-assistant-status" id="cr-assistant-status" hidden></span>
                                <button type="submit" class="cr-assistant-send-btn" id="cr-assistant-send-btn">
                                    <i class="fa-solid fa-paper-plane"></i>
                                    <span id="cr-assistant-send-label">Envoyer</span>
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </section>
            
            <section class="cr-tool-panel" data-tool-panel="simulate">
                <style>
                    .sim-grid { display: grid; grid-template-columns: 1fr 2fr; gap: 1.5rem; }
                    .sim-card { background: var(--cr-bg-card, #fefefe); padding: 1.5rem; border-radius: 12px; border: 1px solid var(--cr-border, #eaeaea); }
                    .sim-val { font-size: 1.8rem; font-weight: 700; color: var(--cr-primary, #4f46e5); }
                    .sim-val.risk { color: var(--cr-error, #ef4444); }
                    @media (max-width: 768px) { .sim-grid { grid-template-columns: 1fr; } }
                    .proj-bar { width: 100%; border-radius: 4px 4px 0 0; position: relative; transition: height 0.3s ease; }
                    .proj-bar-wrap { flex: 1; display: flex; flex-direction: column; justify-content: flex-end; align-items: center; gap: 5px; height: 100%; }
                    .proj-bar span { font-size: 0.7rem; color: #666; text-align: center; }
                </style>
                <div class="sim-grid">
                    <div class="sim-card">
                        <h4 style="margin-bottom: 1rem; color: var(--cr-title);">Paramètres du crédit</h4>
                        <div style="margin-bottom: 1rem;">
                            <label style="display:block; font-size:0.85rem; margin-bottom:0.3rem;">Montant (DT)</label>
                            <input type="number" id="sim-montant" value="20000" style="width:100%; padding:0.6rem; border-radius:6px; border:1px solid #ccc; outline:none;">
                        </div>
                        <div style="margin-bottom: 1rem;">
                            <label style="display:block; font-size:0.85rem; margin-bottom:0.3rem;">Durée (Mois)</label>
                            <input type="number" id="sim-duree" value="36" style="width:100%; padding:0.6rem; border-radius:6px; border:1px solid #ccc; outline:none;">
                        </div>
                        <div style="margin-bottom: 1.5rem;">
                            <label style="display:block; font-size:0.85rem; margin-bottom:0.3rem;">Taux Annuel (%)</label>
                            <input type="number" step="0.1" id="sim-taux" value="8" style="width:100%; padding:0.6rem; border-radius:6px; border:1px solid #ccc; outline:none;">
                        </div>
                        <button id="sim-btn" style="width:100%; padding:0.8rem; border:none; border-radius:6px; background:var(--cr-primary, #4f46e5); color:#fff; font-weight:600; cursor:pointer;">Simuler Amortissement</button>
                    </div>
                    <div class="sim-card">
                        <div id="sim-result" hidden>
                            <div style="display:flex; justify-content: space-between; align-items:center; margin-bottom: 1.5rem; padding-bottom: 1rem; border-bottom: 1px solid #eaeaea;">
                                <div>
                                    <div style="font-size:0.85rem; color:#666;">Mensualité estimée</div>
                                    <div class="sim-val" id="sim-mensualite">0.00 <span style="font-size:1rem;">DT</span></div>
                                </div>
                                <div style="text-align:right;">
                                    <div style="font-size:0.85rem; color:#666;">Coût total du crédit</div>
                                    <div class="sim-val risk" id="sim-cout-total">0.00 <span style="font-size:1rem;">DT</span></div>
                                </div>
                            </div>
                            <h5 style="margin-bottom:0.5rem; color:var(--cr-title);">Tableau Prévisionnel</h5>
                            <div style="max-height: 250px; overflow-y: auto; border: 1px solid #eaeaea; border-radius: 8px;">
                                <table class="cr-tool-table" style="width:100%; text-align:right; border-collapse:collapse;">
                                    <thead style="position:sticky; top:0; background:#f9f9f9; z-index:1;">
                                        <tr>
                                            <th style="padding:0.5rem;">Mois</th>
                                            <th style="padding:0.5rem;">Part Intérêt</th>
                                            <th style="padding:0.5rem;">Part Capital</th>
                                            <th style="padding:0.5rem;">Capital Restant</th>
                                        </tr>
                                    </thead>
                                    <tbody id="sim-tbody"></tbody>
                                </table>
                            </div>
                        </div>
                        <div id="sim-placeholder" style="display:flex; align-items:center; justify-content:center; height:100%; color:#aaa; font-style:italic;">
                            Remplissez les critères pour lancer la simulation.
                        </div>
                    </div>
                </div>
            </section>

            <section class="cr-tool-panel" data-tool-panel="projection">
                 <div class="sim-grid">
                    <div class="sim-card">
                        <h4 style="margin-bottom: 1rem; color: var(--cr-title);">Modèle de Projection</h4>
                        <div style="margin-bottom: 1rem;">
                            <label style="display:block; font-size:0.85rem; margin-bottom:0.3rem;">Revenus mensuels (DT)</label>
                            <input type="number" id="proj-revenus" value="3000" style="width:100%; padding:0.6rem; border-radius:6px; border:1px solid #ccc; outline:none;">
                        </div>
                        <div style="margin-bottom: 1rem;">
                            <label style="display:block; font-size:0.85rem; margin-bottom:0.3rem;">Dépenses courantes (DT)</label>
                            <input type="number" id="proj-depenses" value="1200" style="width:100%; padding:0.6rem; border-radius:6px; border:1px solid #ccc; outline:none;">
                        </div>
                        <div style="margin-bottom: 1rem;">
                            <label style="display:block; font-size:0.85rem; margin-bottom:0.3rem;">Mensualité du crédit (DT)</label>
                            <input type="number" id="proj-mensualite" value="500" style="width:100%; padding:0.6rem; border-radius:6px; border:1px solid #ccc; outline:none;">
                        </div>
                        <div style="margin-bottom: 1.5rem;">
                            <label style="display:block; font-size:0.85rem; margin-bottom:0.3rem;">Inflation annuelle Prévue (%)</label>
                            <input type="number" step="0.1" id="proj-inflation" value="6.5" style="width:100%; padding:0.6rem; border-radius:6px; border:1px solid #ccc; outline:none;">
                        </div>
                        <button id="proj-btn" style="width:100%; padding:0.8rem; border:none; border-radius:6px; background:#10b981; color:#fff; font-weight:600; cursor:pointer;">Projeter sur 5 ans</button>
                    </div>
                    <div class="sim-card">
                        <div id="proj-result" hidden>
                             <h4 style="margin-bottom: 0.5rem; color: var(--cr-title);">Capacité Résiduelle Nette (5 Ans)</h4>
                             <p style="font-size:0.85rem; color:#666; margin-bottom:1rem;">Évaluation de votre reste-à-vivre face à l'inflation constante des dépenses.</p>
                             
                             <div id="proj-chart" style="display:flex; align-items:flex-end; gap:8px; height:200px; padding:1rem; border-radius:8px; background:#fafafa; border:1px solid #eaeaea;">
                                 <!-- Barres générées en JS -->
                             </div>
                             
                             <div id="proj-conclusion" style="margin-top: 1.5rem; padding: 1rem; border-radius: 8px; font-weight: 500; text-align:center;"></div>
                        </div>
                        <div id="proj-placeholder" style="display:flex; align-items:center; justify-content:center; height:100%; color:#aaa; font-style:italic;">
                            Définissez vos revenus/dépenses actuels pour projeter votre viabilité financière.
                        </div>
                    </div>
                 </div>
            </section>
        </div>
    </section>
    <div class="cr-restruct-overlay" id="cr-restruct-overlay" hidden></div>
    <section class="cr-restruct-modal" id="cr-restruct-modal" hidden role="dialog" aria-modal="true" aria-labelledby="cr-restruct-title">
        <header class="cr-restruct-header">
            <div>
                <h3 id="cr-restruct-title">Propositions de Restructuration</h3>
                <p id="cr-restruct-subtitle">Analyse intelligente des options pour alleger votre charge financiere.</p>
            </div>
            <button class="cr-restruct-close" id="cr-restruct-close" type="button" aria-label="Fermer">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </header>
        <div class="cr-restruct-body">
            <div class="cr-restruct-alert" id="cr-restruct-alert" hidden>
                <strong id="cr-restruct-alert-title">Difficultes financieres detectees</strong>
                <div class="cr-restruct-alert-grid">
                    <div class="cr-restruct-alert-item">
                        <span id="cr-restruct-debt-label">Taux d endettement</span>
                        <strong id="cr-restruct-debt-value">--</strong>
                    </div>
                    <div class="cr-restruct-alert-item">
                        <span id="cr-restruct-monthly-label">Mensualite actuelle</span>
                        <strong id="cr-restruct-monthly-value">--</strong>
                    </div>
                    <div class="cr-restruct-alert-item">
                        <span id="cr-restruct-type-label">Type de credit</span>
                        <strong id="cr-restruct-type-value">--</strong>
                    </div>
                </div>
            </div>

            <div class="cr-restruct-empty" id="cr-restruct-empty" hidden>
                <i class="fa-solid fa-circle-info"></i>
                <p id="cr-restruct-empty-text">Aucun credit ne necessite une restructuration pour le moment.</p>
            </div>

            <div class="cr-restruct-options" id="cr-restruct-options"></div>
            <div class="cr-restruct-apply-state" id="cr-restruct-apply-state" hidden></div>
        </div>
        <footer class="cr-restruct-footer">
            <p id="cr-restruct-info">Ces simulations sont indicatives et doivent etre confirmees avant toute modification contractuelle.</p>
            <button type="button" class="cr-restruct-dismiss" id="cr-restruct-dismiss">Fermer</button>
        </footer>
    </section>
    <div class="cr-pay-overlay" id="cr-pay-overlay" hidden></div>
    <section class="cr-pay-modal" id="cr-pay-modal" hidden role="dialog" aria-modal="true" aria-labelledby="cr-pay-title">
        <header class="cr-pay-header">
            <div>
                <h3 id="cr-pay-title">Payer une mensualite</h3>
                <p id="cr-pay-subtitle">Reglez la mensualite Stripe du credit selectionne.</p>
            </div>
            <button class="cr-pay-close" id="cr-pay-close" type="button" aria-label="Fermer">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </header>
        <div class="cr-pay-body">
            <div class="cr-pay-summary">
                <div class="cr-pay-summary-main">
                    <strong id="cr-pay-credit-label">Credit</strong>
                    <span id="cr-pay-credit-status" class="cr-pay-status-chip">En attente</span>
                </div>
                <div class="cr-pay-summary-grid">
                    <div class="cr-pay-summary-item">
                        <span class="cr-pay-summary-key" id="cr-pay-amount-label">Montant</span>
                        <strong id="cr-pay-amount">0.00 DT</strong>
                    </div>
                    <div class="cr-pay-summary-item">
                        <span class="cr-pay-summary-key" id="cr-pay-monthly-label">Mensualite</span>
                        <strong id="cr-pay-monthly">0.00 DT</strong>
                    </div>
                </div>
            </div>

            <div class="cr-pay-otp-row">
                <span class="cr-pay-otp-state{{ payment_otp_verified ? ' is-verified' : '' }}" id="cr-pay-otp-state">
                    {{ payment_otp_verified ? 'Etape 3 disponible' : (payment_otp_sent ? 'Etape 2 disponible' : 'Commencez par envoyer OTP') }}
                </span>
            </div>

            <div class="cr-pay-steps">
                <div class="cr-pay-step-item{{ payment_current_step == 1 ? ' is-active' : '' }}{{ payment_current_step > 1 ? ' is-done' : '' }}" data-pay-step-indicator="1">
                    <div class="cr-pay-step-dot">1</div>
                    <span id="cr-pay-step-label-1">Envoyer OTP</span>
                </div>
                <div class="cr-pay-step-line"></div>
                <div class="cr-pay-step-item{{ payment_current_step == 2 ? ' is-active' : '' }}{{ payment_current_step > 2 ? ' is-done' : '' }}" data-pay-step-indicator="2">
                    <div class="cr-pay-step-dot">2</div>
                    <span id="cr-pay-step-label-2">Verifier OTP</span>
                </div>
                <div class="cr-pay-step-line"></div>
                <div class="cr-pay-step-item{{ payment_current_step == 3 ? ' is-active' : '' }}" data-pay-step-indicator="3">
                    <div class="cr-pay-step-dot">3</div>
                    <span id="cr-pay-step-label-3">Stripe</span>
                </div>
            </div>

            <div class="cr-pay-step-body" data-pay-step-body="1" {{ payment_current_step != 1 ? 'hidden' : '' }}>
                <form method="post" class="cr-pay-card" data-pay-step="send">
                    <input type="hidden" name="tab" value="credits">
                    <input type="hidden" name="action" value="send_payment_otp">
                    <input type="hidden" name="payment_credit" id="cr-pay-send-credit" value="">

                    <div class="cr-pay-card-head">
                        <h4 id="cr-pay-send-title">1. Envoyer OTP</h4>
                        <p id="cr-pay-send-subtitle">Recevez un code de verification avant le paiement.</p>
                    </div>

                    <label class="cr-pay-field">
                        <span id="cr-pay-phone-label">Telephone</span>
                        <input type="text" name="telephone" id="cr-pay-phone" value="{{ payment_phone }}" required>
                    </label>

                    <label class="cr-pay-field">
                        <span id="cr-pay-channel-label">Canal OTP</span>
                        <select name="otp_channel" id="cr-pay-channel">
                            <option value="sms" {{ payment_channel == 'sms' ? 'selected' : '' }}>SMS</option>
                            <option value="whatsapp" {{ payment_channel == 'whatsapp' ? 'selected' : '' }}>WhatsApp</option>
                        </select>
                    </label>

                    <button class="cr-pay-secondary-btn" id="cr-pay-send-btn" type="submit">
                        <i class="fa-solid fa-paper-plane"></i>
                        <span>Envoyer OTP</span>
                    </button>
                </form>
            </div>

            <div class="cr-pay-step-body" data-pay-step-body="2" {{ payment_current_step != 2 ? 'hidden' : '' }}>
                <form method="post" class="cr-pay-card" data-pay-step="verify">
                    <input type="hidden" name="tab" value="credits">
                    <input type="hidden" name="action" value="verify_payment_otp">
                    <input type="hidden" name="payment_credit" id="cr-pay-verify-credit" value="">

                    <div class="cr-pay-card-head">
                        <h4 id="cr-pay-verify-title">2. Verifier OTP</h4>
                        <p id="cr-pay-verify-subtitle">Confirmez le code recu pour debloquer Stripe.</p>
                    </div>

                    <label class="cr-pay-field">
                        <span id="cr-pay-verify-phone-label">Telephone</span>
                        <input type="text" name="telephone" id="cr-pay-verify-phone" value="{{ payment_phone }}" required>
                    </label>

                    <label class="cr-pay-field">
                        <span id="cr-pay-otp-label">Code OTP</span>
                        <input type="text" name="otp" id="cr-pay-otp-input" placeholder="123456" required>
                    </label>

                    <button class="cr-pay-secondary-btn" id="cr-pay-verify-btn" type="submit">
                        <i class="fa-solid fa-shield-check"></i>
                        <span>Verifier OTP</span>
                    </button>
                </form>
            </div>

            <div class="cr-pay-step-body" data-pay-step-body="3" {{ payment_current_step != 3 ? 'hidden' : '' }}>
            <form method="post" class="cr-pay-main-form" id="cr-pay-form" data-pay-step="stripe" action="{{ path('portal_credit_checkout_start') }}">
                <input type="hidden" name="payment_credit" id="cr-pay-payment-credit" value="">
                <input type="hidden" name="idCredit" id="cr-pay-credit-id" value="">
                <input type="hidden" name="amount" id="cr-pay-amount-input" value="">

                <div class="cr-pay-main-head">
                    <div>
                        <h4 id="cr-pay-main-title">3. Payer avec Stripe</h4>
                        <p id="cr-pay-main-subtitle">Le montant de la mensualite est pre-rempli pour ce credit.</p>
                    </div>
                    <span class="cr-pay-badge" id="cr-pay-main-badge">Mensualite Stripe</span>
                </div>

                <div class="cr-pay-main-grid">
                    <label class="cr-pay-field">
                        <span id="cr-pay-account-label">Compte a debiter</span>
                        <select name="idCompte" id="cr-pay-account" required>
                            {% for account in payment_accounts %}
                                <option value="{{ account.idCompte }}">
                                    {{ account.numeroCompte|default('Compte') }} | {{ account.solde|default(0)|number_format(2, '.', ' ') }} DT
                                </option>
                            {% endfor %}
                        </select>
                    </label>
                </div>

                <p class="cr-pay-note" id="cr-pay-note">
                    Montant Stripe: devise {{ payment_config.stripe_charge_currency|default('eur')|upper }}.
                    Taux applique: 1 TND = {{ payment_config.stripe_tnd_to_charge_rate|default(0.30) }} {{ payment_config.stripe_charge_currency|default('eur')|upper }}.
                    Vous serez redirige vers la page securisee Stripe pour saisir la carte.
                </p>

                <button class="cr-pay-primary-btn" id="cr-pay-submit-btn" type="submit" {{ payment_accounts is empty ? 'disabled' : '' }}>
                    <i class="fa-solid fa-credit-card"></i>
                    <span>Continuer vers Stripe</span>
                </button>
            </form>
            </div>
        </div>
    </section>
    <div class="cr-split">

        {# â”€â”€â”€ LEFT: FORM COLUMN â”€â”€â”€ #}
        <aside class="cr-form-col" id="cr-form-col">
            <div class="cr-form-card" id="garantie-form-card">
