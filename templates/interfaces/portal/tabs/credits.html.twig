}

.cr-cc-pdf-btn:hover {
  background: linear-gradient(120deg, #0f766e, #14b8a6);
  color: #fff;
  border-color: transparent;
}

.cr-cc-edit-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 42px;
  height: 42px;
  border-radius: 10px;
  background: linear-gradient(120deg, #e8f0fd, #dbeafe);
  color: #1565c0;
  font: inherit;
  font-size: 12px;
  font-weight: 700;
  border: 1px solid #c3d9f5;
  cursor: pointer;
  transition: all .15s;
}

.cr-cc-garanties-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 42px;
  height: 42px;
  border-radius: 10px;
  background: linear-gradient(120deg, #eff6ff, #dbeafe);
  color: #1d4ed8;
  font: inherit;
  font-size: 12px;
  font-weight: 700;
  border: 1px solid #bfdbfe;
  cursor: pointer;
  transition: all .15s;
}

.cr-cc-pay-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  min-width: 108px;
  height: 42px;
  padding: 0 16px;
  border-radius: 12px;
  background: linear-gradient(135deg, #12325d, #1565c0);
  color: #fff;
  font: inherit;
  font-size: 13px;
  font-weight: 800;
  border: none;
  cursor: pointer;
  transition: all .15s;
}

.cr-cc-pay-btn:hover {
  transform: translateY(-1px);
  box-shadow: 0 10px 20px rgba(21, 101, 192, .2);
}

.cr-cc-pay-label {
  line-height: 1;
}

.cr-cc-garanties-btn:hover {
  background: linear-gradient(120deg, #1d4ed8, #2563eb);
  color: #fff;
  border-color: transparent;
}

.cr-cc-pdf-btn i,
.cr-cc-garanties-btn i,
.cr-cc-edit-btn i,
.cr-cc-pay-btn i {
  font-size: 15px;
}

.cr-cc-edit-btn:hover {
  background: linear-gradient(120deg, #1565c0, #1e88e5);
  color: #fff;
  border-color: transparent;
}

.cr-cc-delete-form { display: flex; }

.cr-cc-delete-btn {
  width: 36px;
  height: 36px;
  border-radius: 10px;
  background: #fff0f0;
  border: 1px solid #fecaca;
  color: #dc2626;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  font-size: 13px;
  transition: all .15s;
}

.cr-cc-delete-btn:hover { background: #dc2626; color: #fff; }

/* √Ę‚ÄĚ‚ā¨√Ę‚ÄĚ‚ā¨ Empty state √Ę‚ÄĚ‚ā¨√Ę‚ÄĚ‚ā¨ */
.cr-empty-state {
