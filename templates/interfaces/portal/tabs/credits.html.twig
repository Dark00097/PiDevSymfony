    const analyzeGarantieDocumentFile = async (file) => {
      const fileName = String(file?.name || '').trim();
      const lowerName = fileName.toLowerCase();
      const allowedTypes = ['image/jpeg', 'image/png', 'application/pdf'];
      const suspiciousName = /(screen|screenshot|capture|captur|ecran|printscreen|snip|whatsapp)/i.test(lowerName)
        || /(\.\.|[<>:"|?*]|(php|phtml|phar|js|exe|sh|bat|cmd)\b)/i.test(lowerName);
      if (!allowedTypes.includes(String(file?.type || ''))) {
        return { ok: false, verdict: 'suspect', message: 'Type de fichier non autorise. Utilisez uniquement JPG, PNG ou PDF.' };
      }
      if (suspiciousName) {
        return { ok: false, verdict: 'suspect', message: 'Nom de fichier suspect (capture/screen). Utilisez un document officiel.' };
      }
      if (Number(file?.size || 0) < 25_000) {
        return { ok: false, verdict: 'suspect', message: 'Le fichier est trop petit (minimum 25 Ko).' };
      }
      if (Number(file?.size || 0) > 5_242_880) {
        return { ok: false, verdict: 'suspect', message: 'Le fichier depasse 5 Mo.' };
      }

      if (String(file?.type || '') === 'application/pdf') {
        return { ok: true, verdict: 'valide', message: 'PDF valide (format et taille conformes).', blurScore: 0, width: 0, height: 0 };
      }

      const image = await loadImageFromFile(file);
      const width = Number(image.naturalWidth || 0);
      const height = Number(image.naturalHeight || 0);
      if (width < 500 || height < 500) {
        return { ok: false, verdict: 'suspect', message: 'Resolution insuffisante: minimum 500x500 px.', width, height, blurScore: 0 };
      }
      const blurScore = computeImageSharpnessScore(image);
      if (blurScore < 45) {
        return { ok: false, verdict: 'flou', message: 'Image floue detectee. Fournissez une image nette.', width, height, blurScore };
      }
      return { ok: true, verdict: 'valide', message: `Document net valide (${width}x${height}, score ${blurScore}).`, width, height, blurScore };
    };
    const runGarantieDocumentAnalysis = async ({ showOkMessage = true } = {}) => {
      const file = garantieDocumentField instanceof HTMLInputElement ? garantieDocumentField.files?.[0] ?? null : null;
      const existingPath = garantieExistingDocumentField instanceof HTMLInputElement
        ? String(garantieExistingDocumentField.value || '').trim()
