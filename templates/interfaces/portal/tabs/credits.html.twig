  color: #fff;
  padding: 10px 14px;
  font-size: 13px;
  font-weight: 800;
  cursor: pointer;
}

.cr-assistant-projection-actions {
  display: flex;
  justify-content: flex-end;
}

.cr-assistant-projection-result {
  display: grid;
  gap: 10px;
}

.cr-assistant-projection-metrics {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 10px;
}

.cr-assistant-projection-metric {
  border: 1px solid #dce8f6;
  border-radius: 12px;
  background: #fff;
  padding: 10px 12px;
  display: grid;
  gap: 4px;
}

.cr-assistant-projection-metric span {
  font-size: 11px;
  font-weight: 800;
  color: #6d8aa3;
}

.cr-assistant-projection-metric strong {
  font-size: 14px;
  font-weight: 900;
  color: #0a2540;
}

.cr-assistant-projection-conclusion {
  border-radius: 12px;
  padding: 10px 12px;
  font-size: 13px;
  font-weight: 800;
  border: 1px solid #dce8f6;
  background: #eff6ff;
  color: #1d4ed8;
}

.cr-assistant-projection-conclusion.is-ameliore {
  background: #ecfdf3;
  border-color: #bbf7d0;
  color: #15803d;
}

.cr-assistant-projection-conclusion.is-stable {
  background: #eff6ff;
  border-color: #bfdbfe;
  color: #1d4ed8;
}

.cr-assistant-projection-conclusion.is-risque {
  background: #fff1f2;
  border-color: #fecdd3;
  color: #be123c;
}

.cr-assistant-projection-charts {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10px;
}

.cr-assistant-projection-chart-card {
  border: 1px solid #dce8f6;
  border-radius: 14px;
  background: #fff;
  padding: 10px;
}

.cr-assistant-projection-chart-card h5 {
  margin: 0 0 8px;
  font-size: 12px;
  font-weight: 900;
  color: #355774;
}

.cr-assistant-projection-chart-card svg {
  width: 100%;
  height: 180px;
  display: block;
  background: linear-gradient(180deg, #f8fbff, #ffffff);
  border-radius: 10px;
}

.cr-assistant-form {
  padding: 14px 18px 18px;
  border-top: 1px solid #e5eef8;
  background: #fff;
}

.cr-assistant-input-wrap textarea {
  width: 100%;
  min-height: 92px;
  resize: vertical;
  border: 1px solid #d8e6f7;
  border-radius: 14px;
  padding: 14px 15px;
  font-size: 14px;
  color: #0a2540;
  background: #f9fbfe;
  font-family: inherit;
  outline: none;
}

.cr-assistant-input-wrap textarea:focus {
  border-color: #1e88e5;
  box-shadow: 0 0 0 4px rgba(30, 136, 229, .12);
}

.cr-assistant-form-row {
  margin-top: 12px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}

.cr-assistant-status {
  font-size: 12px;
  font-weight: 800;
  color: #1565c0;
}

.cr-assistant-status.is-error {
  color: #dc2626;
}

.cr-assistant-send-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  border: none;
  border-radius: 12px;
  background: linear-gradient(120deg, #1565c0, #1e88e5);
  color: #fff;
  padding: 12px 16px;
  font-size: 13px;
  font-weight: 800;
  cursor: pointer;
}

.cr-assistant-send-btn:disabled {
  opacity: .65;
  cursor: wait;
}

@media (max-width: 980px) {
  .cr-assistant-shell {
    grid-template-columns: 1fr;
  }

  .cr-assistant-main {
    min-height: 460px;
  }
}

@media (max-width: 640px) {
  .cr-assistant-metrics {
    grid-template-columns: 1fr;
  }

  .cr-assistant-projection-grid,
  .cr-assistant-projection-metrics,
  .cr-assistant-projection-charts {
    grid-template-columns: 1fr;
  }

  .cr-assistant-offer-grid {
    grid-template-columns: 1fr;
  }

  .cr-assistant-summary-grid,
  .cr-assistant-market-grid {
    grid-template-columns: 1fr;
  }

  .cr-assistant-msg {
    max-width: 100%;
  }

  .cr-assistant-form-row {
    flex-direction: column;
    align-items: stretch;
  }

  .cr-assistant-send-btn {
    justify-content: center;
  }

  .cr-restruct-alert-grid,
  .cr-restruct-options,
  .cr-restruct-option-meta {
    grid-template-columns: 1fr;
  }

  .cr-restruct-footer {
    flex-direction: column;
    align-items: stretch;
  }
}

.cr-tool-grid-2 {
