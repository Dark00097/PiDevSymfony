}

.cr-assistant-compare-table th,
.cr-assistant-compare-table td {
  padding: 11px 12px;
  border-bottom: 1px solid #e8f0f8;
  text-align: left;
  font-size: 12px;
}

.cr-assistant-compare-table th {
  background: #f6faff;
  color: #5e7893;
