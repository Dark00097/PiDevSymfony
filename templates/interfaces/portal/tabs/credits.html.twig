}

.cr-assistant-ai-card p {
  margin: 10px 0 0;
  font-size: 13px;
  line-height: 1.7;
  color: #2f5571;
}

.cr-assistant-offers,
.cr-assistant-constraints {
  display: grid;
  gap: 10px;
  margin-top: 10px;
}

.cr-assistant-offer-card,
.cr-assistant-constraint-card {
  border: 1px solid #e0ebf7;
  border-radius: 14px;
  background: #fbfdff;
