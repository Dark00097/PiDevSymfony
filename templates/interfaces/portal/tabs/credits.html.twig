    const computeImageSharpnessScore = (imageElement) => {
      const width = Math.max(1, Number(imageElement.naturalWidth || imageElement.width || 0));
      const height = Math.max(1, Number(imageElement.naturalHeight || imageElement.height || 0));
      const maxSide = 720;
      const scale = Math.min(1, maxSide / Math.max(width, height));
      const canvas = document.createElement('canvas');
      canvas.width = Math.max(1, Math.round(width * scale));
      canvas.height = Math.max(1, Math.round(height * scale));
      const ctx = canvas.getContext('2d', { willReadFrequently: true });
      if (!ctx) {
        return 0;
      }
      ctx.drawImage(imageElement, 0, 0, canvas.width, canvas.height);
      const { data } = ctx.getImageData(0, 0, canvas.width, canvas.height);
      const gray = new Float32Array(canvas.width * canvas.height);
      for (let i = 0, p = 0; i < data.length; i += 4, p += 1) {
        gray[p] = (data[i] * 0.299) + (data[i + 1] * 0.587) + (data[i + 2] * 0.114);
      }

      let sum = 0;
      let sqSum = 0;
      let count = 0;
      for (let y = 1; y < canvas.height - 1; y += 1) {
        for (let x = 1; x < canvas.width - 1; x += 1) {
          const idx = (y * canvas.width) + x;
          const laplacian = (
            (-1 * gray[idx - canvas.width - 1]) + (-1 * gray[idx - canvas.width]) + (-1 * gray[idx - canvas.width + 1]) +
            (-1 * gray[idx - 1]) + (8 * gray[idx]) + (-1 * gray[idx + 1]) +
            (-1 * gray[idx + canvas.width - 1]) + (-1 * gray[idx + canvas.width]) + (-1 * gray[idx + canvas.width + 1])
          );
          sum += laplacian;
          sqSum += laplacian * laplacian;
          count += 1;
        }
      }
      if (count <= 0) {
        return 0;
      }
      const mean = sum / count;
      const variance = Math.max(0, (sqSum / count) - (mean * mean));
      return Math.round(variance * 100) / 100;
    };
    const loadImageFromFile = (file) => new Promise((resolve, reject) => {
