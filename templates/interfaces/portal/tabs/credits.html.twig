    const normalizeIsoDate = (rawValue) => {
      const raw = String(rawValue ?? '').trim();
      if (raw === '') return '';
      if (/^\d{4}-\d{2}-\d{2}$/.test(raw)) return raw;
      const parsed = new Date(raw);
      if (Number.isNaN(parsed.getTime())) return '';
      const y = parsed.getFullYear();
      const m = String(parsed.getMonth() + 1).padStart(2, '0');
      const d = String(parsed.getDate()).padStart(2, '0');
      return `${y}-${m}-${d}`;
    };

    const setGarantieField = (name, value) => {
      const field = garantieForm?.querySelector(`[name="${name}"]`);
      if (field instanceof HTMLInputElement || field instanceof HTMLSelectElement || field instanceof HTMLTextAreaElement) {
        field.value = value ?? '';
      }
    };
    const getGarantieField = (name) => garantieForm?.querySelector(`[name="${name}"]`);
    const getGarantieMessage = (name) => $(`#cr-garantie-err-${name}`, garantieForm);
    const syncGarantieDocumentMeta = (path = '', label = '') => {
      const resolvedPath = String(path ?? '').trim();
      if (garantieExistingDocumentField instanceof HTMLInputElement) {
        garantieExistingDocumentField.value = resolvedPath;
      }
      if (garantieDocumentLabel) {
        garantieDocumentLabel.textContent = label || (resolvedPath !== '' ? t('savedImage') : t('acceptedFormats'));
      }
      if (garantieDocumentLink instanceof HTMLAnchorElement) {
        if (resolvedPath !== '') {
          garantieDocumentLink.href = resolvedPath.startsWith('/') ? resolvedPath : `/${resolvedPath}`;
          garantieDocumentLink.hidden = false;
        } else {
          garantieDocumentLink.href = '#';
          garantieDocumentLink.hidden = true;
        }
      }
    };
    const waitLeafletReady = (callback) => {
      if (typeof window.L !== 'undefined') {
        callback();
        return;
      }
      let attempts = 0;
      const intervalId = window.setInterval(() => {
        if (typeof window.L !== 'undefined') {
          window.clearInterval(intervalId);
          callback();
          return;
        }
        attempts += 1;
        if (attempts > 40) {
          window.clearInterval(intervalId);
        }
      }, 150);
    };
    const parseCoordinateValue = (value) => {
      const normalized = String(value ?? '').replace(',', '.').trim();
      const number = Number.parseFloat(normalized);
      return Number.isFinite(number) ? number : null;
    };
    const invalidateGarantieMapSize = (delay = 0) => {
      window.setTimeout(() => {
        if (!garantieMapInstance) {
          return;
        }
        try {
          garantieMapInstance.invalidateSize({ pan: false });
        } catch (_error) {
        }
      }, delay);
    };
    const invalidateGarantieMapBurst = () => {
      invalidateGarantieMapSize(0);
      invalidateGarantieMapSize(120);
      invalidateGarantieMapSize(320);
    };
    const ensureGarantieMap = () => {
      if (!(garantieMapFrame instanceof HTMLElement) || typeof window.L === 'undefined') {
        return false;
      }
      if (garantieMapInstance) {
        return true;
      }

      garantieMapInstance = window.L.map(garantieMapFrame, {
        scrollWheelZoom: true,
        preferCanvas: true,
        zoomControl: true,
      }).setView([garantieDefaultMapCenter.lat, garantieDefaultMapCenter.lng], garantieDefaultMapCenter.zoom);

      window.L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        maxZoom: 19,
        keepBuffer: 4,
        updateWhenIdle: true,
        attribution: '&copy; OpenStreetMap',
      }).addTo(garantieMapInstance);

      garantieMapInstance.on('click', (event) => {
        applyGarantieMapSelection(event.latlng.lat, event.latlng.lng);
      });

      window.addEventListener('resize', () => {
        window.clearTimeout(garantieMapResizeTimer);
        garantieMapResizeTimer = window.setTimeout(() => {
          invalidateGarantieMapBurst();
        }, 90);
      });

      invalidateGarantieMapBurst();
      return true;
    };
    const updateGarantieMapFrame = (latValue, lngValue) => {
      if (!ensureGarantieMap()) {
        return;
      }
      const latitude = parseCoordinateValue(latValue);
      const longitude = parseCoordinateValue(lngValue);
      if (latitude === null || longitude === null) {
        if (garantieMapMarker) {
          garantieMapInstance.removeLayer(garantieMapMarker);
          garantieMapMarker = null;
        }
        garantieMapInstance.setView([garantieDefaultMapCenter.lat, garantieDefaultMapCenter.lng], garantieDefaultMapCenter.zoom);
        invalidateGarantieMapBurst();
        return;
      }

      const latLng = [latitude, longitude];
      if (!garantieMapMarker) {
        garantieMapMarker = window.L.marker(latLng, { draggable: true }).addTo(garantieMapInstance);
        garantieMapMarker.on('dragend', () => {
          const position = garantieMapMarker.getLatLng();
          applyGarantieMapSelection(position.lat, position.lng);
        });
      } else {
        garantieMapMarker.setLatLng(latLng);
      }

      garantieMapInstance.setView(latLng, 15);
      invalidateGarantieMapBurst();
    };
    const setGarantieAddressStatus = (status) => {
      const resolvedStatus = String(status ?? '').trim() || 'A verifier';
      if (garantieAddressStatusField instanceof HTMLInputElement) {
        garantieAddressStatusField.value = resolvedStatus;
      }
      if (garantieAddressStatusLabel instanceof HTMLInputElement) {
        garantieAddressStatusLabel.value = resolvedStatus;
      }
    };
    const hideGarantieSuggestions = () => {
      if (!(garantieAddressSuggestions instanceof HTMLElement)) {
        return;
      }
      garantieAddressSuggestions.hidden = true;
      garantieAddressSuggestions.innerHTML = '';
    };
    const fillGarantieAddressDetails = (item, { overwriteAddress = false } = {}) => {
      const address = item?.address ?? {};
      const latitude = Number(item?.lat ?? '');
      const longitude = Number(item?.lon ?? '');
      const city = address.city || address.town || address.village || address.county || address.state || '';
      const postalCode = address.postcode || '';
      const country = address.country || '';
      const displayName = String(item?.display_name ?? '').trim();

      if (garantieAddressCompleteField instanceof HTMLInputElement) {
        garantieAddressCompleteField.value = displayName;
      }
      if (garantieAddressField instanceof HTMLInputElement && (overwriteAddress || garantieAddressField.value.trim() === '')) {
        garantieAddressField.value = displayName;
      }
      if (garantieCityField instanceof HTMLInputElement) {
        garantieCityField.value = city;
      }
      if (garantiePostalField instanceof HTMLInputElement) {
        garantiePostalField.value = postalCode;
      }
      if (garantieCountryField instanceof HTMLInputElement) {
        garantieCountryField.value = country;
      }
      if (garantieLatitudeField instanceof HTMLInputElement) {
        garantieLatitudeField.value = Number.isFinite(latitude) ? String(latitude) : '';
      }
      if (garantieLongitudeField instanceof HTMLInputElement) {
        garantieLongitudeField.value = Number.isFinite(longitude) ? String(longitude) : '';
      }
      setGarantieAddressStatus(displayName !== '' && Number.isFinite(latitude) && Number.isFinite(longitude) ? 'Verifiee' : 'A verifier');
      updateGarantieMapFrame(latitude, longitude);
      hideGarantieSuggestions();
      validateGarantieField('adresseBien');
      validateGarantieField('adresseComplete');
    };
    const reverseGarantieCoordinates = async (lat, lng) => {
      const response = await fetch(`https://nominatim.openstreetmap.org/reverse?format=jsonv2&addressdetails=1&zoom=18&lat=${encodeURIComponent(String(lat))}&lon=${encodeURIComponent(String(lng))}`, {
        headers: {
          'Accept': 'application/json',
          'Accept-Language': 'fr',
        },
      });
      if (!response.ok) {
        throw new Error('Reverse geocoding indisponible.');
      }
      return response.json();
    };
    const applyGarantieMapSelection = async (lat, lng) => {
      const normalizedLat = Number(lat);
      const normalizedLng = Number(lng);
      if (!Number.isFinite(normalizedLat) || !Number.isFinite(normalizedLng)) {
        return;
      }

      const latValue = normalizedLat.toFixed(6);
      const lngValue = normalizedLng.toFixed(6);
      if (garantieLatitudeField instanceof HTMLInputElement) {
        garantieLatitudeField.value = latValue;
      }
      if (garantieLongitudeField instanceof HTMLInputElement) {
        garantieLongitudeField.value = lngValue;
      }
      setGarantieAddressStatus('Verification...');
      updateGarantieMapFrame(latValue, lngValue);
      hideGarantieSuggestions();

      const lookupToken = ++garantieReverseLookupToken;
      try {
        const place = await reverseGarantieCoordinates(latValue, lngValue);
        if (lookupToken !== garantieReverseLookupToken) {
          return;
        }
        fillGarantieAddressDetails(place, { overwriteAddress: true });
      } catch (_error) {
        if (lookupToken !== garantieReverseLookupToken) {
          return;
        }
        const fallbackAddress = `Point choisi sur la carte (${latValue}, ${lngValue})`;
        if (garantieAddressCompleteField instanceof HTMLInputElement) {
          garantieAddressCompleteField.value = fallbackAddress;
        }
        if (garantieAddressField instanceof HTMLInputElement && garantieAddressField.value.trim() === '') {
          garantieAddressField.value = fallbackAddress;
        }
        setGarantieAddressStatus('Verifiee');
        validateGarantieField('adresseBien');
        validateGarantieField('adresseComplete');
      }
    };
    const clearGarantieAddressDetails = () => {
      if (garantieCityField instanceof HTMLInputElement) {
        garantieCityField.value = '';
      }
      if (garantiePostalField instanceof HTMLInputElement) {
        garantiePostalField.value = '';
      }
      if (garantieCountryField instanceof HTMLInputElement) {
        garantieCountryField.value = '';
      }
      if (garantieLatitudeField instanceof HTMLInputElement) {
        garantieLatitudeField.value = '';
      }
      if (garantieLongitudeField instanceof HTMLInputElement) {
        garantieLongitudeField.value = '';
      }
      setGarantieAddressStatus('A verifier');
      updateGarantieMapFrame('', '');
    };
    const renderGarantieSuggestions = (items) => {
      if (!(garantieAddressSuggestions instanceof HTMLElement)) {
        return;
      }
      garantieAddressSuggestions.innerHTML = '';
      if (!Array.isArray(items) || items.length === 0) {
        garantieAddressSuggestions.hidden = true;
        return;
      }

      items.forEach((item) => {
        const option = document.createElement('button');
        option.type = 'button';
        option.className = 'cr-ai-generate-btn';
        option.style.justifyContent = 'flex-start';
        option.style.textAlign = 'left';
        option.textContent = String(item.display_name ?? '').trim();
        option.addEventListener('click', () => fillGarantieAddressDetails(item));
        garantieAddressSuggestions.appendChild(option);
      });
      garantieAddressSuggestions.hidden = false;
    };
    const searchGarantieAddresses = async (query) => {
      const response = await fetch(`https://nominatim.openstreetmap.org/search?format=jsonv2&addressdetails=1&limit=5&q=${encodeURIComponent(query)}`, {
        headers: {
          'Accept': 'application/json',
          'Accept-Language': 'fr',
        },
      });
      if (!response.ok) {
        throw new Error('Recherche OpenStreetMap indisponible.');
      }
      return response.json();
    };
    const setGarantieAiStatus = (message = '', tone = '', visible = false) => {
      if (!(garantieAiStatus instanceof HTMLElement)) {
        return;
      }

      garantieAiStatus.hidden = !visible || message.trim() === '';
      garantieAiStatus.textContent = message;
      garantieAiStatus.classList.remove('is-ok', 'is-warn', 'is-risk');
      if (tone !== '') {
        garantieAiStatus.classList.add(tone);
      }
    };

    const normalizeGarantieTypeKey = (value) => String(value ?? '')
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '')
      .toLowerCase()
      .trim();
    const getGarantieRetentionRate = () => {
      const retentionRates = {
        'hypotheque immobiliere': 0.8,
        'titre vehicule': 0.7,
        'caution personnelle': 0.5,
        'garantie bancaire': 1,
        'police assurance': 0.6,
        'nantissement': 0.75,
        'autre garantie': 0.5,
      };

      return retentionRates[normalizeGarantieTypeKey(getGarantieField('typeGarantie')?.value ?? '')] ?? 0.8;
    };
    const syncGarantieRetainedHint = () => {
      if (!(garantieRetainedHint instanceof HTMLElement)) {
        return;
      }

      const typeLabel = String(getGarantieField('typeGarantie')?.value ?? '').trim();
      const ratePercent = Math.round(getGarantieRetentionRate() * 100);
      garantieRetainedHint.textContent = typeLabel !== ''
        ? `Calcul auto: ${ratePercent}% pour ${typeLabel}`
        : 'Calcul auto selon le type de garantie';
    };
    const getExpectedGarantieRetained = () => {
      if (!(garantieEstimatedField instanceof HTMLInputElement)) {
        return 0;
      }

      const estimated = parseNum(garantieEstimatedField.value);
      return estimated > 0 ? Number((estimated * getGarantieRetentionRate()).toFixed(2)) : 0;
    };

    const syncRetainedFromEstimated = () => {
      if (!(garantieEstimatedField instanceof HTMLInputElement) || !(garantieRetainedField instanceof HTMLInputElement)) {
        return;
      }

      const retained = getExpectedGarantieRetained();
      garantieRetainedField.dataset.manual = '0';
      garantieRetainedField.value = formatDecimalDisplay(retained);
      syncGarantieRetainedHint();
    };

    const isGarantieEditMode = () => {
      if (!(garantieIdField instanceof HTMLInputElement)) {
        return false;
      }
      return garantieIdField.value.trim() !== '' && Number(garantieIdField.value) > 0;
    };

    const validateGarantieField = (name) => {
      const field = getGarantieField(name);
      const messageEl = getGarantieMessage(name);
      const rawValue = field?.value ?? '';
      const value = String(rawValue).trim();

      if (!field && name !== 'documentJustificatif') {
        return true;
      }

      switch (name) {
        case 'typeGarantie':
          return value === ''
            ? setFieldError(field, messageEl, 'Veuillez selectionner un type de garantie.')
            : setFieldOk(field, messageEl);
        case 'valeurEstimee': {
          const estimated = parseNum(value);
          if (value === '') {
            return setFieldError(field, messageEl, 'La valeur estimee est obligatoire.');
          }
          if (estimated <= 0) {
            return setFieldError(field, messageEl, 'La valeur estimee doit etre positive.');
          }
          if (estimated < 1000 || estimated > 100000000) {
            return setFieldError(field, messageEl, 'La valeur estimee doit etre comprise entre 1000 et 100000000 DT.');
          }
          return setFieldOk(field, messageEl);
        }
        case 'valeurRetenue': {
          const retained = parseNum(value);
          const estimated = parseNum(garantieEstimatedField?.value);
          if (value === '') {
            return setFieldError(field, messageEl, 'La valeur retenue est obligatoire.');
          }
          if (retained <= 0) {
            return setFieldError(field, messageEl, 'La valeur retenue doit etre positive.');
          }
          if (estimated > 0 && retained > estimated) {
            return setFieldError(field, messageEl, "La valeur retenue ne doit pas depasser l'estimee.");
          }
          return setFieldOk(field, messageEl);
        }
        case 'dateEvaluation': {
          const parsedDate = parseInputDate(value);
          if (value === '') {
            return setFieldError(field, messageEl, "La date d'evaluation est obligatoire.");
          }
          if (!parsedDate) {
            return setFieldError(field, messageEl, "Date d'evaluation invalide.");
          }
          if (!isGarantieEditMode() && parsedDate < todayDate) {
            return setFieldError(field, messageEl, "La date d'évaluation ne peut pas être dans le passé.");
          }
          return setFieldOk(field, messageEl);
        }
        case 'nomGarant':
          if (value === '') {
            return setFieldError(field, messageEl, 'Le nom du garant est obligatoire.');
          }
          if (value.length < 2) {
            return setFieldError(field, messageEl, 'Le nom doit contenir au moins 2 caracteres.');
          }
          if (!/^[\p{L}\s\-']+$/u.test(value)) {
            return setFieldError(field, messageEl, 'Le nom du garant ne doit contenir que des lettres.');
          }
          return setFieldOk(field, messageEl);
        case 'adresseBien':
          if (value === '') {
            return setFieldError(field, messageEl, "L'adresse du bien est obligatoire.");
          }
          if (value.length < 5) {
            return setFieldError(field, messageEl, "L'adresse doit contenir au moins 5 caracteres.");
          }
          return setFieldOk(field, messageEl);
        case 'adresseComplete':
          if (value === '') {
            return clearFieldValidation(field, messageEl);
          }
          if (value.length < 5) {
            return setFieldError(field, messageEl, "L'adresse complete est trop courte.");
          }
          return setFieldOk(field, messageEl);
        case 'documentJustificatif': {
          const file = garantieDocumentField instanceof HTMLInputElement ? garantieDocumentField.files?.[0] ?? null : null;
          const existingPath = garantieExistingDocumentField instanceof HTMLInputElement ? garantieExistingDocumentField.value.trim() : '';
          const allowedTypes = ['image/jpeg', 'image/png', 'image/webp', 'image/gif'];

          if (file) {
            if (!allowedTypes.includes(file.type)) {
              return setFieldError(garantieDocumentField, messageEl, 'Le document justificatif doit etre une image JPG, PNG, WEBP ou GIF.');
            }
            return setFieldOk(garantieDocumentField, messageEl);
          }
          if (existingPath === '') {
            return setFieldError(garantieDocumentField, messageEl, 'Le document justificatif est obligatoire.');
          }
          return setFieldOk(garantieDocumentField, messageEl);
        }
        case 'description':
          if (value === '') {
            return setFieldError(field, messageEl, 'La description est obligatoire.');
          }
          if (value.length < 10) {
            return setFieldError(field, messageEl, 'La description doit contenir au moins 10 caracteres.');
          }
          return setFieldOk(field, messageEl);
        default:
          return true;
      }
    };
    const validateGarantieFormValues = () => garantieFieldNames.map((name) => validateGarantieField(name)).every((res) => res);

    const resetGarantieFormState = (withFormReset = true) => {
