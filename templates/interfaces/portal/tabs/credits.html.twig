      if (assistantSideTitle) assistantSideTitle.textContent = t('assistantSideTitle');
      if (assistantSideSubtitle) assistantSideSubtitle.textContent = t('assistantSideSubtitle');
      if (assistantCreditLabel) assistantCreditLabel.textContent = t('assistantTargetCredit');
      if (assistantGarantieLabel) assistantGarantieLabel.textContent = t('assistantTargetGuarantee');
      refreshAssistantTargetOptions();
      if (assistantInput) assistantInput.placeholder = t('assistantPlaceholder');
      if (assistantSendLabel) assistantSendLabel.textContent = t('assistantSend');
      if (assistantQuickSimulate) assistantQuickSimulate.textContent = t('assistantSimulate');
      if (assistantQuickScore) assistantQuickScore.textContent = t('assistantScore');
      if (assistantQuickGaranties) assistantQuickGaranties.textContent = t('assistantGuarantees');
      if (assistantQuickDecision) assistantQuickDecision.textContent = t('assistantDecision');
      if (assistantQuickRecommend) assistantQuickRecommend.textContent = t('assistantRecommend');
      $$('[data-credit-row]').forEach((row) => {
        syncCreditRestructState(row);
      });
      if (restructTitle) restructTitle.textContent = t('restructurationTitle');
      if (restructSubtitle) restructSubtitle.textContent = t('restructurationSubtitle');
      if (restructAlertTitle) restructAlertTitle.textContent = t('restructurationAlertTitle');
      if (restructDebtLabel) restructDebtLabel.textContent = t('restructurationDebtRatio');
      if (restructMonthlyLabel) restructMonthlyLabel.textContent = t('restructurationCurrentMonthly');
      if (restructTypeLabel) restructTypeLabel.textContent = t('restructurationCreditType');
      if (restructEmptyText) restructEmptyText.textContent = t('restructurationEmpty');
      if (restructInfo) restructInfo.textContent = t('restructurationInfo');
      if (restructDismiss) restructDismiss.textContent = t('restructurationClose');

      if (sortSelect instanceof HTMLSelectElement) {
        const sortLabels = {
          id_desc: t('sortRecent'),
          id_asc: t('sortOldest'),
          amount_high: t('sortAmountHigh'),
          amount_medium: t('sortAmountMedium'),
          amount_low: t('sortAmountLow'),
          risk_desc: t('sortRiskHigh')
        };
        Array.from(sortSelect.options).forEach((option) => {
          option.textContent = sortLabels[option.value] ?? option.textContent;
        });
      }

      if (payTitle) payTitle.textContent = t('payTitle');
      if (paySubtitle) paySubtitle.textContent = t('paySubtitle');
      if (payAmountLabel) payAmountLabel.textContent = t('amount');
      if (payMonthlyLabel) payMonthlyLabel.textContent = t('monthlyPayment');
      if (paySendTitle) paySendTitle.textContent = `1. ${t('sendOtp')}`;
      if (paySendSubtitle) paySendSubtitle.textContent = t('sendOtpSubtitle');
      if (paySendPhoneLabel) paySendPhoneLabel.textContent = t('paymentPhone');
      if (payChannelLabel) payChannelLabel.textContent = t('otpChannel');
      if (payStepLabel1) payStepLabel1.textContent = t('sendOtp');
      setButtonText(paySendBtn, t('sendOtp'));
      if (payVerifyTitle) payVerifyTitle.textContent = `2. ${t('verifyOtp')}`;
      if (payVerifySubtitle) payVerifySubtitle.textContent = t('verifyOtpSubtitle');
      if (payVerifyPhoneLabel) payVerifyPhoneLabel.textContent = t('paymentPhone');
      if (payOtpLabel) payOtpLabel.textContent = t('otpCode');
      if (payStepLabel2) payStepLabel2.textContent = t('verifyOtp');
      setButtonText(payVerifyBtn, t('verifyOtp'));
      if (payMainTitle) payMainTitle.textContent = `3. ${t('payWithStripe')}`;
      if (payMainSubtitle) payMainSubtitle.textContent = t('payWithStripeSubtitle');
      if (payMainBadge) payMainBadge.textContent = t('stripeBadge');
      if (payAccountLabel) payAccountLabel.textContent = t('paymentAccount');
      if (payNote) payNote.textContent = t('stripeMethodHint');
      if (payStepLabel3) payStepLabel3.textContent = 'Stripe';
      setButtonText(paySubmitBtn, t('payNow'));
      syncPaymentStepsUI();
      syncPaymentOtpState();
      syncPaymentSubmitState();

      setFilterButtonText(filterAllBtn, t('filterAll'));
      setFilterButtonText(filterPendingBtn, t('filterPending'));
      setFilterButtonText(filterInProgressBtn, t('filterInProgress'));
      setFilterButtonText(filterAcceptedBtn, t('filterAccepted'));
      setFilterButtonText(filterRefusedBtn, t('filterRefused'));

      $$('[data-credit-row]').forEach((row) => {
        const pdfBtn = row.querySelector('.cr-cc-pdf-btn');
        const statusEl = row.querySelector('.cr-cc-status');
        const monthlyLabel = row.querySelector('.cr-cc-monthly-label');
        const riskLabel = row.querySelector('.cr-cc-risk-label');
        const garantiesBtn = row.querySelector('.cr-cc-garanties-btn');
        const editBtn = row.querySelector('.cr-cc-edit-btn');
        const payBtn = row.querySelector('.cr-cc-pay-btn');

        if (statusEl) {
          statusEl.dataset.baseStatus = row.dataset.creditStatus || statusEl.dataset.baseStatus || statusEl.textContent.trim();
          const icon = statusEl.querySelector('i');
          const translated = translateStatusLabel(statusEl.dataset.baseStatus);
          statusEl.textContent = '';
          if (icon) {
            statusEl.appendChild(icon);
            statusEl.appendChild(document.createTextNode(` ${translated}`));
          } else {
            statusEl.textContent = translated;
          }
        }
        if (monthlyLabel) monthlyLabel.textContent = t('monthlyPayment');
        if (riskLabel) riskLabel.textContent = t('riskScore');
        setIconOnlyActionLabel(pdfBtn, t('exportPdf'));
        setIconOnlyActionLabel(garantiesBtn, t('guarantees'));
        setIconOnlyActionLabel(editBtn, t('edit'));
        setButtonText(payBtn, t('pay'));
        syncCreditRestructState(row);
      });

      $$('[data-main-garantie-row]').forEach((row) => {
        const statusEl = row.querySelector('.cr-cc-status');
        const monthlyLabel = row.querySelector('.cr-cc-monthly-label');
        const riskLabel = row.querySelector('.cr-cc-risk-label');
        const linkMeta = row.querySelector('.cr-cc-meta .cr-cc-meta-item:first-child span');
        const editBtn = row.querySelector('.cr-garantie-edit-btn');

        if (statusEl) {
          statusEl.dataset.baseStatus = row.dataset.garantieStatus || statusEl.dataset.baseStatus || statusEl.textContent.trim();
          const icon = statusEl.querySelector('i');
          const translated = translateStatusLabel(statusEl.dataset.baseStatus);
          statusEl.textContent = '';
          if (icon) {
            statusEl.appendChild(icon);
            statusEl.appendChild(document.createTextNode(` ${translated}`));
          } else {
            statusEl.textContent = translated;
          }
        }
        if (monthlyLabel) monthlyLabel.textContent = t('retainedValue');
        if (riskLabel) riskLabel.textContent = t('retainedCoverage');
        if (linkMeta) {
          const linkedId = String(row.dataset.garantieCreditId ?? '').trim();
          linkMeta.textContent = linkedId !== '' ? t('linkedCredit')(linkedId) : t('notLinked');
        }
        if (editBtn instanceof HTMLButtonElement) {
          editBtn.title = t('edit');
        }
      });

      const garantieEmpty = $('#cr-garanties-view .cr-garanties-empty span');
      if (garantieEmpty) garantieEmpty.textContent = t('noGuarantee');

      const footerStats = $$('.cr-table-footer .cr-tf-stat span');
      if (footerStats[0]) footerStats[0].innerHTML = `${t('total')}: <strong>${footerStats[0].querySelector('strong')?.textContent ?? '0'}</strong>`;
      if (footerStats[1]) footerStats[1].innerHTML = `${t('filterPending')}: <strong>${footerStats[1].querySelector('strong')?.textContent ?? '0'}</strong>`;
      if (footerStats[2]) footerStats[2].innerHTML = `${t('filterAccepted')}: <strong>${footerStats[2].querySelector('strong')?.textContent ?? '0'}</strong>`;
      if (footerStats[3]) footerStats[3].innerHTML = `${t('averageRiskCompact')}: <strong>${footerStats[3].querySelector('strong')?.textContent ?? '0'}</strong>`;
      if (footerStats[4]) footerStats[4].innerHTML = `${t('totalGuarantees')}: <strong>${footerStats[4].querySelector('strong')?.textContent ?? '0'}</strong>`;

      tableRefreshLinks.forEach((link) => {
        link.innerHTML = `<i class="fa-solid fa-rotate"></i> ${t('refresh')}`;
      });

      if (emptyTitle) emptyTitle.textContent = t('noCredit');
      if (emptySubtitle) emptySubtitle.textContent = t('noCreditSubtitle');
      setButtonText(emptyCta, t('newCredit'));

      if (garantieDocumentLink) {
        garantieDocumentLink.textContent = t('viewImage');
      }

      const garantieDocumentLabelText = garantieExistingDocumentField instanceof HTMLInputElement && garantieExistingDocumentField.value.trim() !== ''
        ? t('savedImage')
        : t('acceptedFormats');
      if (garantieDocumentLabel) {
        garantieDocumentLabel.textContent = garantieDocumentLabelText;
      }

      if (activePaymentCard) {
        fillPaymentModal(activePaymentCard);
      }

      updateListingUI();
      if (toolsTitle && toolsModal && !toolsModal.hidden) {
        const activePanel = toolsModal.dataset.activePanel || 'history';
        toolsTitle.textContent = (getToolMeta()[activePanel] ?? getToolMeta().history).title;
      }
      if (toolsSubtitle && toolsModal && !toolsModal.hidden) {
        const activePanel = toolsModal.dataset.activePanel || 'history';
        toolsSubtitle.textContent = (getToolMeta()[activePanel] ?? getToolMeta().history).subtitle;
      }
    };
    const syncLanguageSelect = () => {
      if (!langSel) {
        return;
      }

      const selectedLabel = langSel.options[langSel.selectedIndex]?.textContent?.trim() || langSel.value;
      if (langValue) {
        langValue.textContent = selectedLabel;
      }
      langSel.title = `${t('chooseLanguage')}: ${selectedLabel}`;
      document.documentElement.lang = langSel.value;
    };
    if (langSel && savedLanguage && Array.from(langSel.options).some((option) => option.value === savedLanguage)) {
      langSel.value = savedLanguage;
    }
    applyCreditsInterfaceLanguage(langSel?.value || savedLanguage || 'fr');
    syncLanguageSelect();
    langSel?.addEventListener('change', () => {
      applyCreditsInterfaceLanguage(langSel.value);
      syncLanguageSelect();
      window.localStorage.setItem('nexora.portal.credits.language', langSel.value);
      window.dispatchEvent(new CustomEvent('nexora:portal-language-change', {
        detail: { language: langSel.value }
      }));
    });
  });
})();
</script>


