                        </p>

                        <div class="cr-field-group">
                            <div class="cr-field">
                                <label class="cr-field-label">
                                    <i class="fa-solid fa-hashtag"></i> ID (modification)
                                </label>
                                <input class="cr-input{{ garantie_errors.idGarantie is defined ? ' cr-input--error' : '' }}" type="number" name="idGarantie" id="cr-garantie-id" placeholder="Laisser vide pour creer" value="{{ garantie_old.idGarantie|default('') }}">
                                <span id="cr-garantie-err-idGarantie" class="cr-val-msg{{ garantie_errors.idGarantie is defined ? ' is-error' : '' }}">{{ garantie_errors.idGarantie|default('') }}</span>
                            </div>
                        </div>

                        <div class="cr-field-group cr-field-group-2">
                            <div class="cr-field">
                                <label class="cr-field-label">
                                    <i class="fa-solid fa-shield-halved"></i> Type garantie <span class="cr-req">*</span>
                                </label>
                                <div class="cr-select-wrap">
                                    <select class="cr-input cr-select{{ garantie_errors.typeGarantie is defined ? ' cr-input--error' : '' }}" name="typeGarantie" id="cr-garantie-type">
                                        <option value="">Selectionner</option>
                                        {% for type in ['Hypotheque immobiliere', 'Titre vehicule', 'Caution personnelle', 'Garantie bancaire', 'Police assurance', 'Nantissement', 'Autre garantie'] %}
