<script>
(() => {
  'use strict';

  const ready = (fn) => {
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', fn);
    } else {
      fn();
    }
  };

  ready(() => {
    const root = document.querySelector('.cr-root');
    if (!root) return;

    /* â”€â”€ helpers â”€â”€ */
    const $  = (sel, ctx = root) => ctx.querySelector(sel);
    const $$ = (sel, ctx = root) => Array.from(ctx.querySelectorAll(sel));
    const parseNum = (v) => {
      const normalized = String(v ?? '')
        .replace(/\s+/g, '')
        .replace(',', '.')
        .trim();
      const n = Number(normalized);
      return isFinite(n) ? n : 0;
    };
    const fmtNum = (n, dec = 2) => n.toLocaleString('fr-TN', { minimumFractionDigits: dec, maximumFractionDigits: dec });
    const normalizeSearchValue = (value) => String(value ?? '')
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '')
      .toLowerCase()
      .replace(/\s+/g, ' ')
      .trim();
    const matchesSearchTokens = (searchText, query) => {
      const normalizedQuery = normalizeSearchValue(query);
      if (normalizedQuery === '') {
        return true;
      }

      const haystack = normalizeSearchValue(searchText);
      return normalizedQuery.split(' ').every((token) => haystack.includes(token));
    };
    const parseSortableDate = (value) => {
      const raw = String(value ?? '').trim();
      if (raw === '') {
        return 0;
      }

      const parsed = Date.parse(raw);
      return Number.isNaN(parsed) ? 0 : parsed;
    };
    const medianOf = (values) => {
      const sorted = values.filter((value) => value > 0).sort((a, b) => a - b);
      if (sorted.length === 0) {
        return 0;
      }

      const middle = Math.floor(sorted.length / 2);
      if (sorted.length % 2 === 0) {
        return (sorted[middle - 1] + sorted[middle]) / 2;
      }

      return sorted[middle];
    };
    const currentDateIso = '{{ current_date }}';
    const todayDate = new Date(`${currentDateIso}T00:00:00`);
    const setFieldError = (field, messageEl, message) => {
      if (field) {
        field.classList.add('cr-input--error');
        field.classList.remove('cr-input--valid');
        field.style.setProperty('border-color', '#dc2626', 'important');
        field.style.setProperty('box-shadow', '0 0 0 3px rgba(220,38,38,0.12)', 'important');
        field.style.setProperty('background-color', '#fff5f5', 'important');
      }
      if (messageEl) {
        messageEl.textContent = '⚠ ' + message;
        messageEl.classList.add('is-error');
        messageEl.style.color = '#dc2626';
        messageEl.style.fontWeight = '600';
      }
      return false;
    };
    const setFieldOk = (field, messageEl) => {
      if (field) {
        field.classList.remove('cr-input--error');
        field.classList.add('cr-input--valid');
        field.style.setProperty('border-color', '#16a34a', 'important');
        field.style.setProperty('box-shadow', '0 0 0 3px rgba(22,163,74,0.1)', 'important');
        field.style.setProperty('background-color', '#f0fdf4', 'important');
      }
      if (messageEl) {
        messageEl.textContent = '✓ Valide';
        messageEl.classList.remove('is-error');
        messageEl.style.color = '#16a34a';
        messageEl.style.fontWeight = '600';
      }
      return true;
    };
    const setFieldNeutral = (field, messageEl, message = '') => {
      if (field) {
        field.classList.remove('cr-input--error', 'cr-input--valid');
        field.style.removeProperty('border-color');
        field.style.removeProperty('box-shadow');
        field.style.removeProperty('background-color');
      }
      if (messageEl) {
        messageEl.textContent = message;
        messageEl.classList.remove('is-error');
        messageEl.style.removeProperty('color');
        messageEl.style.removeProperty('font-weight');
      }
      return true;
    };
    const clearFieldValidation = (field, messageEl) => {
      if (field) {
        field.classList.remove('cr-input--error', 'cr-input--valid');
        field.style.removeProperty('border-color');
        field.style.removeProperty('box-shadow');
        field.style.removeProperty('background-color');
      }
      if (messageEl) {
        messageEl.textContent = '';
        messageEl.classList.remove('is-error');
      }
    };
    const parseInputDate = (rawValue) => {
      const raw = String(rawValue ?? '').trim();
      if (raw === '') {
        return null;
      }

      const parsed = new Date(`${raw}T00:00:00`);
      return Number.isNaN(parsed.getTime()) ? null : parsed;
    };
    const analyzeEndpoint = '{{ path('portal_credit_capacity_analyze') }}';

    /* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
       DARK MODE
    â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
    const darkBtn  = $('#cr-dark-toggle');
    const DARK_KEY = 'nexora-credits-dark';

    const applyDark = (on) => {
      root.classList.toggle('cr-dark', on);
      if (darkBtn) darkBtn.querySelector('i').className = on ? 'fa-solid fa-sun' : 'fa-solid fa-moon';
    };

    applyDark(localStorage.getItem(DARK_KEY) === '1');

    darkBtn?.addEventListener('click', () => {
      const next = !root.classList.contains('cr-dark');
      applyDark(next);
      localStorage.setItem(DARK_KEY, next ? '1' : '0');
    });

    /* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
       MULTI-STEP FORM
    â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
    const creditForm  = $('#credit-form');
    const creditIdField = $('#cr-credit-id');
    const stepBodies  = creditForm ? $$('[data-step-body]', creditForm) : [];
    const stepDots    = $$('[data-step]', root);
    let currentStep   = 1;
    const syncNextCreditId = () => {
      if (!creditIdField) return;
      creditIdField.value = '';
    };

    const creditStepFields = {
      1: ['idCompte', 'typeCredit', 'idGarantie', 'dateDemande'],
      2: ['montantDemande', 'autofinancement', 'duree', 'tauxInteret', 'mensualite', 'montantAccorde'],
      3: ['salaire', 'typeContrat', 'ancienneteAnnees']
    };
    const getCreditField = (name) => creditForm?.querySelector(`[name="${name}"]`);
    const getCreditMessage = (name) => $(`#cr-err-${name}`, creditForm);
    const validateCreditField = (name) => {
      const field = getCreditField(name);
      const messageEl = getCreditMessage(name);
      const rawValue = field?.value ?? '';
      const value = String(rawValue).trim();

      if (!field) {
        return true;
      }

      switch (name) {
        case 'idCompte':
          return value === ''
            ? setFieldError(field, messageEl, 'Veuillez selectionner un compte.')
            : setFieldOk(field, messageEl);
        case 'typeCredit':
          return value === ''
            ? setFieldError(field, messageEl, 'Veuillez selectionner un type de credit.')
            : setFieldOk(field, messageEl);
        case 'idGarantie':
          return value === ''
            ? setFieldError(field, messageEl, 'Veuillez selectionner une garantie.')
            : setFieldOk(field, messageEl);
        case 'dateDemande': {
          const parsedDate = parseInputDate(value);
          if (value === '') {
            return setFieldError(field, messageEl, 'La date de demande est obligatoire.');
          }
          if (!parsedDate) {
            return setFieldError(field, messageEl, 'Date de demande invalide.');
          }
          if (parsedDate < todayDate) {
            return setFieldError(field, messageEl, "La date de demande ne peut pas être dans le passé.");
          }
          return setFieldOk(field, messageEl);
        }
        case 'montantDemande': {
          const amount = parseNum(value);
          if (value === '') {
            return setFieldError(field, messageEl, 'Le montant demande est obligatoire.');
          }
          if (amount <= 0) {
            return setFieldError(field, messageEl, 'Le montant demande doit etre positif.');
          }
          if (amount < 500 || amount > 10000000) {
            return setFieldError(field, messageEl, 'Le montant doit etre compris entre 500 et 10000000 DT.');
          }
          return setFieldOk(field, messageEl);
        }
        case 'autofinancement': {
          if (value === '') {
            return setFieldError(field, messageEl, "L'autofinancement est obligatoire.");
          }
          const amount = parseNum(getCreditField('montantDemande')?.value);
          const autoFunding = parseNum(value);
          if (autoFunding < 0) {
            return setFieldError(field, messageEl, "L'autofinancement doit etre positif ou nul.");
          }
          if (amount > 0 && autoFunding > amount) {
            return setFieldError(field, messageEl, "L'autofinancement ne doit pas depasser le montant demande.");
          }
          return setFieldOk(field, messageEl);
        }
        case 'duree': {
          const allowedDurations = ['6', '12', '18', '24', '36', '48', '60', '72', '84', '120'];
          if (value === '') {
            return setFieldError(field, messageEl, 'La duree est obligatoire.');
          }
          if (!allowedDurations.includes(value)) {
            return setFieldError(field, messageEl, 'Veuillez selectionner une duree valide.');
          }
          return setFieldOk(field, messageEl);
        }
        case 'tauxInteret': {
          const rate = parseNum(value);
          if (value === '') {
            return setFieldError(field, messageEl, "Le taux d'interet est obligatoire.");
          }
          if (rate < 0 || rate > 100) {
            return setFieldError(field, messageEl, "Le taux d'interet doit etre compris entre 0 et 100%.");
          }
          return setFieldOk(field, messageEl);
        }
        case 'mensualite': {
          if (value === '') {
            return setFieldNeutral(field, messageEl, 'Calcule automatiquement');
          }
          return parseNum(value) <= 0
            ? setFieldError(field, messageEl, 'La mensualite doit etre positive.')
            : setFieldOk(field, messageEl);
        }
        case 'montantAccorde': {
          if (value === '') {
            return setFieldNeutral(field, messageEl, 'Calcule automatiquement');
          }
          if (parseNum(value) < 0) {
            return setFieldError(field, messageEl, 'Le montant accorde doit etre positif ou nul.');
          }
          return setFieldOk(field, messageEl);
        }
        case 'salaire': {
          const salary = parseNum(value);
          if (value === '') {
            return setFieldError(field, messageEl, 'Le salaire est obligatoire.');
          }
          if (salary <= 0) {
            return setFieldError(field, messageEl, 'Le salaire doit etre positif.');
          }
          if (salary > 1000000) {
            return setFieldError(field, messageEl, 'Le salaire doit rester inferieur ou egal a 1000000 DT.');
          }
          return setFieldOk(field, messageEl);
        }
        case 'typeContrat':
          return value === ''
            ? setFieldError(field, messageEl, 'Veuillez selectionner un type de contrat.')
            : setFieldOk(field, messageEl);
        case 'ancienneteAnnees': {
          if (value === '') {
            return setFieldError(field, messageEl, "L'anciennete est obligatoire.");
          }
          if (!/^\d+$/.test(value)) {
            return setFieldError(field, messageEl, "L'anciennete doit etre un entier.");
          }
          const seniority = parseNum(value);
          if (seniority < 0 || seniority > 60) {
            return setFieldError(field, messageEl, "L'anciennete doit etre comprise entre 0 et 60 ans.");
          }
          return setFieldOk(field, messageEl);
        }
        default:
          return true;
      }
    };
    const validateStep = (step = currentStep) => {
      const fields = creditStepFields[step] ?? [];
      return fields.map((name) => validateCreditField(name)).every((res) => res);
    };
    const validateCreditForm = () => Object.values(creditStepFields).flat().map((name) => validateCreditField(name)).every((res) => res);

    const showStep = (n) => {
      currentStep = n;
      stepBodies.forEach((b) => {
        b.hidden = parseInt(b.dataset.stepBody, 10) !== n;
      });
      stepDots.forEach((d) => {
        const s = parseInt(d.dataset.step, 10);
        d.classList.toggle('cr-step-active', s === n);
        d.classList.toggle('cr-step-done', s < n);
      });

      const activeBody = creditForm?.querySelector(`[data-step-body="${n}"]`);
      activeBody?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    };

    $$('[data-next]', root).forEach((btn) => {
      btn.addEventListener('click', () => {
        if (!validateStep(currentStep)) return;
        showStep(parseInt(btn.dataset.next, 10));
      });
    });

    $$('[data-back]', root).forEach((btn) => {
      btn.addEventListener('click', () => showStep(parseInt(btn.dataset.back, 10)));
    });

    Object.values(creditStepFields).flat().forEach((name) => {
      const field = getCreditField(name);
      if (!field) {
        return;
      }

      field.addEventListener('input', () => validateCreditField(name));
      field.addEventListener('change', () => validateCreditField(name));
      field.addEventListener('blur', () => validateCreditField(name));
    });

    const initialCreditStep = Math.max(1, Math.min(3, parseInt(creditForm?.dataset.initialStep || '1', 10) || 1));
    showStep(initialCreditStep);

    /* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
       LOAN CALCULATOR
    â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
    const amountField  = $('#cr-credit-amount');
    const durationField= $('#cr-credit-duree');
    const rateField    = $('#cr-credit-rate');
    const monthlyField = $('#cr-credit-monthly');
    const approvedField= $('#cr-credit-approved');

    const previewMonthly  = $('#cr-preview-monthly');
    const previewTotal    = $('#cr-preview-total');
    const previewInterest = $('#cr-preview-interest');

    const recalculate = () => {
      const amount   = parseNum(amountField?.value);
      const duration = parseNum(durationField?.value);
      const rate     = parseNum(rateField?.value);

      if (amount <= 0 || duration <= 0) {
        if (monthlyField)  monthlyField.value  = '';
        if (approvedField) approvedField.value = '';
        if (previewMonthly)  previewMonthly.textContent  = '-- DT';
        if (previewTotal)    previewTotal.textContent    = '-- DT';
        if (previewInterest) previewInterest.textContent = '-- DT';
        return;
      }

      const mr = rate / 100 / 12;
      const mensualite = mr <= 0
        ? amount / duration
        : (amount * mr) / (1 - Math.pow(1 + mr, -duration));

      const totalCost     = mensualite * duration;
      const interestCost  = totalCost - amount;

      if (monthlyField)  monthlyField.value  = mensualite.toFixed(2);
      if (approvedField) approvedField.value = amount.toFixed(2);

      if (previewMonthly)  previewMonthly.textContent  = fmtNum(mensualite) + ' DT';
      if (previewTotal)    previewTotal.textContent    = fmtNum(totalCost) + ' DT';
      if (previewInterest) previewInterest.textContent = fmtNum(interestCost) + ' DT';
    };

    amountField?.addEventListener('input', () => {
      recalculate();
      validateCreditField('montantDemande');
      validateCreditField('autofinancement');
      validateCreditField('mensualite');
      validateCreditField('montantAccorde');
    });
    durationField?.addEventListener('change', () => {
      recalculate();
      validateCreditField('duree');
      validateCreditField('mensualite');
      validateCreditField('montantAccorde');
    });
    rateField?.addEventListener('input', () => {
      recalculate();
      validateCreditField('tauxInteret');
      validateCreditField('mensualite');
      validateCreditField('montantAccorde');
    });
    recalculate();

    creditForm?.addEventListener('submit', (event) => {
      recalculate();
      if (!validateCreditForm()) {
        event.preventDefault();
        return;
      }
    });
    creditForm?.addEventListener('reset', () => {
      window.requestAnimationFrame(() => {
        Object.values(creditStepFields).flat().forEach((name) => {
          clearFieldValidation(getCreditField(name), getCreditMessage(name));
        });
        recalculate();
        showStep(1);
      });
    });

    /* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
       CAPACITY ANALYSIS
    â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
    const analyzeBtn     = $('#cr-credit-analyze');
    const analysisOutput = $('#cr-analysis-output');
    const salaryField    = $('#cr-credit-salary');
    const contractField = $('#cr-credit-contract');
    const seniorityField = $('#cr-credit-seniority');
    const autoFundingField = $('#cr-credit-auto');
    const typeCreditField = $('#cr-credit-type');
    const aiModal = $('#cr-ai-modal');
    const aiModalOverlay = $('#cr-ai-modal-overlay');
    const aiModalCloseBtn = $('#cr-ai-modal-close');
    const aiModalOkBtn = $('#cr-ai-modal-ok');
    const aiStatus = $('#cr-ai-status');
    const aiScoreVal = $('#cr-ai-score-val');
    const aiProgressFill = $('#cr-ai-progress-fill');
    const aiDebtRatio = $('#cr-ai-debt-ratio');
    const aiDebtMark = $('#cr-ai-debt-mark');
    const aiAuto = $('#cr-ai-autofinancing');
    const aiAutoMark = $('#cr-ai-autofinancing-mark');
    const aiDuration = $('#cr-ai-duration');
    const aiDurationMark = $('#cr-ai-duration-mark');
    const aiSalary = $('#cr-ai-salary');
    const aiSalaryMark = $('#cr-ai-salary-mark');
    const aiApproval = $('#cr-ai-approval');
    const aiApprovalMark = $('#cr-ai-approval-mark');
    const aiRisk = $('#cr-ai-risk');
    const aiRiskMark = $('#cr-ai-risk-mark');
    const aiRecommendation = $('#cr-ai-recommendation');

    const resolveAnalysisTone = (approval, riskLevel) => {
      const normalizedRisk = normalizeSearchValue(riskLevel);
      if (approval >= 70 && normalizedRisk.includes('faible')) {
        return 'is-ok';
      }
      if (approval < 45 || normalizedRisk.includes('eleve')) {
        return 'is-risk';
      }

      return 'is-warn';
    };

    const openAiModal = () => {
      if (!aiModal || !aiModalOverlay) return;
      aiModal.hidden = false;
      aiModalOverlay.hidden = false;
      document.body.style.overflow = 'hidden';
    };

    const closeAiModal = () => {
      if (!aiModal || !aiModalOverlay) return;
      aiModal.hidden = true;
      aiModalOverlay.hidden = true;
      document.body.style.overflow = '';
    };

    const setMark = (el, tone) => {
      if (!el) return;
      el.classList.remove('is-ok', 'is-warn', 'is-risk');
      el.classList.add(tone);
      el.textContent = tone === 'is-ok' ? 'OK' : (tone === 'is-warn' ? '⚠' : '✖');
    };

    const renderAiModalResult = (payload, scoring, provider) => {
      if (!aiModal) return;

      const approval = parseNum(scoring.approval_probability);
      const score = parseNum(scoring.score);
      const riskLevel = String(scoring.risk_level ?? 'Moyen');
      const suggestedStatus = String(scoring.suggested_status ?? 'En attente');
      const explanation = String(scoring.explanation ?? '').trim();
      const tone = resolveAnalysisTone(approval, riskLevel);

      const montantDemande = parseNum(payload.montantDemande);
      const autofinancement = parseNum(payload.autofinancement);
      const duree = parseNum(payload.duree);
      const salaire = parseNum(payload.salaire);
      const mensualite = parseNum(payload.mensualite);
      const debtRatio = salaire > 0 ? (mensualite / salaire) * 100 : 0;
      const autoRatio = montantDemande > 0 ? (autofinancement / montantDemande) * 100 : 0;

      if (aiStatus) {
        aiStatus.classList.remove('is-ok', 'is-warn', 'is-risk');
        aiStatus.classList.add(tone);

        const normalizedStatus = normalizeSearchValue(suggestedStatus);
        aiStatus.textContent = normalizedStatus.includes('accepte')
          ? '✔ Crédit accepté'
          : (normalizedStatus.includes('refuse') ? '✖ Crédit refusé' : '⌛ Crédit en attente');
      }

      if (aiScoreVal) {
        aiScoreVal.textContent = `${fmtNum(score, 1)} / 100`;
      }

      if (aiProgressFill) {
        const scoreClamped = Math.max(0, Math.min(100, score));
        aiProgressFill.style.width = `${scoreClamped}%`;
        aiProgressFill.classList.remove('is-warn', 'is-risk');
        if (tone === 'is-warn') aiProgressFill.classList.add('is-warn');
        if (tone === 'is-risk') aiProgressFill.classList.add('is-risk');
      }

      if (aiDebtRatio) aiDebtRatio.textContent = `${fmtNum(debtRatio, 1)}%`;
      if (aiAuto) aiAuto.textContent = `${fmtNum(autoRatio, 1)}%`;
      if (aiDuration) aiDuration.textContent = `${fmtNum(duree, 0)} mois`;
      if (aiSalary) aiSalary.textContent = `${fmtNum(salaire, 2)} DT`;
      if (aiApproval) aiApproval.textContent = `${fmtNum(approval, 1)}%`;
      if (aiRisk) aiRisk.textContent = riskLevel;

      setMark(aiDebtMark, debtRatio <= 35 ? 'is-ok' : (debtRatio <= 45 ? 'is-warn' : 'is-risk'));
      setMark(aiAutoMark, autoRatio >= 20 ? 'is-ok' : (autoRatio >= 10 ? 'is-warn' : 'is-risk'));
      setMark(aiDurationMark, duree <= 84 ? 'is-ok' : (duree <= 120 ? 'is-warn' : 'is-risk'));
      setMark(aiSalaryMark, salaire >= 1500 ? 'is-ok' : (salaire >= 900 ? 'is-warn' : 'is-risk'));
      setMark(aiApprovalMark, approval >= 70 ? 'is-ok' : (approval >= 45 ? 'is-warn' : 'is-risk'));

      const normalizedRisk = normalizeSearchValue(riskLevel);
      setMark(
        aiRiskMark,
        normalizedRisk.includes('faible')
          ? 'is-ok'
          : (normalizedRisk.includes('eleve') ? 'is-risk' : 'is-warn')
      );

      if (aiRecommendation) {
        const generatedReco = tone === 'is-ok'
          ? `Profil solide. Statut suggere: ${suggestedStatus}.`
          : (tone === 'is-risk'
              ? `Risque eleve detecte. Ajustez montant/duree avant validation.`
              : `Profil moyen: renforcez salaire ou autofinancement pour augmenter l approbation.`);
        const recoText = explanation !== '' ? explanation : generatedReco;
        aiRecommendation.textContent = `${recoText} (Source IA: ${provider})`;
      }
    };

    const showAiErrorModal = (message) => {
      if (aiStatus) {
        aiStatus.classList.remove('is-ok', 'is-warn');
        aiStatus.classList.add('is-risk');
        aiStatus.textContent = '✖ Analyse indisponible';
      }
      if (aiScoreVal) aiScoreVal.textContent = '-- / 100';
      if (aiProgressFill) {
        aiProgressFill.style.width = '0%';
        aiProgressFill.classList.remove('is-warn', 'is-risk');
      }

      [aiDebtRatio, aiAuto, aiDuration, aiSalary, aiApproval, aiRisk].forEach((el) => {
        if (el) el.textContent = '--';
      });
      [aiDebtMark, aiAutoMark, aiDurationMark, aiSalaryMark, aiApprovalMark, aiRiskMark].forEach((el) => setMark(el, 'is-risk'));

      if (aiRecommendation) {
        aiRecommendation.textContent = message || 'Analyse indisponible pour le moment.';
      }

      openAiModal();
    };

    aiModalCloseBtn?.addEventListener('click', closeAiModal);
    aiModalOkBtn?.addEventListener('click', closeAiModal);
    aiModalOverlay?.addEventListener('click', closeAiModal);
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && aiModal && !aiModal.hidden) {
        closeAiModal();
      }
    });

    analyzeBtn?.addEventListener('click', async () => {
      if (!analysisOutput) return;

      recalculate();

      const requiredBeforeAnalysis = ['montantDemande', 'autofinancement', 'duree', 'tauxInteret', 'salaire', 'typeContrat', 'ancienneteAnnees'];
      const isValid = requiredBeforeAnalysis.map((name) => validateCreditField(name)).every((res) => res);
      if (!isValid) {
        analysisOutput.textContent = 'Veuillez corriger les champs obligatoires avant de lancer l analyse.';
        analysisOutput.className = 'cr-analysis-output is-warn';
        analysisOutput.hidden = false;
        return;
      }

      const payload = {
        typeCredit: typeCreditField?.value ?? '',
        montantDemande: parseNum(amountField?.value),
        autofinancement: parseNum(autoFundingField?.value),
        duree: parseNum(durationField?.value),
        tauxInteret: parseNum(rateField?.value),
        mensualite: parseNum(monthlyField?.value),
        montantAccorde: parseNum(approvedField?.value),
        salaire: parseNum(salaryField?.value),
        typeContrat: contractField?.value ?? '',
        ancienneteAnnees: parseNum(seniorityField?.value),
      };

      const originalLabel = analyzeBtn.innerHTML;
      analyzeBtn.disabled = true;
      analyzeBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Analyse en cours...';
      analysisOutput.hidden = true;

      try {
        const response = await fetch(analyzeEndpoint, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest',
          },
          body: JSON.stringify(payload),
        });

        const result = await response.json().catch(() => null);
        if (!response.ok || !result || result.ok !== true) {
          const errorMessage = (result && typeof result.message === 'string' && result.message.trim() !== '')
            ? result.message
            : 'Analyse indisponible pour le moment.';
          throw new Error(errorMessage);
        }

        const scoring = result.scoring ?? {};
        const approval = parseNum(scoring.approval_probability);
        const failure = parseNum(scoring.failure_probability);
        const score = parseNum(scoring.score);
        const riskLevel = String(scoring.risk_level ?? 'Moyen');
        const suggestedStatus = String(scoring.suggested_status ?? 'En attente');
        const explanation = String(scoring.explanation ?? '').trim();
        const provider = String(result.provider ?? 'Fallback');

        renderAiModalResult(payload, scoring, provider);
        openAiModal();

        analysisOutput.className = `cr-analysis-output ${resolveAnalysisTone(approval, riskLevel)}`;
        analysisOutput.textContent = [
          `Chance d obtention: ${fmtNum(approval, 1)}%`,
          `Chance d echec: ${fmtNum(failure, 1)}%`,
          `Score IA: ${fmtNum(score, 1)}/100`,
          `Risque: ${riskLevel}`,
          `Statut suggere: ${suggestedStatus}`,
          explanation !== '' ? `Motif: ${explanation}` : null,
          `Provider: ${provider}`,
        ].filter(Boolean).join('\n');
      } catch (error) {
        const message = error instanceof Error ? error.message : 'Analyse indisponible pour le moment.';
        showAiErrorModal(message);
        analysisOutput.className = 'cr-analysis-output is-warn';
        analysisOutput.textContent = message;
      } finally {
        analyzeBtn.disabled = false;
        analyzeBtn.innerHTML = originalLabel;
        analysisOutput.hidden = true;
      }
    });

    /* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
       EDIT BUTTON â†’ fill form
    â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
    const fillForm = (row) => {
      if (!creditForm || !row) return;

      const set = (name, val) => {
        const f = creditForm.querySelector(`[name="${name}"]`);
        if (f) f.value = val ?? '';
      };

      set('idCredit',       row.dataset.creditId);
      set('idCompte',       row.dataset.creditAccount);
      set('typeCredit',     row.dataset.creditType);
      set('idGarantie',     row.dataset.creditGarantieId);
      set('montantDemande', row.dataset.creditAmount);
      set('autofinancement',row.dataset.creditAuto);
      set('duree',          row.dataset.creditDuration);
      set('tauxInteret',    row.dataset.creditRate);
      set('mensualite',     row.dataset.creditMonthly);
      set('montantAccorde', row.dataset.creditApproved);
      set('dateDemande',    row.dataset.creditDate);
      set('salaire',        row.dataset.creditSalary);
      set('typeContrat',    row.dataset.creditContract);
      set('ancienneteAnnees', row.dataset.creditSeniority);

      recalculate();

      if (analysisOutput) {
        analysisOutput.hidden = true;
      }

      showStep(1);
      openDrawer();
      document.getElementById('credit-form-card')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    };

    $$('[data-credit-edit]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const card = btn.closest('[data-credit-row]');
        fillForm(card);
      });
    });

    /* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
       ADD NEW BUTTON (header)
    â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
    const addBtn      = $('#cr-add-credit-btn');
    const emptyAddBtn = $('#cr-empty-add-btn');

    const resetAndFocus = () => {
      creditForm?.reset();
      syncNextCreditId();
      recalculate();
      if (analysisOutput) { analysisOutput.hidden = true; }
      showStep(1);
      openDrawer();
      document.getElementById('credit-form-card')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    };

    addBtn?.addEventListener('click', resetAndFocus);
    emptyAddBtn?.addEventListener('click', resetAndFocus);

    /* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
       FORM COLLAPSE (toggle)
    â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
    const collapseBtn = $('#cr-collapse-form');
    const formBody    = creditForm;

    collapseBtn?.addEventListener('click', () => {
      const collapsed = formBody?.classList.toggle('cr-form-collapsed');
      const icon = collapseBtn.querySelector('i');
      if (icon) icon.className = collapsed ? 'fa-solid fa-chevron-right' : 'fa-solid fa-chevron-left';
    });

    /* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
       SEARCH & SORT & FILTER
    â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
    const searchInput  = $('#cr-search-input');
    const searchClear  = $('#cr-search-clear');
    const sortSelect   = $('#cr-sort-select');
    const filterTabs   = $$('.cr-filter-tab');
    const allCards     = $$('[data-credit-row]');
    const garantieRows = $$('[data-main-garantie-row]');
    const creditsView  = $('#cr-credits-view');
    const garantiesView = $('#cr-garanties-view');
    const garantiesInlineBtn = $('#cr-open-garanties-inline');
    const garantiesInlineLabel = $('#cr-open-garanties-inline-label');
    const mainListLabel = $('#cr-main-list-label');
    const mainListCount = $('#cr-main-list-count');
    const mainListIcon = $('#cr-main-list-icon');
    const creditFilterTabs = $('#cr-credit-filter-tabs');
    const creditMedianAmount = medianOf(allCards.map((card) => parseNum(card.dataset.creditAmount)));
    const garantieMedianAmount = medianOf(garantieRows.map((row) => parseNum(row.dataset.garantieEstimated)));

    let activeFilter = 'all';
    let activeListing = 'credits';
    let selectedGarantieCreditId = null;

    const updateListingUI = () => {
      const showingGaranties = activeListing === 'garanties';

      creditsView && (creditsView.hidden = showingGaranties);
      garantiesView && (garantiesView.hidden = !showingGaranties);
      creditFilterTabs && (creditFilterTabs.hidden = showingGaranties);

      if (searchInput) {
        searchInput.placeholder = showingGaranties ? 'Rechercher une garantie...' : 'Rechercher un credit...';
        searchInput.value = '';
      }
      if (searchClear) searchClear.hidden = true;

      if (mainListLabel) {
        mainListLabel.textContent = showingGaranties
          ? (selectedGarantieCreditId ? `Garanties du credit #${selectedGarantieCreditId}` : 'Mes Garanties')
          : 'Mes Credits';
      }
      if (mainListCount) mainListCount.textContent = String(showingGaranties ? garantieRows.length : allCards.length);
      if (mainListIcon) {
        mainListIcon.className = showingGaranties ? 'fa-solid fa-shield-halved' : 'fa-solid fa-credit-card';
      }
      if (garantiesInlineLabel) {
        garantiesInlineLabel.textContent = showingGaranties
          ? (selectedGarantieCreditId ? 'Toutes les garanties' : 'Tous les credits')
          : 'Toutes les garanties';
      }
      if (garantiesInlineBtn) {
        garantiesInlineBtn.classList.toggle('is-active-alt', showingGaranties);
        const icon = garantiesInlineBtn.querySelector('i');
        if (icon) {
          icon.className = showingGaranties
            ? (selectedGarantieCreditId ? 'fa-solid fa-shield-halved' : 'fa-solid fa-credit-card')
            : 'fa-solid fa-shield-halved';
        }
      }
    };

    const applyState = () => {
      const kw       = searchInput?.value ?? '';
      const sortBy   = sortSelect?.value ?? 'id_desc';

      if (searchClear) searchClear.hidden = kw.trim() === '';

      if (activeListing === 'garanties') {
        const garantieList = $('.cr-garanties-list-main');
        const visibleGaranties = garantieRows.filter((row) => {
          const searchText = row.dataset.garantieSearch ?? '';
          const matchesCredit = !selectedGarantieCreditId || row.dataset.garantieCreditId === String(selectedGarantieCreditId);
          const show = matchesCredit && matchesSearchTokens(searchText, kw);
          row.classList.toggle('cr-hidden', !show);
          return show;
        });

        if (mainListCount) {
          mainListCount.textContent = String(visibleGaranties.length);
        }
        if (garantieList) {
          visibleGaranties.sort((a, b) => {
            const idA = parseNum(a.dataset.garantieId);
            const idB = parseNum(b.dataset.garantieId);
            const valA = parseNum(a.dataset.garantieEstimated);
            const valB = parseNum(b.dataset.garantieEstimated);
            const dateA = parseSortableDate(a.dataset.garantieDate);
            const dateB = parseSortableDate(b.dataset.garantieDate);

            switch (sortBy) {
              case 'id_asc':
                return dateA !== dateB ? dateA - dateB : idA - idB;
              case 'amount_high':
                return valB - valA || idB - idA;
              case 'amount_medium':
                return Math.abs(valA - garantieMedianAmount) - Math.abs(valB - garantieMedianAmount) || idB - idA;
              case 'amount_low':
                return valA - valB || idA - idB;
              default:
                return dateB !== dateA ? dateB - dateA : idB - idA;
            }
          }).forEach((row) => garantieList.appendChild(row));
        }

        return;
      }

      const visible = allCards.filter((card) => {
        const searchText = card.dataset.creditSearch ?? '';
        const matchKw    = matchesSearchTokens(searchText, kw);

        let matchFilter = true;
        if (activeFilter !== 'all') {
          const st = normalizeSearchValue(card.dataset.creditStatus ?? '');
          matchFilter = st.includes(activeFilter);
        }

        const show = matchKw && matchFilter;
        card.classList.toggle('cr-hidden', !show);
        return show;
      });

      if (mainListCount) {
        mainListCount.textContent = String(visible.length);
      }
      const grid = $('#cr-credits-grid');
      if (grid) {
        visible.sort((a, b) => {
          const idA  = parseNum(a.dataset.creditId);
          const idB  = parseNum(b.dataset.creditId);
          const amA  = parseNum(a.dataset.creditAmount);
          const amB  = parseNum(b.dataset.creditAmount);
          const rkA  = parseNum(a.dataset.creditRisk);
          const rkB  = parseNum(b.dataset.creditRisk);
          const dtA  = parseSortableDate(a.dataset.creditDate);
          const dtB  = parseSortableDate(b.dataset.creditDate);

          switch (sortBy) {
            case 'id_asc':
              return dtA !== dtB ? dtA - dtB : idA - idB;
            case 'amount_high':
              return amB - amA || idB - idA;
            case 'amount_medium':
              return Math.abs(amA - creditMedianAmount) - Math.abs(amB - creditMedianAmount) || idB - idA;
            case 'amount_low':
              return amA - amB || idA - idB;
            case 'risk_desc':
              return rkB - rkA || idB - idA;
            default:
              return dtB !== dtA ? dtB - dtA : idB - idA;
          }
        }).forEach((card) => grid.appendChild(card));
      }

    };

    searchInput?.addEventListener('input', applyState);
    searchClear?.addEventListener('click', () => { if (searchInput) searchInput.value = ''; applyState(); });
    sortSelect?.addEventListener('change', applyState);

    filterTabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        activeFilter = tab.dataset.filter ?? 'all';
        filterTabs.forEach((t) => t.classList.remove('cr-filter-tab-active'));
        tab.classList.add('cr-filter-tab-active');
        applyState();
      });
    });

    garantiesInlineBtn?.addEventListener('click', () => {
      if (activeListing === 'credits') {
        activeListing = 'garanties';
        selectedGarantieCreditId = null;
      } else if (selectedGarantieCreditId) {
        selectedGarantieCreditId = null;
        activeListing = 'garanties';
      } else {
        activeListing = 'credits';
        selectedGarantieCreditId = null;
      }
      updateListingUI();
      applyState();
    });

    $$('[data-credit-garanties]').forEach((btn) => {
      btn.addEventListener('click', () => {
        selectedGarantieCreditId = btn.dataset.creditGaranties ?? null;
        activeListing = 'garanties';
        updateListingUI();
        applyState();
      });
    });

    /* ════════════════════════════════════════════════════════════════════
       TOOLS MODAL
    ════════════════════════════════════════════════════════════════════ */
    const toolsOverlay = $('#cr-tools-overlay');
    const toolsModal = $('#cr-tools-modal');
    const toolsTitle = $('#cr-tools-title');
    const toolsSubtitle = $('#cr-tools-subtitle');
    const toolsClose = $('#cr-tools-close');
    const toolTabs = $$('[data-tool-tab]', root);
    const toolPanels = $$('[data-tool-panel]', root);
    const toolOpenButtons = $$('[data-tool-open]', root);
    const toolMeta = {
      simulate: {
        title: 'Simuler & Comparer',
        subtitle: 'Analysez vos credits sans quitter cette page.'
      },
      history: {
        title: 'Historique des credits',
        subtitle: 'Consultez rapidement l historique complet de vos credits.'
      },
      ratio: {
        title: 'Ratio d endettement',
        subtitle: 'Visualisez votre capacite financiere en temps reel.'
      },
      projection: {
        title: 'Projection future',
        subtitle: 'Anticipez l evolution de vos remboursements.'
      },
      restruct: {
        title: 'Restructuration',
        subtitle: 'Comparez des scenarios de reajustement.'
      },
      assistant: {
        title: 'Assistant IA',
        subtitle: 'Obtenez des suggestions contextuelles sur vos credits.'
      }
    };

    const openToolPanel = (panelName) => {
      if (!toolsModal || !toolsOverlay) return;
      const meta = toolMeta[panelName] ?? toolMeta.simulate;

      toolTabs.forEach((tab) => {
        tab.classList.toggle('is-active', tab.dataset.toolTab === panelName);
      });
      toolPanels.forEach((panel) => {
        panel.classList.toggle('is-active', panel.dataset.toolPanel === panelName);
      });

      if (toolsTitle) toolsTitle.textContent = meta.title;
      if (toolsSubtitle) toolsSubtitle.textContent = meta.subtitle;

      toolsModal.hidden = false;
      toolsOverlay.hidden = false;
      document.body.style.overflow = 'hidden';
    };

    const closeToolPanel = () => {
      if (!toolsModal || !toolsOverlay) return;
      toolsModal.hidden = true;
      toolsOverlay.hidden = true;
      document.body.style.overflow = '';
    };

    toolOpenButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        openToolPanel(btn.dataset.toolOpen || 'simulate');
      });
    });

    toolTabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        openToolPanel(tab.dataset.toolTab || 'simulate');
      });
    });

    toolsClose?.addEventListener('click', closeToolPanel);
    toolsOverlay?.addEventListener('click', closeToolPanel);

    syncNextCreditId();
    updateListingUI();
    applyState();

    /* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
       GARANTIES DRAWER
    â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
    const overlay    = $('#cr-drawer-overlay');
    const drawer     = $('#cr-garanties-drawer');
    const openBtns   = [$('#cr-open-garanties')];
    const closeBtn   = $('#cr-close-garanties');
    const garantieForm = $('#cr-garantie-form');
    const garantieIdField = $('#cr-garantie-id');
    const garantieEstimatedField = $('#cr-garantie-estimated');
    const garantieRetainedField = $('#cr-garantie-retained');
    const garantieDateField = $('#cr-garantie-date');
    const garantieDocumentField = $('#cr-garantie-document');
    const garantieExistingDocumentField = $('#cr-garantie-document-existing');
    const garantieDocumentLabel = $('#cr-garantie-document-label');
    const garantieDocumentLink = $('#cr-garantie-document-link');
    const garantieFieldNames = ['typeGarantie', 'valeurEstimee', 'valeurRetenue', 'dateEvaluation', 'nomGarant', 'adresseBien', 'documentJustificatif', 'description'];

    const setDrawerUrlState = (isOpen) => {
      const url = new URL(window.location.href);
      if (isOpen) {
        url.searchParams.set('panel', 'credit');
      } else {
        url.searchParams.delete('panel');
      }
      const query = url.searchParams.toString();
      window.history.replaceState({}, '', url.pathname + (query ? `?${query}` : ''));
    };

    const openDrawer = () => {
      if (!drawer || !overlay) return;
      drawer.hidden  = false;
      overlay.hidden = false;
      document.body.style.overflow = 'hidden';
      setDrawerUrlState(true);
    };

    const closeDrawer = () => {
      if (!drawer || !overlay) return;
      drawer.hidden  = true;
      overlay.hidden = true;
      document.body.style.overflow = '';
      setDrawerUrlState(false);
    };

    const normalizeIsoDate = (rawValue) => {
      const raw = String(rawValue ?? '').trim();
      if (raw === '') return '';
      if (/^\d{4}-\d{2}-\d{2}$/.test(raw)) return raw;
      const parsed = new Date(raw);
      if (Number.isNaN(parsed.getTime())) return '';
      const y = parsed.getFullYear();
      const m = String(parsed.getMonth() + 1).padStart(2, '0');
      const d = String(parsed.getDate()).padStart(2, '0');
      return `${y}-${m}-${d}`;
    };

    const setGarantieField = (name, value) => {
      const field = garantieForm?.querySelector(`[name="${name}"]`);
      if (field instanceof HTMLInputElement || field instanceof HTMLSelectElement || field instanceof HTMLTextAreaElement) {
        field.value = value ?? '';
      }
    };
    const getGarantieField = (name) => garantieForm?.querySelector(`[name="${name}"]`);
    const getGarantieMessage = (name) => $(`#cr-garantie-err-${name}`, garantieForm);
    const syncGarantieDocumentMeta = (path = '', label = '') => {
      const resolvedPath = String(path ?? '').trim();
      if (garantieExistingDocumentField instanceof HTMLInputElement) {
        garantieExistingDocumentField.value = resolvedPath;
      }
      if (garantieDocumentLabel) {
        garantieDocumentLabel.textContent = label || (resolvedPath !== '' ? 'Image deja enregistree' : 'Formats acceptes: PNG, JPG, WEBP, GIF');
      }
      if (garantieDocumentLink instanceof HTMLAnchorElement) {
        if (resolvedPath !== '') {
          garantieDocumentLink.href = resolvedPath.startsWith('/') ? resolvedPath : `/${resolvedPath}`;
          garantieDocumentLink.hidden = false;
        } else {
          garantieDocumentLink.href = '#';
          garantieDocumentLink.hidden = true;
        }
      }
    };

    const syncRetainedFromEstimated = () => {
      if (!(garantieEstimatedField instanceof HTMLInputElement) || !(garantieRetainedField instanceof HTMLInputElement)) {
        return;
      }
      if (garantieRetainedField.dataset.manual === '1') {
        return;
      }

      const estimated = parseNum(garantieEstimatedField.value);
      garantieRetainedField.value = estimated > 0 ? (estimated * 0.8).toFixed(2) : '';
    };

    const validateGarantieField = (name) => {
      const field = getGarantieField(name);
      const messageEl = getGarantieMessage(name);
      const rawValue = field?.value ?? '';
      const value = String(rawValue).trim();

      if (!field && name !== 'documentJustificatif') {
        return true;
      }

      switch (name) {
        case 'typeGarantie':
          return value === ''
            ? setFieldError(field, messageEl, 'Veuillez selectionner un type de garantie.')
            : setFieldOk(field, messageEl);
        case 'valeurEstimee': {
          const estimated = parseNum(value);
          if (value === '') {
            return setFieldError(field, messageEl, 'La valeur estimee est obligatoire.');
          }
          if (estimated <= 0) {
            return setFieldError(field, messageEl, 'La valeur estimee doit etre positive.');
          }
          if (estimated < 1000 || estimated > 100000000) {
            return setFieldError(field, messageEl, 'La valeur estimee doit etre comprise entre 1000 et 100000000 DT.');
          }
          return setFieldOk(field, messageEl);
        }
        case 'valeurRetenue': {
          const retained = parseNum(value);
          const estimated = parseNum(garantieEstimatedField?.value);
          if (value === '') {
            return setFieldError(field, messageEl, 'La valeur retenue est obligatoire.');
          }
          if (retained <= 0) {
            return setFieldError(field, messageEl, 'La valeur retenue doit etre positive.');
          }
          if (estimated > 0 && retained > estimated) {
            return setFieldError(field, messageEl, "La valeur retenue ne doit pas depasser l'estimee.");
          }
          return setFieldOk(field, messageEl);
        }
        case 'dateEvaluation': {
          const parsedDate = parseInputDate(value);
          if (value === '') {
            return setFieldError(field, messageEl, "La date d'evaluation est obligatoire.");
          }
          if (!parsedDate) {
            return setFieldError(field, messageEl, "Date d'evaluation invalide.");
          }
          if (parsedDate < todayDate) {
            return setFieldError(field, messageEl, "La date d'évaluation ne peut pas être dans le passé.");
          }
          return setFieldOk(field, messageEl);
        }
        case 'nomGarant':
          if (value === '') {
            return setFieldError(field, messageEl, 'Le nom du garant est obligatoire.');
          }
          if (value.length < 2) {
            return setFieldError(field, messageEl, 'Le nom doit contenir au moins 2 caracteres.');
          }
          if (!/^[\p{L}\s\-']+$/u.test(value)) {
            return setFieldError(field, messageEl, 'Le nom du garant ne doit contenir que des lettres.');
          }
          return setFieldOk(field, messageEl);
        case 'adresseBien':
          if (value === '') {
            return setFieldError(field, messageEl, "L'adresse du bien est obligatoire.");
          }
          if (value.length < 5) {
            return setFieldError(field, messageEl, "L'adresse doit contenir au moins 5 caracteres.");
          }
          return setFieldOk(field, messageEl);
        case 'documentJustificatif': {
          const file = garantieDocumentField instanceof HTMLInputElement ? garantieDocumentField.files?.[0] ?? null : null;
          const existingPath = garantieExistingDocumentField instanceof HTMLInputElement ? garantieExistingDocumentField.value.trim() : '';
          const allowedTypes = ['image/jpeg', 'image/png', 'image/webp', 'image/gif'];

          if (file) {
            if (!allowedTypes.includes(file.type)) {
              return setFieldError(garantieDocumentField, messageEl, 'Le document justificatif doit etre une image JPG, PNG, WEBP ou GIF.');
            }
            return setFieldOk(garantieDocumentField, messageEl);
          }
          if (existingPath === '') {
            return setFieldError(garantieDocumentField, messageEl, 'Le document justificatif est obligatoire.');
          }
          return setFieldOk(garantieDocumentField, messageEl);
        }
        case 'description':
          if (value === '') {
            return setFieldError(field, messageEl, 'La description est obligatoire.');
          }
          if (value.length < 10) {
            return setFieldError(field, messageEl, 'La description doit contenir au moins 10 caracteres.');
          }
          return setFieldOk(field, messageEl);
        default:
          return true;
      }
    };
    const validateGarantieFormValues = () => garantieFieldNames.map((name) => validateGarantieField(name)).every((res) => res);

    const resetGarantieFormState = (withFormReset = true) => {
      if (withFormReset && garantieForm instanceof HTMLFormElement) {
        garantieForm.reset();
      }
      if (garantieIdField instanceof HTMLInputElement) {
        garantieIdField.value = '';
      }
      if (garantieDateField instanceof HTMLInputElement && garantieDateField.value === '') {
        garantieDateField.value = '{{ current_date }}';
      }
      if (garantieRetainedField instanceof HTMLInputElement) {
        garantieRetainedField.dataset.manual = '0';
      }
      if (garantieDocumentField instanceof HTMLInputElement) {
        garantieDocumentField.value = '';
      }
      syncGarantieDocumentMeta('', '');
      garantieFieldNames.forEach((name) => {
        clearFieldValidation(getGarantieField(name), getGarantieMessage(name));
      });
      syncRetainedFromEstimated();
    };

    garantieEstimatedField?.addEventListener('input', () => {
      syncRetainedFromEstimated();
      validateGarantieField('valeurEstimee');
      validateGarantieField('valeurRetenue');
    });

    garantieRetainedField?.addEventListener('input', () => {
      if (!(garantieRetainedField instanceof HTMLInputElement)) {
        return;
      }
      garantieRetainedField.dataset.manual = garantieRetainedField.value.trim() === '' ? '0' : '1';
      validateGarantieField('valeurRetenue');
    });
    garantieDocumentField?.addEventListener('change', () => {
      const file = garantieDocumentField instanceof HTMLInputElement ? garantieDocumentField.files?.[0] ?? null : null;
      syncGarantieDocumentMeta(
        garantieExistingDocumentField instanceof HTMLInputElement ? garantieExistingDocumentField.value : '',
        file ? `Fichier selectionne: ${file.name}` : ''
      );
      validateGarantieField('documentJustificatif');
    });
    garantieFieldNames.forEach((name) => {
      const field = getGarantieField(name);
      if (!field || name === 'documentJustificatif') {
        return;
      }

      field.addEventListener('input', () => validateGarantieField(name));
      field.addEventListener('change', () => validateGarantieField(name));
      field.addEventListener('blur', () => validateGarantieField(name));
    });

    garantieForm?.addEventListener('reset', () => {
      window.requestAnimationFrame(() => {
        resetGarantieFormState(false);
      });
    });

    garantieForm?.addEventListener('submit', (event) => {
      if (garantieRetainedField instanceof HTMLInputElement && garantieRetainedField.value.trim() === '') {
        garantieRetainedField.dataset.manual = '0';
        syncRetainedFromEstimated();
      }
      if (!validateGarantieFormValues()) {
        event.preventDefault();
      }
    });

    const fillGarantieForm = (row) => {
      if (!(row instanceof HTMLElement)) {
        return;
      }

      setGarantieField('idGarantie', row.dataset.garantieId ?? '');
      setGarantieField('typeGarantie', row.dataset.garantieType ?? '');
      setGarantieField('description', row.dataset.garantieDescription ?? '');
      setGarantieField('adresseBien', row.dataset.garantieAddress ?? '');
      setGarantieField('valeurEstimee', row.dataset.garantieEstimated ?? '');
      setGarantieField('valeurRetenue', row.dataset.garantieRetained ?? '');
      setGarantieField('dateEvaluation', normalizeIsoDate(row.dataset.garantieDate ?? ''));
      setGarantieField('nomGarant', row.dataset.garantieGuarantor ?? '');
      if (garantieDocumentField instanceof HTMLInputElement) {
        garantieDocumentField.value = '';
      }
      syncGarantieDocumentMeta(row.dataset.garantieDocument ?? '', '');

      if (garantieRetainedField instanceof HTMLInputElement) {
        garantieRetainedField.dataset.manual = (row.dataset.garantieRetained ?? '').trim() !== '' ? '1' : '0';
      }
      syncRetainedFromEstimated();
      validateGarantieFormValues();

      closeDrawer();
      document.getElementById('garantie-form-card')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      garantieForm?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    };

    $$('[data-garantie-edit]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const row = btn.closest('[data-garantie-row]');
        fillGarantieForm(row);
      });
    });

    syncGarantieDocumentMeta(garantieExistingDocumentField instanceof HTMLInputElement ? garantieExistingDocumentField.value : '', '');
    openBtns.forEach((btn) => btn?.addEventListener('click', () => {
      resetGarantieFormState();
      openDrawer();
      garantieForm?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }));
    closeBtn?.addEventListener('click', closeDrawer);
    overlay?.addEventListener('click', closeDrawer);

    /* open if redirected back with panel=credit */
    if (new URLSearchParams(location.search).get('panel') === 'credit') {
      openDrawer();
    }

    /* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
       LANGUAGE SELECT (UI stub)
    â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
    const langSel = $('#cr-language');
    const savedLanguage = window.localStorage.getItem('nexora.portal.credits.language');
    if (langSel && savedLanguage && Array.from(langSel.options).some((option) => option.value === savedLanguage)) {
      langSel.value = savedLanguage;
      document.documentElement.lang = savedLanguage;
    }
    langSel?.addEventListener('change', () => {
      const selectedLabel = langSel.options[langSel.selectedIndex]?.textContent?.trim() || langSel.value;
      langSel.title = `Langue: ${selectedLabel}`;
      document.documentElement.lang = langSel.value;
      window.localStorage.setItem('nexora.portal.credits.language', langSel.value);
    });
  });
})();
</script>


