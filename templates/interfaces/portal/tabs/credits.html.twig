          getGarantieMessage('documentJustificatif'),
          garantieDocumentAnalysisState.message
        );
        return { ok: false, verdict: 'pending', message: garantieDocumentAnalysisState.message };
      }

      const token = ++garantieDocumentAnalysisToken;
      garantieDocumentAnalysisState.status = 'pending';
      garantieDocumentAnalysisState.fileKey = garantieDocFileKey(file);
      setGarantieAnalyzeStatus('pending', `${t('assistantThinking')}`);
      if (garantieDocumentAnalyzeBtn instanceof HTMLButtonElement) {
        garantieDocumentAnalyzeBtn.disabled = true;
      }

      try {
        const result = await analyzeGarantieDocumentFile(file);
        if (token !== garantieDocumentAnalysisToken) {
          return { ok: false, verdict: 'pending', message: 'Analyse obsol√®te.' };
        }
        garantieDocumentAnalysisState.status = 'done';
        garantieDocumentAnalysisState.verdict = String(result.verdict || (result.ok ? 'valide' : 'suspect'));
        garantieDocumentAnalysisState.message = String(result.message || '');
        garantieDocumentAnalysisState.blurScore = Number(result.blurScore || 0);
        garantieDocumentAnalysisState.width = Number(result.width || 0);
        garantieDocumentAnalysisState.height = Number(result.height || 0);
        setGarantieAnalyzeStatus(garantieDocumentAnalysisState.verdict);
        if (!result.ok) {
          setFieldError(garantieDocumentField, getGarantieMessage('documentJustificatif'), garantieDocumentAnalysisState.message);
        } else if (showOkMessage) {
          setFieldOk(garantieDocumentField, getGarantieMessage('documentJustificatif'));
