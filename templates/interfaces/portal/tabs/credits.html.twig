  color: #fff;
  box-shadow: 0 6px 18px rgba(21,101,192,.28);
}

.cr-hdr-btn-primary:hover { box-shadow: 0 8px 24px rgba(21,101,192,.38); opacity: .93; }

/* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
   KPI STRIP
   â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
.cr-kpi-strip {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14px;
  padding: 0;
  background: transparent;
}

.cr-kpi-card {
  display: flex;
  flex-direction: column;
  gap: 12px;
  background: #fff;
  border-radius: 16px;
  padding: 16px 18px 12px;
  border: 1px solid #dde8f5;
  box-shadow: 0 6px 20px rgba(23, 54, 84, 0.07);
  position: relative;
  overflow: hidden;
  transition: box-shadow .2s, transform .2s;
}

.cr-kpi-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3px;
  border-radius: 16px 16px 0 0;
}

.cr-kpi-card--amount::before { background: linear-gradient(90deg, #14b8a6, #0f766e); }
.cr-kpi-card--monthly::before { background: linear-gradient(90deg, #2563eb, #1d4ed8); }
.cr-kpi-card--active::before { background: linear-gradient(90deg, #16a34a, #22c55e); }
.cr-kpi-card--risk::before { background: linear-gradient(90deg, #ef4444, #dc2626); }

.cr-kpi-card:hover {
  box-shadow: 0 8px 24px rgba(10,37,64,.10);
  transform: translateY(-2px);
}

.cr-kpi-head {
  display: flex;
  align-items: center;
  gap: 10px;
}

.cr-kpi-icon {
  width: 44px;
  height: 44px;
  border-radius: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  color: #fff;
  flex-shrink: 0;
}

.cr-kpi-icon-blue  { background: linear-gradient(135deg, #1565c0, #1e88e5); }
.cr-kpi-icon-amber { background: linear-gradient(135deg, #f59e0b, #fbbf24); }
.cr-kpi-icon-green { background: linear-gradient(135deg, #16a34a, #22c55e); }
.cr-kpi-icon-red   { background: linear-gradient(135deg, #dc2626, #f87171); }
.cr-kpi-icon-teal  { background: linear-gradient(135deg, #0097a7, #00bcd4); }

.cr-kpi-copy {
  display: flex;
  flex-direction: column;
  gap: 2px;
  z-index: 1;
}

.cr-kpi-metric {
  display: flex;
  align-items: baseline;
  gap: 4px;
}

.cr-kpi-value {
  font-size: clamp(20px, 1.8vw, 28px);
  font-weight: 900;
  color: #0a2540;
  line-height: 1;
  letter-spacing: -0.3px;
}

.cr-kpi-unit {
  font-size: 12px;
  font-weight: 700;
  color: #7294ae;
}

.cr-kpi-label {
  font-size: 10px;
  color: #5d7d97;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

.cr-kpi-sub {
  font-size: 11px;
  color: #94aec2;
}

.cr-kpi-bar {
  height: 6px;
  border-radius: 999px;
  background: #e8eef5;
  overflow: hidden;
}

.cr-kpi-bar span {
  display: block;
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #14b8a6, #0f766e);
}

.cr-kpi-bar span.is-danger {
  background: linear-gradient(90deg, #ef4444, #dc2626);
}

/* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
   QUICK LINKS
   â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
.cr-quick-links {
  display: flex;
  align-items: stretch;
  gap: 10px;
  padding: 0 28px 16px;
  flex-wrap: wrap;
}

.cr-ql-item {
  display: flex;
  align-items: center;
  gap: 10px;
  background: #fff;
  border: 1px solid #dde8f5;
  border-radius: 12px;
  padding: 11px 16px;
  text-decoration: none;
  color: #1565c0;
  font-size: 13px;
  font-weight: 700;
  transition: all .18s;
  flex: 1;
  min-width: 160px;
  cursor: pointer;
  text-align: left;
  font-family: inherit;
  appearance: none;
}

.cr-ql-item:hover {
  background: linear-gradient(120deg, #1565c0, #00bcd4);
  color: #fff;
  border-color: transparent;
  box-shadow: 0 6px 18px rgba(21,101,192,.22);
  transform: translateY(-1px);
}

.cr-ql-icon {
  width: 30px;
  height: 30px;
  border-radius: 8px;
  background: #eaf2fd;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 13px;
  flex-shrink: 0;
  transition: background .18s;
}

.cr-ql-item:hover .cr-ql-icon {
  background: rgba(255,255,255,.2);
}

.cr-ql-label { flex: 1; }

.cr-ql-arrow {
  font-size: 11px;
  opacity: .5;
  transition: transform .18s, opacity .18s;
}

.cr-ql-item:hover .cr-ql-arrow {
  transform: translateX(4px);
  opacity: 1;
}

.cr-ql-item:focus-visible {
  outline: 2px solid #1e88e5;
  outline-offset: 2px;
}

/* modal quick tools */
.cr-tools-overlay {
  position: fixed;
  inset: 0;
  background: rgba(10, 37, 64, .48);
  backdrop-filter: blur(2px);
  z-index: 210;
}

.cr-tools-modal {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: min(1100px, calc(100vw - 44px));
  max-height: calc(100vh - 72px);
  background: #fff;
  border: 1px solid #d9e6f5;
  border-radius: 18px;
  box-shadow: 0 24px 60px rgba(10, 37, 64, .28);
  z-index: 211;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.cr-tools-overlay[hidden],
.cr-tools-modal[hidden] {
  display: none !important;
}

.cr-tools-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16px;
  padding: 18px 20px 14px;
  border-bottom: 1px solid #e8f0fb;
  background: linear-gradient(180deg, #f8fbff, #ffffff);
}

.cr-tools-header h3 {
  font-size: 18px;
  font-weight: 900;
  color: #0a2540;
}

.cr-tools-header p {
  margin-top: 4px;
  font-size: 12px;
  color: #6d8aa3;
}

.cr-tools-close {
  width: 34px;
  height: 34px;
  border-radius: 10px;
  border: 1px solid #dce8f6;
  background: #f4f8fd;
  color: #29527a;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  cursor: pointer;
}

.cr-tools-close:hover {
  background: #e8f1fc;
}

.cr-tools-tabs {
  display: flex;
  gap: 8px;
  padding: 10px 16px;
  border-bottom: 1px solid #e8f0fb;
  overflow-x: auto;
  background: #fff;
}

.cr-tools-tab {
  border: 1px solid #d9e7f6;
  background: #f5f9fe;
  color: #2f5f87;
  border-radius: 999px;
  padding: 7px 12px;
  font-size: 12px;
  font-weight: 700;
  cursor: pointer;
  white-space: nowrap;
}

.cr-tools-tab.is-active,
.cr-tools-tab:hover {
  background: linear-gradient(120deg, #1565c0, #1e88e5);
  border-color: transparent;
  color: #fff;
}

.cr-tools-body {
  padding: 16px;
  overflow: auto;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.cr-tool-panel {
  display: none;
}

.cr-tool-panel.is-active {
  display: block;
}

.cr-tool-grid-2 {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12px;
}

.cr-tool-card {
  border: 1px solid #dbe8f5;
  border-radius: 14px;
  background: #f8fbff;
  padding: 14px;
}

.cr-tool-card h4 {
  font-size: 14px;
  font-weight: 900;
  color: #0a2540;
  margin-bottom: 10px;
}

.cr-tool-fields {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10px;
}

.cr-tool-field {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.cr-tool-field span {
  font-size: 11px;
  font-weight: 700;
  color: #567a97;
}

.cr-tool-field input,
.cr-tool-field select,
.cr-tool-field textarea {
  width: 100%;
  min-height: 38px;
  border: 1px solid #d7e6f7;
  border-radius: 10px;
  background: #fff;
  color: #0a2540;
  font-size: 13px;
  padding: 8px 10px;
  font-family: inherit;
}

.cr-tool-field textarea {
  min-height: 88px;
  resize: vertical;
}

.cr-tool-kpis {
  margin-top: 12px;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 8px;
}

.cr-tool-kpis > div {
  display: flex;
  flex-direction: column;
  gap: 2px;
  border: 1px solid #e1ecf9;
  background: #fff;
  border-radius: 10px;
  padding: 8px 10px;
}

.cr-tool-kpis span {
  font-size: 10px;
  color: #6b87a0;
  text-transform: uppercase;
  font-weight: 700;
  letter-spacing: .4px;
}

.cr-tool-kpis strong {
  font-size: 14px;
  color: #0a2540;
  font-weight: 900;
}

.cr-tool-result {
  margin-top: 12px;
  border: 1px dashed #c4d8ef;
  border-radius: 12px;
  padding: 11px;
  background: #f5f9ff;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 8px;
}

.cr-tool-result > div {
  display: flex;
  flex-direction: column;
  gap: 3px;
}

.cr-tool-result span {
  font-size: 10px;
  color: #5b7a96;
  text-transform: uppercase;
  font-weight: 700;
}

.cr-tool-result strong {
  font-size: 14px;
  color: #0a2540;
  font-weight: 900;
}

.cr-tool-bar {
  margin-top: 10px;
  height: 9px;
  background: #e5eef8;
  border-radius: 999px;
  overflow: hidden;
}

.cr-tool-bar-fill {
  display: block;
  height: 100%;
  width: 0;
  background: linear-gradient(120deg, #16a34a, #22c55e);
  transition: width .2s;
}

.cr-tool-note {
  margin-top: 10px;
  font-size: 12px;
  color: #486a88;
  line-height: 1.45;
}

.cr-tool-table-wrap {
  border: 1px solid #dae8f6;
  border-radius: 12px;
  overflow: auto;
  background: #fff;
}

.cr-tool-table {
  width: 100%;
  border-collapse: collapse;
  min-width: 640px;
}

.cr-tool-table th,
.cr-tool-table td {
  padding: 9px 10px;
  border-bottom: 1px solid #edf3fb;
  text-align: left;
  white-space: nowrap;
  font-size: 12px;
}

.cr-tool-table th {
  background: #f5f9fe;
  color: #3a6488;
  font-weight: 800;
}

.cr-tool-empty {
  border: 1px dashed #c4d8ef;
  background: #f5f9ff;
  color: #567b99;
  border-radius: 12px;
  padding: 28px;
  text-align: center;
  font-weight: 700;
}

.cr-tool-actions {
  margin-top: 10px;
  display: flex;
  justify-content: flex-end;
}

.cr-tool-answer {
  margin-top: 10px;
  border: 1px solid #dbe8f5;
  border-radius: 12px;
  background: #fff;
  padding: 12px;
  min-height: 66px;
  color: #1f4363;
  font-size: 13px;
  line-height: 1.45;
}

.cr-ai-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 10px;
}

.cr-ai-chip {
  border: 1px solid #d7e6f7;
  background: #edf5ff;
  color: #1d4f7a;
  border-radius: 999px;
  font-size: 11px;
  font-weight: 700;
  padding: 7px 10px;
  cursor: pointer;
}

.cr-ai-chip:hover {
  background: #dcecff;
}

/* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
   SPLIT LAYOUT
   â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
.cr-split {
  display: grid;
  grid-template-columns: 420px 1fr;
  gap: 16px;
  padding: 0 28px 28px;
  align-items: start;
}

/* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
   FORM COLUMN
   â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
.cr-form-col {
  position: sticky;
  top: 76px;
}

.cr-form-card {
  background: #fff;
  border-radius: 20px;
  border: 1px solid #dde8f5;
  box-shadow: 0 4px 24px rgba(10,37,64,.07);
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

/* â”€â”€ Form Card Header â”€â”€ */
.cr-form-card-header {
  background: linear-gradient(135deg, #0a2540 0%, #1565c0 100%);
  padding: 22px 22px 0;
}

.cr-form-card-header-top {
  display: flex;
  align-items: flex-start;
  gap: 14px;
  padding-bottom: 18px;
}

.cr-fch-icon {
  width: 44px;
  height: 44px;
  border-radius: 14px;
  background: rgba(255,255,255,.15);
  border: 1px solid rgba(255,255,255,.25);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 17px;
  flex-shrink: 0;
}

.cr-fch-title {
  font-size: 17px;
  font-weight: 800;
  color: #fff;
  line-height: 1.2;
}

.cr-fch-sub {
  font-size: 12px;
  color: rgba(255,255,255,.68);
  margin-top: 3px;
}

.cr-form-collapse-btn {
  margin-left: auto;
  width: 32px;
  height: 32px;
  border-radius: 9px;
  background: rgba(255,255,255,.1);
  border: 1px solid rgba(255,255,255,.2);
  color: rgba(255,255,255,.8);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  font-size: 12px;
  flex-shrink: 0;
  transition: background .15s;
}

.cr-form-collapse-btn:hover { background: rgba(255,255,255,.2); }

/* â”€â”€ Steps indicator â”€â”€ */
.cr-form-steps {
  display: flex;
  align-items: center;
  padding: 0 4px 0;
}

.cr-step {
  display: flex;
  align-items: center;
  gap: 7px;
  padding: 10px 0;
  cursor: default;
  opacity: 0.5;
  transition: opacity .2s;
}

.cr-step.cr-step-active { opacity: 1; }

.cr-step-dot {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  border: 2px solid rgba(255,255,255,.4);
  color: rgba(255,255,255,.7);
  font-size: 11px;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all .2s;
}

.cr-step.cr-step-active .cr-step-dot {
  background: #fff;
  color: #1565c0;
  border-color: #fff;
}

.cr-step.cr-step-done .cr-step-dot {
  background: #00bcd4;
  color: #fff;
  border-color: #00bcd4;
}

.cr-step span {
  font-size: 11px;
  font-weight: 700;
  color: rgba(255,255,255,.75);
  white-space: nowrap;
}

.cr-step.cr-step-active span { color: #fff; }

.cr-step-line {
  flex: 1;
  height: 1px;
  background: rgba(255,255,255,.2);
  margin: 0 8px;
}

/* â”€â”€ Form body â”€â”€ */
.cr-form {
  display: flex;
  flex-direction: column;
}

.cr-form-step-body {
  padding: 20px 20px 4px;
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.cr-form-step-body[hidden] {
  display: none !important;
}

.cr-field-group {
  display: grid;
  gap: 12px;
}

.cr-field-group-2 { grid-template-columns: 1fr 1fr; }

.cr-field {
  display: flex;
  flex-direction: column;
  gap: 5px;
}

.cr-field-label {
  font-size: 11px;
  font-weight: 700;
  color: #4e7490;
  display: flex;
  align-items: center;
  gap: 5px;
}

.cr-field-label i { color: #1565c0; font-size: 10px; }

.cr-req { color: #e53935; }

.cr-input {
  width: 100%;
  min-height: 40px;
  border-radius: 11px;
  border: 1.5px solid #ccddef;
  background: #f7faff;
  padding: 0 12px;
  font: inherit;
  font-size: 13px;
  color: #0a2540;
  outline: none;
  appearance: none;
  transition: border-color .18s, box-shadow .18s;
}

.cr-input:focus {
  border-color: #1e88e5;
  background: #fff;
  box-shadow: 0 0 0 3px rgba(30,136,229,.12);
}

.cr-input::placeholder { color: #aabece; font-size: 12px; }

.cr-select { cursor: pointer; padding-right: 30px; }

.cr-select-wrap { position: relative; }

.cr-select-icon {
  position: absolute;
  right: 11px;
  top: 50%;
  transform: translateY(-50%);
  color: #8aafc8;
  font-size: 10px;
  pointer-events: none;
}

/* Prefixed input */
.cr-input-pfx-wrap { position: relative; }

.cr-input-pfx {
  position: absolute;
  left: 0;
  top: 0;
  height: 100%;
  padding: 0 10px;
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #1565c0, #1e88e5);
  color: #fff;
  font-size: 10px;
  font-weight: 800;
  border-radius: 11px 0 0 11px;
  letter-spacing: 0.3px;
  z-index: 1;
  white-space: nowrap;
}

.cr-input-pfx-auto {
  background: linear-gradient(135deg, #00838f, #00bcd4);
}

.cr-input-pfx-field { padding-left: 52px; }

/* Auto fields styling */
.cr-auto-field { background: #f0fbfd; color: #006064; font-weight: 700; }

/* â”€â”€ Calculator preview â”€â”€ */
.cr-calc-preview {
  background: linear-gradient(135deg, #f0f9ff, #e0f7fa);
  border: 1px solid #b2ebf2;
  border-radius: 14px;
  padding: 14px 16px;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.cr-calc-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.cr-calc-row span {
  font-size: 12px;
  color: #006064;
  font-weight: 600;
}

.cr-calc-row strong {
  font-size: 13px;
  font-weight: 800;
  color: #00838f;
}

/* â”€â”€ Analyze block â”€â”€ */
.cr-analyze-block {
  background: linear-gradient(135deg, #fffbeb, #fef3c7);
  border: 1px solid #fde68a;
  border-radius: 14px;
  padding: 14px 16px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.cr-analyze-header {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 12px;
  font-weight: 700;
  color: #92400e;
}

.cr-analyze-header i { color: #d97706; }

.cr-analyze-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  min-height: 38px;
  padding: 0 16px;
  border-radius: 10px;
  background: linear-gradient(120deg, #d97706, #f59e0b);
  color: #fff;
  font: inherit;
  font-size: 12px;
  font-weight: 700;
  border: none;
  cursor: pointer;
  transition: opacity .15s, transform .15s;
  width: fit-content;
}

.cr-analyze-btn:hover { opacity: .9; transform: scale(.98); }

.cr-analysis-output {
  font-size: 12px;
  font-weight: 600;
  padding: 8px 12px;
  border-radius: 8px;
  line-height: 1.5;
}

.cr-analysis-output.is-ok   { background: #d1fae5; color: #065f46; }
.cr-analysis-output.is-warn { background: #fef3c7; color: #92400e; }
.cr-analysis-output.is-risk { background: #fee2e2; color: #991b1b; }

/* â”€â”€ Step navigation â”€â”€ */
.cr-step-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 0 18px;
  border-top: 1px solid #edf4fb;
  margin-top: 6px;
}

.cr-step-nav-final { flex-direction: column; gap: 10px; align-items: stretch; }

.cr-step-btn {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  min-height: 38px;
  padding: 0 16px;
  border-radius: 10px;
  font: inherit;
  font-size: 13px;
  font-weight: 700;
  cursor: pointer;
  border: none;
  transition: all .15s;
}

.cr-step-next {
  background: linear-gradient(120deg, #1565c0, #1e88e5);
  color: #fff;
}

.cr-step-back {
  background: #f0f4f8;
  color: #5b80a0;
  border: 1px solid #dde8f5;
}

.cr-step-back:hover { background: #e2ecf8; }
.cr-step-next:hover { opacity: .9; }

.cr-final-actions {
  display: flex;
  gap: 10px;
}

.cr-submit-btn {
  flex: 1;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  min-height: 44px;
  padding: 0 20px;
  border-radius: 12px;
  background: linear-gradient(120deg, #1565c0, #00bcd4);
  color: #fff;
  font: inherit;
  font-size: 14px;
  font-weight: 800;
  border: none;
  cursor: pointer;
  box-shadow: 0 6px 20px rgba(21,101,192,.28);
  transition: all .18s;
}

.cr-submit-btn:hover { opacity: .92; box-shadow: 0 8px 24px rgba(21,101,192,.38); }

.cr-submit-btn-sm { min-height: 38px; font-size: 13px; }

.cr-form-reset-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 7px;
  min-height: 44px;
  padding: 0 16px;
  border-radius: 12px;
  background: transparent;
  border: 1.5px solid #cddff0;
  color: #5b80a0;
  font: inherit;
  font-size: 13px;
  font-weight: 700;
  cursor: pointer;
  transition: all .15s;
}

.cr-form-reset-btn:hover { background: #f0f4f8; }

/* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
   TABLE COLUMN
   â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
.cr-table-col {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

/* â”€â”€ Toolbar â”€â”€ */
.cr-table-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  background: #fff;
  border-radius: 16px;
  padding: 14px 18px;
  border: 1px solid #dde8f5;
  box-shadow: 0 2px 10px rgba(10,37,64,.05);
  flex-wrap: wrap;
}

.cr-table-toolbar-left {
  display: flex;
  align-items: center;
  gap: 10px;
}

.cr-table-title {
  font-size: 17px;
  font-weight: 800;
  color: #0a2540;
  display: flex;
  align-items: center;
  gap: 9px;
}

.cr-table-title i { color: #1565c0; }

.cr-table-count-badge {
  padding: 3px 10px;
  border-radius: 999px;
  background: linear-gradient(120deg, #1565c0, #1e88e5);
  color: #fff;
  font-size: 11px;
  font-weight: 800;
}

.cr-table-toolbar-right {
  display: flex;
  align-items: center;
  gap: 10px;
}

.cr-search-box {
  display: flex;
  align-items: center;
  gap: 8px;
  background: #f7faff;
  border: 1.5px solid #cddff0;
  border-radius: 11px;
  padding: 0 12px;
  min-height: 40px;
  transition: border-color .18s;
}

.cr-search-box:focus-within {
  border-color: #1e88e5;
  box-shadow: 0 0 0 3px rgba(30,136,229,.10);
}

.cr-search-box i { color: #8aafc8; font-size: 12px; }

.cr-search-box input {
  border: none;
  outline: none;
  background: transparent;
  font: inherit;
  font-size: 13px;
  color: #0a2540;
  width: 190px;
}

.cr-search-box input::placeholder { color: #aabece; }

.cr-search-clear {
  width: 20px;
  height: 20px;
  border-radius: 50%;
  background: #e2ecf8;
  border: none;
  color: #5b80a0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 11px;
  cursor: pointer;
}

.cr-sort-wrap { min-width: 140px; }

.cr-sort-select { font-size: 12px; min-height: 40px; }

.cr-garanties-btn {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  min-height: 40px;
  padding: 0 14px;
  border-radius: 11px;
  background: linear-gradient(120deg, #0a2540, #1565c0);
  color: #fff;
  font: inherit;
  font-size: 12px;
  font-weight: 700;
  border: none;
  cursor: pointer;
  white-space: nowrap;
  transition: opacity .15s;
}

.cr-garanties-btn:hover { opacity: .88; }

.cr-garanties-btn.is-active-alt {
  background: linear-gradient(120deg, #eef5ff, #dbeafe);
  color: #1565c0;
  border: 1px solid #bfdbfe;
}

/* â”€â”€ Filter tabs â”€â”€ */
.cr-filter-tabs {
  display: flex;
  align-items: center;
  gap: 6px;
  background: #fff;
  border-radius: 14px;
  padding: 10px 14px;
  border: 1px solid #dde8f5;
  flex-wrap: wrap;
}

.cr-filter-tab {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  min-height: 34px;
  padding: 0 14px;
  border-radius: 9px;
  background: transparent;
  border: 1px solid transparent;
  font: inherit;
  font-size: 12px;
  font-weight: 700;
  color: #7294ae;
  cursor: pointer;
  transition: all .15s;
}

.cr-filter-tab:hover { background: #f0f4f8; color: #0a2540; }

.cr-filter-tab-active {
  background: linear-gradient(120deg, #1565c0, #1e88e5);
  color: #fff;
  box-shadow: 0 4px 12px rgba(21,101,192,.2);
}

.cr-filter-tab-active:hover { background: linear-gradient(120deg, #1565c0, #1e88e5); color: #fff; }

.cr-tab-count {
  background: rgba(255,255,255,.25);
  border-radius: 999px;
  padding: 1px 7px;
  font-size: 10px;
  font-weight: 800;
}

.cr-filter-tab:not(.cr-filter-tab-active) .cr-tab-count {
  background: #e8f0fb;
  color: #1565c0;
}

/* â”€â”€ Credits card grid â”€â”€ */
.cr-credits-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 14px;
}

/* â”€â”€ Single credit card â”€â”€ */
.cr-credit-card {
  background: #fff;
  border-radius: 18px;
  border: 1px solid #dde8f5;
  padding: 18px;
  display: flex;
  flex-direction: column;
  gap: 14px;
  box-shadow: 0 2px 12px rgba(10,37,64,.05);
  transition: box-shadow .2s, transform .2s, border-color .2s;
  position: relative;
  overflow: hidden;
}

.cr-credit-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: linear-gradient(90deg, #1565c0, #00bcd4);
}

.cr-credit-card:hover {
  box-shadow: 0 10px 32px rgba(10,37,64,.12);
  transform: translateY(-3px);
  border-color: #b8d4f0;
}

.cr-cc-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 8px;
}

.cr-cc-id { display: flex; flex-direction: column; gap: 3px; }

.cr-cc-id-label {
  font-size: 11px;
  font-weight: 800;
  color: #7294ae;
  letter-spacing: 0.3px;
}

.cr-cc-type {
  font-size: 15px;
  font-weight: 800;
  color: #0a2540;
}

/* Status badge on card */
.cr-cc-status {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  padding: 5px 11px;
  border-radius: 999px;
  font-size: 11px;
  font-weight: 800;
  white-space: nowrap;
  flex-shrink: 0;
}

.cr-status-green  { background: #dcfce7; color: #166534; }
.cr-status-red    { background: #fee2e2; color: #991b1b; }
.cr-status-amber  { background: #fef9c3; color: #854d0e; }

.cr-cc-amount-row {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 10px;
}

.cr-cc-amount {
  font-size: 26px;
  font-weight: 900;
  color: #0a2540;
  letter-spacing: -0.5px;
  line-height: 1;
}

.cr-cc-amount small {
  font-size: 12px;
  font-weight: 600;
  color: #7294ae;
  margin-left: 3px;
}

.cr-cc-monthly {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 2px;
}

.cr-cc-monthly-label {
  font-size: 10px;
  color: #aabece;
  text-transform: uppercase;
  letter-spacing: 0.4px;
  font-weight: 700;
}

.cr-cc-monthly-val {
  font-size: 13px;
  font-weight: 800;
  color: #1565c0;
}

.cr-cc-meta {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 10px 0;
  border-top: 1px solid #f0f4f8;
  border-bottom: 1px solid #f0f4f8;
}

.cr-cc-meta-item {
  display: flex;
  align-items: center;
  gap: 5px;
  font-size: 12px;
  color: #5b80a0;
  font-weight: 600;
}

.cr-cc-meta-item i { color: #1e88e5; font-size: 11px; }

.cr-cc-risk-row {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.cr-cc-risk-label {
  font-size: 10px;
  color: #aabece;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.4px;
}

.cr-cc-risk-bar-wrap {
  display: flex;
  align-items: center;
  gap: 10px;
}

.cr-cc-risk-bar {
  flex: 1;
  height: 6px;
  background: #e8f0f8;
  border-radius: 999px;
  overflow: hidden;
}

.cr-cc-risk-fill {
  height: 100%;
  border-radius: 999px;
  transition: width .6s ease;
}

.cr-risk-low    .cr-cc-risk-fill,
.cr-cc-risk-fill.cr-risk-low    { background: linear-gradient(90deg, #22c55e, #4ade80); }
.cr-risk-medium .cr-cc-risk-fill,
.cr-cc-risk-fill.cr-risk-medium { background: linear-gradient(90deg, #f59e0b, #fbbf24); }
.cr-risk-high   .cr-cc-risk-fill,
.cr-cc-risk-fill.cr-risk-high   { background: linear-gradient(90deg, #ef4444, #f87171); }

.cr-cc-risk-val {
  font-size: 11px;
  font-weight: 800;
  white-space: nowrap;
}

.cr-risk-low    { color: #166534; }
.cr-risk-medium { color: #854d0e; }
.cr-risk-high   { color: #991b1b; }

.cr-cc-actions {
  display: flex;
  align-items: center;
  gap: 8px;
}

.cr-cc-pdf-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 7px;
  min-height: 36px;
  padding: 0 14px;
  border-radius: 10px;
  background: linear-gradient(120deg, #ecfeff, #cffafe);
  color: #0f766e;
  font: inherit;
  font-size: 12px;
  font-weight: 700;
  border: 1px solid #99f6e4;
  text-decoration: none;
  transition: all .15s;
}

.cr-cc-pdf-btn:hover {
  background: linear-gradient(120deg, #0f766e, #14b8a6);
  color: #fff;
  border-color: transparent;
}

.cr-cc-edit-btn {
  flex: 1;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 7px;
  min-height: 36px;
  border-radius: 10px;
  background: linear-gradient(120deg, #e8f0fd, #dbeafe);
  color: #1565c0;
  font: inherit;
  font-size: 12px;
  font-weight: 700;
  border: 1px solid #c3d9f5;
  cursor: pointer;
  transition: all .15s;
}

.cr-cc-edit-btn:hover {
  background: linear-gradient(120deg, #1565c0, #1e88e5);
  color: #fff;
  border-color: transparent;
}

.cr-cc-delete-form { display: flex; }

.cr-cc-delete-btn {
  width: 36px;
  height: 36px;
  border-radius: 10px;
  background: #fff0f0;
  border: 1px solid #fecaca;
  color: #dc2626;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  font-size: 13px;
  transition: all .15s;
}

.cr-cc-delete-btn:hover { background: #dc2626; color: #fff; }

/* â”€â”€ Empty state â”€â”€ */
.cr-empty-state {
  grid-column: 1 / -1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
  padding: 60px 20px;
  background: #fff;
  border-radius: 18px;
  border: 1px dashed #c4d9ee;
  text-align: center;
}

.cr-empty-icon {
  width: 70px;
  height: 70px;
  border-radius: 50%;
  background: linear-gradient(135deg, #eaf2fd, #dbeafe);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
  color: #7294ae;
}

.cr-empty-state strong { font-size: 17px; color: #0a2540; }
.cr-empty-state span { font-size: 13px; color: #7294ae; max-width: 300px; }

.cr-empty-cta {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  min-height: 40px;
  padding: 0 20px;
  border-radius: 12px;
  background: linear-gradient(120deg, #1565c0, #1e88e5);
  color: #fff;
  font: inherit;
  font-size: 13px;
  font-weight: 700;
  border: none;
  cursor: pointer;
  margin-top: 6px;
  transition: opacity .15s;
}

.cr-empty-cta:hover { opacity: .88; }

/* â”€â”€ Table footer â”€â”€ */
.cr-table-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 10px;
  background: #fff;
  border-radius: 14px;
  padding: 13px 18px;
  border: 1px solid #dde8f5;
}

.cr-tf-stat {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  font-size: 12px;
  color: #7294ae;
  font-weight: 600;
}

.cr-tf-stat i { color: #1565c0; }
.cr-tf-stat strong { color: #0a2540; }

.cr-tf-refresh {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  font-size: 12px;
  font-weight: 700;
  color: #1565c0;
  text-decoration: none;
  padding: 6px 14px;
  border-radius: 9px;
  background: #eaf2fd;
  border: 1px solid #c3d9f5;
  transition: all .15s;
}

.cr-tf-refresh:hover { background: #1565c0; color: #fff; }

/* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
   GARANTIES DRAWER
   â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
.cr-drawer-overlay {
  position: fixed;
  inset: 0;
  background: rgba(10,37,64,.4);
  backdrop-filter: blur(4px);
  z-index: 200;
}

.cr-drawer {
  position: fixed;
  top: 0;
  right: 0;
  width: min(680px, 100vw);
  height: 100vh;
  background: #fff;
  border-left: 1px solid #dde8f5;
  box-shadow: -8px 0 40px rgba(10,37,64,.15);
  z-index: 201;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* hidden attribute must win against class display rules */
.cr-drawer-overlay[hidden],
.cr-drawer[hidden] {
  display: none !important;
}

.cr-drawer-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  padding: 20px 24px;
  background: linear-gradient(135deg, #0a2540, #1565c0);
}

.cr-drawer-header-left {
  display: flex;
  align-items: center;
  gap: 14px;
}

.cr-drawer-icon {
  width: 44px;
  height: 44px;
  border-radius: 14px;
  background: rgba(255,255,255,.15);
  border: 1px solid rgba(255,255,255,.25);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 18px;
  flex-shrink: 0;
}

.cr-drawer-header h3 {
  font-size: 16px;
  font-weight: 800;
  color: #fff;
}

.cr-drawer-header p {
  font-size: 12px;
  color: rgba(255,255,255,.68);
  margin-top: 3px;
}

