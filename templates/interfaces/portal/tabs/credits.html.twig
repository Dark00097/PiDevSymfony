{% set current_date = 'now'|date('Y-m-d') %}
{% set garanties = support.garanties|default([]) %}
{% set pending_total = 0 %}
{% set accepted_total = 0 %}
{% set refused_total = 0 %}
{% set average_risk = 0 %}
{% set risk_sum = 0 %}
{% set total_amount = 0 %}
{% set total_monthly = 0 %}
{% set current_month = 'now'|date('Y-m') %}
{% set credits_month = 0 %}
{% set max_credit_id = 0 %}
{% for item in items %}
    {% set status_key = item.statut|default('')|lower %}
    {% if 'attente' in status_key %}
        {% set pending_total = pending_total + 1 %}
    {% endif %}
    {% if 'accepte' in status_key or 'cours' in status_key or 'approved' in status_key %}
        {% set accepted_total = accepted_total + 1 %}
    {% endif %}
    {% if 'refuse' in status_key %}
        {% set refused_total = refused_total + 1 %}
    {% endif %}
    {% set risk_sum = risk_sum + (item.risk_score|default(0)) %}
    {% set total_amount = total_amount + (item.montantDemande|default(0)) %}
    {% set total_monthly = total_monthly + (item.mensualite|default(0)) %}
    {% if item.idCredit|default(0) > max_credit_id %}
        {% set max_credit_id = item.idCredit %}
    {% endif %}
    {% if item.dateDemande is not empty and item.dateDemande|date('Y-m') == current_month %}
        {% set credits_month = credits_month + 1 %}
    {% endif %}
{% endfor %}
{% set next_credit_id = max_credit_id + 1 %}
{% if items|length > 0 %}
    {% set average_risk = (risk_sum / items|length)|round(1, 'common') %}
{% endif %}

<div class="cr-root">

    <section class="cr-hero">
        <div class="cr-hero-main">
            <div class="cr-hero-brand">
                <div class="cr-hero-icon">
                    <i class="fa-solid fa-hand-holding-dollar"></i>
                </div>
                <div class="cr-hero-copy">
                    <h1>Gestion des credits</h1>
                    <p>Demandez des prets, gerez vos credits et suivez les remboursements</p>
                </div>
            </div>

            <div class="cr-hero-center">
                <div class="cr-hero-stat">
                    <span class="cr-hero-stat-num">{{ items|length }}</span>
                    <span class="cr-hero-stat-lbl">Total dossiers</span>
                </div>
                <div class="cr-hero-divider"></div>
                <div class="cr-hero-stat">
                    <span class="cr-hero-stat-num">{{ credits_month }}</span>
                    <span class="cr-hero-stat-lbl">Ce mois</span>
                </div>
                <div class="cr-hero-divider"></div>
                <div class="cr-hero-stat">
                    <span class="cr-hero-stat-num">{{ pending_total }}</span>
                    <span class="cr-hero-stat-lbl">En attente</span>
                </div>
            </div>

            <div class="cr-hero-nav">
                <button type="button" class="cr-nav-pill" data-tool-open="history">
                    <i class="fa-solid fa-clock-rotate-left"></i><span>Historique</span>
                </button>
                <button type="button" class="cr-nav-pill" id="cr-open-garanties">
                    <i class="fa-solid fa-shield-halved"></i><span>Garanties</span>
                </button>
                <button type="button" class="cr-nav-pill cr-nav-pill--cta" id="cr-add-credit-btn">
                    <i class="fa-solid fa-plus"></i><span>Nouveau</span>
                </button>
        </div>

        <div class="cr-hero-toolbar">
            <div class="cr-hero-toolbar-right">
                <label class="cr-lang-select">
                    <i class="fa-solid fa-globe"></i>
                    <select id="cr-language">
                        <option>Francais</option>
                        <option>English</option>
                        <option>Arabic</option>
                    </select>
                </label>
                <button class="cr-topbar-btn" id="cr-dark-toggle" type="button">
                    <i class="fa-solid fa-moon"></i>
                </button>
                <a class="cr-topbar-btn" href="{{ path(route_name, { tab: 'credits' }) }}" title="Actualiser">
                    <i class="fa-solid fa-rotate"></i>
                </a>
                <div class="cr-user-chip">
                    <div class="cr-user-avatar">
                        {{ current_user.prenom|first|upper }}{{ current_user.nom|first|upper }}
                    </div>
                    <div class="cr-user-info">
                        <strong>{{ current_user.prenom }} {{ current_user.nom }}</strong>
                        <small>#{{ current_user.idUser }}</small>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div class="cr-kpi-strip">
        <div class="cr-kpi-card cr-kpi-card--amount">
            <div class="cr-kpi-head">
                <div class="cr-kpi-icon cr-kpi-icon-teal">
                    <i class="fa-solid fa-coins"></i>
                </div>
                <div class="cr-kpi-copy">
                    <span class="cr-kpi-label">Montant demande</span>
                    <span class="cr-kpi-sub">Volume global</span>
                </div>
            </div>
            <div class="cr-kpi-metric">
                <strong class="cr-kpi-value">{{ total_amount|number_format(2, '.', ' ') }}</strong>
                <span class="cr-kpi-unit">DT</span>
            </div>
            <div class="cr-kpi-bar"><span style="width:100%"></span></div>
        </div>
        <div class="cr-kpi-card cr-kpi-card--monthly">
            <div class="cr-kpi-head">
                <div class="cr-kpi-icon cr-kpi-icon-blue">
                    <i class="fa-solid fa-calendar-check"></i>
                </div>
                <div class="cr-kpi-copy">
                    <span class="cr-kpi-label">Mensualites</span>
                    <span class="cr-kpi-sub">Charge cumulee</span>
                </div>
            </div>
            <div class="cr-kpi-metric">
                <strong class="cr-kpi-value">{{ total_monthly|number_format(2, '.', ' ') }}</strong>
                <span class="cr-kpi-unit">DT</span>
            </div>
            <div class="cr-kpi-bar"><span style="width:{{ total_amount > 0 ? ((total_monthly / total_amount) * 100)|round : 0 }}%"></span></div>
        </div>
        <div class="cr-kpi-card cr-kpi-card--active">
            <div class="cr-kpi-head">
                <div class="cr-kpi-icon cr-kpi-icon-green">
                    <i class="fa-solid fa-circle-check"></i>
                </div>
                <div class="cr-kpi-copy">
                    <span class="cr-kpi-label">Acceptes / Actifs</span>
                    <span class="cr-kpi-sub">Dossiers valides</span>
                </div>
            </div>
            <div class="cr-kpi-metric">
                <strong class="cr-kpi-value">{{ accepted_total }}</strong>
                <span class="cr-kpi-unit">credits</span>
            </div>
            <div class="cr-kpi-bar"><span style="width:{{ items|length > 0 ? ((accepted_total / items|length) * 100)|round : 0 }}%"></span></div>
        </div>
        <div class="cr-kpi-card cr-kpi-card--risk">
            <div class="cr-kpi-head">
                <div class="cr-kpi-icon cr-kpi-icon-red">
                    <i class="fa-solid fa-triangle-exclamation"></i>
                </div>
                <div class="cr-kpi-copy">
                    <span class="cr-kpi-label">Risque moyen</span>
                    <span class="cr-kpi-sub">Evaluation portefeuille</span>
                </div>
            </div>
            <div class="cr-kpi-metric">
                <strong class="cr-kpi-value">{{ average_risk }}</strong>
                <span class="cr-kpi-unit">/100</span>
            </div>
            <div class="cr-kpi-bar"><span class="is-danger" style="width:{{ average_risk > 100 ? 100 : average_risk }}%"></span></div>
        </div>
    </div>
    {# â”€â”€ MAIN SPLIT LAYOUT â”€â”€ #}
    <div class="cr-tools-overlay" id="cr-tools-overlay" hidden></div>
    <section class="cr-tools-modal" id="cr-tools-modal" hidden role="dialog" aria-modal="true" aria-labelledby="cr-tools-title">
        <header class="cr-tools-header">
            <div>
                <h3 id="cr-tools-title">Simuler & Comparer</h3>
                <p id="cr-tools-subtitle">Analysez vos credits sans quitter cette page.</p>
            </div>
            <button class="cr-tools-close" id="cr-tools-close" type="button" aria-label="Fermer">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </header>

        <nav class="cr-tools-tabs" id="cr-tools-tabs">
            <button type="button" class="cr-tools-tab is-active" data-tool-tab="simulate">Simulation</button>
            <button type="button" class="cr-tools-tab" data-tool-tab="history">Historique</button>

            <button type="button" class="cr-tools-tab" data-tool-tab="ratio">Endettement</button>
            <button type="button" class="cr-tools-tab" data-tool-tab="projection">Projection</button>
            <button type="button" class="cr-tools-tab" data-tool-tab="restruct">Restructuration</button>
            <button type="button" class="cr-tools-tab" data-tool-tab="assistant">Assistant IA</button>
        </nav>

        <div class="cr-tools-body">
            <section class="cr-tool-panel is-active" data-tool-panel="simulate">
                <div class="cr-tool-grid-2">
                    <article class="cr-tool-card">
                        <h4>Scenario A</h4>
                        <div class="cr-tool-fields">
                            <label class="cr-tool-field">
                                <span>Montant (DT)</span>
                                <input type="number" step="0.01" min="0" id="cr-sim-a-amount" value="{{ items|length > 0 ? (items[0].montantDemande|default(10000)) : 10000 }}">
                            </label>
                            <label class="cr-tool-field">
                                <span>Duree (mois)</span>
                                <input type="number" min="1" id="cr-sim-a-duration" value="{{ items|length > 0 ? (items[0].duree|default(36)) : 36 }}">
                            </label>
                            <label class="cr-tool-field">
                                <span>Taux annuel (%)</span>
                                <input type="number" step="0.01" min="0" id="cr-sim-a-rate" value="{{ items|length > 0 ? (items[0].tauxInteret|default(8)) : 8 }}">
                            </label>
                        </div>
                        <div class="cr-tool-kpis">
                            <div><span>Mensualite</span><strong id="cr-sim-a-monthly">0.00 DT</strong></div>
                            <div><span>Cout total</span><strong id="cr-sim-a-total">0.00 DT</strong></div>
                            <div><span>Interets</span><strong id="cr-sim-a-interest">0.00 DT</strong></div>
                        </div>
                    </article>

                    <article class="cr-tool-card">
                        <h4>Scenario B</h4>
                        <div class="cr-tool-fields">
                            <label class="cr-tool-field">
                                <span>Montant (DT)</span>
                                <input type="number" step="0.01" min="0" id="cr-sim-b-amount" value="{{ items|length > 0 ? (items[0].montantDemande|default(10000)) : 10000 }}">
                            </label>
                            <label class="cr-tool-field">
                                <span>Duree (mois)</span>
                                <input type="number" min="1" id="cr-sim-b-duration" value="{{ items|length > 0 ? ((items[0].duree|default(36)) + 12) : 48 }}">
                            </label>
                            <label class="cr-tool-field">
                                <span>Taux annuel (%)</span>
                                <input type="number" step="0.01" min="0" id="cr-sim-b-rate" value="{{ items|length > 0 ? (items[0].tauxInteret|default(8)) : 8 }}">
                            </label>
                        </div>
                        <div class="cr-tool-kpis">
                            <div><span>Mensualite</span><strong id="cr-sim-b-monthly">0.00 DT</strong></div>
                            <div><span>Cout total</span><strong id="cr-sim-b-total">0.00 DT</strong></div>
                            <div><span>Interets</span><strong id="cr-sim-b-interest">0.00 DT</strong></div>
                        </div>
                    </article>
                </div>

                <div class="cr-tool-result" id="cr-sim-compare">
                    <div><span>Difference mensualite</span><strong id="cr-sim-diff-monthly">0.00 DT</strong></div>
                    <div><span>Ecart interets</span><strong id="cr-sim-diff-interest">0.00 DT</strong></div>
                    <div><span>Scenario conseille</span><strong id="cr-sim-best">Aucun</strong></div>
                </div>
            </section>

            <section class="cr-tool-panel" data-tool-panel="history">
                {% if items|length > 0 %}
                    <div class="cr-tool-table-wrap">
                        <table class="cr-tool-table">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Type</th>
                                    <th>Montant</th>
                                    <th>Mensualite</th>
                                    <th>Statut</th>
                                    <th>Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for item in items %}
                                    <tr>
                                        <td>#{{ item.idCredit }}</td>
                                        <td>{{ item.typeCredit|default('-') }}</td>
                                        <td>{{ item.montantDemande|default(0)|number_format(2, '.', ' ') }} DT</td>
                                        <td>{{ item.mensualite|default(0)|number_format(2, '.', ' ') }} DT</td>
                                        <td>{{ item.statut|default('-') }}</td>
                                        <td>{{ item.dateDemande|default('-') }}</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% else %}
                    <div class="cr-tool-empty">Aucun historique credit disponible.</div>
                {% endif %}
            </section>

            <section class="cr-tool-panel" data-tool-panel="ratio">
                <div class="cr-tool-grid-2">
                    <article class="cr-tool-card">
                        <h4>Calcul du ratio d'endettement</h4>
                        <div class="cr-tool-fields">
                            <label class="cr-tool-field">
                                <span>Credit</span>
                                <select id="cr-ratio-credit">
                                    {% for item in items %}
                                        <option value="{{ item.idCredit }}" data-monthly="{{ item.mensualite|default(0) }}" data-salary="{{ item.salaire|default(0) }}">
                                            #{{ item.idCredit }} - {{ item.typeCredit|default('Credit') }}
                                        </option>
                                    {% else %}
                                        <option value="">Aucun credit</option>
                                    {% endfor %}
                                </select>
                            </label>
                            <label class="cr-tool-field">
                                <span>Salaire mensuel (DT)</span>
                                <input type="number" step="0.01" min="0" id="cr-ratio-salary" value="">
                            </label>
                        </div>
                    </article>

                    <article class="cr-tool-card">
                        <h4>Resultat</h4>
                        <div class="cr-tool-kpis">
                            <div><span>Mensualite</span><strong id="cr-ratio-monthly">0.00 DT</strong></div>
                            <div><span>Ratio</span><strong id="cr-ratio-percent">0.0%</strong></div>
                        </div>
                        <div class="cr-tool-bar">
                            <span class="cr-tool-bar-fill" id="cr-ratio-fill" style="width:0%;"></span>
                        </div>
                        <p class="cr-tool-note" id="cr-ratio-advice">Selectionnez un credit pour lancer l'analyse.</p>
                    </article>
                </div>
            </section>

            <section class="cr-tool-panel" data-tool-panel="projection">
                <div class="cr-tool-grid-2">
                    <article class="cr-tool-card">
                        <h4>Projection future</h4>
                        <div class="cr-tool-fields">
                            <label class="cr-tool-field">
                                <span>Credit</span>
                                <select id="cr-projection-credit">
                                    {% for item in items %}
                                        <option value="{{ item.idCredit }}" data-approved="{{ item.montantAccorde|default(item.montantDemande|default(0)) }}" data-monthly="{{ item.mensualite|default(0) }}" data-duration="{{ item.duree|default(0) }}" data-date="{{ item.dateDemande|default(current_date)|slice(0, 10) }}">
                                            #{{ item.idCredit }} - {{ item.typeCredit|default('Credit') }}
                                        </option>
                                    {% else %}
                                        <option value="">Aucun credit</option>
                                    {% endfor %}
                                </select>
                            </label>
                            <label class="cr-tool-field">
                                <span>Horizon (mois)</span>
                                <input type="number" min="1" id="cr-projection-months" value="12">
                            </label>
                        </div>
                    </article>

                    <article class="cr-tool-card">
                        <h4>Estimation</h4>
                        <div class="cr-tool-kpis">
                            <div><span>Montant paye</span><strong id="cr-projection-paid">0.00 DT</strong></div>
                            <div><span>Reste estime</span><strong id="cr-projection-remaining">0.00 DT</strong></div>
                            <div><span>Date cible</span><strong id="cr-projection-date">-</strong></div>
                        </div>
                        <div class="cr-tool-bar">
                            <span class="cr-tool-bar-fill" id="cr-projection-fill" style="width:0%;"></span>
                        </div>
                        <p class="cr-tool-note" id="cr-projection-progress">Progression estimee: 0%</p>
                    </article>
                </div>
            </section>

            <section class="cr-tool-panel" data-tool-panel="restruct">
                <div class="cr-tool-grid-2">
                    <article class="cr-tool-card">
                        <h4>Simulation de restructuration</h4>
                        <div class="cr-tool-fields">
                            <label class="cr-tool-field">
                                <span>Credit</span>
                                <select id="cr-restruct-credit">
                                    {% for item in items %}
                                        <option value="{{ item.idCredit }}" data-principal="{{ item.montantAccorde|default(item.montantDemande|default(0)) }}" data-rate="{{ item.tauxInteret|default(0) }}" data-duration="{{ item.duree|default(0) }}" data-monthly="{{ item.mensualite|default(0) }}">
                                            #{{ item.idCredit }} - {{ item.typeCredit|default('Credit') }}
                                        </option>
                                    {% else %}
                                        <option value="">Aucun credit</option>
                                    {% endfor %}
                                </select>
                            </label>
                            <label class="cr-tool-field">
                                <span>Nouvelle duree (mois)</span>
                                <input type="number" min="1" id="cr-restruct-duration" value="60">
                            </label>
                            <label class="cr-tool-field">
                                <span>Nouveau taux (%)</span>
                                <input type="number" step="0.01" min="0" id="cr-restruct-rate" value="6.50">
                            </label>
                        </div>
                    </article>

                    <article class="cr-tool-card">
                        <h4>Impact previsionnel</h4>
                        <div class="cr-tool-kpis">
                            <div><span>Mensualite actuelle</span><strong id="cr-restruct-current">0.00 DT</strong></div>
                            <div><span>Nouvelle mensualite</span><strong id="cr-restruct-new">0.00 DT</strong></div>
                            <div><span>Gain mensuel</span><strong id="cr-restruct-diff">0.00 DT</strong></div>
                            <div><span>Nouveau cout total</span><strong id="cr-restruct-total">0.00 DT</strong></div>
                        </div>
                    </article>
                </div>
            </section>

            <section class="cr-tool-panel" data-tool-panel="assistant">
                <article class="cr-tool-card">
                    <h4>Assistant IA Credit (mode local)</h4>
                    <p class="cr-tool-note">Reponses basees sur vos donnees affichees: {{ items|length }} credit(s), mensualites cumulees {{ total_monthly|number_format(2, '.', ' ') }} DT.</p>
                    <div class="cr-ai-chips">
                        <button type="button" class="cr-ai-chip" data-ai-question="Quel est mon niveau global de risque credit ?">Risque global</button>
                        <button type="button" class="cr-ai-chip" data-ai-question="Comment reduire mon ratio d'endettement ?">Reduire ratio</button>
                        <button type="button" class="cr-ai-chip" data-ai-question="Faut-il restructurer un credit ?">Restructuration</button>
                        <button type="button" class="cr-ai-chip" data-ai-question="Resume mon historique credits.">Resume historique</button>
                    </div>
                    <label class="cr-tool-field">
                        <span>Votre question</span>
                        <textarea id="cr-ai-question" rows="3" placeholder="Ex: Comment ameliorer ma capacite de remboursement ?"></textarea>
                    </label>
                    <div class="cr-tool-actions">
                        <button type="button" class="cr-hdr-btn cr-hdr-btn-primary" id="cr-ai-send">
                            <i class="fa-solid fa-paper-plane"></i>
                            Generer la reponse
                        </button>
                    </div>
                    <div class="cr-tool-answer" id="cr-ai-answer">
                        L'assistant affichera ici une recommandation concise adaptee a vos credits.
                    </div>
                </article>
            </section>
        </div>
    </section>
    <div class="cr-split">

        {# â”€â”€â”€ LEFT: FORM COLUMN â”€â”€â”€ #}
        <aside class="cr-form-col" id="cr-form-col">
            <div class="cr-form-card" id="credit-form-card">
                <div class="cr-form-card-header">
                    <div class="cr-form-card-header-top">
                        <div class="cr-fch-icon">
                            <i class="fa-solid fa-file-pen"></i>
                        </div>
                        <div>
                            <h2 class="cr-fch-title">Demande de Credit</h2>
                            <p class="cr-fch-sub">Remplissez le formulaire ci-dessous</p>
                        </div>
                        <button class="cr-form-collapse-btn" id="cr-collapse-form" type="button" title="Reduire">
                            <i class="fa-solid fa-chevron-left"></i>
                        </button>
                    </div>
                    <div class="cr-form-steps">
                        <div class="cr-step cr-step-active" data-step="1">
                            <div class="cr-step-dot">1</div>
                            <span>Identite</span>
                        </div>
                        <div class="cr-step-line"></div>
                        <div class="cr-step" data-step="2">
                            <div class="cr-step-dot">2</div>
                            <span>Financier</span>
                        </div>
                        <div class="cr-step-line"></div>
                        <div class="cr-step" data-step="3">
                            <div class="cr-step-dot">3</div>
                            <span>Profil</span>
                        </div>
                    </div>
                </div>

                <form method="post" class="cr-form" id="credit-form" novalidate>
                    <input type="hidden" name="tab" value="credits">
                    <input type="hidden" name="action" value="credit_save">

                    {# STEP 1 â€” Identity #}
                    <div class="cr-form-step-body" data-step-body="1">

                        <div class="cr-field-group">
                            <div class="cr-field">
                                <label class="cr-field-label">
                                    <i class="fa-solid fa-hashtag"></i> ID (auto)
                                </label>
                                <input class="cr-input" type="number" name="idCredit" id="cr-credit-id" placeholder="Laisser vide pour creer" readonly>
                            </div>
                        </div>

                        <div class="cr-field-group cr-field-group-2">
                            <div class="cr-field">
                                <label class="cr-field-label">
                                    <i class="fa-solid fa-building-columns"></i> Compte <span class="cr-req">*</span>
                                </label>
                                <div class="cr-select-wrap">
                                    <select class="cr-input cr-select" name="idCompte" id="cr-credit-account">
                                        <option value="">Selectionner</option>
                                        {% for account in support.accounts|default([]) %}
                                            <option value="{{ account.idCompte }}">{{ account.idCompte }} - {{ account.numeroCompte }}</option>
                                        {% endfor %}
                                    </select>
                                    <i class="fa-solid fa-chevron-down cr-select-icon"></i>
                                </div>
                                <span id="cr-err-idCompte" class="cr-val-msg"></span>
                            </div>
                            <div class="cr-field">
                                <label class="cr-field-label">
                                    <i class="fa-solid fa-tag"></i> Type de credit <span class="cr-req">*</span>
                                </label>
                                <div class="cr-select-wrap">
                                    <select class="cr-input cr-select" name="typeCredit" id="cr-credit-type">
                                        <option value="">Selectionner</option>
                                        <option value="Professionnel">Professionnel</option>
                                        <option value="Immobilier">Immobilier</option>
                                        <option value="Auto">Auto</option>
                                        <option value="Consommation">Consommation</option>
                                        <option value="Etudes">Etudes</option>
                                        <option value="Travaux">Travaux</option>
                                        <option value="Personnel">Personnel</option>
                                        <option value="Autre">Autre</option>
                                    </select>
                                    <i class="fa-solid fa-chevron-down cr-select-icon"></i>
                                </div>
                                <span id="cr-err-typeCredit" class="cr-val-msg"></span>
                            </div>
                        </div>

                        <div class="cr-field-group">
                            <div class="cr-field">
                                <label class="cr-field-label">
                                    <i class="fa-solid fa-calendar-day"></i> Date de demande <span class="cr-req">*</span>
                                </label>
                                <input class="cr-input" type="date" name="dateDemande" id="cr-credit-date" value="{{ current_date }}">
                                <span id="cr-err-dateDemande" class="cr-val-msg"></span>
                            </div>
                        </div>

                        <div class="cr-step-nav">
                            <span></span>
                            <button type="button" class="cr-step-btn cr-step-next" data-next="2">
                                Suivant <i class="fa-solid fa-arrow-right"></i>
                            </button>
                        </div>
                    </div>

                    {# STEP 2 â€” Financial #}
                    <div class="cr-form-step-body" data-step-body="2" hidden>

                        <div class="cr-field-group cr-field-group-2">
                            <div class="cr-field">
                                <label class="cr-field-label">
                                    <i class="fa-solid fa-money-bill-wave"></i> Montant demande (TND) <span class="cr-req">*</span>
                                </label>
                                <div class="cr-input-pfx-wrap">
                                    <span class="cr-input-pfx">TND</span>
                                    <input class="cr-input cr-input-pfx-field" type="number" step="0.01" min="0" name="montantDemande" id="cr-credit-amount" placeholder="0.00">
                                </div>
                                <span id="cr-err-montantDemande" class="cr-val-msg"></span>
                            </div>
                            <div class="cr-field">
                                <label class="cr-field-label">
                                    <i class="fa-solid fa-piggy-bank"></i> Autofinancement (TND)
                                </label>
                                <div class="cr-input-pfx-wrap">
                                    <span class="cr-input-pfx">TND</span>
                                    <input class="cr-input cr-input-pfx-field" type="number" step="0.01" min="0" name="autofinancement" id="cr-credit-auto" placeholder="0.00">
                                </div>
                                <span id="cr-err-autofinancement" class="cr-val-msg"></span>
                            </div>
                        </div>

                        <div class="cr-field-group cr-field-group-2">
                            <div class="cr-field">
                                <label class="cr-field-label">
                                    <i class="fa-solid fa-hourglass-half"></i> Duree (mois) <span class="cr-req">*</span>
                                </label>
                                <div class="cr-select-wrap">
                                    <select class="cr-input cr-select" name="duree" id="cr-credit-duree">
                                        <option value="">Selectionner</option>
                                        {% for month in [6, 12, 18, 24, 36, 48, 60, 72, 84, 120] %}
                                            <option value="{{ month }}" {{ month == 12 ? 'selected' : '' }}>{{ month }} mois</option>
                                        {% endfor %}
                                    </select>
                                    <i class="fa-solid fa-chevron-down cr-select-icon"></i>
                                </div>
                                <span id="cr-err-duree" class="cr-val-msg"></span>
                            </div>
                            <div class="cr-field">
                                <label class="cr-field-label">
                                    <i class="fa-solid fa-percent"></i> Taux TAEG (%) <span class="cr-req">*</span>
                                </label>
                                <input class="cr-input" type="number" step="0.01" min="0" name="tauxInteret" id="cr-credit-rate" value="3.5">
                                <span id="cr-err-tauxInteret" class="cr-val-msg"></span>
                            </div>
                        </div>

                        <div class="cr-field-group cr-field-group-2">
                            <div class="cr-field">
                                <label class="cr-field-label">
                                    <i class="fa-solid fa-calendar-check"></i> Mensualite estimee (TND)
                                </label>
                                <div class="cr-input-pfx-wrap">
                                    <span class="cr-input-pfx cr-input-pfx-auto">AUTO</span>
                                    <input class="cr-input cr-input-pfx-field cr-auto-field" type="number" step="0.01" min="0" name="mensualite" id="cr-credit-monthly" placeholder="Calcule auto">
                                </div>
                            </div>
                            <div class="cr-field">
                                <label class="cr-field-label">
                                    <i class="fa-solid fa-handshake"></i> Montant accorde (TND)
                                </label>
                                <div class="cr-input-pfx-wrap">
                                    <span class="cr-input-pfx cr-input-pfx-auto">AUTO</span>
                                    <input class="cr-input cr-input-pfx-field cr-auto-field" type="number" step="0.01" min="0" name="montantAccorde" id="cr-credit-approved" placeholder="Calcule auto">
                                </div>
                            </div>
                        </div>

                        {# Live calculator preview #}
                        <div class="cr-calc-preview" id="cr-calc-preview">
                            <div class="cr-calc-row">
                                <span>Mensualite estimee</span>
                                <strong id="cr-preview-monthly">-- DT</strong>
                            </div>
                            <div class="cr-calc-row">
                                <span>Cout total credit</span>
                                <strong id="cr-preview-total">-- DT</strong>
                            </div>
                            <div class="cr-calc-row">
                                <span>Cout interets</span>
                                <strong id="cr-preview-interest">-- DT</strong>
                            </div>
                        </div>

                        <div class="cr-step-nav">
                            <button type="button" class="cr-step-btn cr-step-back" data-back="1">
                                <i class="fa-solid fa-arrow-left"></i> Precedent
                            </button>
                            <button type="button" class="cr-step-btn cr-step-next" data-next="3">
                                Suivant <i class="fa-solid fa-arrow-right"></i>
                            </button>
                        </div>
                    </div>

                    {# STEP 3 â€” Profile #}
                    <div class="cr-form-step-body" data-step-body="3" hidden>

                        <div class="cr-field-group cr-field-group-2">
                            <div class="cr-field">
                                <label class="cr-field-label">
                                    <i class="fa-solid fa-wallet"></i> Salaire mensuel (TND) <span class="cr-req">*</span>
                                </label>
                                <div class="cr-input-pfx-wrap">
                                    <span class="cr-input-pfx">TND</span>
                                    <input class="cr-input cr-input-pfx-field" type="number" step="0.01" min="0" name="salaire" id="cr-credit-salary" placeholder="Ex: 2500">
                                </div>
                                <span id="cr-err-salaire" class="cr-val-msg"></span>
                            </div>
                            <div class="cr-field">
                                <label class="cr-field-label">
                                    <i class="fa-solid fa-briefcase"></i> Type de contrat <span class="cr-req">*</span>
                                </label>
                                <div class="cr-select-wrap">
                                    <select class="cr-input cr-select" name="typeContrat" id="cr-credit-contract">
                                        <option value="">Selectionner</option>
                                        <option value="CDI">CDI</option>
                                        <option value="CDD">CDD</option>
                                        <option value="Fonctionnaire">Fonctionnaire</option>
                                        <option value="Profession liberale">Profession liberale</option>
                                        <option value="Autre">Autre</option>
                                    </select>
                                    <i class="fa-solid fa-chevron-down cr-select-icon"></i>
                                </div>
                                <span id="cr-err-typeContrat" class="cr-val-msg"></span>
                            </div>
                        </div>

                        <div class="cr-field-group">
                            <div class="cr-field">
                                <label class="cr-field-label">
                                    <i class="fa-solid fa-medal"></i> Anciennete (annees) <span class="cr-req">*</span>
                                </label>
                                <input class="cr-input" type="number" min="0" name="ancienneteAnnees" id="cr-credit-seniority" placeholder="Ex: 3">
                                <span id="cr-err-ancienneteAnnees" class="cr-val-msg"></span>
                            </div>
                        </div>

                        {# Analysis block #}
                        <div class="cr-analyze-block">
                            <div class="cr-analyze-header">
                                <i class="fa-solid fa-brain"></i>
                                <span>Analyse automatique de capacite</span>
                            </div>
                            <button class="cr-analyze-btn" id="cr-credit-analyze" type="button">
                                <i class="fa-solid fa-chart-simple"></i>
                                Lancer l'analyse
                            </button>
                            <div class="cr-analysis-output" id="cr-analysis-output" hidden></div>
                        </div>

                        <div class="cr-step-nav cr-step-nav-final">
                            <button type="button" class="cr-step-btn cr-step-back" data-back="2">
                                <i class="fa-solid fa-arrow-left"></i> Precedent
                            </button>
                            <div class="cr-final-actions">
                                <button class="cr-form-reset-btn" type="reset">
                                    <i class="fa-solid fa-xmark"></i> Annuler
                                </button>
                                <button class="cr-submit-btn" type="submit">
                                    <i class="fa-solid fa-floppy-disk"></i>
                                    Enregistrer le credit
                                </button>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </aside>

        {# â”€â”€â”€ RIGHT: TABLE COLUMN â”€â”€â”€ #}
        <main class="cr-table-col" id="cr-table-section">

            {# Table toolbar #}
            <div class="cr-table-toolbar">
                <div class="cr-table-toolbar-left">
                    <h2 class="cr-table-title">
                        <i class="fa-solid fa-credit-card" id="cr-main-list-icon"></i>
                        <span id="cr-main-list-label">Mes Credits</span>
                    </h2>
                    <span class="cr-table-count-badge" id="cr-main-list-count">{{ items|length }}</span>
                </div>
                <div class="cr-table-toolbar-right">
                    <div class="cr-search-box">
                        <i class="fa-solid fa-magnifying-glass"></i>
                        <input type="text" id="cr-search-input" placeholder="Rechercher un credit...">
                        <button class="cr-search-clear" id="cr-search-clear" type="button" hidden>
                            <i class="fa-solid fa-xmark"></i>
                        </button>
                    </div>
                    <div class="cr-select-wrap cr-sort-wrap">
                        <select class="cr-input cr-select cr-sort-select" id="cr-sort-select">
                            <option value="id_desc">Plus recent</option>
                            <option value="id_asc">Plus ancien</option>
                            <option value="amount_high">Montant eleve</option>
                            <option value="amount_medium">Montant moyen</option>
                            <option value="amount_low">Montant faible</option>
                            <option value="risk_desc">Risque eleve</option>
                        </select>
                        <i class="fa-solid fa-chevron-down cr-select-icon"></i>
                    </div>
                    <button type="button" class="cr-garanties-btn" id="cr-open-garanties-inline">
                        <i class="fa-solid fa-shield-halved"></i>
                        <span id="cr-open-garanties-inline-label">Garanties</span>
                    </button>
                </div>
            </div>

            <div id="cr-credits-view">
            {# Status filter tabs #}
            <div class="cr-filter-tabs" id="cr-credit-filter-tabs">
                <button class="cr-filter-tab cr-filter-tab-active" data-filter="all" type="button">
                    Tous <span class="cr-tab-count">{{ items|length }}</span>
                </button>
                <button class="cr-filter-tab" data-filter="attente" type="button">
                    En attente <span class="cr-tab-count">{{ pending_total }}</span>
                </button>
                <button class="cr-filter-tab" data-filter="accepte" type="button">
                    Acceptes <span class="cr-tab-count">{{ accepted_total }}</span>
                </button>
                <button class="cr-filter-tab" data-filter="refuse" data-filter-val="refuse" type="button">
                    Refuses <span class="cr-tab-count">{{ refused_total }}</span>
                </button>
            </div>

            {# Cards grid view #}
            <div class="cr-credits-grid" id="cr-credits-grid">
                {% for item in items %}
                    <div class="cr-credit-card"
                         data-credit-row
                         data-credit-id="{{ item.idCredit }}"
                         data-credit-account="{{ item.idCompte|default('') }}"
                         data-credit-account-number="{{ item.compte_numero|default('')|e('html_attr') }}"
                         data-credit-type="{{ item.typeCredit|default('')|e('html_attr') }}"
                         data-credit-amount="{{ item.montantDemande|default(0) }}"
                         data-credit-auto="{{ item.autofinancement|default('') }}"
                         data-credit-duration="{{ item.duree|default('') }}"
                         data-credit-rate="{{ item.tauxInteret|default('') }}"
                         data-credit-monthly="{{ item.mensualite|default('') }}"
                         data-credit-approved="{{ item.montantAccorde|default('') }}"
                         data-credit-date="{{ item.dateDemande|default(current_date) }}"
                         data-credit-salary="{{ item.salaire|default('') }}"
                         data-credit-contract="{{ item.typeContrat|default('')|e('html_attr') }}"
                         data-credit-seniority="{{ item.ancienneteAnnees|default('') }}"
                         data-credit-status="{{ item.statut|default('En attente')|e('html_attr') }}"
                         data-credit-risk="{{ item.risk_score|default(0) }}"
                         data-credit-search="{{ (item.idCredit ~ ' ' ~ item.idCompte ~ ' ' ~ item.compte_numero ~ ' ' ~ item.typeCredit ~ ' ' ~ item.statut ~ ' ' ~ item.montantDemande ~ ' ' ~ item.mensualite ~ ' ' ~ item.typeContrat ~ ' ' ~ item.dateDemande)|lower|e('html_attr') }}"
                    >
                        {% set st = item.statut|default('En attente')|lower %}
                        {% set risk = item.risk_score|default(0) %}
                        {% set risk_cls = risk > 70 ? 'high' : (risk > 40 ? 'medium' : 'low') %}

                        <div class="cr-cc-top">
                            <div class="cr-cc-id">
                                <span class="cr-cc-id-label">#{{ item.idCredit }}</span>
                                <span class="cr-cc-type">{{ item.typeCredit|default('-') }}</span>
                            </div>
                            <span class="cr-cc-status cr-status-{{ 'accepte' in st or 'cours' in st ? 'green' : ('refuse' in st ? 'red' : 'amber') }}">
                                <i class="fa-solid fa-{{ 'accepte' in st or 'cours' in st ? 'circle-check' : ('refuse' in st ? 'circle-xmark' : 'clock') }}"></i>
                                {{ item.statut|default('En attente') }}
                            </span>
                        </div>

                        <div class="cr-cc-amount-row">
                            <div class="cr-cc-amount">
                                {{ item.montantDemande|default(0)|number_format(0, '.', ' ') }}
                                <small>TND</small>
                            </div>
                            <div class="cr-cc-monthly">
                                <span class="cr-cc-monthly-label">Mensualite</span>
                                <span class="cr-cc-monthly-val">{{ item.mensualite|default(0)|number_format(2, '.', ' ') }} DT</span>
                            </div>
                        </div>

                        <div class="cr-cc-meta">
                            <div class="cr-cc-meta-item">
                                <i class="fa-solid fa-hourglass-half"></i>
                                <span>{{ item.duree|default('-') }} mois</span>
                            </div>
                            <div class="cr-cc-meta-item">
                                <i class="fa-solid fa-percent"></i>
                                <span>{{ item.tauxInteret|default('-') }}%</span>
                            </div>
                            <div class="cr-cc-meta-item">
                                <i class="fa-solid fa-calendar-day"></i>
                                <span>{{ item.dateDemande|default('-') }}</span>
                            </div>
                        </div>

                        <div class="cr-cc-risk-row">
                            <span class="cr-cc-risk-label">Score risque</span>
                            <div class="cr-cc-risk-bar-wrap">
                                <div class="cr-cc-risk-bar">
                                    <div class="cr-cc-risk-fill cr-risk-{{ risk_cls }}" style="width: {{ risk }}%"></div>
                                </div>
                                <span class="cr-cc-risk-val cr-risk-{{ risk_cls }}">{{ risk }}/100</span>
                            </div>
                        </div>

                        <div class="cr-cc-actions">
                            <a class="cr-cc-pdf-btn" href="{{ path('portal_feature_pdf_download', { kind: 'credits' }) }}" title="Exporter en PDF">
                                <i class="fa-solid fa-download"></i>
                                PDF
                            </a>
                            <button class="cr-cc-edit-btn" type="button" data-credit-edit="{{ item.idCredit }}">
                                <i class="fa-solid fa-pen-to-square"></i>
                                Modifier
                            </button>
                            <form method="post" onsubmit="return confirm('Supprimer ce credit ?');" class="cr-cc-delete-form">
                                <input type="hidden" name="tab" value="credits">
                                <input type="hidden" name="action" value="credit_delete">
                                <input type="hidden" name="idCredit" value="{{ item.idCredit }}">
                                <button class="cr-cc-delete-btn" type="submit">
                                    <i class="fa-solid fa-trash-can"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                {% else %}
                    <div class="cr-empty-state" id="cr-empty-main">
                        <div class="cr-empty-icon">
                            <i class="fa-solid fa-file-circle-xmark"></i>
                        </div>
                        <strong>Aucun credit enregistre</strong>
                        <span>Utilisez le formulaire pour creer votre premier dossier de credit.</span>
                        <button type="button" class="cr-empty-cta" id="cr-empty-add-btn">
                            <i class="fa-solid fa-plus"></i> Ajouter un credit
                        </button>
                    </div>
                {% endfor %}

            </div>

            {# Table footer stats #}
            <div class="cr-table-footer">
                <div class="cr-tf-stat">
                    <i class="fa-solid fa-layer-group"></i>
                    <span>Total: <strong>{{ items|length }}</strong></span>
                </div>
                <div class="cr-tf-stat">
                    <i class="fa-solid fa-clock"></i>
                    <span>En attente: <strong>{{ pending_total }}</strong></span>
                </div>
                <div class="cr-tf-stat">
                    <i class="fa-solid fa-circle-check"></i>
                    <span>Acceptes: <strong>{{ accepted_total }}</strong></span>
                </div>
                <div class="cr-tf-stat">
                    <i class="fa-solid fa-gauge"></i>
                    <span>Risque moyen: <strong>{{ average_risk }}/100</strong></span>
                </div>
                <a class="cr-tf-refresh" href="{{ path(route_name, { tab: 'credits' }) }}">
                    <i class="fa-solid fa-rotate"></i>
                    Actualiser
                </a>
            </div>
            </div>

            <div id="cr-garanties-view" hidden>
                {% if garanties|length > 0 %}
                    <div class="cr-garanties-grid cr-garanties-list-main">
                        {% for garantie in garanties %}
                            {% set garantie_status_key = garantie.statut|default('')|lower %}
                            {% set garantie_status_class = ('accepte' in garantie_status_key or 'verifie' in garantie_status_key or 'cours' in garantie_status_key or 'rembourse' in garantie_status_key) ? 'green' : (('refuse' in garantie_status_key or 'rejete' in garantie_status_key) ? 'red' : 'amber') %}
                            {% set retained_percent = garantie.valeurEstimee|default(0) > 0 ? ((garantie.valeurRetenue|default(0) / garantie.valeurEstimee|default(1)) * 100)|round : 0 %}
                            <div
                                class="cr-garantie-card"
                                data-main-garantie-row
                                data-garantie-row
                                data-garantie-id="{{ garantie.idGarantie }}"
                                data-garantie-credit-id="{{ garantie.idCredit }}"
                                data-garantie-type="{{ garantie.typeGarantie|default('')|e('html_attr') }}"
                                data-garantie-description="{{ garantie.description|default('')|e('html_attr') }}"
                                data-garantie-address="{{ garantie.adresseBien|default('')|e('html_attr') }}"
                                data-garantie-estimated="{{ garantie.valeurEstimee|default(0) }}"
                                data-garantie-retained="{{ garantie.valeurRetenue|default('') }}"
                                data-garantie-document="{{ garantie.documentJustificatif|default('')|e('html_attr') }}"
                                data-garantie-date="{{ garantie.dateEvaluation|default(current_date)|slice(0, 10) }}"
                                data-garantie-guarantor="{{ garantie.nomGarant|default('')|e('html_attr') }}"
                                data-garantie-status="{{ garantie.statut|default('')|e('html_attr') }}"
                                data-garantie-search="{{ (garantie.idGarantie ~ ' ' ~ garantie.idCredit ~ ' ' ~ garantie.typeGarantie ~ ' ' ~ garantie.description ~ ' ' ~ garantie.statut ~ ' ' ~ garantie.nomGarant ~ ' ' ~ garantie.adresseBien ~ ' ' ~ garantie.valeurEstimee ~ ' ' ~ garantie.valeurRetenue)|lower|e('html_attr') }}"
                            >
                                <div class="cr-cc-top">
                                    <div class="cr-cc-id">
                                        <span class="cr-cc-id-label">#{{ garantie.idGarantie }}</span>
                                        <span class="cr-cc-type">{{ garantie.typeGarantie|default('-') }}</span>
                                    </div>
                                    <span class="cr-cc-status cr-status-{{ garantie_status_class }}">
                                        <i class="fa-solid fa-{{ garantie_status_class == 'green' ? 'circle-check' : (garantie_status_class == 'red' ? 'circle-xmark' : 'clock') }}"></i>
                                        {{ garantie.statut|default('-') }}
                                    </span>
                                </div>

                                <div class="cr-cc-amount-row">
                                    <div class="cr-cc-amount">
                                        {{ garantie.valeurEstimee|default(0)|number_format(0, '.', ' ') }}
                                        <small>TND</small>
                                    </div>
                                    <div class="cr-cc-monthly">
                                        <span class="cr-cc-monthly-label">Valeur retenue</span>
                                        <span class="cr-cc-monthly-val">{{ garantie.valeurRetenue|default(0)|number_format(2, '.', ' ') }} DT</span>
                                    </div>
                                </div>

                                <div class="cr-cc-meta">
                                    <div class="cr-cc-meta-item">
                                        <i class="fa-solid fa-link"></i>
                                        <span>Credit #{{ garantie.idCredit }}</span>
                                    </div>
                                    <div class="cr-cc-meta-item">
                                        <i class="fa-solid fa-calendar-day"></i>
                                        <span>{{ garantie.dateEvaluation|default('-') }}</span>
                                    </div>
                                    <div class="cr-cc-meta-item">
                                        <i class="fa-solid fa-user-tie"></i>
                                        <span>{{ garantie.nomGarant|default('Sans garant') }}</span>
                                    </div>
                                </div>

                                <div class="cr-cc-risk-row">
                                    <span class="cr-cc-risk-label">Couverture retenue</span>
                                    <div class="cr-cc-risk-bar-wrap">
                                        <div class="cr-cc-risk-bar">
                                            <div class="cr-cc-risk-fill cr-risk-{{ retained_percent > 79 ? 'low' : (retained_percent > 49 ? 'medium' : 'high') }}" style="width: {{ retained_percent > 100 ? 100 : retained_percent }}%"></div>
                                        </div>
                                        <span class="cr-cc-risk-val cr-risk-{{ retained_percent > 79 ? 'low' : (retained_percent > 49 ? 'medium' : 'high') }}">{{ retained_percent }}%</span>
                                    </div>
                                </div>

                                <div class="cr-cc-actions">
                                    <a class="cr-cc-pdf-btn" href="{{ path('portal_feature_pdf_download', { kind: 'garanties' }) }}" title="Exporter les garanties en PDF">
                                        <i class="fa-solid fa-download"></i>
                                        PDF
                                    </a>
                                    <button class="cr-garantie-edit-btn" type="button" data-garantie-edit="{{ garantie.idGarantie }}" title="Modifier">
                                        <i class="fa-solid fa-pen-to-square"></i>
                                    </button>
                                    <form method="post" onsubmit="return confirm('Supprimer cette garantie ?');" class="cr-garantie-del-form">
                                        <input type="hidden" name="tab" value="credits">
                                        <input type="hidden" name="action" value="garantie_delete">
                                        <input type="hidden" name="panel" value="garanties">
                                        <input type="hidden" name="idGarantie" value="{{ garantie.idGarantie }}">
                                        <button class="cr-garantie-del-btn" type="submit" title="Supprimer">
                                            <i class="fa-solid fa-trash-can"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="cr-garanties-empty">
                        <i class="fa-solid fa-shield-halved"></i>
                        <span>Aucune garantie enregistree</span>
                    </div>
                {% endif %}

                <div class="cr-table-footer">
                    <div class="cr-tf-stat">
                        <i class="fa-solid fa-shield-halved"></i>
                        <span>Total garanties: <strong>{{ garanties|length }}</strong></span>
                    </div>
                    <a class="cr-tf-refresh" href="{{ path(route_name, { tab: 'credits' }) }}">
                        <i class="fa-solid fa-rotate"></i>
                        Actualiser
                    </a>
                </div>
            </div>
        </main>
    </div>

    {# â”€â”€ GARANTIES DRAWER â”€â”€ #}
    <div class="cr-drawer-overlay" id="cr-drawer-overlay" hidden></div>
    <aside class="cr-drawer" id="cr-garanties-drawer" hidden>
        <div class="cr-drawer-header">
            <div class="cr-drawer-header-left">
                <div class="cr-drawer-icon">
                    <i class="fa-solid fa-shield-halved"></i>
                </div>
                <div>
                    <h3>Garanties du Credit</h3>
                    <p>Gerer les garanties associees a vos dossiers</p>
                </div>
            </div>
            <button class="cr-drawer-close" id="cr-close-garanties" type="button">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>

        <div class="cr-drawer-body">

            {# Garantie form #}
            <div class="cr-drawer-section">
                <div class="cr-drawer-section-title">
                    <i class="fa-solid fa-plus-circle"></i>
                    Ajouter une garantie
                </div>

                <form method="post" class="cr-form cr-drawer-form" id="cr-garantie-form" novalidate>
                    <input type="hidden" name="tab" value="credits">
                    <input type="hidden" name="action" value="garantie_save">
                    <input type="hidden" name="panel" value="garanties">

                    <p class="cr-drawer-form-note">
                        Creation et modification d'une garantie, avec les memes regles metier que la version Java.
                    </p>

                    <div class="cr-field-group cr-field-group-2">
                        <div class="cr-field">
                            <label class="cr-field-label">
                                <i class="fa-solid fa-hashtag"></i> ID (modification)
                            </label>
                            <input class="cr-input" type="number" name="idGarantie" id="cr-garantie-id" placeholder="Laisser vide pour creer">
                        </div>
                        <div class="cr-field">
                            <label class="cr-field-label">
                                <i class="fa-solid fa-link"></i> Credit lie <span class="cr-req">*</span>
                            </label>
                            <div class="cr-select-wrap">
                                <select class="cr-input cr-select" name="idCredit" id="cr-garantie-credit">
                                    <option value="">Selectionner</option>
                                    {% for credit in items %}
                                        <option value="{{ credit.idCredit }}">#{{ credit.idCredit }} - {{ credit.typeCredit|default('Credit') }}</option>
                                    {% endfor %}
                                </select>
                                <i class="fa-solid fa-chevron-down cr-select-icon"></i>
                            </div>
                        </div>
                    </div>

                    <div class="cr-field-group cr-field-group-2">
                        <div class="cr-field">
                            <label class="cr-field-label">
                                <i class="fa-solid fa-shield-halved"></i> Type garantie <span class="cr-req">*</span>
                            </label>
                            <div class="cr-select-wrap">
                                <select class="cr-input cr-select" name="typeGarantie" id="cr-garantie-type">
                                    {% for type in ['Hypotheque immobiliere', 'Titre vehicule', 'Caution personnelle', 'Garantie bancaire', 'Police assurance', 'Nantissement', 'Autre garantie'] %}
                                        <option value="{{ type }}">{{ type }}</option>
                                    {% endfor %}
                                </select>
                                <i class="fa-solid fa-chevron-down cr-select-icon"></i>
                            </div>
                        </div>
                        <div class="cr-field">
                            <label class="cr-field-label">
                                <i class="fa-solid fa-coins"></i> Valeur estimee (TND) <span class="cr-req">*</span>
                            </label>
                            <div class="cr-input-pfx-wrap">
                                <span class="cr-input-pfx">TND</span>
                                <input class="cr-input cr-input-pfx-field" type="number" step="0.01" name="valeurEstimee" id="cr-garantie-estimated" placeholder="0.00">
                            </div>
                        </div>
                    </div>

                    <div class="cr-field-group cr-field-group-2">
                        <div class="cr-field">
                            <label class="cr-field-label">
                                <i class="fa-solid fa-percent"></i> Valeur retenue (TND)
                            </label>
                            <div class="cr-input-pfx-wrap">
                                <span class="cr-input-pfx cr-input-pfx-auto">AUTO</span>
                                <input class="cr-input cr-input-pfx-field cr-auto-field" type="number" step="0.01" name="valeurRetenue" id="cr-garantie-retained" placeholder="Auto (80% de l'estimee)">
                            </div>
                        </div>
                        <div class="cr-field">
                            <label class="cr-field-label">
                                <i class="fa-solid fa-calendar-day"></i> Date d'evaluation
                            </label>
                            <input class="cr-input" type="date" name="dateEvaluation" id="cr-garantie-date" value="{{ current_date }}">
                        </div>
                    </div>

                    <div class="cr-field-group">
                        <div class="cr-field">
                            <label class="cr-field-label">
                                <i class="fa-solid fa-user-tie"></i> Nom garant
                            </label>
                            <input class="cr-input" type="text" name="nomGarant" id="cr-garantie-guarantor" placeholder="Nom du garant">
                        </div>
                    </div>

                    <div class="cr-field-group cr-field-group-2">
                        <div class="cr-field">
                            <label class="cr-field-label">
                                <i class="fa-solid fa-location-dot"></i> Adresse du bien
                            </label>
                            <input class="cr-input" type="text" name="adresseBien" id="cr-garantie-address" placeholder="Adresse du bien">
                        </div>
                        <div class="cr-field">
                            <label class="cr-field-label">
                                <i class="fa-solid fa-file-lines"></i> Document justificatif
                            </label>
                            <input class="cr-input" type="text" name="documentJustificatif" id="cr-garantie-document" placeholder="Reference document">
                        </div>
                    </div>

                    <div class="cr-field-group">
                        <div class="cr-field">
                            <label class="cr-field-label">
                                <i class="fa-solid fa-align-left"></i> Description
                            </label>
                            <input class="cr-input" type="text" name="description" id="cr-garantie-description" placeholder="Details de la garantie...">
                        </div>
                    </div>

                    <div class="cr-form-actions cr-drawer-actions">
                        <button class="cr-form-reset-btn" type="reset" id="cr-garantie-reset">
                            <i class="fa-solid fa-rotate-left"></i>
                            Vider
                        </button>
                        <button class="cr-submit-btn cr-submit-btn-sm" type="submit">
                            <i class="fa-solid fa-floppy-disk"></i>
                            Enregistrer la garantie
                        </button>
                    </div>
                </form>
            </div>

            {# Garanties list #}
            <div class="cr-drawer-section">
                {% if garanties|length > 0 %}
                    <div class="cr-garanties-list">
                        {% for garantie in garanties %}
                            {% set garantie_status_key = garantie.statut|default('')|lower %}
                            {% set garantie_status_class = ('accepte' in garantie_status_key or 'verifie' in garantie_status_key or 'cours' in garantie_status_key or 'rembourse' in garantie_status_key) ? 'green' : (('refuse' in garantie_status_key or 'rejete' in garantie_status_key) ? 'red' : 'amber') %}
                            <div
                                class="cr-garantie-row"
                                data-garantie-row
                                data-garantie-id="{{ garantie.idGarantie }}"
                                data-garantie-credit-id="{{ garantie.idCredit }}"
                                data-garantie-type="{{ garantie.typeGarantie|default('')|e('html_attr') }}"
                                data-garantie-description="{{ garantie.description|default('')|e('html_attr') }}"
                                data-garantie-address="{{ garantie.adresseBien|default('')|e('html_attr') }}"
                                data-garantie-estimated="{{ garantie.valeurEstimee|default('') }}"
                                data-garantie-retained="{{ garantie.valeurRetenue|default('') }}"
                                data-garantie-document="{{ garantie.documentJustificatif|default('')|e('html_attr') }}"
                                data-garantie-date="{{ garantie.dateEvaluation|default(current_date)|slice(0, 10) }}"
                                data-garantie-guarantor="{{ garantie.nomGarant|default('')|e('html_attr') }}"
                                data-garantie-status="{{ garantie.statut|default('')|e('html_attr') }}"
                            >
                                <div class="cr-garantie-row-left">
                                    <div class="cr-garantie-icon">
                                        <i class="fa-solid fa-shield-halved"></i>
                                    </div>
                                    <div class="cr-garantie-info">
                                        <strong>{{ garantie.typeGarantie|default('-') }}</strong>
                                        <span>Credit #{{ garantie.idCredit }} - {{ garantie.valeurEstimee|default(0)|number_format(2, '.', ' ') }} DT</span>
                                        <span>Retenue {{ garantie.valeurRetenue|default(0)|number_format(2, '.', ' ') }} DT</span>
                                        <span class="cr-garantie-status cr-gstatus-{{ garantie_status_class }}">
                                            {{ garantie.statut|default('-') }}
                                        </span>
                                    </div>
                                </div>
                                <div class="cr-garantie-actions">
                                    <button class="cr-garantie-edit-btn" type="button" data-garantie-edit="{{ garantie.idGarantie }}" title="Modifier">
                                        <i class="fa-solid fa-pen-to-square"></i>
                                    </button>
                                    <form method="post" onsubmit="return confirm('Supprimer cette garantie ?');" class="cr-garantie-del-form">
                                        <input type="hidden" name="tab" value="credits">
                                        <input type="hidden" name="action" value="garantie_delete">
                                        <input type="hidden" name="panel" value="garanties">
                                        <input type="hidden" name="idGarantie" value="{{ garantie.idGarantie }}">
                                        <button class="cr-garantie-del-btn" type="submit" title="Supprimer">
                                            <i class="fa-solid fa-trash-can"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="cr-garanties-empty">
                        <i class="fa-solid fa-shield-halved"></i>
                        <span>Aucune garantie enregistree</span>
                    </div>
                {% endif %}
            </div>
        </div>
    </aside>

</div>

