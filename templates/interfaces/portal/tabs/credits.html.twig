   QUICK LINKS
   â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
.cr-quick-links {
  display: flex;
  align-items: stretch;
  gap: 10px;
  padding: 0 28px 16px;
  flex-wrap: wrap;
}

.cr-ql-item {
  display: flex;
  align-items: center;
  gap: 10px;
  background: #fff;
  border: 1px solid #dde8f5;
  border-radius: 12px;
  padding: 11px 16px;
  text-decoration: none;
  color: #1565c0;
  font-size: 13px;
  font-weight: 700;
  transition: all .18s;
  flex: 1;
  min-width: 160px;
  cursor: pointer;
  text-align: left;
  font-family: inherit;
  appearance: none;
}

.cr-ql-item:hover {
  background: linear-gradient(120deg, #1565c0, #00bcd4);
  color: #fff;
  border-color: transparent;
  box-shadow: 0 6px 18px rgba(21,101,192,.22);
  transform: translateY(-1px);
}

.cr-ql-icon {
  width: 30px;
  height: 30px;
  border-radius: 8px;
  background: #eaf2fd;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 13px;
  flex-shrink: 0;
  transition: background .18s;
}

.cr-ql-item:hover .cr-ql-icon {
  background: rgba(255,255,255,.2);
}

.cr-ql-label { flex: 1; }

.cr-ql-arrow {
  font-size: 11px;
  opacity: .5;
  transition: transform .18s, opacity .18s;
}

.cr-ql-item:hover .cr-ql-arrow {
  transform: translateX(4px);
  opacity: 1;
}

.cr-ql-item:focus-visible {
  outline: 2px solid #1e88e5;
  outline-offset: 2px;
}

/* modal quick tools */
.cr-tools-overlay {
  position: fixed;
  inset: 0;
  background: rgba(10, 37, 64, .48);
  backdrop-filter: blur(2px);
  z-index: 210;
}

.cr-tools-modal {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: min(1100px, calc(100vw - 44px));
  max-height: calc(100vh - 72px);
  background: #fff;
  border: 1px solid #d9e6f5;
  border-radius: 18px;
  box-shadow: 0 24px 60px rgba(10, 37, 64, .28);
  z-index: 211;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.cr-tools-overlay[hidden],
.cr-tools-modal[hidden] {
  display: none !important;
}

.cr-tools-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16px;
  padding: 18px 20px 14px;
  border-bottom: 1px solid #e8f0fb;
  background: linear-gradient(180deg, #f8fbff, #ffffff);
}

.cr-tools-header h3 {
  font-size: 18px;
  font-weight: 900;
  color: #0a2540;
}

.cr-tools-header p {
  margin-top: 4px;
  font-size: 12px;
  color: #6d8aa3;
}

.cr-tools-close {
  width: 34px;
  height: 34px;
  border-radius: 10px;
  border: 1px solid #dce8f6;
  background: #f4f8fd;
  color: #29527a;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  cursor: pointer;
}

.cr-tools-close:hover {
  background: #e8f1fc;
}

.cr-tools-tabs {
  display: flex;
  gap: 8px;
  padding: 10px 16px;
  border-bottom: 1px solid #e8f0fb;
  overflow-x: auto;
  background: #fff;
}

.cr-tools-tab {
  border: 1px solid #d9e7f6;
  background: #f5f9fe;
  color: #2f5f87;
  border-radius: 999px;
  padding: 7px 12px;
  font-size: 12px;
  font-weight: 700;
  cursor: pointer;
  white-space: nowrap;
}

.cr-tools-tab.is-active,
.cr-tools-tab:hover {
  background: linear-gradient(120deg, #1565c0, #1e88e5);
  border-color: transparent;
  color: #fff;
}

.cr-tools-body {
  padding: 16px;
  overflow: auto;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.cr-tool-panel {
  display: none;
}

.cr-tool-panel.is-active {
  display: block;
}

.cr-assistant-shell {
  display: grid;
  grid-template-columns: 320px minmax(0, 1fr);
  gap: 16px;
}

.cr-assistant-side,
.cr-assistant-main {
  border: 1px solid #dbe8f5;
  border-radius: 16px;
  background: linear-gradient(180deg, #fbfdff, #f5faff);
}

.cr-assistant-side {
  padding: 18px;
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.cr-assistant-side-badge {
  display: inline-flex;
  align-self: flex-start;
  padding: 7px 12px;
  border-radius: 999px;
  background: rgba(21, 101, 192, .10);
  color: #1565c0;
  font-size: 12px;
  font-weight: 800;
}

.cr-assistant-side h4 {
  font-size: 18px;
  font-weight: 900;
  color: #0a2540;
}

.cr-assistant-side p {
  font-size: 13px;
  line-height: 1.6;
  color: #57748f;
}

.cr-assistant-quick {
  display: grid;
  gap: 10px;
}

.cr-assistant-targets {
  display: grid;
  gap: 12px;
}

.cr-assistant-target-field {
  display: grid;
  gap: 6px;
}

.cr-assistant-target-field span {
  font-size: 12px;
  font-weight: 800;
  color: #5f7d98;
}

.cr-assistant-target-field select {
  width: 100%;
  min-height: 44px;
  border-radius: 12px;
  border: 1px solid #d8e7f7;
  background: #fff;
  color: #0a2540;
  font-size: 13px;
  font-weight: 700;
  padding: 0 14px;
  outline: none;
  transition: border-color .18s ease, box-shadow .18s ease;
}

.cr-assistant-target-field select:focus-visible {
  border-color: #1e88e5;
  box-shadow: 0 0 0 3px rgba(30, 136, 229, .14);
}

.cr-assistant-quick-btn {
  display: flex;
  align-items: center;
  gap: 10px;
  width: 100%;
  padding: 12px 14px;
  border: 1px solid #d8e7f7;
  border-radius: 12px;
  background: #fff;
  color: #0a2540;
  font-size: 13px;
  font-weight: 700;
  text-align: left;
  cursor: pointer;
  transition: .18s ease;
}

.cr-assistant-quick-btn:hover,
.cr-assistant-quick-btn:focus-visible {
  border-color: transparent;
  background: linear-gradient(120deg, #1565c0, #1e88e5);
  color: #fff;
  box-shadow: 0 10px 22px rgba(21, 101, 192, .18);
  outline: none;
}

.cr-assistant-context {
  display: grid;
  gap: 10px;
  margin-top: auto;
}

.cr-assistant-context-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  padding: 10px 12px;
  border-radius: 12px;
  background: #fff;
  border: 1px solid #e3edf8;
}

.cr-assistant-context-item span {
  font-size: 12px;
  font-weight: 700;
  color: #6986a1;
}

.cr-assistant-context-item strong {
  font-size: 14px;
  font-weight: 900;
  color: #0a2540;
}

.cr-assistant-main {
  min-height: 520px;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.cr-assistant-thread {
  flex: 1;
  padding: 18px;
  display: flex;
  flex-direction: column;
  gap: 14px;
  overflow-y: auto;
  background:
    radial-gradient(circle at top right, rgba(30, 136, 229, .08), transparent 34%),
    linear-gradient(180deg, #ffffff, #f7fbff);
}

.cr-assistant-msg {
  max-width: 82%;
  padding: 14px 16px;
  border-radius: 16px;
  border: 1px solid #dbe7f5;
  background: #fff;
  box-shadow: 0 10px 24px rgba(10, 37, 64, .05);
}

.cr-assistant-msg.is-user {
  align-self: flex-end;
  background: linear-gradient(135deg, #1565c0, #1e88e5);
  border-color: transparent;
  color: #fff;
}

.cr-assistant-msg.is-bot {
  align-self: flex-start;
}

.cr-assistant-msg-head {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 8px;
  font-size: 12px;
  font-weight: 900;
  color: #5c7a98;
}

.cr-assistant-msg.is-user .cr-assistant-msg-head {
  color: rgba(255, 255, 255, .82);
}

.cr-assistant-msg-title {
  font-size: 16px;
  font-weight: 900;
  color: #0a2540;
  margin-bottom: 8px;
}

.cr-assistant-msg.is-user .cr-assistant-msg-title,
.cr-assistant-msg.is-user .cr-assistant-msg-text {
  color: #fff;
}

.cr-assistant-msg-text {
  font-size: 14px;
  line-height: 1.65;
  color: #284864;
  white-space: pre-wrap;
}

.cr-assistant-pill-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 12px;
}

.cr-assistant-pill {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 7px 10px;
  border-radius: 999px;
  font-size: 12px;
  font-weight: 800;
}

.cr-assistant-pill.is-score {
  background: rgba(21, 101, 192, .10);
  color: #1565c0;
}

.cr-assistant-pill.is-risk {
  background: rgba(245, 158, 11, .14);
  color: #a16207;
}

.cr-assistant-pill.is-decision {
  background: rgba(16, 185, 129, .12);
  color: #047857;
}

.cr-assistant-metrics {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10px;
  margin-top: 12px;
}

.cr-assistant-metric {
  padding: 11px 12px;
  border-radius: 12px;
  border: 1px solid #e3edf8;
  background: #f8fbff;
}

.cr-assistant-metric span {
  display: block;
  font-size: 11px;
  font-weight: 800;
  color: #7290aa;
  margin-bottom: 6px;
}

.cr-assistant-metric strong {
  display: block;
  font-size: 15px;
  font-weight: 900;
  color: #0a2540;
}

.cr-assistant-rec-title {
  margin-top: 12px;
  font-size: 12px;
  font-weight: 900;
  color: #557390;
  text-transform: uppercase;
  letter-spacing: .04em;
}

.cr-assistant-rec-list {
  margin-top: 8px;
  padding-left: 18px;
  color: #284864;
  font-size: 13px;
  line-height: 1.65;
}

.cr-assistant-section-title {
  margin-top: 12px;
  font-size: 12px;
  font-weight: 900;
  color: #557390;
  text-transform: uppercase;
  letter-spacing: .04em;
}

.cr-assistant-best-offer {
  margin-top: 10px;
  padding: 12px 14px;
  border-radius: 14px;
  background: linear-gradient(135deg, #eef7ff, #f8fcff);
  border: 1px solid #d8e8f8;
}

.cr-assistant-best-offer strong {
  display: block;
  font-size: 15px;
  font-weight: 900;
  color: #0a2540;
  margin-bottom: 6px;
}

.cr-assistant-best-offer p {
  margin: 0;
  font-size: 13px;
  line-height: 1.6;
  color: #325673;
}

.cr-assistant-alert {
  margin-top: 12px;
  padding: 12px 14px;
  border-radius: 14px;
  border: 1px solid #fecaca;
  background: #fff5f5;
  color: #b91c1c;
  font-size: 13px;
  font-weight: 800;
}

.cr-assistant-summary-card,
.cr-assistant-ai-card {
  margin-top: 10px;
  border: 1px solid #dce8f6;
  border-radius: 18px;
  background: linear-gradient(180deg, #ffffff, #f8fbff);
  padding: 16px;
}

.cr-assistant-summary-head,
.cr-assistant-market-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  margin-bottom: 12px;
}

.cr-assistant-summary-head strong,
.cr-assistant-market-head strong,
.cr-assistant-ai-card strong {
  font-size: 14px;
  font-weight: 900;
  color: #0a2540;
}

.cr-assistant-summary-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10px 14px;
}

.cr-assistant-summary-item {
  display: grid;
  gap: 4px;
  padding: 10px 12px;
  border-radius: 12px;
  background: #f8fbff;
  border: 1px solid #e6eff9;
}

.cr-assistant-summary-item span {
  font-size: 11px;
  font-weight: 800;
  color: #6f8aa4;
}

.cr-assistant-summary-item strong {
  font-size: 14px;
  font-weight: 900;
  color: #0a2540;
}

.cr-assistant-market-block {
  display: grid;
  gap: 12px;
  margin-top: 10px;
}

.cr-assistant-market-card {
  border: 1px solid #dce8f6;
  border-radius: 18px;
  background: #fff;
  padding: 16px;
  box-shadow: 0 12px 28px rgba(21, 101, 192, 0.06);
}

.cr-assistant-market-card.is-best {
  border-color: #22c55e;
  box-shadow: 0 0 0 1px rgba(34, 197, 94, .08) inset;
  background: linear-gradient(180deg, #f4fff7, #ffffff);
}

.cr-assistant-market-card.is-house-bank {
  border-color: #1d4ed8;
  background: linear-gradient(180deg, #eff6ff, #ffffff 22%, #f6fffb 100%);
}

.cr-assistant-market-card.is-house-bank.is-best {
  border-color: #22c55e;
  box-shadow: 0 0 0 1px rgba(34, 197, 94, .10) inset, 0 18px 36px rgba(21, 101, 192, 0.08);
}

.cr-assistant-market-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 28px;
  padding: 4px 10px;
  border-radius: 999px;
  background: #22c55e;
  color: #fff;
  font-size: 11px;
  font-weight: 900;
}

.cr-assistant-market-grid {
