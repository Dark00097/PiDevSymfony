}

.cr-assistant-offer-badge.is-ok,
.cr-assistant-constraint-badge.is-ok {
  background: rgba(16, 185, 129, .12);
  color: #047857;
}

.cr-assistant-offer-badge.is-warn,
.cr-assistant-constraint-badge.is-warn {
  background: rgba(245, 158, 11, .16);
  color: #a16207;
}

.cr-assistant-offer-badge.is-block,
.cr-assistant-constraint-badge.is-block {
  background: rgba(239, 68, 68, .12);
  color: #b91c1c;
}

.cr-assistant-offer-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 8px;
}

.cr-assistant-offer-grid span {
  display: block;
  font-size: 11px;
  font-weight: 800;
  color: #7290aa;
  margin-bottom: 4px;
}

.cr-assistant-offer-grid strong {
  display: block;
  font-size: 13px;
  font-weight: 900;
  color: #0a2540;
}

.cr-assistant-offer-reason,
.cr-assistant-constraint-card p {
  margin: 8px 0 0;
