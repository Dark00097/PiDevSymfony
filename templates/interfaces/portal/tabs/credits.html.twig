{% set current_date = 'now'|date('Y-m-d') %}
{% set garanties = support.garanties|default([]) %}
{% set credit_garanties = support.all_garanties|default(garanties) %}
{% set pending_total = 0 %}
{% set accepted_total = 0 %}
{% set refused_total = 0 %}
{% set encours_total = 0 %}
{% set average_risk = 0 %}
{% set risk_sum = 0 %}
{% set total_amount = 0 %}
{% set total_monthly = 0 %}
{% set current_month = 'now'|date('Y-m') %}
{% set credits_month = 0 %}
{% set max_credit_id = 0 %}
{% set credit_feedback = support.credit_form_feedback|default({}) %}
{% if credit_feedback is empty %}
    {% set credit_feedback = {'errors': support.form_errors_credit|default({}), 'input': support.form_data_credit|default({})} %}
{% endif %}
{% set credit_old = credit_feedback.input|default({}) %}
{% set credit_errors = credit_feedback.errors|default({}) %}
{% set garantie_feedback = support.garantie_form_feedback|default({}) %}
{% if garantie_feedback is empty %}
    {% set garantie_feedback = {'errors': support.form_errors_garantie|default({}), 'input': support.form_data_garantie|default({})} %}
{% endif %}
{% set garantie_old = garantie_feedback.input|default({}) %}
{% set garantie_errors = garantie_feedback.errors|default({}) %}
{% set current_language = 'fr' %}
{% set credit_error_step = 1 %}
{% if credit_errors.montantDemande is defined or credit_errors.autofinancement is defined or credit_errors.duree is defined or credit_errors.tauxInteret is defined or credit_errors.mensualite is defined or credit_errors.montantAccorde is defined %}
    {% set credit_error_step = 2 %}
{% elseif credit_errors.salaire is defined or credit_errors.typeContrat is defined or credit_errors.ancienneteAnnees is defined %}
    {% set credit_error_step = 3 %}
{% endif %}
{% for item in items %}
    {% set status_key = item.statut|default('')|lower %}
    {% if 'attente' in status_key %}
        {% set pending_total = pending_total + 1 %}
    {% endif %}
    {% if 'accepte' in status_key or 'approved' in status_key %}
        {% set accepted_total = accepted_total + 1 %}
    {% endif %}
    {% if 'cours' in status_key %}
        {% set encours_total = encours_total + 1 %}
    {% endif %}
    {% if 'refuse' in status_key or 'rejet' in status_key %}
        {% set refused_total = refused_total + 1 %}
    {% endif %}
    {% set risk_sum = risk_sum + (item.risk_score|default(0)) %}
    {% set total_amount = total_amount + (item.montantDemande|default(0)) %}
    {% set total_monthly = total_monthly + (item.mensualite|default(0)) %}
    {% if item.idCredit|default(0) > max_credit_id %}
        {% set max_credit_id = item.idCredit %}
    {% endif %}
    {% if item.dateDemande is not empty and item.dateDemande|date('Y-m') == current_month %}
        {% set credits_month = credits_month + 1 %}
    {% endif %}
{% endfor %}
{% set next_credit_id = max_credit_id + 1 %}
{% if items|length > 0 %}
    {% set average_risk = (risk_sum / items|length)|round(1, 'common') %}
{% endif %}

<div class="cr-root">

    <section class="cr-hero">
        <div class="cr-hero-main">
            <div class="cr-hero-brand">
                <div class="cr-hero-icon">
                    <i class="fa-solid fa-hand-holding-dollar"></i>
                </div>
                <div class="cr-hero-copy">
                    <h1>Gestion des credits</h1>
                    <p>Demandez des prets, gerez vos credits et suivez les remboursements</p>
                </div>
            </div>

            <div class="cr-hero-center">
                <div class="cr-hero-stat">
                    <span class="cr-hero-stat-num">{{ items|length }}</span>
                    <span class="cr-hero-stat-lbl">Total dossiers</span>
                </div>
                <div class="cr-hero-divider"></div>
                <div class="cr-hero-stat">
                    <span class="cr-hero-stat-num">{{ credits_month }}</span>
                    <span class="cr-hero-stat-lbl">Ce mois</span>
                </div>
                <div class="cr-hero-divider"></div>
                <div class="cr-hero-stat">
                    <span class="cr-hero-stat-num">{{ pending_total }}</span>
                    <span class="cr-hero-stat-lbl">En attente</span>
                </div>
            </div>

            <div class="cr-hero-nav">
                <button type="button" class="cr-nav-pill" data-tool-open="history">
                    <i class="fa-solid fa-clock-rotate-left"></i><span>Historique</span>
                </button>
                <button type="button" class="cr-nav-pill cr-nav-pill--cta" id="cr-add-credit-btn">
                    <i class="fa-solid fa-plus"></i><span>Nouveau credit</span>
                </button>
        </div>

        <div class="cr-hero-toolbar">
            <div class="cr-hero-toolbar-right">
                <label class="cr-lang-select" for="cr-language" aria-label="Choisir la langue">
                    <span class="cr-visually-hidden">Choisir la langue</span>
                    <i class="fa-solid fa-globe"></i>
                    <select id="cr-language" name="language" aria-label="Choisir la langue">
                        <option value="fr" {{ current_language == 'fr' ? 'selected' : '' }}>Francais</option>
                        <option value="en" {{ current_language == 'en' ? 'selected' : '' }}>English</option>
                        <option value="ar" {{ current_language == 'ar' ? 'selected' : '' }}>العربية</option>
                    </select>
                    <i class="fa-solid fa-chevron-down cr-lang-chevron"></i>
                </label>
                <button class="cr-topbar-btn" id="cr-dark-toggle" type="button">
                    <i class="fa-solid fa-moon"></i>
                </button>
                <a class="cr-topbar-btn" href="{{ path(route_name, { tab: 'credits' }) }}" title="Actualiser">
                    <i class="fa-solid fa-rotate"></i>
                </a>
                <div class="cr-user-chip">
                    <div class="cr-user-avatar">
                        {{ current_user.prenom|first|upper }}{{ current_user.nom|first|upper }}
                    </div>
                    <div class="cr-user-info">
                        <strong>{{ current_user.prenom }} {{ current_user.nom }}</strong>
                        <small>#{{ current_user.idUser }}</small>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div class="cr-kpi-strip">
        <div class="cr-kpi-card cr-kpi-card--amount">
            <div class="cr-kpi-head">
                <div class="cr-kpi-icon cr-kpi-icon-teal">
                    <i class="fa-solid fa-coins"></i>
                </div>
                <div class="cr-kpi-copy">
                    <span class="cr-kpi-label">Montant demande</span>
                    <span class="cr-kpi-sub">Volume global</span>
                </div>
            </div>
            <div class="cr-kpi-metric">
                <strong class="cr-kpi-value">{{ total_amount|number_format(2, '.', ' ') }}</strong>
                <span class="cr-kpi-unit">DT</span>
            </div>
            <div class="cr-kpi-bar"><span style="width:100%"></span></div>
        </div>
        <div class="cr-kpi-card cr-kpi-card--monthly">
            <div class="cr-kpi-head">
                <div class="cr-kpi-icon cr-kpi-icon-blue">
                    <i class="fa-solid fa-calendar-check"></i>
                </div>
                <div class="cr-kpi-copy">
                    <span class="cr-kpi-label">Mensualites</span>
                    <span class="cr-kpi-sub">Charge cumulee</span>
                </div>
            </div>
            <div class="cr-kpi-metric">
                <strong class="cr-kpi-value">{{ total_monthly|number_format(2, '.', ' ') }}</strong>
                <span class="cr-kpi-unit">DT</span>
            </div>
            <div class="cr-kpi-bar"><span style="width:{{ total_amount > 0 ? ((total_monthly / total_amount) * 100)|round : 0 }}%"></span></div>
        </div>
        <div class="cr-kpi-card cr-kpi-card--active">
            <div class="cr-kpi-head">
                <div class="cr-kpi-icon cr-kpi-icon-green">
                    <i class="fa-solid fa-circle-check"></i>
                </div>
                <div class="cr-kpi-copy">
                    <span class="cr-kpi-label">Acceptes / Actifs</span>
                    <span class="cr-kpi-sub">Dossiers valides</span>
                </div>
            </div>
            <div class="cr-kpi-metric">
                <strong class="cr-kpi-value">{{ accepted_total }}</strong>
                <span class="cr-kpi-unit">credits</span>
            </div>
            <div class="cr-kpi-bar"><span style="width:{{ items|length > 0 ? ((accepted_total / items|length) * 100)|round : 0 }}%"></span></div>
        </div>
        <div class="cr-kpi-card cr-kpi-card--risk">
            <div class="cr-kpi-head">
                <div class="cr-kpi-icon cr-kpi-icon-red">
                    <i class="fa-solid fa-triangle-exclamation"></i>
                </div>
                <div class="cr-kpi-copy">
                    <span class="cr-kpi-label">Risque moyen</span>
                    <span class="cr-kpi-sub">Evaluation portefeuille</span>
                </div>
            </div>
            <div class="cr-kpi-metric">
                <strong class="cr-kpi-value">{{ average_risk }}</strong>
                <span class="cr-kpi-unit">/100</span>
            </div>
            <div class="cr-kpi-bar"><span class="is-danger" style="width:{{ average_risk > 100 ? 100 : average_risk }}%"></span></div>
        </div>
    </div>
    {#  MAIN SPLIT LAYOUT #}
    <div class="cr-tools-overlay" id="cr-tools-overlay" hidden></div>
    <section class="cr-tools-modal" id="cr-tools-modal" hidden role="dialog" aria-modal="true" aria-labelledby="cr-tools-title">
        <header class="cr-tools-header">
            <div>
                <h3 id="cr-tools-title">Historique des credits</h3>
                <p id="cr-tools-subtitle">Consultez rapidement l historique complet de vos credits.</p>
            </div>
            <button class="cr-tools-close" id="cr-tools-close" type="button" aria-label="Fermer">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </header>

        <div class="cr-tools-body">
            <section class="cr-tool-panel is-active" data-tool-panel="history">
                {% if items|length > 0 %}
                    <div class="cr-tool-table-wrap">
                        <table class="cr-tool-table">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Type</th>
                                    <th>Montant</th>
                                    <th>Mensualite</th>
                                    <th>Statut</th>
                                    <th>Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for item in items %}
                                    <tr>
                                        <td>#{{ item.idCredit }}</td>
                                        <td>{{ item.typeCredit|default('-') }}</td>
                                        <td>{{ item.montantDemande|default(0)|number_format(2, '.', ' ') }} DT</td>
                                        <td>{{ item.mensualite|default(0)|number_format(2, '.', ' ') }} DT</td>
                                        <td>{{ item.statut|default('-') }}</td>
                                        <td>{{ item.dateDemande|default('-') }}</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% else %}
                    <div class="cr-tool-empty">Aucun historique credit disponible.</div>
                {% endif %}
            </section>
            
            <section class="cr-tool-panel" data-tool-panel="simulate">
                <style>
                    .sim-grid { display: grid; grid-template-columns: 1fr 2fr; gap: 1.5rem; }
                    .sim-card { background: var(--cr-bg-card, #fefefe); padding: 1.5rem; border-radius: 12px; border: 1px solid var(--cr-border, #eaeaea); }
                    .sim-val { font-size: 1.8rem; font-weight: 700; color: var(--cr-primary, #4f46e5); }
                    .sim-val.risk { color: var(--cr-error, #ef4444); }
                    @media (max-width: 768px) { .sim-grid { grid-template-columns: 1fr; } }
                    .proj-bar { width: 100%; border-radius: 4px 4px 0 0; position: relative; transition: height 0.3s ease; }
                    .proj-bar-wrap { flex: 1; display: flex; flex-direction: column; justify-content: flex-end; align-items: center; gap: 5px; height: 100%; }
                    .proj-bar span { font-size: 0.7rem; color: #666; text-align: center; }
                </style>
                <div class="sim-grid">
                    <div class="sim-card">
                        <h4 style="margin-bottom: 1rem; color: var(--cr-title);">Paramètres du crédit</h4>
                        <div style="margin-bottom: 1rem;">
                            <label style="display:block; font-size:0.85rem; margin-bottom:0.3rem;">Montant (DT)</label>
                            <input type="number" id="sim-montant" value="20000" style="width:100%; padding:0.6rem; border-radius:6px; border:1px solid #ccc; outline:none;">
                        </div>
                        <div style="margin-bottom: 1rem;">
                            <label style="display:block; font-size:0.85rem; margin-bottom:0.3rem;">Durée (Mois)</label>
                            <input type="number" id="sim-duree" value="36" style="width:100%; padding:0.6rem; border-radius:6px; border:1px solid #ccc; outline:none;">
                        </div>
                        <div style="margin-bottom: 1.5rem;">
                            <label style="display:block; font-size:0.85rem; margin-bottom:0.3rem;">Taux Annuel (%)</label>
                            <input type="number" step="0.1" id="sim-taux" value="8" style="width:100%; padding:0.6rem; border-radius:6px; border:1px solid #ccc; outline:none;">
                        </div>
                        <button id="sim-btn" style="width:100%; padding:0.8rem; border:none; border-radius:6px; background:var(--cr-primary, #4f46e5); color:#fff; font-weight:600; cursor:pointer;">Simuler Amortissement</button>
                    </div>
                    <div class="sim-card">
                        <div id="sim-result" hidden>
                            <div style="display:flex; justify-content: space-between; align-items:center; margin-bottom: 1.5rem; padding-bottom: 1rem; border-bottom: 1px solid #eaeaea;">
                                <div>
                                    <div style="font-size:0.85rem; color:#666;">Mensualité estimée</div>
                                    <div class="sim-val" id="sim-mensualite">0.00 <span style="font-size:1rem;">DT</span></div>
                                </div>
                                <div style="text-align:right;">
                                    <div style="font-size:0.85rem; color:#666;">Coût total du crédit</div>
                                    <div class="sim-val risk" id="sim-cout-total">0.00 <span style="font-size:1rem;">DT</span></div>
                                </div>
                            </div>
                            <h5 style="margin-bottom:0.5rem; color:var(--cr-title);">Tableau Prévisionnel</h5>
                            <div style="max-height: 250px; overflow-y: auto; border: 1px solid #eaeaea; border-radius: 8px;">
                                <table class="cr-tool-table" style="width:100%; text-align:right; border-collapse:collapse;">
                                    <thead style="position:sticky; top:0; background:#f9f9f9; z-index:1;">
                                        <tr>
                                            <th style="padding:0.5rem;">Mois</th>
                                            <th style="padding:0.5rem;">Part Intérêt</th>
                                            <th style="padding:0.5rem;">Part Capital</th>
                                            <th style="padding:0.5rem;">Capital Restant</th>
                                        </tr>
                                    </thead>
                                    <tbody id="sim-tbody"></tbody>
                                </table>
                            </div>
                        </div>
                        <div id="sim-placeholder" style="display:flex; align-items:center; justify-content:center; height:100%; color:#aaa; font-style:italic;">
                            Remplissez les critères pour lancer la simulation.
                        </div>
                    </div>
                </div>
            </section>

            <section class="cr-tool-panel" data-tool-panel="projection">
                 <div class="sim-grid">
                    <div class="sim-card">
                        <h4 style="margin-bottom: 1rem; color: var(--cr-title);">Modèle de Projection</h4>
                        <div style="margin-bottom: 1rem;">
                            <label style="display:block; font-size:0.85rem; margin-bottom:0.3rem;">Revenus mensuels (DT)</label>
                            <input type="number" id="proj-revenus" value="3000" style="width:100%; padding:0.6rem; border-radius:6px; border:1px solid #ccc; outline:none;">
                        </div>
                        <div style="margin-bottom: 1rem;">
                            <label style="display:block; font-size:0.85rem; margin-bottom:0.3rem;">Dépenses courantes (DT)</label>
                            <input type="number" id="proj-depenses" value="1200" style="width:100%; padding:0.6rem; border-radius:6px; border:1px solid #ccc; outline:none;">
                        </div>
                        <div style="margin-bottom: 1rem;">
                            <label style="display:block; font-size:0.85rem; margin-bottom:0.3rem;">Mensualité du crédit (DT)</label>
                            <input type="number" id="proj-mensualite" value="500" style="width:100%; padding:0.6rem; border-radius:6px; border:1px solid #ccc; outline:none;">
                        </div>
                        <div style="margin-bottom: 1.5rem;">
                            <label style="display:block; font-size:0.85rem; margin-bottom:0.3rem;">Inflation annuelle Prévue (%)</label>
                            <input type="number" step="0.1" id="proj-inflation" value="6.5" style="width:100%; padding:0.6rem; border-radius:6px; border:1px solid #ccc; outline:none;">
                        </div>
                        <button id="proj-btn" style="width:100%; padding:0.8rem; border:none; border-radius:6px; background:#10b981; color:#fff; font-weight:600; cursor:pointer;">Projeter sur 5 ans</button>
                    </div>
                    <div class="sim-card">
                        <div id="proj-result" hidden>
                             <h4 style="margin-bottom: 0.5rem; color: var(--cr-title);">Capacité Résiduelle Nette (5 Ans)</h4>
                             <p style="font-size:0.85rem; color:#666; margin-bottom:1rem;">Évaluation de votre reste-à-vivre face à l'inflation constante des dépenses.</p>
                             
                             <div id="proj-chart" style="display:flex; align-items:flex-end; gap:8px; height:200px; padding:1rem; border-radius:8px; background:#fafafa; border:1px solid #eaeaea;">
                                 <!-- Barres générées en JS -->
                             </div>
                             
                             <div id="proj-conclusion" style="margin-top: 1.5rem; padding: 1rem; border-radius: 8px; font-weight: 500; text-align:center;"></div>
                        </div>
                        <div id="proj-placeholder" style="display:flex; align-items:center; justify-content:center; height:100%; color:#aaa; font-style:italic;">
                            Définissez vos revenus/dépenses actuels pour projeter votre viabilité financière.
                        </div>
                    </div>
                 </div>
            </section>
        </div>
    </section>
    <div class="cr-split">

        {# â”€â”€â”€ LEFT: FORM COLUMN â”€â”€â”€ #}
        <aside class="cr-form-col" id="cr-form-col">
            <div class="cr-form-card" id="garantie-form-card">
                <div class="cr-form-card-header">
                    <div class="cr-form-card-header-top">
                        <div class="cr-fch-icon">
                            <i class="fa-solid fa-shield-halved"></i>
                        </div>
                        <div>
                            <h2 class="cr-fch-title">Demande de Garantie</h2>
                            <p class="cr-fch-sub">Ajoutez une garantie pour la reutiliser ensuite dans la demande de credit</p>
                        </div>
                    </div>
                </div>

                <form method="post" class="cr-form" id="cr-garantie-form" novalidate enctype="multipart/form-data">
                    <input type="hidden" name="tab" value="credits">
                    <input type="hidden" name="action" value="garantie_save">

                    <div class="cr-form-step-body">
                        <p class="cr-drawer-form-note">
                            Creation et modification d'une garantie sans liaison immediate au credit.
                        </p>

                        <div class="cr-field-group">
                            <div class="cr-field">
                                <label class="cr-field-label">
                                    <i class="fa-solid fa-hashtag"></i> ID (modification)
                                </label>
                                <input class="cr-input{{ garantie_errors.idGarantie is defined ? ' cr-input--error' : '' }}" type="number" name="idGarantie" id="cr-garantie-id" placeholder="Laisser vide pour creer" value="{{ garantie_old.idGarantie|default('') }}">
                                <span id="cr-garantie-err-idGarantie" class="cr-val-msg{{ garantie_errors.idGarantie is defined ? ' is-error' : '' }}">{{ garantie_errors.idGarantie|default('') }}</span>
                            </div>
                        </div>

                        <div class="cr-field-group cr-field-group-2">
                            <div class="cr-field">
                                <label class="cr-field-label">
                                    <i class="fa-solid fa-shield-halved"></i> Type garantie <span class="cr-req">*</span>
                                </label>
                                <div class="cr-select-wrap">
                                    <select class="cr-input cr-select{{ garantie_errors.typeGarantie is defined ? ' cr-input--error' : '' }}" name="typeGarantie" id="cr-garantie-type">
                                        <option value="">Selectionner</option>
                                        {% for type in ['Hypotheque immobiliere', 'Titre vehicule', 'Caution personnelle', 'Garantie bancaire', 'Police assurance', 'Nantissement', 'Autre garantie'] %}
                                            <option value="{{ type }}" {{ garantie_old.typeGarantie|default('') == type ? 'selected' : '' }}>{{ type }}</option>
                                        {% endfor %}
                                    </select>
                                    <i class="fa-solid fa-chevron-down cr-select-icon"></i>
                                </div>
                                <span id="cr-garantie-err-typeGarantie" class="cr-val-msg{{ garantie_errors.typeGarantie is defined ? ' is-error' : '' }}">{{ garantie_errors.typeGarantie|default('') }}</span>
                            </div>
                            <div class="cr-field">
                                <label class="cr-field-label">
                                    <i class="fa-solid fa-coins"></i> Valeur estimee (TND) <span class="cr-req">*</span>
                                </label>
                                <div class="cr-input-pfx-wrap">
                                    <span class="cr-input-pfx">TND</span>
                                    <input class="cr-input cr-input-pfx-field{{ garantie_errors.valeurEstimee is defined ? ' cr-input--error' : '' }}" type="number" step="0.01" name="valeurEstimee" id="cr-garantie-estimated" placeholder="0.00" value="{{ garantie_old.valeurEstimee|default('') }}">
                                </div>
                                <span id="cr-garantie-err-valeurEstimee" class="cr-val-msg{{ garantie_errors.valeurEstimee is defined ? ' is-error' : '' }}">{{ garantie_errors.valeurEstimee|default('') }}</span>
                            </div>
                        </div>

                        <div class="cr-field-group cr-field-group-2">
                            <div class="cr-field">
                                <label class="cr-field-label">
                                    <i class="fa-solid fa-percent"></i> Valeur retenue (TND)
                                </label>
                                <div class="cr-input-pfx-wrap">
                                    <span class="cr-input-pfx cr-input-pfx-auto">AUTO</span>
                                    <input class="cr-input cr-input-pfx-field cr-auto-field{{ garantie_errors.valeurRetenue is defined ? ' cr-input--error' : '' }}" type="number" step="0.01" name="valeurRetenue" id="cr-garantie-retained" placeholder="Auto (80% de l'estimee)" value="{{ garantie_old.valeurRetenue|default('') }}">
                                </div>
                                <span id="cr-garantie-err-valeurRetenue" class="cr-val-msg{{ garantie_errors.valeurRetenue is defined ? ' is-error' : '' }}">{{ garantie_errors.valeurRetenue|default('') }}</span>
                            </div>
                            <div class="cr-field">
                                <label class="cr-field-label">
                                    <i class="fa-solid fa-calendar-day"></i> Date d'evaluation <span class="cr-req">*</span>
                                </label>
                                <input class="cr-input{{ garantie_errors.dateEvaluation is defined ? ' cr-input--error' : '' }}" type="date" name="dateEvaluation" id="cr-garantie-date" value="{{ garantie_old.dateEvaluation|default(current_date) }}">
                                <span id="cr-garantie-err-dateEvaluation" class="cr-val-msg{{ garantie_errors.dateEvaluation is defined ? ' is-error' : '' }}">{{ garantie_errors.dateEvaluation|default('') }}</span>
                            </div>
                        </div>

                        <div class="cr-field-group">
                            <div class="cr-field">
                                <label class="cr-field-label">
                                    <i class="fa-solid fa-user-tie"></i> Nom garant <span class="cr-req">*</span>
                                </label>
                                <input class="cr-input{{ garantie_errors.nomGarant is defined ? ' cr-input--error' : '' }}" type="text" name="nomGarant" id="cr-garantie-guarantor" placeholder="Nom du garant" value="{{ garantie_old.nomGarant|default('') }}">
                                <span id="cr-garantie-err-nomGarant" class="cr-val-msg{{ garantie_errors.nomGarant is defined ? ' is-error' : '' }}">{{ garantie_errors.nomGarant|default('') }}</span>
                            </div>
                        </div>

                        <div class="cr-field-group cr-field-group-2">
                            <div class="cr-field">
                                <label class="cr-field-label">
                                    <i class="fa-solid fa-location-dot"></i> Adresse du bien <span class="cr-req">*</span>
                                </label>
                                <input class="cr-input{{ garantie_errors.adresseBien is defined ? ' cr-input--error' : '' }}" type="text" name="adresseBien" id="cr-garantie-address" placeholder="Adresse du bien" value="{{ garantie_old.adresseBien|default('') }}">
                                <span id="cr-garantie-err-adresseBien" class="cr-val-msg{{ garantie_errors.adresseBien is defined ? ' is-error' : '' }}">{{ garantie_errors.adresseBien|default('') }}</span>
                            </div>
                            <div class="cr-field">
                                <label class="cr-field-label">
                                    <i class="fa-solid fa-file-lines"></i> Document justificatif <span class="cr-req">*</span>
                                </label>
                                <input type="hidden" name="existingDocumentJustificatif" id="cr-garantie-document-existing" value="{{ garantie_old.documentJustificatif|default('') }}">
                                <input class="cr-input{{ garantie_errors.documentJustificatif is defined ? ' cr-input--error' : '' }}" type="file" name="documentJustificatifFile" id="cr-garantie-document" accept="image/png,image/jpeg,image/webp,image/gif">
                                <div style="display:flex; gap:10px; align-items:center; margin-top:8px; font-size:12px; color:#6b7280;">
                                    <span id="cr-garantie-document-label">{{ garantie_old.documentJustificatif|default('') ? 'Image deja enregistree' : 'Formats acceptes: PNG, JPG, WEBP, GIF' }}</span>
                                    <a id="cr-garantie-document-link" href="{{ garantie_old.documentJustificatif|default('') ? asset(garantie_old.documentJustificatif) : '#' }}" target="_blank" rel="noopener" {{ garantie_old.documentJustificatif|default('') ? '' : 'hidden' }}>Voir l'image</a>
                                </div>
                                <span id="cr-garantie-err-documentJustificatif" class="cr-val-msg{{ garantie_errors.documentJustificatif is defined ? ' is-error' : '' }}">{{ garantie_errors.documentJustificatif|default('') }}</span>
                            </div>
                        </div>

                        <div class="cr-field-group">
                            <div class="cr-field">
                                <label class="cr-field-label">
                                    <i class="fa-solid fa-align-left"></i> Description <span class="cr-req">*</span>
                                </label>
                                <input class="cr-input{{ garantie_errors.description is defined ? ' cr-input--error' : '' }}" type="text" name="description" id="cr-garantie-description" placeholder="Details de la garantie..." value="{{ garantie_old.description|default('') }}">
                                <span id="cr-garantie-err-description" class="cr-val-msg{{ garantie_errors.description is defined ? ' is-error' : '' }}">{{ garantie_errors.description|default('') }}</span>
                            </div>
                        </div>

                        <div class="cr-form-actions">
                            <button class="cr-form-reset-btn" type="reset" id="cr-garantie-reset">
                                <i class="fa-solid fa-rotate-left"></i>
                                Vider
                            </button>
                            <button class="cr-submit-btn" type="submit">
                                <i class="fa-solid fa-floppy-disk"></i>
                                Enregistrer la garantie
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </aside>

        {# â”€â”€â”€ RIGHT: TABLE COLUMN â”€â”€â”€ #}
        <main class="cr-table-col" id="cr-table-section">

            {# Table toolbar #}
            <div class="cr-table-toolbar">
                <div class="cr-table-toolbar-left">
                    <h2 class="cr-table-title">
                        <i class="fa-solid fa-credit-card" id="cr-main-list-icon"></i>
                        <span id="cr-main-list-label">Mes Credits</span>
                    </h2>
                    <span class="cr-table-count-badge" id="cr-main-list-count">{{ items|length }}</span>
                </div>
                <div class="cr-table-toolbar-right">
                    <div class="cr-search-box">
                        <i class="fa-solid fa-magnifying-glass"></i>
                        <input type="text" id="cr-search-input" placeholder="Rechercher un credit...">
                        <button class="cr-search-clear" id="cr-search-clear" type="button" hidden>
                            <i class="fa-solid fa-xmark"></i>
                        </button>
                    </div>
                    <div class="cr-select-wrap cr-sort-wrap">
                        <select class="cr-input cr-select cr-sort-select" id="cr-sort-select">
                            <option value="id_desc">Plus recent</option>
                            <option value="id_asc">Plus ancien</option>
                            <option value="amount_high">Montant eleve</option>
                            <option value="amount_medium">Montant moyen</option>
                            <option value="amount_low">Montant faible</option>
                            <option value="risk_desc">Risque eleve</option>
                        </select>
                        <i class="fa-solid fa-chevron-down cr-select-icon"></i>
                    </div>
                    <button type="button" class="cr-garanties-btn" id="cr-open-garanties-inline">
                        <i class="fa-solid fa-shield-halved"></i>
                        <span id="cr-open-garanties-inline-label">Toutes les garanties</span>
                    </button>
                </div>
            </div>

            <div id="cr-credits-view">
            {# Status filter tabs #}
            <div class="cr-filter-tabs" id="cr-credit-filter-tabs">
                <button class="cr-filter-tab cr-filter-tab-active" data-filter="all" type="button">
                    Tous <span class="cr-tab-count">{{ items|length }}</span>
                </button>
                <button class="cr-filter-tab" data-filter="attente" type="button">
                    En attente <span class="cr-tab-count">{{ pending_total }}</span>
                </button>
                <button class="cr-filter-tab" data-filter="cours" type="button">
                    En cours <span class="cr-tab-count">{{ encours_total }}</span>
                </button>
                <button class="cr-filter-tab" data-filter="accepte" type="button">
                    Acceptés <span class="cr-tab-count">{{ accepted_total }}</span>
                </button>
                <button class="cr-filter-tab" data-filter="refuse" data-filter-val="refuse" type="button">
                    Refusés <span class="cr-tab-count">{{ refused_total }}</span>
                </button>
            </div>

            {# Cards grid view #}
            <div class="cr-credits-grid" id="cr-credits-grid">
                {% for item in items %}
                    <div class="cr-credit-card"
                         data-credit-row
                         data-credit-id="{{ item.idCredit|default('') }}"
                         data-credit-account="{{ item.idCompte|default('') }}"
                         data-credit-account-number="{{ item.compte_numero|default('')|e('html_attr') }}"
                         data-credit-garantie-id="{{ item.idGarantie|default('') }}"
                         data-credit-garantie-type="{{ item.garantieType|default('')|e('html_attr') }}"
                         data-credit-type="{{ item.typeCredit|default('')|e('html_attr') }}"
                         data-credit-amount="{{ item.montantDemande|default(0) }}"
                         data-credit-auto="{{ item.autofinancement|default('') }}"
                         data-credit-duration="{{ item.duree|default('') }}"
                         data-credit-rate="{{ item.tauxInteret|default('') }}"
                         data-credit-monthly="{{ item.mensualite|default('') }}"
                         data-credit-approved="{{ item.montantAccorde|default('') }}"
                         data-credit-date="{{ item.dateDemande|default(current_date) }}"
                         data-credit-salary="{{ item.salaire|default('') }}"
                         data-credit-contract="{{ item.typeContrat|default('')|e('html_attr') }}"
                         data-credit-seniority="{{ item.ancienneteAnnees|default('') }}"
                         data-credit-status="{{ item.statut|default('En attente')|e('html_attr') }}"
                         data-credit-risk="{{ item.risk_score|default(0) }}"
                         data-credit-search="{{ (item.idCredit ~ ' ' ~ item.idCompte ~ ' ' ~ item.compte_numero ~ ' ' ~ item.typeCredit ~ ' ' ~ item.statut ~ ' ' ~ item.montantDemande ~ ' ' ~ item.mensualite ~ ' ' ~ item.typeContrat ~ ' ' ~ item.dateDemande)|lower|e('html_attr') }}"
                    >
                        {% set st = item.statut|default('En attente')|lower %}
                        {% set risk = item.risk_score|default(0) %}
                        {% set risk_cls = risk > 70 ? 'high' : (risk > 40 ? 'medium' : 'low') %}

                        <div class="cr-cc-top">
                            <div class="cr-cc-id">
                                <span class="cr-cc-id-label">#{{ item.idCredit }}</span>
                                <span class="cr-cc-type">{{ item.typeCredit|default('-') }}</span>
                            </div>
                            <span class="cr-cc-status cr-status-{{ 'accepte' in st or 'cours' in st ? 'green' : ('refuse' in st ? 'red' : 'amber') }}">
                                <i class="fa-solid fa-{{ 'accepte' in st or 'cours' in st ? 'circle-check' : ('refuse' in st ? 'circle-xmark' : 'clock') }}"></i>
                                {{ item.statut|default('En attente') }}
                            </span>
                        </div>

                        <div class="cr-cc-amount-row">
                            <div class="cr-cc-amount">
                                {{ item.montantDemande|default(0)|number_format(0, '.', ' ') }}
                                <small>TND</small>
                            </div>
                            <div class="cr-cc-monthly">
                                <span class="cr-cc-monthly-label">Mensualite</span>
                                <span class="cr-cc-monthly-val">{{ item.mensualite|default(0)|number_format(2, '.', ' ') }} DT</span>
                            </div>
                        </div>

                        <div class="cr-cc-meta">
                            <div class="cr-cc-meta-item">
                                <i class="fa-solid fa-hourglass-half"></i>
                                <span>{{ item.duree|default('-') }} mois</span>
                            </div>
                            <div class="cr-cc-meta-item">
                                <i class="fa-solid fa-percent"></i>
                                <span>{{ item.tauxInteret|default('-') }}%</span>
                            </div>
                            <div class="cr-cc-meta-item">
                                <i class="fa-solid fa-calendar-day"></i>
                                <span>{{ item.dateDemande|default('-') }}</span>
                            </div>
                        </div>

                        <div class="cr-cc-risk-row">
                            <span class="cr-cc-risk-label">Score risque</span>
                            <div class="cr-cc-risk-bar-wrap">
                                <div class="cr-cc-risk-bar">
                                    <div class="cr-cc-risk-fill cr-risk-{{ risk_cls }}" style="width: {{ risk }}%"></div>
                                </div>
                                <span class="cr-cc-risk-val cr-risk-{{ risk_cls }}">{{ risk }}/100</span>
                            </div>
                        </div>

                        <div class="cr-cc-actions">
                            <a class="cr-cc-pdf-btn" href="{{ path('portal_feature_pdf_download', { kind: 'credits' }) }}" title="Exporter en PDF">
                                <i class="fa-solid fa-download"></i>
                                PDF
                            </a>
                            <button class="cr-cc-garanties-btn" type="button" data-credit-garanties="{{ item.idCredit }}">
                                <i class="fa-solid fa-shield-halved"></i>
                                Garanties
                            </button>
                            <button class="cr-cc-edit-btn" type="button" data-credit-edit="{{ item.idCredit }}">
                                <i class="fa-solid fa-pen-to-square"></i>
                                Modifier
                            </button>
                            <form method="post" onsubmit="return confirm('Supprimer ce credit ?');" class="cr-cc-delete-form">
                                <input type="hidden" name="tab" value="credits">
                                <input type="hidden" name="action" value="credit_delete">
                                <input type="hidden" name="idCredit" value="{{ item.idCredit }}">
                                <button class="cr-cc-delete-btn" type="submit">
                                    <i class="fa-solid fa-trash-can"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                {% else %}
                    <div class="cr-empty-state" id="cr-empty-main">
                        <div class="cr-empty-icon">
                            <i class="fa-solid fa-file-circle-xmark"></i>
                        </div>
                        <strong>Aucun credit enregistre</strong>
                        <span>Utilisez le formulaire pour creer votre premier dossier de credit.</span>
                        <button type="button" class="cr-empty-cta" id="cr-empty-add-btn">
                            <i class="fa-solid fa-plus"></i> Nouveau credit
                        </button>
                    </div>
                {% endfor %}

            </div>

            {# Table footer stats #}
            <div class="cr-table-footer">
                <div class="cr-tf-stat">
                    <i class="fa-solid fa-layer-group"></i>
                    <span>Total: <strong>{{ items|length }}</strong></span>
                </div>
                <div class="cr-tf-stat">
                    <i class="fa-solid fa-clock"></i>
                    <span>En attente: <strong>{{ pending_total }}</strong></span>
                </div>
                <div class="cr-tf-stat">
                    <i class="fa-solid fa-circle-check"></i>
                    <span>Acceptes: <strong>{{ accepted_total }}</strong></span>
                </div>
                <div class="cr-tf-stat">
                    <i class="fa-solid fa-gauge"></i>
                    <span>Risque moyen: <strong>{{ average_risk }}/100</strong></span>
                </div>
                <a class="cr-tf-refresh" href="{{ path(route_name, { tab: 'credits' }) }}">
                    <i class="fa-solid fa-rotate"></i>
                    Actualiser
                </a>
            </div>
            </div>

            <div id="cr-garanties-view" hidden>
                {% if garanties|length > 0 %}
                    <div class="cr-garanties-grid cr-garanties-list-main">
                        {% for garantie in garanties %}
                            {% set garantie_status_key = garantie.statut|default('')|lower %}
                            {% set garantie_status_class = ('accepte' in garantie_status_key or 'verifie' in garantie_status_key or 'cours' in garantie_status_key or 'rembourse' in garantie_status_key) ? 'green' : (('refuse' in garantie_status_key or 'rejete' in garantie_status_key) ? 'red' : 'amber') %}
                            {% set retained_percent = garantie.valeurEstimee|default(0) > 0 ? ((garantie.valeurRetenue|default(0) / garantie.valeurEstimee|default(1)) * 100)|round : 0 %}
                            <div
                                class="cr-garantie-card"
                                data-main-garantie-row
                                data-garantie-row
                                data-garantie-id="{{ garantie.idGarantie }}"
                                data-garantie-credit-id="{{ garantie.idCredit }}"
                                data-garantie-type="{{ garantie.typeGarantie|default('')|e('html_attr') }}"
                                data-garantie-description="{{ garantie.description|default('')|e('html_attr') }}"
                                data-garantie-address="{{ garantie.adresseBien|default('')|e('html_attr') }}"
                                data-garantie-estimated="{{ garantie.valeurEstimee|default(0) }}"
                                data-garantie-retained="{{ garantie.valeurRetenue|default('') }}"
                                data-garantie-document="{{ garantie.documentJustificatif|default('')|e('html_attr') }}"
                                data-garantie-date="{{ garantie.dateEvaluation|default(current_date)|slice(0, 10) }}"
                                data-garantie-guarantor="{{ garantie.nomGarant|default('')|e('html_attr') }}"
                                data-garantie-status="{{ garantie.statut|default('')|e('html_attr') }}"
                                data-garantie-search="{{ (garantie.idGarantie ~ ' ' ~ garantie.idCredit ~ ' ' ~ garantie.typeGarantie ~ ' ' ~ garantie.description ~ ' ' ~ garantie.statut ~ ' ' ~ garantie.nomGarant ~ ' ' ~ garantie.adresseBien ~ ' ' ~ garantie.valeurEstimee ~ ' ' ~ garantie.valeurRetenue)|lower|e('html_attr') }}"
                            >
                                <div class="cr-cc-top">
                                    <div class="cr-cc-id">
                                        <span class="cr-cc-id-label">#{{ garantie.idGarantie }}</span>
                                        <span class="cr-cc-type">{{ garantie.typeGarantie|default('-') }}</span>
                                    </div>
                                    <span class="cr-cc-status cr-status-{{ garantie_status_class }}">
                                        <i class="fa-solid fa-{{ garantie_status_class == 'green' ? 'circle-check' : (garantie_status_class == 'red' ? 'circle-xmark' : 'clock') }}"></i>
                                        {{ garantie.statut|default('-') }}
                                    </span>
                                </div>

                                <div class="cr-cc-amount-row">
                                    <div class="cr-cc-amount">
                                        {{ garantie.valeurEstimee|default(0)|number_format(0, '.', ' ') }}
                                        <small>TND</small>
                                    </div>
                                    <div class="cr-cc-monthly">
                                        <span class="cr-cc-monthly-label">Valeur retenue</span>
                                        <span class="cr-cc-monthly-val">{{ garantie.valeurRetenue|default(0)|number_format(2, '.', ' ') }} DT</span>
                                    </div>
                                </div>

                                <div class="cr-cc-meta">
                                    <div class="cr-cc-meta-item">
                                        <i class="fa-solid fa-link"></i>
                                        <span>
                                            {% if garantie.idCredit|default('') %}
                                                Credit associe #{{ garantie.idCredit }}
                                            {% else %}
                                                Non associee
                                            {% endif %}
                                        </span>
                                    </div>
                                    <div class="cr-cc-meta-item">
                                        <i class="fa-solid fa-calendar-day"></i>
                                        <span>{{ garantie.dateEvaluation|default('-') }}</span>
                                    </div>
                                    <div class="cr-cc-meta-item">
                                        <i class="fa-solid fa-user-tie"></i>
                                        <span>{{ garantie.nomGarant|default('Sans garant') }}</span>
                                    </div>
                                </div>

                                <div class="cr-cc-risk-row">
                                    <span class="cr-cc-risk-label">Couverture retenue</span>
                                    <div class="cr-cc-risk-bar-wrap">
                                        <div class="cr-cc-risk-bar">
                                            <div class="cr-cc-risk-fill cr-risk-{{ retained_percent > 79 ? 'low' : (retained_percent > 49 ? 'medium' : 'high') }}" style="width: {{ retained_percent > 100 ? 100 : retained_percent }}%"></div>
                                        </div>
                                        <span class="cr-cc-risk-val cr-risk-{{ retained_percent > 79 ? 'low' : (retained_percent > 49 ? 'medium' : 'high') }}">{{ retained_percent }}%</span>
                                    </div>
                                </div>

                                <div class="cr-cc-actions">
                                    <a class="cr-cc-pdf-btn" href="{{ path('portal_feature_pdf_download', { kind: 'garanties' }) }}" title="Exporter les garanties en PDF">
                                        <i class="fa-solid fa-download"></i>
                                        PDF
                                    </a>
                                    <button class="cr-garantie-edit-btn" type="button" data-garantie-edit="{{ garantie.idGarantie }}" title="Modifier">
                                        <i class="fa-solid fa-pen-to-square"></i>
                                    </button>
                                    <form method="post" onsubmit="return confirm('Supprimer cette garantie ?');" class="cr-garantie-del-form">
                                        <input type="hidden" name="tab" value="credits">
                                        <input type="hidden" name="action" value="garantie_delete">
                                        <input type="hidden" name="idGarantie" value="{{ garantie.idGarantie }}">
                                        <button class="cr-garantie-del-btn" type="submit" title="Supprimer">
                                            <i class="fa-solid fa-trash-can"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="cr-garanties-empty">
                        <i class="fa-solid fa-shield-halved"></i>
                        <span>Aucune garantie enregistree</span>
                    </div>
                {% endif %}

                <div class="cr-table-footer">
                    <div class="cr-tf-stat">
                        <i class="fa-solid fa-shield-halved"></i>
                        <span>Total garanties: <strong>{{ garanties|length }}</strong></span>
                    </div>
                    <a class="cr-tf-refresh" href="{{ path(route_name, { tab: 'credits' }) }}">
                        <i class="fa-solid fa-rotate"></i>
                        Actualiser
                    </a>
                </div>
            </div>
        </main>
    </div>

    {# â”€â”€ GARANTIES DRAWER â”€â”€ #}
    <div class="cr-drawer-overlay" id="cr-drawer-overlay" hidden></div>
    <aside class="cr-drawer" id="cr-garanties-drawer" hidden>
        <div class="cr-drawer-header">
            <div class="cr-drawer-header-left">
                <div class="cr-drawer-icon">
                    <i class="fa-solid fa-file-pen"></i>
                </div>
                <div>
                    <h3>Demande de Credit</h3>
                    <p>Remplissez ou modifiez votre dossier de credit</p>
                </div>
            </div>
            <button class="cr-drawer-close" id="cr-close-garanties" type="button">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>

        <div class="cr-drawer-body">
            <div class="cr-form-card" id="credit-form-card">
                <div class="cr-form-card-header">
                    <div class="cr-form-card-header-top">
                        <div class="cr-fch-icon">
                            <i class="fa-solid fa-file-pen"></i>
                        </div>
                        <div>
                            <h2 class="cr-fch-title">Demande de Credit</h2>
                            <p class="cr-fch-sub">Remplissez le formulaire ci-dessous</p>
                        </div>
                        <button class="cr-form-collapse-btn" id="cr-collapse-form" type="button" title="Reduire">
                            <i class="fa-solid fa-chevron-left"></i>
                        </button>
                    </div>
                    <div class="cr-form-steps">
                        <div class="cr-step {{ credit_error_step == 1 ? 'cr-step-active' : '' }}" data-step="1">
                            <div class="cr-step-dot">1</div>
                            <span>Identite</span>
                        </div>
                        <div class="cr-step-line"></div>
                        <div class="cr-step {{ credit_error_step == 2 ? 'cr-step-active' : '' }}" data-step="2">
                            <div class="cr-step-dot">2</div>
                            <span>Financier</span>
                        </div>
                        <div class="cr-step-line"></div>
                        <div class="cr-step {{ credit_error_step == 3 ? 'cr-step-active' : '' }}" data-step="3">
                            <div class="cr-step-dot">3</div>
                            <span>Profil</span>
                        </div>
                    </div>
                </div>

                <form method="post" class="cr-form" id="credit-form" novalidate data-initial-step="{{ credit_error_step }}">
                    <input type="hidden" name="tab" value="credits">
                    <input type="hidden" name="action" value="credit_save">
                    <input type="hidden" name="panel" value="credit">

                    <div class="cr-form-step-body" data-step-body="1">
                        <div class="cr-field-group">
                            <div class="cr-field">
                                <label class="cr-field-label">
                                    <i class="fa-solid fa-hashtag"></i> ID (auto)
                                </label>
                                <input class="cr-input" type="number" name="idCredit" id="cr-credit-id" placeholder="Laisser vide pour creer" readonly value="{{ credit_old.idCredit|default('') }}">
                            </div>
                        </div>

                        <div class="cr-field-group cr-field-group-2">
                            <div class="cr-field">
                                <label class="cr-field-label">
                                    <i class="fa-solid fa-building-columns"></i> Compte <span class="cr-req">*</span>
                                </label>
                                <div class="cr-select-wrap">
                                    <select class="cr-input cr-select{{ credit_errors.idCompte is defined ? ' cr-input--error' : '' }}" name="idCompte" id="cr-credit-account">
                                        <option value="">Selectionner</option>
                                        {% for account in support.accounts|default([]) %}
                                            <option value="{{ account.idCompte }}" {{ credit_old.idCompte|default('') == account.idCompte ? 'selected' : '' }}>{{ account.idCompte }} - {{ account.numeroCompte }}</option>
                                        {% endfor %}
                                    </select>
                                    <i class="fa-solid fa-chevron-down cr-select-icon"></i>
                                </div>
                                <span id="cr-err-idCompte" class="cr-val-msg{{ credit_errors.idCompte is defined ? ' is-error' : '' }}">{{ credit_errors.idCompte|default('') }}</span>
                            </div>
                            <div class="cr-field">
                                <label class="cr-field-label">
