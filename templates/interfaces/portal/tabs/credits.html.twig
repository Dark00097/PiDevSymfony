                                <input type="hidden" name="documentPublicId" id="cr-garantie-document-public-id" value="{{ garantie_old.documentPublicId|default('') }}">
                                <input type="hidden" name="documentMimeType" id="cr-garantie-document-mime" value="{{ garantie_old.documentMimeType|default('') }}">
                                <input type="hidden" name="documentUploadedAt" id="cr-garantie-document-uploaded-at" value="{{ garantie_old.documentUploadedAt|default('') }}">
                                <input type="hidden" name="statutVerificationDocument" id="cr-garantie-document-status" value="{{ garantie_old.statutVerificationDocument|default('en_attente') }}">
                                <label for="cr-garantie-document" class="cr-ai-generate-btn" id="cr-garantie-document-picker" style="margin-top:8px; cursor:pointer;" role="button" tabindex="0" aria-controls="cr-garantie-document" aria-label="Choisir un document justificatif">
                                    <i class="fa-solid fa-upload"></i>
                                    <span>Choisir un document</span>
                                </label>
                                <input class="cr-input{{ garantie_errors.documentJustificatif is defined ? ' cr-input--error' : '' }}" type="file" name="documentJustificatifFile" id="cr-garantie-document" accept="image/png,image/jpeg,application/pdf" style="margin-top:8px;">
                                <div style="display:flex; gap:10px; align-items:center; margin-top:8px; font-size:12px; color:#6b7280;">
                                    <span id="cr-garantie-document-label">{{ garantie_old.documentJustificatif|default('') ? 'Document deja enregistre' : 'Formats acceptes: PNG, JPG, PDF' }}</span>
                                    <a id="cr-garantie-document-link" href="{{ garantie_old.documentJustificatif|default('') ? asset(garantie_old.documentJustificatif) : '#' }}" target="_blank" rel="noopener" {{ garantie_old.documentJustificatif|default('') ? '' : 'hidden' }}>Voir l'image</a>
                                </div>
                                <div style="margin-top:8px; display:flex; align-items:center; gap:8px; flex-wrap:wrap;">
                                    <button type="button" class="cr-ai-generate-btn" id="cr-garantie-document-analyze-btn">
                                        <i class="fa-solid fa-magnifying-glass-chart"></i>
                                        <span id="cr-garantie-document-analyze-label">Analyser le document</span>
                                    </button>
                                    <span id="cr-garantie-document-analyze-status" class="cr-badge-soft cr-badge-soft-blue" hidden></span>
                                </div>
                                <div style="margin-top:8px; font-size:12px; color:#64748b;">
                                    <strong style="display:block; margin-bottom:4px;">Regles de verification :</strong>
                                    <ul style="margin:0; padding-left:16px; display:grid; gap:4px;">
                                        <li>Document officiel obligatoire</li>
                                        <li>Image nette obligatoire</li>
                                        <li>Capture d ecran interdite</li>
                                    </ul>
                                </div>
                                <div id="cr-garantie-document-preview-wrap" style="margin-top:10px;" hidden>
                                    <img id="cr-garantie-document-preview-image" alt="Apercu du justificatif" style="max-width:100%; border-radius:12px; border:1px solid #d7e2ec;" hidden>
                                    <div id="cr-garantie-document-preview-file" style="padding:10px 12px; border:1px solid #d7e2ec; border-radius:12px; color:#334155; font-size:12px;" hidden></div>
                                </div>
                                <div style="margin-top:10px; display:grid; gap:8px;">
                                    {% set document_status_raw = garantie_old.statutVerificationDocument|default('en_attente') %}
                                    {% set document_status = document_status_raw|lower|replace({' ': '_'}) %}
                                    {% set document_is_pending = document_status in ['en_attente', 'pending'] %}
                                    <div style="display:flex; align-items:center; gap:8px;" {{ document_is_pending ? 'hidden' : '' }}>
                                        <span id="cr-garantie-document-status-badge" class="cr-badge-soft cr-badge-soft-{{ document_status == 'valide' ? 'green' : (document_status == 'incomplet' ? 'amber' : (document_status == 'rejete' ? 'red' : (document_status == 'suspect' ? 'purple' : 'blue'))) }}" {{ document_is_pending ? 'hidden' : '' }}>
                                            {{ document_status == 'valide' ? 'Valide' : (document_status == 'incomplet' ? 'Incomplet' : (document_status == 'rejete' ? 'Rejete' : (document_status == 'suspect' ? 'Suspect' : 'En attente'))) }}
                                        </span>
                                    </div>
                                    <small id="cr-garantie-document-feedback" style="color:#64748b;" {{ document_is_pending ? 'hidden' : '' }}>{{ garantie_old.documentFeedbackMessage|default('Le justificatif est en attente de verification.') }}</small>
                                </div>
                                <span id="cr-garantie-err-documentJustificatif" class="cr-val-msg{{ garantie_errors.documentJustificatif is defined ? ' is-error' : '' }}">{{ garantie_errors.documentJustificatif|default('') }}</span>
                            </div>
                        </div>

                        <input type="hidden" name="latitude" id="cr-garantie-latitude" value="{{ garantie_old.latitude|default('') }}">
                        <input type="hidden" name="longitude" id="cr-garantie-longitude" value="{{ garantie_old.longitude|default('') }}">
                        <input type="hidden" name="statutVerificationAdresse" id="cr-garantie-address-status" value="{{ garantie_old.statutVerificationAdresse|default('En attente') }}">
                        <div class="cr-field-group">
                            <div class="cr-field">
                                <div
                                    id="cr-garantie-map"
                                    title="Carte OpenStreetMap interactive"
                                    style="width:100%; height:240px; border:1px solid #d7e2ec; border-radius:18px; background:#eef5fb; overflow:hidden;"
                                ></div>
                                <small style="display:block; margin-top:8px; color:#64748b; font-size:12px;">
                                    Cliquez sur la carte ou deplacez le marqueur pour choisir l'emplacement exact.
                                </small>
                            </div>
                        </div>

                        <div class="cr-field-group">
                            <div class="cr-field">
                                <div class="cr-field-head">
                                    <label class="cr-field-label">
                                        <i class="fa-solid fa-align-left"></i> Description <span class="cr-req">*</span>
                                    </label>
                                    <button class="cr-ai-generate-btn" id="cr-garantie-generate-ai" type="button">
                                        <i class="fa-solid fa-sparkles"></i>
                                        <span id="cr-garantie-generate-ai-label">Generer par IA</span>
                                    </button>
                                </div>
                                <textarea class="cr-input cr-input-textarea{{ garantie_errors.description is defined ? ' cr-input--error' : '' }}" name="description" id="cr-garantie-description" placeholder="Details de la garantie..." rows="4" required>{{ garantie_old.description|default('') }}</textarea>
                                <span class="cr-ai-inline-status" id="cr-garantie-ai-status" hidden></span>
                                <span id="cr-garantie-err-description" class="cr-val-msg{{ garantie_errors.description is defined ? ' is-error' : '' }}">{{ garantie_errors.description|default('') }}</span>
                            </div>
                        </div>

                        <div class="cr-form-actions">
                            <button class="cr-form-reset-btn" type="reset" id="cr-garantie-reset">
                                <i class="fa-solid fa-rotate-left"></i>
                                Vider
                            </button>
                            <button class="cr-submit-btn" type="submit" id="cr-garantie-submit-btn">
                                <i class="fa-solid fa-floppy-disk"></i>
                                Enregistrer la garantie
                            </button>
                        </div>
                        <div id="cr-garantie-submit-feedback" class="cr-val-msg" style="margin-top:8px;"></div>
                    </div>
                </form>
            </div>
        </aside>

        {# √Ę‚ÄĚ‚ā¨√Ę‚ÄĚ‚ā¨√Ę‚ÄĚ‚ā¨ RIGHT: TABLE COLUMN √Ę‚ÄĚ‚ā¨√Ę‚ÄĚ‚ā¨√Ę‚ÄĚ‚ā¨ #}
        <main class="cr-table-col" id="cr-table-section">
            <section class="cr-list-shell">

            {# Table toolbar #}
            <div class="cr-table-toolbar">
                <div class="cr-table-toolbar-left">
                    <h2 class="cr-table-title">
                        <i class="fa-solid fa-credit-card" id="cr-main-list-icon"></i>
                        <span id="cr-main-list-label">Mes Credits</span>
                    </h2>
                    <span class="cr-table-count-badge" id="cr-main-list-count">{{ items|length }}</span>
                </div>
                <form class="cr-table-toolbar-right" method="get" action="{{ path(route_name) }}">
                    <input type="hidden" name="tab" value="credits">
                    <input type="hidden" name="filter" value="{{ credit_query.filter|default('all') }}">
                    <div class="cr-search-box">
                        <i class="fa-solid fa-magnifying-glass"></i>
                        <input type="text" name="q" value="{{ credit_query.q|default('') }}" placeholder="Rechercher un credit...">
                        {% if credit_query.q|default('') is not empty %}
                            <a class="cr-search-clear" href="{{ path(route_name, query_state|merge({ q: '' })) }}" aria-label="Effacer la recherche">
                                <i class="fa-solid fa-xmark"></i>
                            </a>
                        {% else %}
                            <button class="cr-search-clear" type="submit" disabled hidden>
                                <i class="fa-solid fa-xmark"></i>
                            </button>
                        {% endif %}
                    </div>
                    <div class="cr-select-wrap cr-sort-wrap">
                        <select class="cr-input cr-select cr-sort-select" name="sort" onchange="this.form.submit()">
                            <option value="">Trier par...</option>
                            <option value="id" {{ credit_query.sort|default('') == 'id' ? 'selected' : '' }}>ID</option>
                            <option value="type" {{ credit_query.sort|default('') == 'type' ? 'selected' : '' }}>Type</option>
                            <option value="montant" {{ credit_query.sort|default('') == 'montant' ? 'selected' : '' }}>Montant</option>
                            <option value="mensualite" {{ credit_query.sort|default('') == 'mensualite' ? 'selected' : '' }}>Mensualite</option>
                            <option value="duree" {{ credit_query.sort|default('') == 'duree' ? 'selected' : '' }}>Duree</option>
                            <option value="taux" {{ credit_query.sort|default('') == 'taux' ? 'selected' : '' }}>Taux</option>
                            <option value="date" {{ credit_query.sort|default('') == 'date' ? 'selected' : '' }}>Date</option>
                            <option value="statut" {{ credit_query.sort|default('') == 'statut' ? 'selected' : '' }}>Statut</option>
                        </select>
                        <i class="fa-solid fa-chevron-down cr-select-icon"></i>
                    </div>
                    <div class="cr-select-wrap cr-sort-wrap">
                        <select class="cr-input cr-select cr-sort-select" name="dir" onchange="this.form.submit()">
                            <option value="asc" {{ credit_query.dir|default('asc') == 'asc' ? 'selected' : '' }}>Croissant</option>
                            <option value="desc" {{ credit_query.dir|default('asc') == 'desc' ? 'selected' : '' }}>Decroissant</option>
                        </select>
                        <i class="fa-solid fa-chevron-down cr-select-icon"></i>
                    </div>
                    <a class="cr-garanties-btn" href="{{ path('portal_export_pdf') }}">
                        <i class="fa-solid fa-file-pdf"></i>
                        <span>Exporter PDF complet</span>
                    </a>
                    <button type="button" class="cr-garanties-btn" id="cr-open-garanties-inline">
                        <i class="fa-solid fa-shield-halved"></i>
                        <span id="cr-open-garanties-inline-label">Toutes les garanties</span>
                    </button>
                </form>
            </div>

            <div id="cr-credits-view">
            {# Status filter tabs #}
            <div class="cr-filter-tabs" id="cr-credit-filter-tabs">
                <button class="cr-filter-tab cr-filter-tab-active" data-filter="all" type="button">
                    Tous <span class="cr-tab-count">{{ items|length }}</span>
                </button>
                <button class="cr-filter-tab" data-filter="attente" type="button">
                    En attente <span class="cr-tab-count">{{ pending_total }}</span>
                </button>
                <button class="cr-filter-tab" data-filter="cours" type="button">
                    En cours <span class="cr-tab-count">{{ encours_total }}</span>
                </button>
                <button class="cr-filter-tab" data-filter="accepte" type="button">
                    Accept√©s <span class="cr-tab-count">{{ accepted_total }}</span>
                </button>
                <button class="cr-filter-tab" data-filter="refuse" data-filter-val="refuse" type="button">
                    Refus√©s <span class="cr-tab-count">{{ refused_total }}</span>
                </button>
            </div>

            {# Cards grid view #}
            <div class="cr-credits-grid" id="cr-credits-grid">
                {% for item in items %}
                    {% set restructuration = attribute(restructuration_scenarios, item.idCredit)|default(null) %}
                    {% set st = item.statut|default('En attente')|lower %}
                    {% set risk = item.risk_score|default(0) %}
                    {% set risk_cls = risk > 70 ? 'high' : (risk > 40 ? 'medium' : 'low') %}
                    {% set credit_state_class = ('accepte' in st or 'cours' in st) ? 'cr-credit-card--live' : (('refuse' in st or 'rejete' in st) ? 'cr-credit-card--risk' : 'cr-credit-card--pending') %}
                    <div class="cr-credit-card {{ credit_state_class }}"
                         data-credit-row
                         data-credit-id="{{ item.idCredit|default('') }}"
                         data-credit-account="{{ item.idCompte|default('') }}"
                         data-credit-account-number="{{ item.compte_numero|default('')|e('html_attr') }}"
                         data-credit-garantie-id="{{ item.idGarantie|default('') }}"
                         data-credit-garantie-type="{{ item.garantieType|default('')|e('html_attr') }}"
                         data-credit-type="{{ item.typeCredit|default('')|e('html_attr') }}"
                         data-credit-amount="{{ item.montantDemande|default(0) }}"
                         data-credit-auto="{{ item.autofinancement|default('') }}"
                         data-credit-duration="{{ item.duree|default('') }}"
                         data-credit-rate="{{ item.tauxInteret|default('') }}"
                         data-credit-monthly="{{ item.mensualite|default('') }}"
                         data-credit-approved="{{ item.montantAccorde|default('') }}"
                         data-credit-date="{{ item.dateDemande|default(current_date) }}"
                         data-credit-salary="{{ item.salaire|default('') }}"
                         data-credit-contract="{{ item.typeContrat|default('')|e('html_attr') }}"
                         data-credit-seniority="{{ item.ancienneteAnnees|default('') }}"
                         data-credit-status="{{ item.statut|default('En attente')|e('html_attr') }}"
                         data-credit-risk="{{ item.risk_score|default(0) }}"
                         data-credit-restruct-eligible="{{ restructuration and restructuration.eligible ? '1' : '0' }}"
                         data-credit-restruct-critical="{{ restructuration and restructuration.auto_open ? '1' : '0' }}"
                         data-credit-search="{{ (item.idCredit ~ ' ' ~ item.idCompte ~ ' ' ~ item.compte_numero ~ ' ' ~ item.typeCredit ~ ' ' ~ item.statut ~ ' ' ~ item.montantDemande ~ ' ' ~ item.mensualite ~ ' ' ~ item.typeContrat ~ ' ' ~ item.dateDemande)|lower|e('html_attr') }}"
                    >
                        <div class="cr-cc-top">
                            <div class="cr-cc-id">
                                <span class="cr-cc-id-label">#{{ item.idCredit }}</span>
                                <span class="cr-cc-type">{{ item.typeCredit|default('-') }}</span>
                            </div>
                            <span class="cr-cc-status cr-status-{{ 'accepte' in st or 'cours' in st ? 'green' : ('refuse' in st ? 'red' : 'amber') }}">
                                <i class="fa-solid fa-{{ 'accepte' in st or 'cours' in st ? 'circle-check' : ('refuse' in st ? 'circle-xmark' : 'clock') }}"></i>
                                {{ item.statut|default('En attente') }}
                            </span>
                        </div>

                        <div class="cr-cc-amount-row">
                            <div class="cr-cc-amount">
                                {{ item.montantDemande|default(0)|number_format(0, '.', ' ') }}
                                <small>TND</small>
                            </div>
                            <div class="cr-cc-monthly">
                                <span class="cr-cc-monthly-label">Mensualite</span>
                                <span class="cr-cc-monthly-val">{{ item.mensualite|default(0)|number_format(2, '.', ' ') }} DT</span>
                            </div>
                        </div>

                        <div class="cr-cc-meta">
                            <div class="cr-cc-meta-item">
                                <i class="fa-solid fa-hourglass-half"></i>
                                <span>{{ item.duree|default('-') }} mois</span>
                            </div>
                            <div class="cr-cc-meta-item">
                                <i class="fa-solid fa-percent"></i>
                                <span>{{ item.tauxInteret|default('-') }}%</span>
                            </div>
                            <div class="cr-cc-meta-item">
                                <i class="fa-solid fa-calendar-day"></i>
                                <span>{{ item.dateDemande|default('-') }}</span>
                            </div>
                        </div>

                        <div class="cr-cc-risk-row">
                            <span class="cr-cc-risk-label">Score risque</span>
                            <div class="cr-cc-risk-bar-wrap">
                                <div class="cr-cc-risk-bar">
                                    <div class="cr-cc-risk-fill cr-risk-{{ risk_cls }}" style="width: {{ risk }}%"></div>
                                </div>
                                <span class="cr-cc-risk-val cr-risk-{{ risk_cls }}">{{ risk }}/100</span>
                            </div>
                        </div>

                        <div class="cr-cc-actions">
                            <button class="cr-cc-garanties-btn" type="button" data-credit-garanties="{{ item.idCredit }}" title="Garanties" aria-label="Garanties">
                                <i class="fa-solid fa-shield-halved"></i>
                                <span class="cr-visually-hidden cr-cc-action-text">Garanties</span>
                            </button>
                            <button class="cr-cc-edit-btn" type="button" data-credit-edit="{{ item.idCredit }}" title="Modifier" aria-label="Modifier">
                                <i class="fa-solid fa-pen-to-square"></i>
                                <span class="cr-visually-hidden cr-cc-action-text">Modifier</span>
                            </button>
                            <button class="cr-cc-pay-btn" type="button" data-credit-pay="{{ item.idCredit }}" title="Payer mensualite" aria-label="Payer mensualite">
                                <i class="fa-solid fa-credit-card"></i>
                                <span class="cr-cc-pay-label">Payer</span>
                            </button>
                            <form method="post" onsubmit="return confirm('Supprimer ce credit ?');" class="cr-cc-delete-form">
                                <input type="hidden" name="tab" value="credits">
                                <input type="hidden" name="action" value="credit_delete">
                                <input type="hidden" name="idCredit" value="{{ item.idCredit }}">
                                <button class="cr-cc-delete-btn" type="submit">
                                    <i class="fa-solid fa-trash-can"></i>
                                </button>
                            </form>
                        </div>
                        <button
                            type="button"
                            class="cr-cc-restruct-btn"
                            data-credit-restruct="{{ item.idCredit }}"
                            title="Restructurer"
                            aria-label="Restructurer"
                        >
                            <i class="fa-solid fa-arrows-rotate"></i>
                            <span class="cr-cc-restruct-label">Restructurer</span>
                        </button>
                    </div>
                {% else %}
                    <div class="cr-empty-state" id="cr-empty-main">
                        <div class="cr-empty-icon">
                            <i class="fa-solid fa-file-circle-xmark"></i>
                        </div>
                        <strong>Aucun credit enregistre</strong>
                        <span>Utilisez le formulaire pour creer votre premier dossier de credit.</span>
                        <a class="cr-empty-cta" id="cr-empty-add-btn" href="{{ path(route_name, { tab: 'credits', panel: 'credit' }) }}">
                            <i class="fa-solid fa-plus"></i> Nouveau credit
                        </a>
                    </div>
                {% endfor %}

            </div>
            <div class="cr-list-pager" id="cr-credit-pager" hidden></div>

            </div>

            <div id="cr-garanties-view" hidden>
                {% if garanties|length > 0 %}
                    <div class="cr-garanties-grid cr-garanties-list-main">
                        {% for garantie in garanties %}
                            {% set garantie_status_key = garantie.statut|default('')|lower %}
                            {% set garantie_status_class = ('accepte' in garantie_status_key or 'verifie' in garantie_status_key or 'cours' in garantie_status_key or 'rembourse' in garantie_status_key) ? 'green' : (('refuse' in garantie_status_key or 'rejete' in garantie_status_key) ? 'red' : 'amber') %}
                            {% set garantie_card_state_class = garantie_status_class == 'green' ? 'cr-credit-card--live' : (garantie_status_class == 'red' ? 'cr-credit-card--risk' : 'cr-credit-card--pending') %}
                            {% set retained_percent = garantie.valeurEstimee|default(0) > 0 ? ((garantie.valeurRetenue|default(0) / garantie.valeurEstimee|default(1)) * 100)|round : 0 %}
                            <div
                                class="cr-garantie-card {{ garantie_card_state_class }}"
                                data-main-garantie-row
                                data-garantie-row
                                data-garantie-id="{{ garantie.idGarantie }}"
                                data-garantie-credit-id="{{ garantie.idCredit }}"
                                data-garantie-type-value="{{ garantie.typeGarantieValue|default(garantie.typeGarantie|default(''))|e('html_attr') }}"
                                data-garantie-type="{{ garantie.typeGarantie|default('')|e('html_attr') }}"
                                data-garantie-description="{{ garantie.description|default('')|e('html_attr') }}"
                                data-garantie-address="{{ garantie.adresseBien|default('')|e('html_attr') }}"
                                data-garantie-address-complete="{{ garantie.adresseComplete|default(garantie.adresseBien|default(''))|e('html_attr') }}"
                                data-garantie-city="{{ garantie.ville|default('')|e('html_attr') }}"
                                data-garantie-postal="{{ garantie.codePostal|default('')|e('html_attr') }}"
                                data-garantie-country="{{ garantie.pays|default('')|e('html_attr') }}"
                                data-garantie-latitude="{{ garantie.latitude|default('') }}"
                                data-garantie-longitude="{{ garantie.longitude|default('') }}"
                                data-garantie-address-status="{{ garantie.statutVerificationAdresse|default('En attente')|e('html_attr') }}"
                                data-garantie-estimated="{{ garantie.valeurEstimee|default(0) }}"
                                data-garantie-retained="{{ garantie.valeurRetenue|default('') }}"
                                data-garantie-document="{{ garantie.documentJustificatif|default('')|e('html_attr') }}"
                                data-garantie-document-url="{{ garantie.documentUrl|default(garantie.documentJustificatif|default(''))|e('html_attr') }}"
                                data-garantie-document-public-id="{{ garantie.documentPublicId|default('')|e('html_attr') }}"
                                data-garantie-document-mime="{{ garantie.documentMimeType|default('')|e('html_attr') }}"
                                data-garantie-document-uploaded-at="{{ garantie.documentUploadedAt|default('')|e('html_attr') }}"
                                data-garantie-document-status="{{ garantie.statutVerificationDocument|default('en_attente')|e('html_attr') }}"
                                data-garantie-document-feedback="{{ garantie.documentFeedbackMessage|default('Le justificatif est en attente de verification.')|e('html_attr') }}"
                                data-garantie-admin-remark="{{ garantie.remarqueAdmin|default('')|e('html_attr') }}"
                                data-garantie-date="{{ garantie.dateEvaluation|default(current_date)|slice(0, 10) }}"
                                data-garantie-guarantor="{{ garantie.nomGarant|default('')|e('html_attr') }}"
                                data-garantie-status="{{ garantie.statut|default('')|e('html_attr') }}"
                                data-garantie-search="{{ (garantie.idGarantie ~ ' ' ~ garantie.idCredit ~ ' ' ~ garantie.typeGarantie ~ ' ' ~ garantie.description ~ ' ' ~ garantie.statut ~ ' ' ~ garantie.nomGarant ~ ' ' ~ garantie.adresseBien ~ ' ' ~ garantie.valeurEstimee ~ ' ' ~ garantie.valeurRetenue)|lower|e('html_attr') }}"
                            >
                                <div class="cr-cc-top">
                                    <div class="cr-cc-id">
                                        <span class="cr-cc-id-label">#{{ garantie.idGarantie }}</span>
                                        <span class="cr-cc-type">{{ garantie.typeGarantie|default('-') }}</span>
                                    </div>
                                    <span class="cr-cc-status cr-status-{{ garantie_status_class }}">
                                        <i class="fa-solid fa-{{ garantie_status_class == 'green' ? 'circle-check' : (garantie_status_class == 'red' ? 'circle-xmark' : 'clock') }}"></i>
                                        {{ garantie.statut|default('-') }}
                                    </span>
                                </div>

                                <div class="cr-cc-amount-row">
                                    <div class="cr-cc-amount">
                                        {{ garantie.valeurEstimee|default(0)|number_format(0, '.', ' ') }}
                                        <small>TND</small>
                                    </div>
                                    <div class="cr-cc-monthly">
                                        <span class="cr-cc-monthly-label">Valeur retenue</span>
                                        <span class="cr-cc-monthly-val">{{ garantie.valeurRetenue|default(0)|number_format(2, '.', ' ') }} DT</span>
                                    </div>
                                </div>

                                <div class="cr-cc-meta">
                                    <div class="cr-cc-meta-item">
                                        <i class="fa-solid fa-link"></i>
                                        <span>
                                            {% if garantie.linkedCreditCount|default(0) > 1 %}
                                                Liee a {{ garantie.linkedCreditCount }} credits
                                            {% elseif garantie.idCredit|default('') %}
                                                Credit associe #{{ garantie.idCredit }}
                                            {% else %}
                                                Non associee
                                            {% endif %}
                                        </span>
                                    </div>
                                    <div class="cr-cc-meta-item">
                                        <i class="fa-solid fa-calendar-day"></i>
                                        <span>{{ garantie.dateEvaluation|default('-') }}</span>
                                    </div>
                                    <div class="cr-cc-meta-item">
                                        <i class="fa-solid fa-user-tie"></i>
                                        <span>{{ garantie.nomGarant|default('Sans garant') }}</span>
                                    </div>
                                </div>

                                <div class="cr-cc-risk-row">
                                    <span class="cr-cc-risk-label">Couverture retenue</span>
                                    <div class="cr-cc-risk-bar-wrap">
                                        <div class="cr-cc-risk-bar">
                                            <div class="cr-cc-risk-fill cr-risk-{{ retained_percent > 79 ? 'low' : (retained_percent > 49 ? 'medium' : 'high') }}" style="width: {{ retained_percent > 100 ? 100 : retained_percent }}%"></div>
                                        </div>
                                        <span class="cr-cc-risk-val cr-risk-{{ retained_percent > 79 ? 'low' : (retained_percent > 49 ? 'medium' : 'high') }}">{{ retained_percent }}%</span>
                                    </div>
                                </div>
                                <div class="cr-cc-meta" style="margin-top:8px;">
                                    <div class="cr-cc-meta-item">
                                        <i class="fa-solid fa-file-shield"></i>
                                        <span>{{ garantie.statutDocumentLabel|default(garantie.statutVerificationDocumentLabel|default('En attente')) }}</span>
                                    </div>
                                    <div class="cr-cc-meta-item">
                                        <i class="fa-solid fa-circle-info"></i>
                                        <span>{{ garantie.documentFeedbackMessage|default('Le justificatif est en attente de verification.') }}</span>
                                    </div>
                                </div>

                                <div class="cr-cc-actions">
                                    <a class="cr-cc-pdf-btn" href="{{ path('portal_feature_pdf_download', { kind: 'garanties', id: garantie.idGarantie }) }}" title="Exporter la garantie en PDF" aria-label="Exporter la garantie en PDF">
                                        <i class="fa-solid fa-download"></i>
                                        <span class="cr-visually-hidden cr-cc-action-text">Exporter la garantie en PDF</span>
                                    </a>
                                    <button class="cr-garantie-edit-btn" type="button" data-garantie-edit="{{ garantie.idGarantie }}" title="Modifier">
                                        <i class="fa-solid fa-pen-to-square"></i>
                                    </button>
                                    <form method="post" onsubmit="return confirm('Supprimer cette garantie ?');" class="cr-garantie-del-form">
                                        <input type="hidden" name="tab" value="credits">
                                        <input type="hidden" name="action" value="garantie_delete">
                                        <input type="hidden" name="idGarantie" value="{{ garantie.idGarantie }}">
                                        <button class="cr-garantie-del-btn" type="submit" title="Supprimer">
                                            <i class="fa-solid fa-trash-can"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                    <div class="cr-list-pager" id="cr-garantie-pager" hidden></div>
                {% else %}
                    <div class="cr-garanties-empty">
                        <i class="fa-solid fa-shield-halved"></i>
                        <span>Aucune garantie enregistree</span>
                    </div>
                {% endif %}

            </div>
            </section>
        </main>
    </div>

    {# √Ę‚ÄĚ‚ā¨√Ę‚ÄĚ‚ā¨ GARANTIES DRAWER √Ę‚ÄĚ‚ā¨√Ę‚ÄĚ‚ā¨ #}
