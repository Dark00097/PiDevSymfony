}

.cr-assistant-offer-head,
.cr-assistant-constraint-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  margin-bottom: 8px;
}

.cr-assistant-offer-head strong,
.cr-assistant-constraint-head strong {
  font-size: 14px;
  font-weight: 900;
  color: #0a2540;
}

.cr-assistant-offer-badge,
.cr-assistant-constraint-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 28px;
  padding: 4px 10px;
  border-radius: 999px;
  font-size: 11px;
