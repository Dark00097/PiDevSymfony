  line-height: 1.6;
  color: #456783;
}

.cr-assistant-projection-box {
  border-top: 1px solid #e5eef8;
  padding: 14px 18px;
  background: linear-gradient(180deg, #f8fcff, #ffffff);
  display: grid;
  gap: 12px;
}

.cr-assistant-projection-form {
  display: grid;
  gap: 12px;
}

.cr-assistant-projection-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10px;
}

.cr-assistant-projection-field {
  display: grid;
  gap: 6px;
}

.cr-assistant-projection-field span {
  font-size: 12px;
  font-weight: 800;
  color: #5f7d98;
}

.cr-assistant-projection-field input,
.cr-assistant-projection-field select {
  width: 100%;
  min-height: 40px;
  border-radius: 10px;
  border: 1px solid #d8e7f7;
  background: #fff;
  color: #0a2540;
  font-size: 13px;
  font-weight: 700;
  padding: 0 12px;
  outline: none;
}

.cr-assistant-proj-submit {
  display: inline-flex;
  align-items: center;
  gap: 8px;
