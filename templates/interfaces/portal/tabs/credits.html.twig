      'autre garantie': 0.5
    };
    return rates[normType(type instanceof HTMLSelectElement ? type.value : '')] ?? 0.8;
  };
  const syncRetained = () => {
    const e = num(estimated.value);
    retained.value = e > 0 ? (e * retention()).toFixed(2) : '';
    if (retainedHint) {
      const t = type instanceof HTMLSelectElement ? type.value.trim() : '';
      retainedHint.textContent = t ? `Calcul auto: ${Math.round(retention() * 100)}% pour ${t}` : 'Calcul auto selon le type de garantie';
    }
  };
  estimated.addEventListener('input', syncRetained);
  estimated.addEventListener('change', syncRetained);
  type?.addEventListener('change', syncRetained);
  syncRetained();

  let garantieSubmitAttempted = false;
  const markErr = (el, msg) => {
    if (!(el instanceof HTMLElement)) return;
    el.classList.add('cr-input--error');
    el.classList.remove('cr-input--valid');
    el.style.setProperty('border-color', '#dc2626', 'important');
    el.style.setProperty('box-shadow', '0 0 0 3px rgba(220,38,38,0.12)', 'important');
    el.style.setProperty('background-color', '#fff5f5', 'important');
    const err = document.getElementById(`cr-garantie-err-${el.getAttribute('name') || ''}`);
    if (err) err.textContent = `Erreur: ${msg}`;
  };
  const clearErr = (el) => {
    if (!(el instanceof HTMLElement)) return;
    el.classList.remove('cr-input--error');
    el.classList.add('cr-input--valid');
    el.style.removeProperty('border-color');
    el.style.removeProperty('box-shadow');
    el.style.removeProperty('background-color');
    const err = document.getElementById(`cr-garantie-err-${el.getAttribute('name') || ''}`);
    if (err) err.textContent = 'Valide';
  };

  const fillAddressFromItem = (item) => {
    const a = item && item.address ? item.address : {};
    const display = String(item && item.display_name ? item.display_name : '').trim();
    const c = String(a.city || a.town || a.village || a.county || a.state || '').trim();
    const p = String(a.postcode || '').trim();
    const co = String(a.country || '').trim();
    if (addressComplete instanceof HTMLInputElement && display) addressComplete.value = display;
    if (addressHidden instanceof HTMLInputElement && display) addressHidden.value = display;
    if (city instanceof HTMLInputElement) city.value = c;
    if (postal instanceof HTMLInputElement) postal.value = p;
    if (country instanceof HTMLInputElement) country.value = co;
    if (lat instanceof HTMLInputElement) lat.value = String(item && item.lat ? item.lat : '');
    if (lng instanceof HTMLInputElement) lng.value = String(item && item.lon ? item.lon : '');
  };

  let searchTimer = null;
  addressComplete?.addEventListener('input', () => {
    if (!(addressComplete instanceof HTMLInputElement)) return;
    if (addressHidden instanceof HTMLInputElement) addressHidden.value = addressComplete.value.trim();
    if (city instanceof HTMLInputElement) city.value = '';
    if (postal instanceof HTMLInputElement) postal.value = '';
    if (country instanceof HTMLInputElement) country.value = '';
    clearTimeout(searchTimer);
    const q = addressComplete.value.trim();
    if (q.length < 4) return;
    searchTimer = setTimeout(async () => {
      try {
        const r = await fetch(`${endpointSearch}?q=${encodeURIComponent(q)}&limit=1`, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
        const data = await r.json();
        if (r.ok && data && data.ok && Array.isArray(data.items) && data.items.length > 0) fillAddressFromItem(data.items[0]);
      } catch (_) {}
    }, 300);
  });

  const setMapIframe = (la, lo) => {
    if (!(mapBox instanceof HTMLElement)) return;
    const safeLat = Number.isFinite(Number(la)) ? Number(la) : 36.8065;
    const safeLng = Number.isFinite(Number(lo)) ? Number(lo) : 10.1815;
    const d = 0.02;
    const left = safeLng - d;
    const right = safeLng + d;
    const top = safeLat + d;
    const bottom = safeLat - d;
    const src = `https://www.openstreetmap.org/export/embed.html?bbox=${encodeURIComponent(String(left))}%2C${encodeURIComponent(String(bottom))}%2C${encodeURIComponent(String(right))}%2C${encodeURIComponent(String(top))}&layer=mapnik&marker=${encodeURIComponent(String(safeLat))}%2C${encodeURIComponent(String(safeLng))}`;
    mapBox.innerHTML = `<iframe title="OpenStreetMap" src="${src}" style="width:100%;height:100%;border:0;border-radius:18px;" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>`;
  };
  setMapIframe(lat instanceof HTMLInputElement ? lat.value : '', lng instanceof HTMLInputElement ? lng.value : '');

  const requiredRules = [
    [type, 'Veuillez selectionner un type de garantie.'],
    [estimated, 'Veuillez saisir une valeur estimee valide.'],
    [dateEval, "Veuillez renseigner la date d'evaluation."],
    [guarantor, 'Veuillez saisir le nom du garant.'],
    [addressComplete, "Veuillez saisir l'adresse du bien."],
    [city, 'Veuillez renseigner la ville.'],
    [postal, 'Veuillez renseigner le code postal.'],
    [country, 'Veuillez renseigner le pays.'],
    [description, 'Veuillez renseigner la description.']
  ];

  const validateOne = (el, message) => {
    if (!(el instanceof HTMLInputElement || el instanceof HTMLSelectElement || el instanceof HTMLTextAreaElement)) return true;
    const v = String(el.value || '').trim();
    const invalid = el === estimated ? num(v) <= 0 : v === '';
    if (invalid) {
      markErr(el, message);
      return false;
    }
    clearErr(el);
    return true;
  };

  form.addEventListener('submit', async (e) => {
    garantieSubmitAttempted = true;
    if (addressComplete instanceof HTMLInputElement && addressComplete.value.trim().length >= 4
      && city instanceof HTMLInputElement && city.value.trim() === '') {
      try {
        const r = await fetch(`${endpointSearch}?q=${encodeURIComponent(addressComplete.value.trim())}&limit=1`, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
        const data = await r.json();
        if (r.ok && data && data.ok && Array.isArray(data.items) && data.items.length > 0) fillAddressFromItem(data.items[0]);
      } catch (_) {}
    }

    let bad = null;
    requiredRules.forEach(([el, msg]) => {
      const ok = validateOne(el, msg);
      if (!ok && !bad) bad = el;
    });
    if (bad) {
      e.preventDefault();
      bad.focus();
    }
  });

  const liveFields = [type, estimated, dateEval, guarantor, addressComplete, city, postal, country, description];
  liveFields.forEach((el) => {
    if (!(el instanceof HTMLInputElement || el instanceof HTMLSelectElement || el instanceof HTMLTextAreaElement)) return;
      const liveValidate = () => {
        if (!garantieSubmitAttempted) return;
        const rule = requiredRules.find(([f]) => f === el);
        validateOne(el, rule ? rule[1] : 'Champ invalide.');
      };
    el.addEventListener('input', liveValidate);
    el.addEventListener('change', liveValidate);
    el.addEventListener('blur', liveValidate);
  });

  generateBtn?.addEventListener('click', async () => {
    if (!(description instanceof HTMLTextAreaElement || description instanceof HTMLInputElement)) return;
    const original = generateBtnLabel ? generateBtnLabel.textContent : '';
    if (generateBtn instanceof HTMLButtonElement) generateBtn.disabled = true;
    if (generateBtnLabel) generateBtnLabel.textContent = 'Generation...';

    const payload = {
      typeGarantie: type instanceof HTMLSelectElement ? String(type.value || '').trim() : '',
      valeurEstimee: num(estimated instanceof HTMLInputElement ? estimated.value : ''),
      valeurRetenue: num(retained instanceof HTMLInputElement ? retained.value : ''),
      dateEvaluation: dateEval instanceof HTMLInputElement ? String(dateEval.value || '').trim() : '',
      nomGarant: guarantor instanceof HTMLInputElement ? String(guarantor.value || '').trim() : '',
      adresseBien: addressHidden instanceof HTMLInputElement ? String(addressHidden.value || '').trim() : (addressComplete instanceof HTMLInputElement ? String(addressComplete.value || '').trim() : '')
    };

    try {
      const res = await fetch(endpointGenerate, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
        body: JSON.stringify(payload)
      });
      const data = await res.json().catch(() => null);
      if (res.ok && data && data.ok === true && typeof data.description === 'string' && data.description.trim() !== '') {
        description.value = data.description.trim();
        description.dispatchEvent(new Event('input', { bubbles: true }));
      } else {
        throw new Error(data && data.message ? String(data.message) : 'Generation indisponible');
      }
    } catch (_) {
      const fallback = `Garantie ${payload.typeGarantie || 'non precisee'} situee a ${payload.adresseBien || 'adresse non precisee'}. Valeur estimee ${payload.valeurEstimee || 0} DT, valeur retenue ${payload.valeurRetenue || 0} DT. Garant: ${payload.nomGarant || 'non precise'}. Dossier a verifier avec les justificatifs.`;
      description.value = fallback;
      description.dispatchEvent(new Event('input', { bubbles: true }));
    } finally {
      if (generateBtn instanceof HTMLButtonElement) generateBtn.disabled = false;
      if (generateBtnLabel) generateBtnLabel.textContent = original || 'Generer par IA';
    }
  });
});
</script>
