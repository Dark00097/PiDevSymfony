    const previewMonthly  = $('#cr-preview-monthly');
    const previewTotal    = $('#cr-preview-total');
    const previewInterest = $('#cr-preview-interest');

    const recalculate = () => {
      const amount   = parseNum(amountField?.value);
      const duration = parseNum(durationField?.value);
      const rate     = parseNum(rateField?.value);
      const autoFunding = parseNum(autoFundingField?.value);
      const principal = Math.max(0, amount - autoFunding);

      if (principal <= 0 || duration <= 0) {
        if (monthlyField)  monthlyField.value  = '';
        if (approvedField) approvedField.value = '';
        if (previewMonthly)  previewMonthly.textContent  = '-- DT';
        if (previewTotal)    previewTotal.textContent    = '-- DT';
        if (previewInterest) previewInterest.textContent = '-- DT';
        return;
      }

      const mr = rate / 100 / 12;
      const mensualite = mr <= 0
        ? principal / duration
        : (principal * mr) / (1 - Math.pow(1 + mr, -duration));

      const totalCost     = mensualite * duration;
      const interestCost  = totalCost - principal;

      if (monthlyField)  monthlyField.value  = mensualite.toFixed(2);
      if (approvedField) approvedField.value = principal.toFixed(2);

      if (previewMonthly)  previewMonthly.textContent  = fmtNum(mensualite) + ' DT';
      if (previewTotal)    previewTotal.textContent    = fmtNum(totalCost) + ' DT';
      if (previewInterest) previewInterest.textContent = fmtNum(interestCost) + ' DT';
    };

    amountField?.addEventListener('input', () => {
      recalculate();
      validateCreditField('montantDemande');
      validateCreditField('autofinancement');
      validateCreditField('mensualite');
      validateCreditField('montantAccorde');
    });
    autoFundingField?.addEventListener('input', () => {
      recalculate();
      validateCreditField('autofinancement');
      validateCreditField('mensualite');
      validateCreditField('montantAccorde');
    });
    durationField?.addEventListener('change', () => {
      recalculate();
      validateCreditField('duree');
      validateCreditField('mensualite');
      validateCreditField('montantAccorde');
    });
    rateField?.addEventListener('input', () => {
      recalculate();
      validateCreditField('tauxInteret');
      validateCreditField('mensualite');
      validateCreditField('montantAccorde');
    });
    recalculate();

    creditForm?.addEventListener('submit', (event) => {
      syncCreditDateConstraint();
      recalculate();
      if (!validateCreditForm()) {
        event.preventDefault();
        return;
      }
    });
    creditForm?.addEventListener('reset', () => {
      window.requestAnimationFrame(() => {
        syncCreditDateConstraint();
        Object.values(creditStepFields).flat().forEach((name) => {
          clearFieldValidation(getCreditField(name), getCreditMessage(name));
        });
        recalculate();
        showStep(1);
      });
    });

    /* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
       CAPACITY ANALYSIS
    â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
    const analyzeBtn     = $('#cr-credit-analyze');
    const analysisOutput = $('#cr-analysis-output');
    const salaryField    = $('#cr-credit-salary');
    const contractField = $('#cr-credit-contract');
    const seniorityField = $('#cr-credit-seniority');
    const typeCreditField = $('#cr-credit-type');
    const aiModal = $('#cr-ai-modal');
    const aiModalOverlay = $('#cr-ai-modal-overlay');
    const aiModalCloseBtn = $('#cr-ai-modal-close');
    const aiModalOkBtn = $('#cr-ai-modal-ok');
    const aiStatus = $('#cr-ai-status');
    const aiScoreVal = $('#cr-ai-score-val');
    const aiProgressFill = $('#cr-ai-progress-fill');
    const aiDebtRatio = $('#cr-ai-debt-ratio');
    const aiDebtMark = $('#cr-ai-debt-mark');
    const aiAuto = $('#cr-ai-autofinancing');
    const aiAutoMark = $('#cr-ai-autofinancing-mark');
    const aiDuration = $('#cr-ai-duration');
    const aiDurationMark = $('#cr-ai-duration-mark');
    const aiSalary = $('#cr-ai-salary');
    const aiSalaryMark = $('#cr-ai-salary-mark');
    const aiApproval = $('#cr-ai-approval');
    const aiApprovalMark = $('#cr-ai-approval-mark');
    const aiRisk = $('#cr-ai-risk');
    const aiRiskMark = $('#cr-ai-risk-mark');
    const aiRecommendation = $('#cr-ai-recommendation');

    const resolveAnalysisTone = (approval, riskLevel) => {
      const normalizedRisk = normalizeSearchValue(riskLevel);
      if (approval >= 70 && normalizedRisk.includes('faible')) {
        return 'is-ok';
      }
      if (approval < 45 || normalizedRisk.includes('eleve')) {
        return 'is-risk';
      }

      return 'is-warn';
    };

    const openAiModal = () => {
      if (!aiModal || !aiModalOverlay) return;
      aiModal.hidden = false;
      aiModalOverlay.hidden = false;
      document.body.style.overflow = 'hidden';
    };

    const closeAiModal = () => {
      if (!aiModal || !aiModalOverlay) return;
      aiModal.hidden = true;
      aiModalOverlay.hidden = true;
      document.body.style.overflow = '';
    };

    const setMark = (el, tone) => {
      if (!el) return;
      el.classList.remove('is-ok', 'is-warn', 'is-risk');
      el.classList.add(tone);
      el.textContent = tone === 'is-ok' ? 'OK' : (tone === 'is-warn' ? '⚠' : '✖');
    };

    const renderAiModalResult = (payload, scoring, provider) => {
      if (!aiModal) return;

      const approval = parseNum(scoring.approval_probability);
      const score = parseNum(scoring.score);
      const riskLevel = String(scoring.risk_level ?? 'Moyen');
      const suggestedStatus = String(scoring.suggested_status ?? 'En attente');
      const explanation = String(scoring.explanation ?? '').trim();
      const tone = resolveAnalysisTone(approval, riskLevel);

      const montantDemande = parseNum(payload.montantDemande);
      const autofinancement = parseNum(payload.autofinancement);
      const duree = parseNum(payload.duree);
      const salaire = parseNum(payload.salaire);
      const mensualite = parseNum(payload.mensualite);
      const debtRatio = salaire > 0 ? (mensualite / salaire) * 100 : 0;
      const autoRatio = montantDemande > 0 ? (autofinancement / montantDemande) * 100 : 0;

      if (aiStatus) {
        aiStatus.classList.remove('is-ok', 'is-warn', 'is-risk');
        aiStatus.classList.add(tone);

        const normalizedStatus = normalizeSearchValue(suggestedStatus);
        aiStatus.textContent = normalizedStatus.includes('accepte')
          ? '✔ Crédit accepté'
          : (normalizedStatus.includes('refuse') ? '✖ Crédit refusé' : '⌛ Crédit en attente');
      }

      if (aiScoreVal) {
        aiScoreVal.textContent = `${fmtNum(score, 1)} / 100`;
      }

      if (aiProgressFill) {
        const scoreClamped = Math.max(0, Math.min(100, score));
        aiProgressFill.style.width = `${scoreClamped}%`;
        aiProgressFill.classList.remove('is-warn', 'is-risk');
        if (tone === 'is-warn') aiProgressFill.classList.add('is-warn');
        if (tone === 'is-risk') aiProgressFill.classList.add('is-risk');
      }

      if (aiDebtRatio) aiDebtRatio.textContent = `${fmtNum(debtRatio, 1)}%`;
      if (aiAuto) aiAuto.textContent = `${fmtNum(autoRatio, 1)}%`;
      if (aiDuration) aiDuration.textContent = `${fmtNum(duree, 0)} mois`;
      if (aiSalary) aiSalary.textContent = `${fmtNum(salaire, 2)} DT`;
      if (aiApproval) aiApproval.textContent = `${fmtNum(approval, 1)}%`;
      if (aiRisk) aiRisk.textContent = riskLevel;

      setMark(aiDebtMark, debtRatio <= 35 ? 'is-ok' : (debtRatio <= 45 ? 'is-warn' : 'is-risk'));
      setMark(aiAutoMark, autoRatio >= 20 ? 'is-ok' : (autoRatio >= 10 ? 'is-warn' : 'is-risk'));
      setMark(aiDurationMark, duree <= 84 ? 'is-ok' : (duree <= 120 ? 'is-warn' : 'is-risk'));
      setMark(aiSalaryMark, salaire >= 1500 ? 'is-ok' : (salaire >= 900 ? 'is-warn' : 'is-risk'));
      setMark(aiApprovalMark, approval >= 70 ? 'is-ok' : (approval >= 45 ? 'is-warn' : 'is-risk'));

      const normalizedRisk = normalizeSearchValue(riskLevel);
      setMark(
        aiRiskMark,
        normalizedRisk.includes('faible')
          ? 'is-ok'
          : (normalizedRisk.includes('eleve') ? 'is-risk' : 'is-warn')
      );

      if (aiRecommendation) {
        const generatedReco = tone === 'is-ok'
          ? `Profil solide. Statut suggere: ${suggestedStatus}.`
          : (tone === 'is-risk'
              ? `Risque eleve detecte. Ajustez montant/duree avant validation.`
              : `Profil moyen: renforcez salaire ou autofinancement pour augmenter l approbation.`);
        const recoText = explanation !== '' ? explanation : generatedReco;
        aiRecommendation.textContent = `${recoText} (Source IA: ${provider})`;
      }
    };

    const showAiErrorModal = (message) => {
      if (aiStatus) {
        aiStatus.classList.remove('is-ok', 'is-warn');
        aiStatus.classList.add('is-risk');
        aiStatus.textContent = '✖ Analyse indisponible';
      }
      if (aiScoreVal) aiScoreVal.textContent = '-- / 100';
      if (aiProgressFill) {
        aiProgressFill.style.width = '0%';
        aiProgressFill.classList.remove('is-warn', 'is-risk');
      }

      [aiDebtRatio, aiAuto, aiDuration, aiSalary, aiApproval, aiRisk].forEach((el) => {
        if (el) el.textContent = '--';
      });
      [aiDebtMark, aiAutoMark, aiDurationMark, aiSalaryMark, aiApprovalMark, aiRiskMark].forEach((el) => setMark(el, 'is-risk'));

      if (aiRecommendation) {
        aiRecommendation.textContent = message || 'Analyse indisponible pour le moment.';
      }

      openAiModal();
    };

    aiModalCloseBtn?.addEventListener('click', closeAiModal);
    aiModalOkBtn?.addEventListener('click', closeAiModal);
    aiModalOverlay?.addEventListener('click', closeAiModal);
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && aiModal && !aiModal.hidden) {
        closeAiModal();
      }
    });

    analyzeBtn?.addEventListener('click', async () => {
      if (!analysisOutput) return;

      recalculate();

      const requiredBeforeAnalysis = ['montantDemande', 'autofinancement', 'duree', 'tauxInteret', 'salaire', 'typeContrat', 'ancienneteAnnees'];
      const isValid = requiredBeforeAnalysis.map((name) => validateCreditField(name)).every((res) => res);
      if (!isValid) {
        analysisOutput.textContent = 'Veuillez corriger les champs obligatoires avant de lancer l analyse.';
        analysisOutput.className = 'cr-analysis-output is-warn';
        analysisOutput.hidden = false;
        return;
      }

      const payload = {
        typeCredit: typeCreditField?.value ?? '',
        montantDemande: parseNum(amountField?.value),
        autofinancement: parseNum(autoFundingField?.value),
        duree: parseNum(durationField?.value),
        tauxInteret: parseNum(rateField?.value),
        mensualite: parseNum(monthlyField?.value),
        montantAccorde: parseNum(approvedField?.value),
        salaire: parseNum(salaryField?.value),
        typeContrat: contractField?.value ?? '',
        ancienneteAnnees: parseNum(seniorityField?.value),
      };

      const originalLabel = analyzeBtn.innerHTML;
      analyzeBtn.disabled = true;
      analyzeBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Analyse en cours...';
      analysisOutput.hidden = true;

      try {
        const response = await fetch(analyzeEndpoint, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest',
          },
          body: JSON.stringify(payload),
        });

        const result = await response.json().catch(() => null);
        if (!response.ok || !result || result.ok !== true) {
          const errorMessage = (result && typeof result.message === 'string' && result.message.trim() !== '')
            ? result.message
            : 'Analyse indisponible pour le moment.';
          throw new Error(errorMessage);
        }

        const scoring = result.scoring ?? {};
        const approval = parseNum(scoring.approval_probability);
        const failure = parseNum(scoring.failure_probability);
        const score = parseNum(scoring.score);
        const riskLevel = String(scoring.risk_level ?? 'Moyen');
        const suggestedStatus = String(scoring.suggested_status ?? 'En attente');
        const explanation = String(scoring.explanation ?? '').trim();
        const provider = String(result.provider ?? 'Fallback');

        renderAiModalResult(payload, scoring, provider);
        openAiModal();

        analysisOutput.className = `cr-analysis-output ${resolveAnalysisTone(approval, riskLevel)}`;
        analysisOutput.textContent = [
          `Chance d obtention: ${fmtNum(approval, 1)}%`,
          `Chance d echec: ${fmtNum(failure, 1)}%`,
          `Score IA: ${fmtNum(score, 1)}/100`,
          `Risque: ${riskLevel}`,
          `Statut suggere: ${suggestedStatus}`,
          explanation !== '' ? `Motif: ${explanation}` : null,
          `Provider: ${provider}`,
        ].filter(Boolean).join('\n');
      } catch (error) {
        const message = error instanceof Error ? error.message : 'Analyse indisponible pour le moment.';
        showAiErrorModal(message);
        analysisOutput.className = 'cr-analysis-output is-warn';
        analysisOutput.textContent = message;
      } finally {
        analyzeBtn.disabled = false;
        analyzeBtn.innerHTML = originalLabel;
        analysisOutput.hidden = true;
      }
    });

    /* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
       EDIT BUTTON â†’ fill form
    â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
    const fillForm = (row) => {
      if (!creditForm || !row) return;

      const set = (name, val) => {
        const f = creditForm.querySelector(`[name="${name}"]`);
        if (f) f.value = val ?? '';
      };

      set('idCredit',       row.dataset.creditId);
      set('idCompte',       row.dataset.creditAccount);
      set('typeCredit',     row.dataset.creditType);
      set('idGarantie',     row.dataset.creditGarantieId);
      set('montantDemande', row.dataset.creditAmount);
      set('autofinancement',row.dataset.creditAuto);
      set('duree',          row.dataset.creditDuration);
      set('tauxInteret',    row.dataset.creditRate);
      set('mensualite',     row.dataset.creditMonthly);
      set('montantAccorde', row.dataset.creditApproved);
      set('dateDemande',    row.dataset.creditDate);
      set('salaire',        row.dataset.creditSalary);
      set('typeContrat',    row.dataset.creditContract);
      set('ancienneteAnnees', row.dataset.creditSeniority);

      syncCreditDateConstraint();
      recalculate();

      if (analysisOutput) {
        analysisOutput.hidden = true;
      }

      showStep(1);
      openDrawer();
      document.getElementById('credit-form-card')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    };

    $$('[data-credit-edit]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const card = btn.closest('[data-credit-row]');
        fillForm(card);
      });
    });

    /* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
       ADD NEW BUTTON (header)
    â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
    const addBtn      = $('#cr-add-credit-btn');
    const emptyAddBtn = $('#cr-empty-add-btn');

    const resetAndFocus = () => {
      creditForm?.reset();
      syncNextCreditId();
      syncCreditDateConstraint();
      recalculate();
      if (analysisOutput) { analysisOutput.hidden = true; }
      showStep(1);
      openDrawer();
      document.getElementById('credit-form-card')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    };

    addBtn?.addEventListener('click', resetAndFocus);
    emptyAddBtn?.addEventListener('click', resetAndFocus);

    /* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
       FORM COLLAPSE (toggle)
    â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
    const collapseBtn = $('#cr-collapse-form');
    const formBody    = creditForm;

    collapseBtn?.addEventListener('click', () => {
      const collapsed = formBody?.classList.toggle('cr-form-collapsed');
      const icon = collapseBtn.querySelector('i');
      if (icon) icon.className = collapsed ? 'fa-solid fa-chevron-right' : 'fa-solid fa-chevron-left';
    });

    /* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
       SEARCH & SORT & FILTER
    â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
    const searchInput  = $('#cr-search-input');
    const searchClear  = $('#cr-search-clear');
    const sortSelect   = $('#cr-sort-select');
    const filterTabs   = $$('.cr-filter-tab');
    const allCards     = $$('[data-credit-row]');
    const garantieRows = $$('[data-main-garantie-row]');
    const creditPager = $('#cr-credit-pager');
    const garantiePager = $('#cr-garantie-pager');
    const creditsView  = $('#cr-credits-view');
    const garantiesView = $('#cr-garanties-view');
    const garantiesInlineBtn = $('#cr-open-garanties-inline');
    const garantiesInlineLabel = $('#cr-open-garanties-inline-label');
    const mainListLabel = $('#cr-main-list-label');
    const mainListCount = $('#cr-main-list-count');
    const mainListIcon = $('#cr-main-list-icon');
    const creditFilterTabs = $('#cr-credit-filter-tabs');
    const creditMedianAmount = medianOf(allCards.map((card) => parseNum(card.dataset.creditAmount)));
    const garantieMedianAmount = medianOf(garantieRows.map((row) => parseNum(row.dataset.garantieEstimated)));
    const restructurationScenarios = {{ restructuration_scenarios|json_encode|raw }};
    const restructOverlay = $('#cr-restruct-overlay');
    const restructModal = $('#cr-restruct-modal');
    const restructOpenBtn = $('#cr-open-restructuring-btn');
    const restructCloseBtn = $('#cr-restruct-close');
    const restructDismissBtn = $('#cr-restruct-dismiss');
    const restructAlert = $('#cr-restruct-alert');
    const restructDebtValue = $('#cr-restruct-debt-value');
    const restructMonthlyValue = $('#cr-restruct-monthly-value');
    const restructTypeValue = $('#cr-restruct-type-value');
    const restructOptions = $('#cr-restruct-options');
    const restructEmpty = $('#cr-restruct-empty');
    const restructInfoText = $('#cr-restruct-info');
    const restructApplyState = $('#cr-restruct-apply-state');
    const restructFirstEligibleCreditId = Number(root?.dataset.restructFirstEligibleCredit || 0);
    const restructFirstCriticalCreditId = Number(root?.dataset.restructFirstCriticalCredit || 0);
    const paginationState = {
      credits: 1,
      garanties: 1,
    };
    const paginationSize = {
      credits: 6,
      garanties: 6,
    };

    let activeFilter = 'all';
    let activeListing = 'credits';
    let selectedGarantieCreditId = null;

    const parseDisplayAmount = (value) => {
      const normalized = String(value ?? '')
        .replace(/\s+/g, '')
        .replace(/[^0-9,.-]/g, '')
        .replace(',', '.')
        .trim();
      const parsed = Number(normalized);
      return Number.isFinite(parsed) ? parsed : 0;
    };

    const parseDurationMonths = (value) => {
      const match = String(value ?? '').match(/(\d+(?:[.,]\d+)?)/);
      return match ? Math.round(parseDisplayAmount(match[1])) : 0;
    };

    const buildCreditSearchIndex = (card) => {
      if (!(card instanceof HTMLElement)) {
        return '';
      }

      return normalizeSearchValue([
        card.dataset.creditId,
        card.dataset.creditAccount,
        card.dataset.creditAccountNumber,
        card.dataset.creditType,
        card.dataset.creditStatus,
        card.dataset.creditAmount,
        card.dataset.creditMonthly,
        card.dataset.creditContract,
        card.dataset.creditDate
      ].join(' '));
    };

    const syncCreditRestructState = (card) => {
      if (!(card instanceof HTMLElement)) {
        return;
      }

      const isApplied = card.dataset.creditRestructApplied === '1';
      card.classList.toggle('is-restructured', isApplied);

      const idBlock = card.querySelector('.cr-cc-id');
      let badge = card.querySelector('.cr-cc-applied-badge');
      if (isApplied) {
        if (!badge && idBlock instanceof HTMLElement) {
          badge = document.createElement('span');
          badge.className = 'cr-cc-applied-badge';
          idBlock.appendChild(badge);
        }
        if (badge) {
          badge.textContent = t('restructurationAppliedCard');
          const appliedTitle = String(card.dataset.creditRestructAppliedLabel || '').trim();
          if (appliedTitle !== '') {
            badge.title = appliedTitle;
          } else {
            badge.removeAttribute('title');
          }
        }
      } else if (badge) {
        badge.remove();
      }

      const restructBtn = card.querySelector('.cr-cc-restruct-btn');
      if (restructBtn instanceof HTMLElement) {
        restructBtn.classList.toggle('is-applied', isApplied);
        const label = restructBtn.querySelector('.cr-cc-restruct-label');
        if (label) {
          label.textContent = isApplied ? t('restructurationAppliedCard') : t('restructurationSingle');
        }
      }
    };

    const applyRestructurationOptionToCard = (creditId, scenario, option) => {
      const normalizedCreditId = String(Number(creditId || scenario?.credit_id || 0) || 0);
      if (normalizedCreditId === '0') {
        return false;
      }

      const card = $(`[data-credit-row][data-credit-id="${normalizedCreditId}"]`);
      if (!(card instanceof HTMLElement)) {
        return false;
      }

      const nextMonthlyText = String(option?.new_amount || scenario?.monthly_payment_formatted || '--').trim();
      const nextDurationText = String(option?.new_duration || scenario?.duration_formatted || '--').trim();
      const nextMonthlyValue = parseDisplayAmount(nextMonthlyText);
      const nextDurationValue = parseDurationMonths(nextDurationText);

      if (nextMonthlyValue > 0) {
        card.dataset.creditMonthly = String(nextMonthlyValue);
      }
      if (nextDurationValue > 0) {
        card.dataset.creditDuration = String(nextDurationValue);
      }

      card.dataset.creditRestructApplied = '1';
      card.dataset.creditRestructAppliedLabel = String(option?.title || '').trim();
      card.dataset.creditSearch = buildCreditSearchIndex(card);

      const monthlyValueEl = card.querySelector('.cr-cc-monthly-val');
      if (monthlyValueEl) {
        monthlyValueEl.textContent = nextMonthlyText !== '' ? nextMonthlyText : `${fmtNum(nextMonthlyValue, 2)} DT`;
      }

      const durationValueEl = card.querySelector('.cr-cc-meta .cr-cc-meta-item:first-child span');
      if (durationValueEl) {
        durationValueEl.textContent = nextDurationText !== '' ? nextDurationText : `${nextDurationValue} mois`;
      }

      if (scenario && typeof scenario === 'object') {
        scenario.monthly_payment = nextMonthlyValue;
        scenario.monthly_payment_formatted = nextMonthlyText;
        scenario.duration = nextDurationValue;
        scenario.duration_formatted = nextDurationText;
        scenario.applied_option_key = String(option?.key || '');
      }

      if (restructMonthlyValue) {
        restructMonthlyValue.textContent = nextMonthlyText || '--';
      }

      syncCreditRestructState(card);
      return true;
    };

    const resolveRestructurationScenario = (creditId = 0) => {
      const normalizedId = String(Number(creditId) || 0);
      if (normalizedId !== '0' && restructurationScenarios && typeof restructurationScenarios === 'object' && restructurationScenarios[normalizedId]) {
        return restructurationScenarios[normalizedId];
      }
      if (restructFirstEligibleCreditId > 0 && restructurationScenarios[String(restructFirstEligibleCreditId)]) {
        return restructurationScenarios[String(restructFirstEligibleCreditId)];
      }
      const firstKey = Object.keys(restructurationScenarios || {})[0];
      return firstKey ? restructurationScenarios[firstKey] : null;
    };

    const openRestructurationModal = (creditId = 0) => {
      if (!(restructModal instanceof HTMLElement) || !(restructOverlay instanceof HTMLElement)) {
        return;
      }

      const scenario = resolveRestructurationScenario(creditId);
      const activeCreditId = Number(creditId || scenario?.credit_id || 0);
      if (!(restructOptions instanceof HTMLElement) || !(restructEmpty instanceof HTMLElement)) {
        return;
      }

      restructModal.dataset.creditId = String(activeCreditId || 0);
      restructOptions.innerHTML = '';
      restructApplyState && (restructApplyState.hidden = true);
      if (restructApplyState) restructApplyState.textContent = '';

      if (!scenario || typeof scenario !== 'object') {
        if (restructAlert) restructAlert.hidden = true;
        restructEmpty.hidden = false;
        restructOptions.hidden = true;
        if (restructInfoText) restructInfoText.textContent = t('restructurationInfo');
      } else {
        restructEmpty.hidden = true;
        restructOptions.hidden = false;
        if (restructAlert) restructAlert.hidden = !(scenario.eligible || scenario.auto_open);
        if (restructDebtValue) restructDebtValue.textContent = String(scenario.debt_ratio_formatted || '--');
        if (restructMonthlyValue) restructMonthlyValue.textContent = String(scenario.monthly_payment_formatted || '--');
        if (restructTypeValue) restructTypeValue.textContent = String(scenario.credit_type || '--');
        if (restructInfoText) restructInfoText.textContent = String(scenario.info_text || t('restructurationInfo'));

        (Array.isArray(scenario.options) ? scenario.options : []).forEach((option) => {
          if (!option || typeof option !== 'object') return;
          const card = document.createElement('article');
          card.className = `cr-restruct-option is-${String(option.theme || 'blue')}`;
          const isAppliedOption = String(scenario.applied_option_key || '') !== '' && String(scenario.applied_option_key) === String(option.key || '');
          if (isAppliedOption) {
            card.classList.add('is-selected');
          }

          const title = document.createElement('h4');
          title.textContent = String(option.title || '');
          const description = document.createElement('p');
          description.textContent = String(option.description || '');

          const shift = document.createElement('div');
          shift.className = 'cr-restruct-option-shift';
          const shiftLabel = document.createElement('span');
          shiftLabel.textContent = t('monthlyPayment');
          const shiftValue = document.createElement('strong');
          shiftValue.textContent = String(option.highlight || `${option.old_amount || '--'} -> ${option.new_amount || '--'}`);
          shift.append(shiftLabel, shiftValue);

          const meta = document.createElement('div');
          meta.className = 'cr-restruct-option-meta';
          [
            [t('monthlyPayment'), `${option.old_amount || '--'} -> ${option.new_amount || '--'}`],
            [t('assistantDurationLabel'), `${option.old_duration || '--'} -> ${option.new_duration || '--'}`]
          ].forEach(([label, value]) => {
            const box = document.createElement('div');
            const metaLabel = document.createElement('span');
            metaLabel.textContent = String(label);
            const metaValue = document.createElement('strong');
            metaValue.textContent = String(value);
            box.append(metaLabel, metaValue);
            meta.appendChild(box);
          });

          const applyBtn = document.createElement('button');
          applyBtn.type = 'button';
          applyBtn.className = 'cr-restruct-option-apply';
          applyBtn.textContent = isAppliedOption ? t('restructurationAppliedCard') : t('restructurationApply');
          applyBtn.disabled = isAppliedOption;
          if (isAppliedOption) {
            applyBtn.classList.add('is-applied');
          }
          applyBtn.addEventListener('click', () => {
            const wasApplied = applyRestructurationOptionToCard(activeCreditId, scenario, option);
            openRestructurationModal(activeCreditId);
            if (restructApplyState) {
              restructApplyState.hidden = false;
              restructApplyState.textContent = wasApplied
                ? t('restructurationApplied')(String(option.title || ''))
                : t('restructurationInfo');
            }
          });

          card.append(title, description, shift, meta, applyBtn);
          restructOptions.appendChild(card);
        });
      }

      restructModal.hidden = false;
      restructOverlay.hidden = false;
      document.body.style.overflow = 'hidden';
    };

    const closeRestructurationModal = () => {
      if (!(restructModal instanceof HTMLElement) || !(restructOverlay instanceof HTMLElement)) {
        return;
      }

      restructModal.hidden = true;
      restructOverlay.hidden = true;
      document.body.style.overflow = '';
    };

    const renderListPager = (container, totalItems, pageKey, onChange) => {
      if (!(container instanceof HTMLElement)) {
        return;
      }

      const totalPages = Math.max(1, Math.ceil(totalItems / paginationSize[pageKey]));
      paginationState[pageKey] = Math.min(Math.max(1, paginationState[pageKey]), totalPages);
      container.innerHTML = '';
      container.hidden = totalItems === 0;

      if (container.hidden) {
        return;
      }

      const appendButton = (label, page, { icon = '', disabled = false, active = false, ariaLabel = '' } = {}) => {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'cr-list-pager-btn';
        btn.disabled = disabled;
        btn.setAttribute('aria-label', ariaLabel || String(label));
        btn.innerHTML = icon ? `<i class="${icon}"></i>` : String(label);
        if (active) {
          btn.classList.add('is-active');
          btn.setAttribute('aria-current', 'page');
        }
        btn.addEventListener('click', () => {
          if (disabled || page === paginationState[pageKey]) return;
          paginationState[pageKey] = page;
          onChange();
        });
        container.appendChild(btn);
      };

      appendButton('Prev', Math.max(1, paginationState[pageKey] - 1), {
        icon: 'fa-solid fa-chevron-left',
        disabled: paginationState[pageKey] === 1,
        ariaLabel: 'Page precedente',
      });

      const windowStart = Math.max(1, paginationState[pageKey] - 2);
      const windowEnd = Math.min(totalPages, windowStart + 4);
      for (let page = windowStart; page <= windowEnd; page += 1) {
        appendButton(String(page), page, { active: page === paginationState[pageKey] });
      }

      appendButton('Next', Math.min(totalPages, paginationState[pageKey] + 1), {
        icon: 'fa-solid fa-chevron-right',
        disabled: paginationState[pageKey] === totalPages,
        ariaLabel: 'Page suivante',
      });
    };

    const applyListPagination = (items, container, pageKey, onChange) => {
      const totalPages = Math.max(1, Math.ceil(items.length / paginationSize[pageKey]));
      paginationState[pageKey] = Math.min(Math.max(1, paginationState[pageKey]), totalPages);
      const start = (paginationState[pageKey] - 1) * paginationSize[pageKey];
      const end = start + paginationSize[pageKey];

      items.forEach((item, index) => {
        item.classList.toggle('cr-page-hidden', index < start || index >= end);
      });

      renderListPager(container, items.length, pageKey, onChange);
    };

    const updateListingUI = () => {
      const showingGaranties = activeListing === 'garanties';

      creditsView && (creditsView.hidden = showingGaranties);
      garantiesView && (garantiesView.hidden = !showingGaranties);
      creditFilterTabs && (creditFilterTabs.hidden = showingGaranties);

      if (searchInput) {
        searchInput.placeholder = showingGaranties ? t('searchGuarantee') : t('searchCredit');
        searchInput.value = '';
      }
      if (searchClear) searchClear.hidden = true;

      if (mainListLabel) {
        mainListLabel.textContent = showingGaranties
          ? (selectedGarantieCreditId ? t('guaranteesForCredit')(selectedGarantieCreditId) : t('myGuarantees'))
          : t('myCredits');
      }
      if (mainListCount) mainListCount.textContent = String(showingGaranties ? garantieRows.length : allCards.length);
      if (mainListIcon) {
        mainListIcon.className = showingGaranties ? 'fa-solid fa-shield-halved' : 'fa-solid fa-credit-card';
      }
      if (garantiesInlineLabel) {
        garantiesInlineLabel.textContent = showingGaranties
          ? (selectedGarantieCreditId ? t('allGuarantees') : t('allCredits'))
          : t('allGuarantees');
      }
      if (garantiesInlineBtn) {
        garantiesInlineBtn.classList.toggle('is-active-alt', showingGaranties);
        const icon = garantiesInlineBtn.querySelector('i');
        if (icon) {
          icon.className = showingGaranties
            ? (selectedGarantieCreditId ? 'fa-solid fa-shield-halved' : 'fa-solid fa-credit-card')
            : 'fa-solid fa-shield-halved';
        }
      }
      if (creditPager instanceof HTMLElement) {
        creditPager.hidden = showingGaranties;
      }
      if (garantiePager instanceof HTMLElement) {
        garantiePager.hidden = !showingGaranties;
      }
    };

    const applyState = () => {
      const kw       = searchInput?.value ?? '';
      const sortBy   = sortSelect?.value ?? 'id_desc';

      if (searchClear) searchClear.hidden = kw.trim() === '';

      if (activeListing === 'garanties') {
        const garantieList = $('.cr-garanties-list-main');
        const visibleGaranties = garantieRows.filter((row) => {
          const searchText = row.dataset.garantieSearch ?? '';
          const matchesCredit = !selectedGarantieCreditId || row.dataset.garantieCreditId === String(selectedGarantieCreditId);
          const show = matchesCredit && matchesSearchTokens(searchText, kw);
          row.classList.toggle('cr-hidden', !show);
          return show;
        });

        if (mainListCount) {
          mainListCount.textContent = String(visibleGaranties.length);
        }
        if (garantieList) {
          visibleGaranties.sort((a, b) => {
            const idA = parseNum(a.dataset.garantieId);
            const idB = parseNum(b.dataset.garantieId);
            const valA = parseNum(a.dataset.garantieEstimated);
            const valB = parseNum(b.dataset.garantieEstimated);
            const dateA = parseSortableDate(a.dataset.garantieDate);
            const dateB = parseSortableDate(b.dataset.garantieDate);

            switch (sortBy) {
              case 'id_asc':
                return dateA !== dateB ? dateA - dateB : idA - idB;
              case 'amount_high':
                return valB - valA || idB - idA;
              case 'amount_medium':
                return Math.abs(valA - garantieMedianAmount) - Math.abs(valB - garantieMedianAmount) || idB - idA;
              case 'amount_low':
                return valA - valB || idA - idB;
              default:
                return dateB !== dateA ? dateB - dateA : idB - idA;
            }
          }).forEach((row) => garantieList.appendChild(row));
        }

        applyListPagination(visibleGaranties, garantiePager, 'garanties', applyState);

        return;
      }

      const visible = allCards.filter((card) => {
        const searchText = card.dataset.creditSearch ?? '';
        const matchKw    = matchesSearchTokens(searchText, kw);

        let matchFilter = true;
        if (activeFilter !== 'all') {
          const st = normalizeSearchValue(card.dataset.creditStatus ?? '');
          matchFilter = st.includes(activeFilter);
        }

        const show = matchKw && matchFilter;
        card.classList.toggle('cr-hidden', !show);
        return show;
      });

      if (mainListCount) {
        mainListCount.textContent = String(visible.length);
      }
      const grid = $('#cr-credits-grid');
      if (grid) {
        visible.sort((a, b) => {
          const idA  = parseNum(a.dataset.creditId);
          const idB  = parseNum(b.dataset.creditId);
          const amA  = parseNum(a.dataset.creditAmount);
          const amB  = parseNum(b.dataset.creditAmount);
          const rkA  = parseNum(a.dataset.creditRisk);
          const rkB  = parseNum(b.dataset.creditRisk);
          const dtA  = parseSortableDate(a.dataset.creditDate);
          const dtB  = parseSortableDate(b.dataset.creditDate);

          switch (sortBy) {
            case 'id_asc':
              return dtA !== dtB ? dtA - dtB : idA - idB;
            case 'amount_high':
              return amB - amA || idB - idA;
            case 'amount_medium':
              return Math.abs(amA - creditMedianAmount) - Math.abs(amB - creditMedianAmount) || idB - idA;
            case 'amount_low':
              return amA - amB || idA - idB;
            case 'risk_desc':
              return rkB - rkA || idB - idA;
            default:
              return dtB !== dtA ? dtB - dtA : idB - idA;
          }
        }).forEach((card) => grid.appendChild(card));
      }

      applyListPagination(visible, creditPager, 'credits', applyState);

    };

    searchInput?.addEventListener('input', () => {
      paginationState[activeListing] = 1;
      applyState();
    });
    searchClear?.addEventListener('click', () => {
      if (searchInput) searchInput.value = '';
      paginationState[activeListing] = 1;
      applyState();
    });
    sortSelect?.addEventListener('change', () => {
      paginationState[activeListing] = 1;
      applyState();
    });

    filterTabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        activeFilter = tab.dataset.filter ?? 'all';
        paginationState.credits = 1;
        filterTabs.forEach((t) => t.classList.remove('cr-filter-tab-active'));
        tab.classList.add('cr-filter-tab-active');
        applyState();
      });
    });

    garantiesInlineBtn?.addEventListener('click', () => {
      if (activeListing === 'credits') {
        activeListing = 'garanties';
        selectedGarantieCreditId = null;
        paginationState.garanties = 1;
      } else if (selectedGarantieCreditId) {
        selectedGarantieCreditId = null;
        activeListing = 'garanties';
        paginationState.garanties = 1;
      } else {
        activeListing = 'credits';
        selectedGarantieCreditId = null;
        paginationState.credits = 1;
      }
      updateListingUI();
      applyState();
    });

    $$('[data-credit-garanties]').forEach((btn) => {
      btn.addEventListener('click', () => {
        selectedGarantieCreditId = btn.dataset.creditGaranties ?? null;
        activeListing = 'garanties';
        paginationState.garanties = 1;
        updateListingUI();
        applyState();
      });
    });

    $$('[data-credit-restruct]').forEach((btn) => {
      btn.addEventListener('click', () => {
        openRestructurationModal(btn.dataset.creditRestruct || 0);
      });
    });

    restructCloseBtn?.addEventListener('click', closeRestructurationModal);
    restructDismissBtn?.addEventListener('click', closeRestructurationModal);
    restructOverlay?.addEventListener('click', closeRestructurationModal);
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && restructModal && !restructModal.hidden) {
        closeRestructurationModal();
      }
    });

    const maybeAutoOpenRestructuration = () => {
      if (restructFirstCriticalCreditId <= 0 || !(window.sessionStorage && restructModal instanceof HTMLElement)) {
        return;
      }

      const storageKey = `nexora.portal.credits.restruct.auto.${restructFirstCriticalCreditId}`;
      if (window.sessionStorage.getItem(storageKey) === '1') {
        return;
      }

      window.sessionStorage.setItem(storageKey, '1');
      window.setTimeout(() => {
        openRestructurationModal(restructFirstCriticalCreditId);
      }, 650);
    };

    maybeAutoOpenRestructuration();

    /* ════════════════════════════════════════════════════════════════════
       TOOLS MODAL
    ════════════════════════════════════════════════════════════════════ */
    const toolsOverlay = $('#cr-tools-overlay');
    const toolsModal = $('#cr-tools-modal');
    const toolsTitle = $('#cr-tools-title');
    const toolsSubtitle = $('#cr-tools-subtitle');
    const toolsClose = $('#cr-tools-close');
    const toolTabs = $$('[data-tool-tab]', root);
    const toolPanels = $$('[data-tool-panel]', root);
    const toolOpenButtons = $$('[data-tool-open]', root);
    const getToolMeta = () => ({
      simulate: {
        title: currentInterfaceLanguage === 'ar' ? 'محاكاة ومقارنة' : (currentInterfaceLanguage === 'en' ? 'Simulate & Compare' : 'Simuler & Comparer'),
        subtitle: currentInterfaceLanguage === 'ar' ? 'حلل قروضك دون مغادرة هذه الصفحة.' : (currentInterfaceLanguage === 'en' ? 'Analyze your loans without leaving this page.' : 'Analysez vos credits sans quitter cette page.')
      },
      history: {
        title: t('historyTitle'),
        subtitle: t('historySubtitle')
      },
      ratio: {
        title: currentInterfaceLanguage === 'ar' ? 'نسبة المديونية' : (currentInterfaceLanguage === 'en' ? 'Debt ratio' : 'Ratio d endettement'),
        subtitle: currentInterfaceLanguage === 'ar' ? 'اعرض قدرتك المالية في الوقت الفعلي.' : (currentInterfaceLanguage === 'en' ? 'View your financial capacity in real time.' : 'Visualisez votre capacite financiere en temps reel.')
      },
      projection: {
        title: currentInterfaceLanguage === 'ar' ? 'توقعات مستقبلية' : (currentInterfaceLanguage === 'en' ? 'Future projection' : 'Projection future'),
        subtitle: currentInterfaceLanguage === 'ar' ? 'توقع تطور سدادك مستقبلاً.' : (currentInterfaceLanguage === 'en' ? 'Anticipate how your repayments will evolve.' : 'Anticipez l evolution de vos remboursements.')
      },
      restruct: {
        title: currentInterfaceLanguage === 'ar' ? 'إعادة هيكلة' : (currentInterfaceLanguage === 'en' ? 'Restructuring' : 'Restructuration'),
        subtitle: currentInterfaceLanguage === 'ar' ? 'قارن بين سيناريوهات إعادة الضبط.' : (currentInterfaceLanguage === 'en' ? 'Compare restructuring scenarios.' : 'Comparez des scenarios de reajustement.')
      },
      assistant: {
        title: currentInterfaceLanguage === 'ar' ? 'مساعد ذكي' : (currentInterfaceLanguage === 'en' ? 'AI assistant' : 'Assistant IA'),
        subtitle: currentInterfaceLanguage === 'ar' ? 'احصل على اقتراحات سياقية حول قروضك.' : (currentInterfaceLanguage === 'en' ? 'Get contextual suggestions about your loans.' : 'Obtenez des suggestions contextuelles sur vos credits.')
      }
    });

    const openToolPanel = (panelName) => {
      if (!toolsModal || !toolsOverlay) return;
      const toolMeta = getToolMeta();
      const meta = toolMeta[panelName] ?? toolMeta.simulate;

      toolTabs.forEach((tab) => {
        tab.classList.toggle('is-active', tab.dataset.toolTab === panelName);
      });
      toolPanels.forEach((panel) => {
        panel.classList.toggle('is-active', panel.dataset.toolPanel === panelName);
      });

      if (toolsTitle) toolsTitle.textContent = meta.title;
      if (toolsSubtitle) toolsSubtitle.textContent = meta.subtitle;

      toolsModal.dataset.activePanel = panelName;
      toolsModal.hidden = false;
      toolsOverlay.hidden = false;
      document.body.style.overflow = 'hidden';
      if (panelName === 'assistant') {
        bootstrapAssistant();
      }
    };

    const closeToolPanel = () => {
      if (!toolsModal || !toolsOverlay) return;
      toolsModal.hidden = true;
      toolsOverlay.hidden = true;
      delete toolsModal.dataset.activePanel;
      document.body.style.overflow = '';
    };

    toolOpenButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        openToolPanel(btn.dataset.toolOpen || 'simulate');
      });
    });

    toolTabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        openToolPanel(tab.dataset.toolTab || 'simulate');
      });
    });

    toolsClose?.addEventListener('click', closeToolPanel);
    toolsOverlay?.addEventListener('click', closeToolPanel);

    const assistantEndpoint = "{{ path('portal_credit_chat_assistant') }}";
    const assistantThread = $('#cr-assistant-thread');
    const assistantForm = $('#cr-assistant-form');
    const assistantInput = $('#cr-assistant-input');
    const assistantStatus = $('#cr-assistant-status');
    const assistantSendBtn = $('#cr-assistant-send-btn');
    const assistantCreditSelect = $('#cr-assistant-credit-select');
    const assistantGarantieSelect = $('#cr-assistant-garantie-select');
    const assistantQuickButtons = $$('[data-assistant-intent]');
    const assistantState = {
      bootstrapped: false,
      pending: false
    };

    const setAssistantStatus = (message = '', isError = false, visible = false) => {
      if (!(assistantStatus instanceof HTMLElement)) {
        return;
      }

      assistantStatus.hidden = !visible || message.trim() === '';
      assistantStatus.textContent = message;
      assistantStatus.classList.toggle('is-error', isError);
    };

    const getAssistantDraft = () => {
      const form = $('#credit-form');
      if (!(form instanceof HTMLFormElement)) {
        return {};
      }

      const read = (name) => form.querySelector(`[name="${name}"]`);
      const readValue = (name) => {
        const field = read(name);
        return field instanceof HTMLInputElement || field instanceof HTMLSelectElement || field instanceof HTMLTextAreaElement
          ? field.value.trim()
          : '';
      };

      return {
        typeCredit: readValue('typeCredit'),
        montantDemande: parseNum(readValue('montantDemande')),
        autofinancement: parseNum(readValue('autofinancement')),
        duree: parseNum(readValue('duree')),
        tauxInteret: parseNum(readValue('tauxInteret')),
        mensualite: parseNum(readValue('mensualite')),
        montantAccorde: parseNum(readValue('montantAccorde')),
        salaire: parseNum(readValue('salaire')),
        typeContrat: readValue('typeContrat'),
        ancienneteAnnees: parseNum(readValue('ancienneteAnnees'))
      };
    };

    const resolveAssistantSelectedCreditId = () => {
      if (assistantCreditSelect instanceof HTMLSelectElement && assistantCreditSelect.value.trim() !== '') {
        return Number(assistantCreditSelect.value) || 0;
      }
      if (assistantGarantieSelect instanceof HTMLSelectElement && assistantGarantieSelect.value.trim() !== '') {
        return 0;
      }
      if (selectedGarantieCreditId) {
        return Number(selectedGarantieCreditId) || 0;
      }
      if (activePaymentCard instanceof HTMLElement) {
        return Number(activePaymentCard.dataset.creditId || 0);
      }

      const visibleCard = allCards.find((card) => !card.classList.contains('cr-hidden'));
      return Number(visibleCard?.dataset.creditId || 0);
    };

    const resolveAssistantSelectedGarantieId = () => {
      if (assistantGarantieSelect instanceof HTMLSelectElement && assistantGarantieSelect.value.trim() !== '') {
        return Number(assistantGarantieSelect.value) || 0;
      }

      return 0;
    };

    const refreshAssistantTargetOptions = () => {
      if (assistantCreditSelect instanceof HTMLSelectElement) {
        Array.from(assistantCreditSelect.options).forEach((option) => {
          if (!(option instanceof HTMLOptionElement)) {
            return;
          }

          if (option.hasAttribute('data-assistant-credit-auto')) {
            option.textContent = t('assistantAutoContext');
            return;
          }

          const creditId = option.dataset.creditId || option.value || '';
          const creditType = option.dataset.creditType || 'Credit';
          const creditAmount = `${fmtNum(Number(option.dataset.creditAmount || 0), 0)} DT`;
          option.textContent = t('assistantCreditOption')(creditId, creditType, creditAmount);
        });
      }

      if (assistantGarantieSelect instanceof HTMLSelectElement) {
        Array.from(assistantGarantieSelect.options).forEach((option) => {
          if (!(option instanceof HTMLOptionElement)) {
            return;
          }

          if (option.hasAttribute('data-assistant-garantie-auto')) {
            option.textContent = t('assistantNoGuaranteeTarget');
            return;
          }

          const garantieId = option.dataset.garantieId || option.value || '';
          const garantieType = option.dataset.garantieType || 'Garantie';
          const retainedValue = `${fmtNum(Number(option.dataset.garantieRetained || 0), 0)} DT`;
          option.textContent = t('assistantGuaranteeOption')(garantieId, garantieType, retainedValue);
        });
      }
    };

    let assistantTargetSyncLock = false;

    const syncAssistantGuaranteeFromCredit = () => {
      if (!(assistantCreditSelect instanceof HTMLSelectElement) || !(assistantGarantieSelect instanceof HTMLSelectElement) || assistantTargetSyncLock) {
        return;
      }

      const selectedOption = assistantCreditSelect.selectedOptions?.[0];
      const linkedGuaranteeId = selectedOption instanceof HTMLOptionElement
        ? String(selectedOption.dataset.creditGarantieId || '').trim()
        : '';

      assistantTargetSyncLock = true;
      assistantGarantieSelect.value = linkedGuaranteeId !== '' && Array.from(assistantGarantieSelect.options).some((option) => option.value === linkedGuaranteeId)
        ? linkedGuaranteeId
        : '';
      assistantTargetSyncLock = false;
    };

    const syncAssistantCreditFromGuarantee = () => {
      if (!(assistantCreditSelect instanceof HTMLSelectElement) || !(assistantGarantieSelect instanceof HTMLSelectElement) || assistantTargetSyncLock) {
        return;
      }

      const selectedOption = assistantGarantieSelect.selectedOptions?.[0];
      const linkedCreditId = selectedOption instanceof HTMLOptionElement
        ? String(selectedOption.dataset.garantieCreditId || '').trim()
        : '';

      if (linkedCreditId === '') {
        return;
      }

      assistantTargetSyncLock = true;
      if (Array.from(assistantCreditSelect.options).some((option) => option.value === linkedCreditId)) {
        assistantCreditSelect.value = linkedCreditId;
      }
      assistantTargetSyncLock = false;
    };

    assistantCreditSelect?.addEventListener('change', syncAssistantGuaranteeFromCredit);
    assistantGarantieSelect?.addEventListener('change', syncAssistantCreditFromGuarantee);
    syncAssistantGuaranteeFromCredit();

    const createAssistantMessage = (role, payload = {}) => {
      const card = document.createElement('article');
      card.className = `cr-assistant-msg ${role === 'user' ? 'is-user' : 'is-bot'}`;

      const head = document.createElement('div');
      head.className = 'cr-assistant-msg-head';
      const headIcon = document.createElement('i');
      headIcon.className = role === 'user' ? 'fa-solid fa-user' : 'fa-solid fa-robot';
      const headLabel = document.createElement('span');
      headLabel.textContent = role === 'user' ? 'Vous' : t('assistant');
      head.append(headIcon, headLabel);
      card.appendChild(head);

      if (role === 'user') {
        const text = document.createElement('div');
        text.className = 'cr-assistant-msg-text';
        text.textContent = String(payload.text || '');
        card.appendChild(text);
        return card;
      }

      if (String(payload.title || '').trim() !== '') {
        const title = document.createElement('div');
        title.className = 'cr-assistant-msg-title';
        title.textContent = String(payload.title || '');
        card.appendChild(title);
      }

      const text = document.createElement('div');
      text.className = 'cr-assistant-msg-text';
      text.textContent = String(payload.answer || '');
      card.appendChild(text);

      const assistantIntent = String(payload.intent || 'recommend').trim();
      const isSimulationIntent = assistantIntent === 'simulate';
      const useRichSimulationLayout = isSimulationIntent;
      const showDecisionPill = assistantIntent === 'decision';
      const showScorePill = assistantIntent === 'score' || assistantIntent === 'decision';
      const showRiskPill = assistantIntent === 'score' || assistantIntent === 'decision';
      const showRecommendations = assistantIntent === 'recommend';
      const showBestOffer = false;
      const showOffers = false;
      const showConstraints = assistantIntent === 'decision';

      const pillRow = document.createElement('div');
      pillRow.className = 'cr-assistant-pill-row';
      const addPill = (label, value, modifier) => {
        if (String(value || '').trim() === '') return;
        const pill = document.createElement('span');
        pill.className = `cr-assistant-pill ${modifier}`;
        pill.textContent = `${label}: ${value}`;
        pillRow.appendChild(pill);
      };
      if (showDecisionPill) addPill(t('assistantDecisionLabel'), payload.decision, 'is-decision');
      if (showScorePill) addPill(t('assistantScoreLabel'), payload.score ? `${fmtNum(Number(payload.score), 1)}/100` : '', 'is-score');
      if (showRiskPill) addPill(t('assistantRiskLabel'), payload.risk_level, 'is-risk');
      if (pillRow.childElementCount > 0) {
        card.appendChild(pillRow);
      }

      if (!useRichSimulationLayout && Array.isArray(payload.metrics) && payload.metrics.length > 0) {
        const metrics = document.createElement('div');
        metrics.className = 'cr-assistant-metrics';
        payload.metrics.forEach((metric) => {
          if (!metric || typeof metric !== 'object') return;
          const metricCard = document.createElement('div');
          metricCard.className = 'cr-assistant-metric';
          const label = document.createElement('span');
          label.textContent = String(metric.label || '');
          const value = document.createElement('strong');
          value.textContent = String(metric.value || '');
          metricCard.append(label, value);
          metrics.appendChild(metricCard);
        });
        if (metrics.childElementCount > 0) {
          card.appendChild(metrics);
        }
      }

      if (showRecommendations && Array.isArray(payload.recommendations) && payload.recommendations.length > 0) {
        const recTitle = document.createElement('div');
        recTitle.className = 'cr-assistant-rec-title';
        recTitle.textContent = t('assistantRecommendations');
        card.appendChild(recTitle);

        const list = document.createElement('ul');
        list.className = 'cr-assistant-rec-list';
        payload.recommendations.forEach((item) => {
          const textValue = String(item || '').trim();
          if (textValue === '') return;
          const li = document.createElement('li');
          li.textContent = textValue;
          list.appendChild(li);
        });
        if (list.childElementCount > 0) {
          card.appendChild(list);
        }
      }

      const resolveAssistantTone = (value) => {
        const normalized = normalizeSearchValue(value);
        if (normalized.includes('ok') || normalized.includes('eligible') || normalized.includes('eligib') || normalized.includes('sain') || normalized.includes('salim')) {
          return 'is-ok';
        }
        if (normalized.includes('block') || normalized.includes('bloq') || normalized.includes('non recommande') || normalized.includes('maaiq')) {
          return 'is-block';
        }
        return 'is-warn';
      };

      const translateConstraintState = (value) => {
        const tone = resolveAssistantTone(value);
        if (tone === 'is-ok') return t('assistantConstraintOk');
        if (tone === 'is-block') return t('assistantConstraintBlock');
        return t('assistantConstraintWarn');
      };

      const findMetricValue = (...needles) => {
        if (!Array.isArray(payload.metrics)) {
          return '';
        }

        const normalizedNeedles = needles.map((item) => normalizeSearchValue(item));
        const match = payload.metrics.find((metric) => {
          if (!metric || typeof metric !== 'object') return false;
          const label = normalizeSearchValue(metric.label || '');
          return normalizedNeedles.some((needle) => label.includes(needle));
        });

        return match ? String(match.value || '').trim() : '';
      };

      if (useRichSimulationLayout) {
        const blockingConstraint = Array.isArray(payload.constraints)
          ? payload.constraints.find((constraint) => resolveAssistantTone(constraint?.status) === 'is-block')
          : null;
        const offerList = Array.isArray(payload.offers) ? payload.offers.filter((offer) => offer && typeof offer === 'object' && String(offer.bank || '').trim() !== '') : [];
        const bestOfferBank = String(payload.best_offer?.bank || '').trim();
        const totalCosts = offerList.map((offer) => parseNum(offer.total_cost || 0)).filter((value) => Number.isFinite(value) && value > 0);
        const minTotal = totalCosts.length ? Math.min(...totalCosts) : 0;
        const maxTotal = totalCosts.length ? Math.max(...totalCosts) : 0;
        const savings = minTotal > 0 && maxTotal > minTotal ? maxTotal - minTotal : 0;
        const amountValue = findMetricValue('montant');
        const durationMatch = String(payload.answer || '').match(/sur\s+(\d+)\s+mois/i);
        const durationValue = durationMatch ? `${durationMatch[1]} mois` : '';
        const selectedCreditOption = assistantCreditSelect instanceof HTMLSelectElement ? assistantCreditSelect.selectedOptions?.[0] : null;
        const creditTypeValue = selectedCreditOption instanceof HTMLOptionElement && !selectedCreditOption.hasAttribute('data-assistant-credit-auto')
          ? String(selectedCreditOption.dataset.creditType || '').trim()
          : '';
        const statusValue = blockingConstraint ? t('assistantBlockedStatus') : String(payload.decision || '').trim();
        const hasSimulationContext = amountValue.trim() !== '' && durationValue.trim() !== '';
        const bestOfferSummary = bestOfferBank
          ? `${payload.best_offer?.rate ? `${String(payload.best_offer.rate)} - ` : ''}${payload.best_offer?.monthly ? `${String(payload.best_offer.monthly)}/mois ` : ''}(${bestOfferBank})`.trim()
          : '';

        if (!hasSimulationContext && offerList.length === 0) {
          return card;
        }

        if (blockingConstraint) {
          const alert = document.createElement('div');
          alert.className = 'cr-assistant-alert';
          alert.textContent = `${t('assistantBlockingPrefix')}: ${blockingConstraint.label}. ${blockingConstraint.detail}`;
          card.appendChild(alert);
        }

        const summaryTitle = document.createElement('div');
        summaryTitle.className = 'cr-assistant-section-title';
        summaryTitle.textContent = t('assistantSummarySection');
        card.appendChild(summaryTitle);

        const summaryCard = document.createElement('div');
        summaryCard.className = 'cr-assistant-summary-card';
        const summaryHead = document.createElement('div');
        summaryHead.className = 'cr-assistant-summary-head';
        const summaryHeadText = document.createElement('strong');
        summaryHeadText.textContent = payload.title ? `${t('assistantSummarySection')} - ${String(payload.title)}` : t('assistantSummarySection');
        summaryHead.appendChild(summaryHeadText);
        summaryCard.appendChild(summaryHead);

        const summaryGrid = document.createElement('div');
        summaryGrid.className = 'cr-assistant-summary-grid';
        [
          [t('requestedAmount'), amountValue],
          [t('assistantDurationLabel'), durationValue],
          [t('assistantTypeLabel'), creditTypeValue],
          [t('assistantBestOffer'), bestOfferSummary],
          [t('assistantSavingsLabel'), `${fmtNum(savings, 2)} DT`],
          [t('assistantStatusLabel'), statusValue],
        ].forEach(([label, value]) => {
          if (String(value || '').trim() === '') return;
          const item = document.createElement('div');
          item.className = 'cr-assistant-summary-item';
          const meta = document.createElement('span');
          meta.textContent = String(label);
          const strong = document.createElement('strong');
          strong.textContent = String(value);
          item.append(meta, strong);
          summaryGrid.appendChild(item);
        });
        if (summaryGrid.childElementCount > 0) {
          summaryCard.appendChild(summaryGrid);
          card.appendChild(summaryCard);
        }

        const marketTitle = document.createElement('div');
        marketTitle.className = 'cr-assistant-section-title';
        marketTitle.textContent = t('assistantMarketSection');
        card.appendChild(marketTitle);

        if (offerList.length > 0) {
          const marketWrap = document.createElement('div');
          marketWrap.className = 'cr-assistant-market-block';

          offerList.forEach((offer) => {
            const marketCard = document.createElement('div');
            marketCard.className = 'cr-assistant-market-card';
            const isBest = bestOfferBank !== '' && String(offer.bank || '').trim() === bestOfferBank;
            const isHouseBank = normalizeSearchValue(offer.bank || '').includes('nexora');
            if (isBest) {
              marketCard.classList.add('is-best');
            }
            if (isHouseBank) {
              marketCard.classList.add('is-house-bank');
            }

            const marketHead = document.createElement('div');
            marketHead.className = 'cr-assistant-market-head';
            const name = document.createElement('strong');
            name.textContent = String(offer.bank || '');
            marketHead.appendChild(name);
            if (isBest) {
              const badge = document.createElement('span');
              badge.className = 'cr-assistant-market-badge';
              badge.textContent = t('assistantBestBadge');
              marketHead.appendChild(badge);
            }
            marketCard.appendChild(marketHead);

            const grid = document.createElement('div');
            grid.className = 'cr-assistant-market-grid';
            [
              ['Taux', offer.rate],
              ['TEG', offer.teg],
              [t('monthlyPayment'), offer.monthly],
              ['Cout total', offer.total_cost],
              ['Interets', offer.interest],
            ].forEach(([label, value]) => {
              const box = document.createElement('div');
              box.className = 'cr-assistant-market-metric';
              const meta = document.createElement('span');
              meta.textContent = String(label);
              const strong = document.createElement('strong');
              strong.textContent = String(value || '-');
              box.append(meta, strong);
              grid.appendChild(box);
            });
            marketCard.appendChild(grid);

            const costValue = parseNum(offer.total_cost || 0);
            const progress = maxTotal > minTotal && Number.isFinite(costValue)
              ? 100 - (((costValue - minTotal) / Math.max(1, maxTotal - minTotal)) * 45)
              : 100;
            const bar = document.createElement('div');
            bar.className = 'cr-assistant-market-bar';
            const barFill = document.createElement('span');
            barFill.style.width = `${Math.max(18, Math.min(100, progress))}%`;
            bar.appendChild(barFill);
            marketCard.appendChild(bar);

            const detailRows = [
              ['cr-assistant-market-perk', 'fa-solid fa-check', offer.feature || offer.reason],
              ['cr-assistant-market-condition', 'fa-solid fa-file-lines', offer.condition || 'Condition standard de recevabilite']
            ];
            detailRows.forEach(([className, iconName, value]) => {
              if (String(value || '').trim() === '') return;
              const wrap = document.createElement('div');
              wrap.className = className === 'cr-assistant-market-perk' ? 'cr-assistant-market-perks' : 'cr-assistant-market-conditions';
              const row = document.createElement('div');
              row.className = String(className);
              const icon = document.createElement('i');
              icon.className = String(iconName);
              const textValue = document.createElement('span');
              textValue.textContent = String(value);
              row.append(icon, textValue);
              wrap.appendChild(row);
              marketCard.appendChild(wrap);
            });

            if (String(offer.reason || '').trim() !== '') {
              const note = document.createElement('div');
              note.className = 'cr-assistant-market-note';
              note.textContent = String(offer.reason || '');
              marketCard.appendChild(note);
            }

            const statusBox = document.createElement('div');
            const normalizedStatus = normalizeSearchValue(offer.status || '');
            statusBox.className = 'cr-assistant-market-state';
            if (normalizedStatus.includes('eligible')) {
              statusBox.classList.add('is-ok');
            } else if (normalizedStatus.includes('etudier')) {
              statusBox.classList.add('is-warn');
            }
            statusBox.textContent = normalizedStatus.includes('non recommande')
              ? 'Credit bloque'
              : String(offer.status || 'A etudier');
            marketCard.appendChild(statusBox);

            marketWrap.appendChild(marketCard);
          });

          card.appendChild(marketWrap);

          const tableTitle = document.createElement('div');
          tableTitle.className = 'cr-assistant-section-title';
          tableTitle.textContent = t('assistantTableSection');
          card.appendChild(tableTitle);

          const tableWrap = document.createElement('div');
          tableWrap.className = 'cr-assistant-compare-table-wrap';
          const table = document.createElement('table');
          table.className = 'cr-assistant-compare-table';
          const thead = document.createElement('thead');
          const headRow = document.createElement('tr');
          ['Banque', 'Taux %', 'TEG %', t('monthlyPayment'), 'Cout total', 'Interets'].forEach((label) => {
            const th = document.createElement('th');
            th.textContent = String(label);
            headRow.appendChild(th);
          });
          thead.appendChild(headRow);
          table.appendChild(thead);

          const tbody = document.createElement('tbody');
          offerList.forEach((offer) => {
            const row = document.createElement('tr');
            [offer.bank, offer.rate, offer.teg, offer.monthly, offer.total_cost, offer.interest].forEach((value) => {
              const td = document.createElement('td');
              td.textContent = String(value || '-');
              row.appendChild(td);
            });
            tbody.appendChild(row);
          });
          table.appendChild(tbody);
          tableWrap.appendChild(table);
          card.appendChild(tableWrap);
        } else {
          const offersEmpty = document.createElement('div');
          offersEmpty.className = 'cr-assistant-offer-card';
          const emptyText = document.createElement('p');
          emptyText.className = 'cr-assistant-offer-reason';
          emptyText.textContent = t('assistantOffersMissing');
          offersEmpty.appendChild(emptyText);
          card.appendChild(offersEmpty);
        }

        const aiTitle = document.createElement('div');
        aiTitle.className = 'cr-assistant-section-title';
        aiTitle.textContent = t('assistantAiAdvice');
        card.appendChild(aiTitle);

        const aiCard = document.createElement('div');
        aiCard.className = 'cr-assistant-ai-card';
        const aiStrong = document.createElement('strong');
        aiStrong.textContent = `${t('assistantAiAdvice')} - ${bestOfferBank || t('assistant')}`;
        const aiText = document.createElement('p');
        aiText.textContent = String(payload.answer || '');
        aiCard.append(aiStrong, aiText);
        card.appendChild(aiCard);
      }

      if (showBestOffer && payload.best_offer && typeof payload.best_offer === 'object' && String(payload.best_offer.bank || '').trim() !== '') {
        const bestTitle = document.createElement('div');
        bestTitle.className = 'cr-assistant-section-title';
        bestTitle.textContent = t('assistantBestOffer');
        card.appendChild(bestTitle);

        const bestCard = document.createElement('div');
        bestCard.className = 'cr-assistant-best-offer';
        const bestName = document.createElement('strong');
        bestName.textContent = String(payload.best_offer.bank || '');
        const bestText = document.createElement('p');
        const bestParts = [
          payload.best_offer.rate ? `Taux ${payload.best_offer.rate}` : '',
          payload.best_offer.monthly ? `Mensualite ${payload.best_offer.monthly}` : '',
          payload.best_offer.total_cost ? `Cout total ${payload.best_offer.total_cost}` : '',
          payload.best_offer.reason ? String(payload.best_offer.reason) : ''
        ].filter(Boolean);
        bestText.textContent = bestParts.join(' • ');
        bestCard.append(bestName, bestText);
        card.appendChild(bestCard);
      }

      if (showOffers && Array.isArray(payload.offers) && payload.offers.length > 0) {
        const offersTitle = document.createElement('div');
        offersTitle.className = 'cr-assistant-section-title';
        offersTitle.textContent = t('assistantOffers');
        card.appendChild(offersTitle);

        const offersWrap = document.createElement('div');
        offersWrap.className = 'cr-assistant-offers';
        payload.offers.forEach((offer) => {
          if (!offer || typeof offer !== 'object' || String(offer.bank || '').trim() === '') return;

          const offerCard = document.createElement('div');
          offerCard.className = 'cr-assistant-offer-card';

          const head = document.createElement('div');
          head.className = 'cr-assistant-offer-head';
          const name = document.createElement('strong');
          name.textContent = String(offer.bank || '');
          const badge = document.createElement('span');
          badge.className = `cr-assistant-offer-badge ${resolveAssistantTone(offer.status)}`;
          badge.textContent = String(offer.status || '');
          head.append(name, badge);

          const grid = document.createElement('div');
          grid.className = 'cr-assistant-offer-grid';
          [
            ['Taux', offer.rate],
            ['Mensualite', offer.monthly],
            ['Cout total', offer.total_cost],
            ['Interets', offer.interest]
          ].forEach(([label, value]) => {
            if (String(value || '').trim() === '') return;
            const box = document.createElement('div');
            const meta = document.createElement('span');
            meta.textContent = String(label);
            const strong = document.createElement('strong');
            strong.textContent = String(value);
            box.append(meta, strong);
            grid.appendChild(box);
          });

          offerCard.append(head, grid);
          if (String(offer.reason || '').trim() !== '') {
            const reason = document.createElement('p');
            reason.className = 'cr-assistant-offer-reason';
            reason.textContent = String(offer.reason || '');
            offerCard.appendChild(reason);
          }
          offersWrap.appendChild(offerCard);
        });

        if (offersWrap.childElementCount > 0) {
          card.appendChild(offersWrap);
        }
      } else if (showOffers) {
        const offersTitle = document.createElement('div');
        offersTitle.className = 'cr-assistant-section-title';
        offersTitle.textContent = t('assistantOffers');
        card.appendChild(offersTitle);

        const offersEmpty = document.createElement('div');
        offersEmpty.className = 'cr-assistant-offer-card';
        const emptyText = document.createElement('p');
        emptyText.className = 'cr-assistant-offer-reason';
        emptyText.textContent = t('assistantOffersMissing');
        offersEmpty.appendChild(emptyText);
        card.appendChild(offersEmpty);
      }

      if (showConstraints && Array.isArray(payload.constraints) && payload.constraints.length > 0) {
        const constraintsTitle = document.createElement('div');
        constraintsTitle.className = 'cr-assistant-section-title';
        constraintsTitle.textContent = t('assistantConstraints');
        card.appendChild(constraintsTitle);

        const constraintsWrap = document.createElement('div');
        constraintsWrap.className = 'cr-assistant-constraints';
        payload.constraints.forEach((constraint) => {
          if (!constraint || typeof constraint !== 'object' || String(constraint.label || '').trim() === '') return;

          const constraintCard = document.createElement('div');
          constraintCard.className = 'cr-assistant-constraint-card';

          const head = document.createElement('div');
          head.className = 'cr-assistant-constraint-head';
          const label = document.createElement('strong');
          label.textContent = String(constraint.label || '');
          const badge = document.createElement('span');
          badge.className = `cr-assistant-constraint-badge ${resolveAssistantTone(constraint.status)}`;
          badge.textContent = translateConstraintState(constraint.status);
          head.append(label, badge);

          const detail = document.createElement('p');
          detail.textContent = String(constraint.detail || '');
          constraintCard.append(head, detail);
          constraintsWrap.appendChild(constraintCard);
        });

        if (constraintsWrap.childElementCount > 0) {
          card.appendChild(constraintsWrap);
        }
      }

      return card;
    };

    const appendAssistantMessage = (role, payload = {}) => {
      if (!(assistantThread instanceof HTMLElement)) {
        return;
      }

      assistantThread.appendChild(createAssistantMessage(role, payload));
      assistantThread.scrollTop = assistantThread.scrollHeight;
    };

    const bootstrapAssistant = () => {
      if (!(assistantThread instanceof HTMLElement) || assistantState.bootstrapped) {
        return;
      }

      appendAssistantMessage('bot', {
        title: t('assistantWelcomeTitle'),
        answer: t('assistantWelcomeText'),
        recommendations: [
          t('assistantSimulate'),
          t('assistantScore'),
          t('assistantGuarantees'),
          t('assistantDecision'),
          t('assistantRecommend')
        ]
      });
      assistantState.bootstrapped = true;
    };

    const sendAssistantPrompt = async (message, intent = 'recommend', appendUser = true) => {
      if (!(assistantInput instanceof HTMLTextAreaElement) || assistantState.pending) {
        return;
      }

      const cleanMessage = String(message || '').trim();
      if (cleanMessage === '') {
        return;
      }

      bootstrapAssistant();

      if (appendUser) {
        appendAssistantMessage('user', { text: cleanMessage });
      }

      assistantState.pending = true;
      if (assistantSendBtn instanceof HTMLButtonElement) {
        assistantSendBtn.disabled = true;
      }
      setAssistantStatus(t('assistantThinking'), false, true);

      try {
        const response = await fetch(assistantEndpoint, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
          },
          body: JSON.stringify({
            message: cleanMessage,
            intent,
            language: currentInterfaceLanguage,
            selectedCreditId: resolveAssistantSelectedCreditId(),
            selectedGarantieId: resolveAssistantSelectedGarantieId(),
            draft: getAssistantDraft()
          })
        });

        const result = await response.json().catch(() => ({}));
        if (!response.ok || !result.ok) {
          throw new Error((result && typeof result.message === 'string' && result.message.trim() !== '') ? result.message : t('assistantError'));
        }

        appendAssistantMessage('bot', result.assistant || {});
        assistantInput.value = '';
        setAssistantStatus('', false, false);
      } catch (error) {
        setAssistantStatus(error instanceof Error ? error.message : t('assistantError'), true, true);
      } finally {
        assistantState.pending = false;
        if (assistantSendBtn instanceof HTMLButtonElement) {
          assistantSendBtn.disabled = false;
        }
      }
    };

    assistantForm?.addEventListener('submit', (event) => {
      event.preventDefault();
      sendAssistantPrompt(assistantInput instanceof HTMLTextAreaElement ? assistantInput.value : '', 'recommend');
    });

    assistantQuickButtons.forEach((button) => {
      button.addEventListener('click', () => {
        sendAssistantPrompt(button.dataset.assistantPrompt || '', button.dataset.assistantIntent || 'recommend', true);
      });
    });

    /* ════════════════════════════════════════════════════════════════════
       PAYMENT MODAL
    ════════════════════════════════════════════════════════════════════ */
    const payOverlay = $('#cr-pay-overlay');
    const payModal = $('#cr-pay-modal');
    const payClose = $('#cr-pay-close');
    const payTitle = $('#cr-pay-title');
    const paySubtitle = $('#cr-pay-subtitle');
    const payCreditLabel = $('#cr-pay-credit-label');
    const payCreditStatus = $('#cr-pay-credit-status');
