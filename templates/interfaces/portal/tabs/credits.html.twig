          garantieDocumentAnalysisState.status = 'done';
          garantieDocumentAnalysisState.verdict = 'suspect';
          garantieDocumentAnalysisState.message = 'Analyse impossible. Reessayez avec un autre fichier.';
          setGarantieAnalyzeStatus('suspect', 'Suspect');
          setFieldError(garantieDocumentField, getGarantieMessage('documentJustificatif'), garantieDocumentAnalysisState.message);
        }
        return { ok: false, verdict: 'suspect', message: 'Analyse impossible.' };
      } finally {
        if (garantieDocumentAnalyzeBtn instanceof HTMLButtonElement) {
          garantieDocumentAnalyzeBtn.disabled = false;
        }
      }
    };
    const resolveGarantieTypeValue = (rawType = '') => {
      const select = getGarantieField('typeGarantie');
      if (!(select instanceof HTMLSelectElement)) {
        return String(rawType ?? '').trim();
      }

      const input = String(rawType ?? '').trim();
      if (input === '') {
