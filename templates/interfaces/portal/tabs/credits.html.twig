    <div class="cr-pay-overlay" id="cr-pay-overlay" hidden></div>
    <section class="cr-pay-modal" id="cr-pay-modal" hidden role="dialog" aria-modal="true" aria-labelledby="cr-pay-title">
        <header class="cr-pay-header">
            <div>
                <h3 id="cr-pay-title">Payer une mensualite</h3>
                <p id="cr-pay-subtitle">Reglez la mensualite Stripe du credit selectionne.</p>
            </div>
            <button class="cr-pay-close" id="cr-pay-close" type="button" aria-label="Fermer">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </header>
        <div class="cr-pay-body">
            <div class="cr-pay-summary">
                <div class="cr-pay-summary-main">
                    <strong id="cr-pay-credit-label">Credit</strong>
                    <span id="cr-pay-credit-status" class="cr-pay-status-chip">En attente</span>
                </div>
                <div class="cr-pay-summary-grid">
                    <div class="cr-pay-summary-item">
                        <span class="cr-pay-summary-key" id="cr-pay-amount-label">Montant</span>
                        <strong id="cr-pay-amount">0.00 DT</strong>
                    </div>
                    <div class="cr-pay-summary-item">
                        <span class="cr-pay-summary-key" id="cr-pay-monthly-label">Mensualite</span>
                        <strong id="cr-pay-monthly">0.00 DT</strong>
                    </div>
                </div>
            </div>

            <div class="cr-pay-otp-row">
                <span class="cr-pay-otp-state{{ payment_otp_verified ? ' is-verified' : '' }}" id="cr-pay-otp-state">
                    {{ payment_otp_verified ? 'Etape 3 disponible' : (payment_otp_sent ? 'Etape 2 disponible' : 'Commencez par envoyer OTP') }}
                </span>
            </div>

            <div class="cr-pay-steps">
                <div class="cr-pay-step-item{{ payment_current_step == 1 ? ' is-active' : '' }}{{ payment_current_step > 1 ? ' is-done' : '' }}" data-pay-step-indicator="1">
                    <div class="cr-pay-step-dot">1</div>
                    <span id="cr-pay-step-label-1">Envoyer OTP</span>
                </div>
                <div class="cr-pay-step-line"></div>
                <div class="cr-pay-step-item{{ payment_current_step == 2 ? ' is-active' : '' }}{{ payment_current_step > 2 ? ' is-done' : '' }}" data-pay-step-indicator="2">
                    <div class="cr-pay-step-dot">2</div>
                    <span id="cr-pay-step-label-2">Verifier OTP</span>
                </div>
                <div class="cr-pay-step-line"></div>
                <div class="cr-pay-step-item{{ payment_current_step == 3 ? ' is-active' : '' }}" data-pay-step-indicator="3">
                    <div class="cr-pay-step-dot">3</div>
                    <span id="cr-pay-step-label-3">Stripe</span>
                </div>
            </div>

            <div class="cr-pay-step-body" data-pay-step-body="1" {{ payment_current_step != 1 ? 'hidden' : '' }}>
                <form method="post" class="cr-pay-card" data-pay-step="send">
                    <input type="hidden" name="tab" value="credits">
                    <input type="hidden" name="action" value="send_payment_otp">
                    <input type="hidden" name="payment_credit" id="cr-pay-send-credit" value="">

                    <div class="cr-pay-card-head">
                        <h4 id="cr-pay-send-title">1. Envoyer OTP</h4>
                        <p id="cr-pay-send-subtitle">Recevez un code de verification avant le paiement.</p>
                    </div>

                    <label class="cr-pay-field">
                        <span id="cr-pay-phone-label">Telephone</span>
                        <input type="text" name="telephone" id="cr-pay-phone" value="{{ payment_phone }}" required>
                    </label>

                    <label class="cr-pay-field">
                        <span id="cr-pay-channel-label">Canal OTP</span>
                        <select name="otp_channel" id="cr-pay-channel">
                            <option value="sms" {{ payment_channel == 'sms' ? 'selected' : '' }}>SMS</option>
                            <option value="whatsapp" {{ payment_channel == 'whatsapp' ? 'selected' : '' }}>WhatsApp</option>
                        </select>
                    </label>

                    <button class="cr-pay-secondary-btn" id="cr-pay-send-btn" type="submit">
                        <i class="fa-solid fa-paper-plane"></i>
                        <span>Envoyer OTP</span>
                    </button>
                </form>
            </div>

            <div class="cr-pay-step-body" data-pay-step-body="2" {{ payment_current_step != 2 ? 'hidden' : '' }}>
                <form method="post" class="cr-pay-card" data-pay-step="verify">
                    <input type="hidden" name="tab" value="credits">
                    <input type="hidden" name="action" value="verify_payment_otp">
                    <input type="hidden" name="payment_credit" id="cr-pay-verify-credit" value="">

                    <div class="cr-pay-card-head">
                        <h4 id="cr-pay-verify-title">2. Verifier OTP</h4>
                        <p id="cr-pay-verify-subtitle">Confirmez le code recu pour debloquer Stripe.</p>
                    </div>

                    <label class="cr-pay-field">
                        <span id="cr-pay-verify-phone-label">Telephone</span>
                        <input type="text" name="telephone" id="cr-pay-verify-phone" value="{{ payment_phone }}" required>
                    </label>

                    <label class="cr-pay-field">
                        <span id="cr-pay-otp-label">Code OTP</span>
                        <input type="text" name="otp" id="cr-pay-otp-input" placeholder="123456" required>
                    </label>

                    <button class="cr-pay-secondary-btn" id="cr-pay-verify-btn" type="submit">
                        <i class="fa-solid fa-shield-check"></i>
                        <span>Verifier OTP</span>
                    </button>
                </form>
            </div>

            <div class="cr-pay-step-body" data-pay-step-body="3" {{ payment_current_step != 3 ? 'hidden' : '' }}>
            <form method="post" class="cr-pay-main-form" id="cr-pay-form" data-pay-step="stripe" action="{{ path('portal_credit_checkout_start') }}">
                <input type="hidden" name="payment_credit" id="cr-pay-payment-credit" value="">
                <input type="hidden" name="idCredit" id="cr-pay-credit-id" value="">
                <input type="hidden" name="amount" id="cr-pay-amount-input" value="">

                <div class="cr-pay-main-head">
                    <div>
                        <h4 id="cr-pay-main-title">3. Payer avec Stripe</h4>
                        <p id="cr-pay-main-subtitle">Le montant de la mensualite est pre-rempli pour ce credit.</p>
                    </div>
                    <span class="cr-pay-badge" id="cr-pay-main-badge">Mensualite Stripe</span>
                </div>

                <div class="cr-pay-main-grid">
                    <label class="cr-pay-field">
                        <span id="cr-pay-account-label">Compte a debiter</span>
                        <select name="idCompte" id="cr-pay-account" required>
                            {% for account in payment_accounts %}
                                <option value="{{ account.idCompte }}">
                                    {{ account.numeroCompte|default('Compte') }} | {{ account.solde|default(0)|number_format(2, '.', ' ') }} DT
                                </option>
                            {% endfor %}
                        </select>
                    </label>
                </div>

                <p class="cr-pay-note" id="cr-pay-note">
                    Montant Stripe: devise {{ payment_config.stripe_charge_currency|default('eur')|upper }}.
                    Taux applique: 1 TND = {{ payment_config.stripe_tnd_to_charge_rate|default(0.30) }} {{ payment_config.stripe_charge_currency|default('eur')|upper }}.
                    Vous serez redirige vers la page securisee Stripe pour saisir la carte.
                </p>

                <button class="cr-pay-primary-btn" id="cr-pay-submit-btn" type="submit" {{ payment_accounts is empty ? 'disabled' : '' }}>
                    <i class="fa-solid fa-credit-card"></i>
                    <span>Continuer vers Stripe</span>
                </button>
            </form>
            </div>
        </div>
    </section>
    <div class="cr-split">

