  background: #dcecff;
}

/* √Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź
   SPLIT LAYOUT
   √Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź */
.cr-split {
  display: grid;
  grid-template-columns: 420px 1fr;
  gap: 16px;
  padding: 0 28px 28px;
  align-items: start;
}

/* √Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź
   FORM COLUMN
   √Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź */
.cr-form-col {
  position: sticky;
  top: 76px;
}

.cr-form-card {
  background: #fff;
  border-radius: 20px;
  border: 1px solid #dde8f5;
  box-shadow: 0 4px 24px rgba(10,37,64,.07);
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

/* √Ę‚ÄĚ‚ā¨√Ę‚ÄĚ‚ā¨ Form Card Header √Ę‚ÄĚ‚ā¨√Ę‚ÄĚ‚ā¨ */
.cr-form-card-header {
  background: linear-gradient(135deg, #0a2540 0%, #1565c0 100%);
  padding: 22px 22px 0;
}

.cr-form-card-header-top {
  display: flex;
  align-items: flex-start;
  gap: 14px;
  padding-bottom: 18px;
}

.cr-fch-icon {
  width: 44px;
  height: 44px;
  border-radius: 14px;
  background: rgba(255,255,255,.15);
  border: 1px solid rgba(255,255,255,.25);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 17px;
  flex-shrink: 0;
}

.cr-fch-title {
  font-size: 17px;
  font-weight: 800;
  color: #fff;
  line-height: 1.2;
}

.cr-fch-sub {
  font-size: 12px;
  color: rgba(255,255,255,.68);
  margin-top: 3px;
}

.cr-form-collapse-btn {
  margin-left: auto;
  width: 32px;
  height: 32px;
  border-radius: 9px;
  background: rgba(255,255,255,.1);
  border: 1px solid rgba(255,255,255,.2);
  color: rgba(255,255,255,.8);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  font-size: 12px;
  flex-shrink: 0;
  transition: background .15s;
}

.cr-form-collapse-btn:hover { background: rgba(255,255,255,.2); }

/* √Ę‚ÄĚ‚ā¨√Ę‚ÄĚ‚ā¨ Steps indicator √Ę‚ÄĚ‚ā¨√Ę‚ÄĚ‚ā¨ */
.cr-form-steps {
  display: flex;
  align-items: center;
  padding: 0 4px 0;
}

.cr-step {
  display: flex;
  align-items: center;
  gap: 7px;
  padding: 10px 0;
  cursor: default;
  opacity: 0.5;
  transition: opacity .2s;
}

.cr-step.cr-step-active { opacity: 1; }

.cr-step-dot {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  border: 2px solid rgba(255,255,255,.4);
  color: rgba(255,255,255,.7);
  font-size: 11px;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all .2s;
}

.cr-step.cr-step-active .cr-step-dot {
  background: #fff;
  color: #1565c0;
  border-color: #fff;
}

.cr-step.cr-step-done .cr-step-dot {
  background: #00bcd4;
  color: #fff;
  border-color: #00bcd4;
}

.cr-step span {
  font-size: 11px;
  font-weight: 700;
  color: rgba(255,255,255,.75);
  white-space: nowrap;
}

.cr-step.cr-step-active span { color: #fff; }

.cr-step-line {
  flex: 1;
  height: 1px;
  background: rgba(255,255,255,.2);
  margin: 0 8px;
}

/* √Ę‚ÄĚ‚ā¨√Ę‚ÄĚ‚ā¨ Form body √Ę‚ÄĚ‚ā¨√Ę‚ÄĚ‚ā¨ */
.cr-form {
  display: flex;
  flex-direction: column;
}

.cr-form-step-body {
  padding: 20px 20px 4px;
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.cr-form-step-body[hidden] {
  display: none !important;
}

.cr-field-group {
  display: grid;
  gap: 12px;
}

.cr-field-group-2 { grid-template-columns: 1fr 1fr; }
.cr-field-group-3 { grid-template-columns: repeat(3, 1fr); }

.cr-field {
  display: flex;
  flex-direction: column;
  gap: 5px;
}

.cr-field-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  flex-wrap: wrap;
}

.cr-field-label {
  font-size: 11px;
  font-weight: 700;
  color: #4e7490;
  display: flex;
  align-items: center;
  gap: 5px;
}

.cr-field-label i { color: #1565c0; font-size: 10px; }

.cr-req { color: #e53935; }

.cr-input {
  width: 100%;
  min-height: 40px;
  border-radius: 11px;
  border: 1.5px solid #ccddef;
  background: #f7faff;
  padding: 0 12px;
  font: inherit;
  font-size: 13px;
  color: #0a2540;
  outline: none;
  appearance: none;
  transition: border-color .18s, box-shadow .18s;
}

.cr-input-textarea {
  min-height: 108px;
  padding: 10px 12px;
  resize: vertical;
}

.cr-input:focus {
  border-color: #1e88e5;
  background: #fff;
  box-shadow: 0 0 0 3px rgba(30,136,229,.12);
}

.cr-input::placeholder { color: #aabece; font-size: 12px; }

.cr-input--error {
  border-color: #ef5350 !important;
  background: #fff8f7;
  box-shadow: 0 0 0 3px rgba(239, 83, 80, 0.12);
}

.cr-val-msg {
  min-height: 16px;
  font-size: 12px;
  font-weight: 700;
  color: transparent;
}

.cr-field-hint {
  min-height: 14px;
  font-size: 11px;
  color: #6b7f92;
}

.cr-ai-generate-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  min-height: 34px;
  padding: 0 12px;
  border-radius: 999px;
  border: 1px solid #c9dcf3;
  background: linear-gradient(120deg, #eef5ff, #e0f2fe);
  color: #1565c0;
  font: inherit;
  font-size: 12px;
  font-weight: 800;
  cursor: pointer;
  transition: all .15s;
}

.cr-ai-generate-btn:hover {
  background: linear-gradient(120deg, #1565c0, #1e88e5);
  color: #fff;
  border-color: transparent;
}

.cr-ai-generate-btn:disabled {
  opacity: .7;
  cursor: wait;
}

.cr-ai-inline-status {
  min-height: 16px;
  font-size: 11px;
  font-weight: 700;
  color: #5b80a0;
}

.cr-ai-inline-status.is-ok { color: #15803d; }
.cr-ai-inline-status.is-warn { color: #b45309; }
.cr-ai-inline-status.is-risk { color: #b91c1c; }

.cr-val-msg.is-error {
  color: #d93025;
}

.cr-badge-soft {
  display: inline-flex;
  align-items: center;
  min-height: 24px;
  padding: 4px 10px;
  border-radius: 999px;
  font-size: 11px;
  font-weight: 800;
}

.cr-badge-soft-blue { background: #dbeafe; color: #1e40af; }
.cr-badge-soft-green { background: #dcfce7; color: #166534; }
.cr-badge-soft-amber { background: #fef3c7; color: #92400e; }
.cr-badge-soft-red { background: #fee2e2; color: #991b1b; }
.cr-badge-soft-purple { background: #ede9fe; color: #5b21b6; }

.cr-select { cursor: pointer; padding-right: 30px; }

.cr-select-wrap { position: relative; }

.cr-select-icon {
  position: absolute;
  right: 11px;
  top: 50%;
  transform: translateY(-50%);
  color: #8aafc8;
  font-size: 10px;
  pointer-events: none;
}

/* Prefixed input */
.cr-input-pfx-wrap { position: relative; }

.cr-input-pfx {
  position: absolute;
  left: 0;
  top: 0;
  height: 100%;
  padding: 0 10px;
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #1565c0, #1e88e5);
  color: #fff;
  font-size: 10px;
  font-weight: 800;
  border-radius: 11px 0 0 11px;
  letter-spacing: 0.3px;
  z-index: 1;
  white-space: nowrap;
}

.cr-input-pfx-auto {
  background: linear-gradient(135deg, #00838f, #00bcd4);
}

.cr-input-pfx-field { padding-left: 52px; }

/* Auto fields styling */
.cr-auto-field { background: #f0fbfd; color: #006064; font-weight: 700; }

/* √Ę‚ÄĚ‚ā¨√Ę‚ÄĚ‚ā¨ Calculator preview √Ę‚ÄĚ‚ā¨√Ę‚ÄĚ‚ā¨ */
.cr-calc-preview {
  background: linear-gradient(135deg, #f0f9ff, #e0f7fa);
  border: 1px solid #b2ebf2;
  border-radius: 14px;
  padding: 14px 16px;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.cr-calc-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.cr-calc-row span {
  font-size: 12px;
  color: #006064;
  font-weight: 600;
}

.cr-calc-row strong {
  font-size: 13px;
  font-weight: 800;
  color: #00838f;
}

/* √Ę‚ÄĚ‚ā¨√Ę‚ÄĚ‚ā¨ Analyze block √Ę‚ÄĚ‚ā¨√Ę‚ÄĚ‚ā¨ */
.cr-analyze-block {
  background: linear-gradient(135deg, #fffbeb, #fef3c7);
  border: 1px solid #fde68a;
  border-radius: 14px;
  padding: 14px 16px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.cr-analyze-header {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 12px;
  font-weight: 700;
  color: #92400e;
}

.cr-analyze-header i { color: #d97706; }

.cr-analyze-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  min-height: 38px;
  padding: 0 16px;
  border-radius: 10px;
  background: linear-gradient(120deg, #d97706, #f59e0b);
  color: #fff;
  font: inherit;
  font-size: 12px;
  font-weight: 700;
  border: none;
  cursor: pointer;
  transition: opacity .15s, transform .15s;
  width: fit-content;
}

.cr-analyze-btn:hover { opacity: .9; transform: scale(.98); }

.cr-analysis-output {
  font-size: 12px;
  font-weight: 600;
  padding: 8px 12px;
  border-radius: 8px;
  line-height: 1.5;
  white-space: pre-line;
}

.cr-analysis-output.is-ok   { background: #d1fae5; color: #065f46; }
.cr-analysis-output.is-warn { background: #fef3c7; color: #92400e; }
.cr-analysis-output.is-risk { background: #fee2e2; color: #991b1b; }

.cr-ai-modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(10, 37, 64, 0.45);
  backdrop-filter: blur(2px);
  z-index: 520;
}

.cr-ai-modal {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: min(690px, calc(100vw - 28px));
  max-height: calc(100vh - 30px);
  overflow: auto;
  background: #fff;
  border: 1px solid #d8e6f4;
  border-radius: 16px;
  box-shadow: 0 26px 60px rgba(10, 37, 64, 0.28);
  z-index: 530;
  display: flex;
  flex-direction: column;
}

.cr-ai-modal[hidden],
.cr-ai-modal-overlay[hidden] {
  display: none !important;
}

.cr-ai-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 18px;
  border-bottom: 1px solid #e7eff8;
  background: #f9fcff;
}

.cr-ai-modal-header h3 {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 30px;
  font-weight: 900;
  color: #0a2540;
  margin: 0;
}

.cr-ai-modal-header h3 i { color: #1565c0; }

.cr-ai-modal-close {
  width: 34px;
  height: 34px;
  border-radius: 10px;
  border: 1px solid #d8e6f4;
  background: #fff;
  color: #5b80a0;
  font-size: 14px;
  cursor: pointer;
}

.cr-ai-modal-close:hover { background: #eff6ff; color: #1565c0; }

.cr-ai-modal-body {
  padding: 18px;
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.cr-ai-status {
  font-size: 18px;
  font-weight: 900;
  color: #0a2540;
}

.cr-ai-status.is-ok   { color: #15803d; }
.cr-ai-status.is-warn { color: #b45309; }
.cr-ai-status.is-risk { color: #b91c1c; }

.cr-ai-score-row {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 15px;
  color: #0a2540;
}

.cr-ai-score-row strong { font-size: 19px; font-weight: 900; }

.cr-ai-progress {
  width: 100%;
  height: 16px;
  border-radius: 999px;
  background: #e3f2ea;
  overflow: hidden;
}

.cr-ai-progress-fill {
  display: block;
  height: 100%;
  width: 0%;
  background: linear-gradient(90deg, #16a34a, #22c55e);
  transition: width .35s ease;
}

.cr-ai-progress-fill.is-warn {
  background: linear-gradient(90deg, #d97706, #f59e0b);
}

.cr-ai-progress-fill.is-risk {
  background: linear-gradient(90deg, #dc2626, #ef4444);
}

.cr-ai-metrics {
  border: 1px solid #e3edf8;
  border-radius: 12px;
  background: #f8fbff;
  padding: 12px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}

.cr-ai-metric {
  border-radius: 10px;
  background: #fff;
  border: 1px solid #e6eef8;
  padding: 10px;
  display: grid;
  grid-template-columns: 1fr auto auto;
  align-items: center;
  column-gap: 10px;
}

.cr-ai-metric-label {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 13px;
  font-weight: 700;
  color: #274d70;
}

.cr-ai-metric-label i { color: #1565c0; }

.cr-ai-metric strong {
  font-size: 14px;
  font-weight: 800;
  color: #0a2540;
}

.cr-ai-metric-mark {
  min-width: 32px;
  text-align: right;
  font-size: 13px;
  font-weight: 900;
  color: #7294ae;
}

.cr-ai-metric-mark.is-ok { color: #15803d; }
.cr-ai-metric-mark.is-warn { color: #b45309; }
.cr-ai-metric-mark.is-risk { color: #b91c1c; }

.cr-ai-reco {
  border: 1px solid #e6eef8;
  border-radius: 12px;
  background: #ffffff;
  padding: 12px;
}

.cr-ai-reco h4 {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  font-size: 16px;
  font-weight: 900;
  color: #0a2540;
  margin: 0 0 8px;
}

.cr-ai-reco h4 i { color: #0d9488; }

.cr-ai-reco p {
  margin: 0;
  font-size: 16px;
  line-height: 1.55;
  color: #244665;
  white-space: pre-line;
}

.cr-ai-modal-footer {
  padding: 0 18px 16px;
  display: flex;
  justify-content: flex-end;
}

.cr-ai-ok-btn {
  min-height: 40px;
  min-width: 120px;
  padding: 0 18px;
  border-radius: 11px;
  border: none;
  background: linear-gradient(120deg, #0284c7, #0891b2);
  color: #fff;
  font-size: 25px;
  font-weight: 800;
  cursor: pointer;
}

.cr-ai-ok-btn:hover { opacity: .92; }

@media (max-width: 760px) {
  .cr-ai-modal-header h3 { font-size: 19px; }
  .cr-ai-score-row { font-size: 13px; }
  .cr-ai-score-row strong { font-size: 16px; }
  .cr-ai-metrics { grid-template-columns: 1fr; }
  .cr-ai-reco h4 { font-size: 14px; }
  .cr-ai-reco p { font-size: 13px; }
  .cr-ai-ok-btn { min-width: 96px; font-size: 13px; }
}

/* √Ę‚ÄĚ‚ā¨√Ę‚ÄĚ‚ā¨ Step navigation √Ę‚ÄĚ‚ā¨√Ę‚ÄĚ‚ā¨ */
.cr-step-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 0 18px;
  border-top: 1px solid #edf4fb;
  margin-top: 6px;
}

.cr-step-nav-final { flex-direction: column; gap: 10px; align-items: stretch; }

.cr-step-btn {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  min-height: 38px;
  padding: 0 16px;
  border-radius: 10px;
  font: inherit;
  font-size: 13px;
  font-weight: 700;
  cursor: pointer;
  border: none;
  transition: all .15s;
}

.cr-step-next {
  background: linear-gradient(120deg, #1565c0, #1e88e5);
  color: #fff;
}

.cr-step-back {
  background: #f0f4f8;
  color: #5b80a0;
  border: 1px solid #dde8f5;
}

.cr-step-back:hover { background: #e2ecf8; }
.cr-step-next:hover { opacity: .9; }

.cr-final-actions {
  display: flex;
  gap: 10px;
}

.cr-submit-btn {
  flex: 1;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  min-height: 44px;
  padding: 0 20px;
  border-radius: 12px;
  background: linear-gradient(120deg, #1565c0, #00bcd4);
  color: #fff;
  font: inherit;
  font-size: 14px;
  font-weight: 800;
  border: none;
  cursor: pointer;
  box-shadow: 0 6px 20px rgba(21,101,192,.28);
  transition: all .18s;
}

.cr-submit-btn:hover { opacity: .92; box-shadow: 0 8px 24px rgba(21,101,192,.38); }

.cr-submit-btn-sm { min-height: 38px; font-size: 13px; }

.cr-form-reset-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 7px;
  min-height: 44px;
  padding: 0 16px;
  border-radius: 12px;
  background: transparent;
  border: 1.5px solid #cddff0;
  color: #5b80a0;
  font: inherit;
  font-size: 13px;
  font-weight: 700;
  cursor: pointer;
  transition: all .15s;
}

.cr-form-reset-btn:hover { background: #f0f4f8; }

/* √Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź
   TABLE COLUMN
   √Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź */
.cr-table-col {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.cr-list-shell {
  display: flex;
  flex-direction: column;
  gap: 18px;
  background: #fff;
  border: 1px solid #dde8f5;
  border-radius: 24px;
  padding: 18px;
  box-shadow: 0 8px 24px rgba(10,37,64,.06);
}

/* √Ę‚ÄĚ‚ā¨√Ę‚ÄĚ‚ā¨ Toolbar √Ę‚ÄĚ‚ā¨√Ę‚ÄĚ‚ā¨ */
.cr-table-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  background: transparent;
  border-radius: 0;
  padding: 0;
  border: none;
  box-shadow: none;
  flex-wrap: wrap;
}

.cr-table-toolbar-left {
  display: flex;
  align-items: center;
  gap: 10px;
}

.cr-table-title {
  font-size: 17px;
  font-weight: 800;
  color: #0a2540;
  display: flex;
  align-items: center;
  gap: 9px;
}

.cr-table-title i { color: #1565c0; }

.cr-table-count-badge {
  padding: 3px 10px;
  border-radius: 999px;
  background: linear-gradient(120deg, #1565c0, #1e88e5);
  color: #fff;
  font-size: 11px;
  font-weight: 800;
}

.cr-table-toolbar-right {
  display: flex;
  align-items: center;
  gap: 10px;
}

.cr-search-box {
  display: flex;
  align-items: center;
  gap: 8px;
  background: #f7faff;
  border: 1.5px solid #cddff0;
  border-radius: 11px;
  padding: 0 12px;
  min-height: 40px;
  transition: border-color .18s;
}

.cr-search-box:focus-within {
  border-color: #1e88e5;
  box-shadow: 0 0 0 3px rgba(30,136,229,.10);
}

.cr-search-box i { color: #8aafc8; font-size: 12px; }

.cr-search-box input {
  border: none;
  outline: none;
  background: transparent;
  font: inherit;
  font-size: 13px;
  color: #0a2540;
  width: 190px;
}

.cr-search-box input::placeholder { color: #aabece; }

.cr-search-clear {
  width: 20px;
  height: 20px;
  border-radius: 50%;
  background: #e2ecf8;
  border: none;
  color: #5b80a0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 11px;
  cursor: pointer;
}

.cr-sort-wrap { min-width: 140px; }

.cr-sort-select { font-size: 12px; min-height: 40px; }

.cr-garanties-btn {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  min-height: 40px;
  padding: 0 14px;
  border-radius: 11px;
  background: linear-gradient(120deg, #0a2540, #1565c0);
  color: #fff;
  font: inherit;
  font-size: 12px;
  font-weight: 700;
  border: none;
  cursor: pointer;
  white-space: nowrap;
  transition: opacity .15s;
}

.cr-garanties-btn:hover { opacity: .88; }

.cr-garanties-btn.is-active-alt {
  background: linear-gradient(120deg, #eef5ff, #dbeafe);
  color: #1565c0;
  border: 1px solid #bfdbfe;
}

#cr-credits-view,
#cr-garanties-view {
  display: flex;
  flex-direction: column;
  gap: 18px;
}

#cr-credits-view[hidden],
#cr-garanties-view[hidden] {
  display: none !important;
}

/* √Ę‚ÄĚ‚ā¨√Ę‚ÄĚ‚ā¨ Filter tabs √Ę‚ÄĚ‚ā¨√Ę‚ÄĚ‚ā¨ */
.cr-filter-tabs {
  display: flex;
  align-items: center;
  gap: 6px;
  background: transparent;
  border-radius: 0;
  padding: 0 0 14px;
  border: none;
  border-bottom: 1px solid #dde8f5;
  flex-wrap: wrap;
}

.cr-filter-tab {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  min-height: 34px;
  padding: 0 14px;
  border-radius: 9px;
  background: transparent;
  border: 1px solid transparent;
  font: inherit;
  font-size: 12px;
  font-weight: 700;
  color: #7294ae;
  cursor: pointer;
  transition: all .15s;
}

.cr-filter-tab:hover { background: #f0f4f8; color: #0a2540; }

.cr-filter-tab-active {
  background: linear-gradient(120deg, #1565c0, #1e88e5);
  color: #fff;
  box-shadow: 0 4px 12px rgba(21,101,192,.2);
}

.cr-filter-tab-active:hover { background: linear-gradient(120deg, #1565c0, #1e88e5); color: #fff; }

.cr-tab-count {
  background: rgba(255,255,255,.25);
  border-radius: 999px;
  padding: 1px 7px;
  font-size: 10px;
  font-weight: 800;
}

.cr-filter-tab:not(.cr-filter-tab-active) .cr-tab-count {
  background: #e8f0fb;
  color: #1565c0;
}

/* √Ę‚ÄĚ‚ā¨√Ę‚ÄĚ‚ā¨ Credits card grid √Ę‚ÄĚ‚ā¨√Ę‚ÄĚ‚ā¨ */
.cr-credits-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 14px;
}

.cr-list-pager {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 10px;
  margin-top: 18px;
  flex-wrap: wrap;
}

.cr-list-pager[hidden] {
  display: none !important;
}

.cr-list-pager-btn {
  width: 40px;
  height: 40px;
  border-radius: 999px;
  border: 1px solid #cfe0f2;
  background: #fff;
  color: #58789a;
  font-size: 14px;
  font-weight: 800;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: transform .18s ease, box-shadow .18s ease, background .18s ease, color .18s ease, border-color .18s ease;
}

.cr-list-pager-btn:hover:not(:disabled) {
  transform: translateY(-1px);
  box-shadow: 0 10px 24px rgba(21, 101, 192, 0.12);
  border-color: #8dc7f3;
}

.cr-list-pager-btn.is-active {
  border-color: transparent;
  background: linear-gradient(135deg, #16a34a, #14b8a6);
  color: #fff;
  box-shadow: 0 12px 28px rgba(20, 184, 166, 0.22);
}

.cr-list-pager-btn:disabled {
  opacity: .45;
  cursor: default;
  box-shadow: none;
}

/* √Ę‚ÄĚ‚ā¨√Ę‚ÄĚ‚ā¨ Single credit card √Ę‚ÄĚ‚ā¨√Ę‚ÄĚ‚ā¨ */
.cr-credit-card {
  background: #fff;
  border-radius: 18px;
  border: 1px solid #dde8f5;
  padding: 18px;
  display: flex;
  flex-direction: column;
  gap: 14px;
  box-shadow: 0 2px 12px rgba(10,37,64,.05);
  transition: box-shadow .2s, transform .2s, border-color .2s;
  position: relative;
  overflow: hidden;
  animation: crCreditCardIn .45s ease both;
  cursor: pointer;
}

.cr-credit-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: linear-gradient(90deg, #1565c0, #00bcd4);
}

.cr-credit-card:nth-child(2n) { animation-delay: .03s; }
.cr-credit-card:nth-child(3n) { animation-delay: .06s; }
.cr-credit-card:nth-child(4n) { animation-delay: .09s; }

.cr-credit-card:hover {
  box-shadow: 0 10px 32px rgba(10,37,64,.12);
  transform: translateY(-3px);
  border-color: #b8d4f0;
}

.cr-credit-card:focus-visible {
  outline: none;
  box-shadow: 0 0 0 4px rgba(30, 136, 229, 0.2), 0 10px 32px rgba(10,37,64,.12);
  border-color: #60a5fa;
}

.cr-credit-card.is-selected {
  border-color: #3b82f6;
  box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.14), 0 12px 36px rgba(10,37,64,.14);
  animation: crCreditSelectedPop .26s ease-out;
}

@keyframes crCreditSelectedPop {
  0% { transform: translateY(0) scale(1); }
  45% { transform: translateY(-2px) scale(1.01); }
  100% { transform: translateY(0) scale(1); }
}

.cr-credit-card.is-restructured {
  border-color: #c4b5fd;
  box-shadow: 0 16px 38px rgba(124, 58, 237, .14);
}

.cr-credit-card.is-restructured::before {
  background: linear-gradient(90deg, #7c3aed, #22c55e);
}

.cr-credit-card .cr-cc-top,
.cr-garantie-card .cr-cc-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 8px;
  margin: -18px -18px 0;
  padding: 14px 16px 12px;
  border-bottom: 1px solid rgba(255, 255, 255, .2);
  position: relative;
  overflow: hidden;
  background: linear-gradient(135deg, #1d4ed8 0%, #0ea5e9 100%);
}

.cr-credit-card .cr-cc-top::before,
.cr-garantie-card .cr-cc-top::before {
  content: '';
  position: absolute;
  width: 120px;
  height: 120px;
  top: -40px;
  right: -30px;
  border-radius: 50%;
  background: rgba(255, 255, 255, .14);
  pointer-events: none;
}

.cr-cc-id { display: flex; flex-direction: column; gap: 3px; }

.cr-cc-applied-badge {
  display: inline-flex;
  align-items: center;
  width: fit-content;
  margin-top: 4px;
  padding: 4px 10px;
  border-radius: 999px;
  background: linear-gradient(120deg, #ede9fe, #dcfce7);
  color: #5b21b6;
  font-size: 10px;
  font-weight: 800;
  letter-spacing: .03em;
  text-transform: uppercase;
}

.cr-credit-card .cr-cc-id-label,
.cr-garantie-card .cr-cc-id-label {
  font-size: 11px;
  font-weight: 800;
  color: rgba(255, 255, 255, .82);
  letter-spacing: 0.3px;
}

.cr-credit-card .cr-cc-type,
.cr-garantie-card .cr-cc-type {
  font-size: 15px;
  font-weight: 800;
  color: #fff;
}

/* Status badge on card */
.cr-cc-status {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  padding: 5px 11px;
  border-radius: 999px;
  font-size: 11px;
  font-weight: 800;
  white-space: nowrap;
  flex-shrink: 0;
}

.cr-status-green  { background: #dcfce7; color: #166534; }
.cr-status-red    { background: #fee2e2; color: #991b1b; }
.cr-status-amber  { background: #fef9c3; color: #854d0e; }

.cr-credit-card--pending {
  border: 2px dashed #f59e0b;
  box-shadow: 0 0 0 4px rgba(245, 158, 11, .12), 0 12px 28px rgba(15, 40, 72, .08);
  animation: crCreditCardIn .45s ease both, crCreditPendingFloat 3s ease-in-out infinite;
}

.cr-credit-card--pending .cr-cc-top {
  background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
}

.cr-credit-card--pending .cr-cc-status i {
  animation: crCreditSpin 2s linear infinite;
}

.cr-credit-card--live .cr-cc-top {
  background: linear-gradient(135deg, #1d4ed8 0%, #0ea5e9 100%);
}

.cr-credit-card--risk .cr-cc-top {
  background: linear-gradient(135deg, #b91c1c 0%, #ef4444 100%);
}

.cr-cc-amount-row {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 10px;
}

.cr-cc-amount {
  font-size: 26px;
  font-weight: 900;
  color: #0a2540;
  letter-spacing: -0.5px;
  line-height: 1;
}

.cr-cc-amount small {
  font-size: 12px;
  font-weight: 600;
  color: #7294ae;
  margin-left: 3px;
}

.cr-cc-monthly {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 2px;
}

.cr-cc-monthly-label {
  font-size: 10px;
  color: #aabece;
  text-transform: uppercase;
  letter-spacing: 0.4px;
  font-weight: 700;
}

.cr-cc-monthly-val {
  font-size: 13px;
  font-weight: 800;
  color: #1565c0;
}

.cr-cc-meta {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 10px 0;
  border-top: 1px solid #f0f4f8;
  border-bottom: 1px solid #f0f4f8;
}

.cr-cc-meta-item {
  display: flex;
  align-items: center;
  gap: 5px;
  font-size: 12px;
  color: #5b80a0;
  font-weight: 600;
}

.cr-cc-meta-item i { color: #1e88e5; font-size: 11px; }

.cr-cc-risk-row {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.cr-cc-risk-label {
  font-size: 10px;
  color: #aabece;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.4px;
}

.cr-cc-risk-bar-wrap {
  display: flex;
  align-items: center;
  gap: 10px;
}

.cr-cc-risk-bar {
  flex: 1;
  height: 6px;
  background: #e8f0f8;
  border-radius: 999px;
  overflow: hidden;
}

.cr-cc-risk-fill {
  height: 100%;
  border-radius: 999px;
  transition: width .6s ease;
}

.cr-risk-low    .cr-cc-risk-fill,
.cr-cc-risk-fill.cr-risk-low    { background: linear-gradient(90deg, #22c55e, #4ade80); }
.cr-risk-medium .cr-cc-risk-fill,
.cr-cc-risk-fill.cr-risk-medium { background: linear-gradient(90deg, #f59e0b, #fbbf24); }
.cr-risk-high   .cr-cc-risk-fill,
.cr-cc-risk-fill.cr-risk-high   { background: linear-gradient(90deg, #ef4444, #f87171); }

.cr-cc-risk-val {
  font-size: 11px;
  font-weight: 800;
  white-space: nowrap;
}

@keyframes crCreditCardIn {
  from {
    opacity: 0;
    transform: translateY(12px) scale(.985);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

@keyframes crCreditPendingFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-6px); }
}

@keyframes crCreditSpin {
  to { transform: rotate(360deg); }
}

@media (prefers-reduced-motion: reduce) {
  .cr-credit-card,
  .cr-garantie-card,
  .cr-credit-card--pending .cr-cc-status i {
    animation: none !important;
  }
}

.cr-risk-low    { color: #166534; }
.cr-risk-medium { color: #854d0e; }
.cr-risk-high   { color: #991b1b; }

.cr-cc-actions {
  display: flex;
  align-items: center;
  gap: 8px;
}

.cr-cc-restruct-btn {
  margin-top: 10px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  width: 100%;
  min-height: 42px;
  border-radius: 12px;
  border: 1px solid #c7d8f6;
  background: linear-gradient(120deg, #f5f9ff, #e8f0fd);
