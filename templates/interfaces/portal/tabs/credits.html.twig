   GARANTIES DRAWER
   √Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź */
.cr-drawer-overlay {
  position: fixed;
  inset: 0;
  background: rgba(10,37,64,.4);
  backdrop-filter: blur(4px);
  z-index: 200;
}

.cr-drawer {
  position: fixed;
  top: 0;
  right: 0;
  width: min(680px, 100vw);
  height: 100vh;
  background: #fff;
  border-left: 1px solid #dde8f5;
  box-shadow: -8px 0 40px rgba(10,37,64,.15);
  z-index: 201;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* hidden attribute must win against class display rules */
.cr-drawer-overlay[hidden],
.cr-drawer[hidden] {
  display: none !important;
}

.cr-drawer-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  padding: 20px 24px;
  background: linear-gradient(135deg, #0a2540, #1565c0);
}

.cr-drawer-header-left {
  display: flex;
  align-items: center;
  gap: 14px;
}

.cr-drawer-icon {
  width: 44px;
  height: 44px;
  border-radius: 14px;
  background: rgba(255,255,255,.15);
  border: 1px solid rgba(255,255,255,.25);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 18px;
  flex-shrink: 0;
}

.cr-drawer-header h3 {
  font-size: 16px;
  font-weight: 800;
  color: #fff;
}

.cr-drawer-header p {
  font-size: 12px;
  color: rgba(255,255,255,.68);
  margin-top: 3px;
}

.cr-drawer-close {
  width: 36px;
  height: 36px;
  border-radius: 10px;
  background: rgba(255,255,255,.12);
  border: 1px solid rgba(255,255,255,.2);
  color: rgba(255,255,255,.85);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  font-size: 14px;
  transition: background .15s;
}

.cr-drawer-close:hover { background: rgba(255,255,255,.22); }

.cr-drawer-body {
  flex: 1;
  overflow-y: auto;
  padding: 20px 24px;
  display: flex;
  flex-direction: column;
  gap: 24px;
}

.cr-drawer-section {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.cr-drawer-section-title {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 12px;
  font-weight: 800;
  color: #1565c0;
  text-transform: uppercase;
  letter-spacing: 0.7px;
  padding-bottom: 10px;
  border-bottom: 1.5px solid #e8f0fb;
}

.cr-drawer-badge {
  margin-left: auto;
  padding: 2px 9px;
  border-radius: 999px;
  background: linear-gradient(120deg, #1565c0, #00bcd4);
  color: #fff;
  font-size: 10px;
  font-weight: 800;
}

.cr-drawer-form { gap: 12px; }

.cr-drawer-form-note {
  font-size: 11.5px;
  color: #5d7f9a;
  background: #eef5ff;
  border: 1px solid #d5e6fb;
  border-radius: 10px;
  padding: 8px 10px;
}

.cr-form-actions { display: flex; justify-content: flex-end; gap: 8px; }

.cr-drawer-actions { padding-top: 6px; border-top: 1px solid #edf4fb; }

/* Garantie list rows */
.cr-garanties-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.cr-garanties-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 14px;
  margin-top: 10px;
}

.cr-garanties-list-main {
  margin-top: 10px;
}

.cr-garantie-card {
  background: #fff;
  border-radius: 18px;
  border: 1px solid #dde8f5;
  padding: 18px;
  display: flex;
  flex-direction: column;
  gap: 14px;
  box-shadow: 0 2px 12px rgba(10,37,64,.05);
  transition: box-shadow .2s, transform .2s, border-color .2s;
  position: relative;
  overflow: hidden;
  animation: crCreditCardIn .45s ease both;
  cursor: pointer;
}

.cr-garantie-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: linear-gradient(90deg, #1565c0, #00bcd4);
}

.cr-garantie-card:hover {
  box-shadow: 0 10px 32px rgba(10,37,64,.12);
  transform: translateY(-3px);
  border-color: #b8d4f0;
}

.cr-garantie-card:focus-visible {
  outline: none;
  box-shadow: 0 0 0 4px rgba(30, 136, 229, 0.2), 0 10px 32px rgba(10,37,64,.12);
  border-color: #60a5fa;
}

.cr-garantie-card.is-selected {
  border-color: #3b82f6;
  box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.14), 0 12px 36px rgba(10,37,64,.14);
  animation: crGarantieSelectedPop .26s ease-out;
}

@keyframes crGarantieSelectedPop {
  0% { transform: translateY(0) scale(1); }
  45% { transform: translateY(-2px) scale(1.01); }
  100% { transform: translateY(0) scale(1); }
}

.cr-garantie-row:hover { border-color: #a8c8f0; }

.cr-garantie-row-left {
  display: flex;
  align-items: center;
  gap: 12px;
}

.cr-garantie-icon {
  width: 36px;
  height: 36px;
  border-radius: 10px;
  background: linear-gradient(135deg, #1565c0, #00bcd4);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  flex-shrink: 0;
}

.cr-garantie-info {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.cr-garantie-info strong {
  font-size: 13px;
  font-weight: 800;
  color: #0a2540;
}

.cr-garantie-info span {
  font-size: 11px;
  color: #7294ae;
}

.cr-garantie-status {
  display: inline-block;
  padding: 2px 8px;
  border-radius: 999px;
  font-size: 10px;
  font-weight: 800;
  width: fit-content;
}

.cr-gstatus-green  { background: #dcfce7; color: #166534; }
.cr-gstatus-red    { background: #fee2e2; color: #991b1b; }
.cr-gstatus-amber  { background: #fef9c3; color: #854d0e; }

.cr-garantie-actions {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  flex-shrink: 0;
}

.cr-garantie-edit-btn,
.cr-garantie-del-btn {
  width: 36px;
  height: 36px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  font-size: 12px;
  transition: all .15s;
}

.cr-garantie-edit-btn {
  background: linear-gradient(120deg, #e8f0fd, #dbeafe);
  border: 1px solid #c3d9f5;
  color: #1565c0;
}

.cr-garantie-edit-btn:hover {
  background: linear-gradient(120deg, #1565c0, #1e88e5);
  color: #fff;
}

.cr-garantie-del-form { margin: 0; }

.cr-garantie-del-btn {
  background: #fff0f0;
  border: 1px solid #fecaca;
  color: #dc2626;
}

.cr-garantie-del-btn:hover { background: #dc2626; color: #fff; }

.cr-garanties-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  padding: 32px 20px;
  background: #f7faff;
  border: 1px dashed #c4d9ee;
  border-radius: 14px;
  text-align: center;
  color: #7294ae;
