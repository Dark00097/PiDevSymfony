ÔĽŅ{% set current_date = 'now'|date('Y-m-d') %}
{% set garanties = support.garanties|default([]) %}
{% set credits = support.credits|default([]) %}
{% set garantie_type_choices = {
    'titre_vehicule': 'Titre v√©hicule',
    'hypotheque': 'Hypoth√®que',
    'caution_bancaire': 'Caution bancaire',
    'depot_garantie': 'D√©p√īt de garantie'
} %}
{% set credit_garanties = support.all_garanties|default(garanties) %}
{% set credit_query = support.credit_query|default({ q: '', search_in: 'all', filter: 'all', sort: '', dir: 'asc' }) %}
{% set query_state = {
    tab: 'credits',
    q: credit_query.q|default(''),
    search_in: credit_query.search_in|default('all'),
    filter: credit_query.filter|default('all'),
    sort: credit_query.sort|default(''),
    dir: credit_query.dir|default('asc')
} %}
{% set pending_total = 0 %}
{% set accepted_total = 0 %}
{% set refused_total = 0 %}
{% set encours_total = 0 %}
{% set average_risk = 0 %}
{% set risk_sum = 0 %}
{% set total_amount = 0 %}
{% set total_monthly = 0 %}
{% set current_month = 'now'|date('Y-m') %}
{% set credits_month = 0 %}
{% set max_credit_id = 0 %}
{% set open_credit_panel = app.request.query.get('panel') == 'credit' %}
{% set credit_feedback = support.credit_form_feedback|default({}) %}
{% if credit_feedback is empty %}
    {% set credit_feedback = {'errors': support.form_errors_credit|default({}), 'input': support.form_data_credit|default({})} %}
{% endif %}
{% set credit_old = credit_feedback.input|default({}) %}
{% set credit_errors = credit_feedback.errors|default({}) %}
{% set garantie_feedback = support.garantie_form_feedback|default({}) %}
{% if garantie_feedback is empty %}
    {% set garantie_feedback = {'errors': support.form_errors_garantie|default({}), 'input': support.form_data_garantie|default({})} %}
{% endif %}
{% set garantie_old = garantie_feedback.input|default({}) %}
{% set garantie_errors = garantie_feedback.errors|default({}) %}
{% set payment_accounts = support.payment_accounts|default(support.accounts|default([])) %}
{% set payment_otp_sent = support.payment_otp_sent|default(false) %}
{% set payment_otp_verified = support.payment_otp_verified|default(false) %}
{% set payment_phone = support.payment_phone|default(current_user.telephone|default('')) %}
{% set payment_channel = support.payment_channel|default('sms') %}
{% set payment_open_credit_id = support.payment_open_credit_id|default(0) %}
{% set payment_config = support.payment_config|default({}) %}
{% set restructuration_scenarios = support.restructuration_scenarios|default({}) %}
{% set restructuration_first_eligible_credit_id = support.restructuration_first_eligible_credit_id|default(0) %}
{% set restructuration_first_critical_credit_id = support.restructuration_first_critical_credit_id|default(0) %}
{% set payment_current_step = payment_otp_verified ? 3 : (payment_otp_sent ? 2 : 1) %}
{% set current_language = 'fr' %}
{% set credit_error_step = 1 %}
{% if credit_errors.montantDemande is defined or credit_errors.autofinancement is defined or credit_errors.duree is defined or credit_errors.tauxInteret is defined or credit_errors.mensualite is defined or credit_errors.montantAccorde is defined %}
    {% set credit_error_step = 2 %}
{% elseif credit_errors.salaire is defined or credit_errors.typeContrat is defined or credit_errors.ancienneteAnnees is defined %}
    {% set credit_error_step = 3 %}
{% endif %}
{% for item in items %}
    {% set status_key = item.statut|default('')|lower %}
    {% if 'attente' in status_key %}
        {% set pending_total = pending_total + 1 %}
    {% endif %}
    {% if 'accepte' in status_key or 'approved' in status_key %}
        {% set accepted_total = accepted_total + 1 %}
    {% endif %}
    {% if 'cours' in status_key %}
        {% set encours_total = encours_total + 1 %}
    {% endif %}
    {% if 'refuse' in status_key or 'rejet' in status_key %}
        {% set refused_total = refused_total + 1 %}
    {% endif %}
    {% set risk_sum = risk_sum + (item.risk_score|default(0)) %}
    {% set total_amount = total_amount + (item.montantDemande|default(0)) %}
    {% set total_monthly = total_monthly + (item.mensualite|default(0)) %}
    {% if item.idCredit|default(0) > max_credit_id %}
        {% set max_credit_id = item.idCredit %}
    {% endif %}
    {% if item.dateDemande is not empty and item.dateDemande|date('Y-m') == current_month %}
        {% set credits_month = credits_month + 1 %}
    {% endif %}
{% endfor %}
{% set next_credit_id = max_credit_id + 1 %}
{% if items|length > 0 %}
    {% set average_risk = (risk_sum / items|length)|round(1, 'common') %}
{% endif %}

<div class="cr-root"
     data-payment-open-credit="{{ payment_open_credit_id }}"
     data-payment-otp-sent="{{ payment_otp_sent ? '1' : '0' }}"
     data-payment-otp-verified="{{ payment_otp_verified ? '1' : '0' }}"
     data-payment-current-step="{{ payment_current_step }}"
     data-restruct-first-eligible-credit="{{ restructuration_first_eligible_credit_id }}"
     data-restruct-first-critical-credit="{{ restructuration_first_critical_credit_id }}">

    <section class="cr-hero">
        <div class="cr-hero-main">
            <div class="cr-hero-brand">
                <div class="cr-hero-icon">
                    <i class="fa-solid fa-hand-holding-dollar"></i>
                </div>
                <div class="cr-hero-copy">
                    <h1>Gestion des credits</h1>
                    <p>Demandez des prets, gerez vos credits et suivez les remboursements</p>
                </div>
            </div>

            <div class="cr-hero-center">
                <div class="cr-hero-stat">
                    <span class="cr-hero-stat-num">{{ items|length }}</span>
                    <span class="cr-hero-stat-lbl">Total dossiers</span>
                </div>
                <div class="cr-hero-divider"></div>
                <div class="cr-hero-stat">
                    <span class="cr-hero-stat-num">{{ credits_month }}</span>
                    <span class="cr-hero-stat-lbl">Ce mois</span>
                </div>
                <div class="cr-hero-divider"></div>
                <div class="cr-hero-stat">
                    <span class="cr-hero-stat-num">{{ pending_total }}</span>
                    <span class="cr-hero-stat-lbl">En attente</span>
                </div>
            </div>

            <div class="cr-hero-nav">
                <button type="button" class="cr-nav-pill" data-tool-open="history">
                    <i class="fa-solid fa-clock-rotate-left"></i><span>Historique</span>
                </button>
                <a class="cr-nav-pill cr-nav-pill--cta" id="cr-add-credit-btn" href="{{ path(route_name, { tab: 'credits', panel: 'credit' }) }}" role="button" aria-controls="credit-form-card" aria-label="Nouveau credit" onclick="window.location.assign(this.getAttribute('href')); return false;">
                    <i class="fa-solid fa-plus"></i><span>Nouveau credit</span>
                </a>
            </div>
        </div>

        <div class="cr-hero-toolbar">
            <div class="cr-hero-toolbar-right">
                <label class="cr-lang-select" for="cr-language">
                    <span class="cr-visually-hidden" id="cr-language-label">Choisir la langue</span>
                    <i class="fa-solid fa-globe" aria-hidden="true"></i>
                    <span class="cr-lang-value" id="cr-language-value" aria-hidden="true">Francais</span>
                    <select id="cr-language" name="language" aria-labelledby="cr-language-label">
                        <option value="fr" {{ current_language == 'fr' ? 'selected' : '' }}>Francais</option>
                        <option value="en" {{ current_language == 'en' ? 'selected' : '' }}>English</option>
                        <option value="ar" {{ current_language == 'ar' ? 'selected' : '' }}>???????</option>
                    </select>
                    <i class="fa-solid fa-chevron-down cr-lang-chevron" aria-hidden="true"></i>
                </label>
                <button class="cr-topbar-btn" id="cr-dark-toggle" type="button">
                    <i class="fa-solid fa-moon"></i>
                </button>
                <a class="cr-topbar-btn" href="{{ path(route_name, { tab: 'credits' }) }}" title="Actualiser">
                    <i class="fa-solid fa-rotate"></i>
                </a>
                <div class="cr-user-chip">
                    <div class="cr-user-avatar">
                        {{ current_user.prenom|first|upper }}{{ current_user.nom|first|upper }}
                    </div>
                    <div class="cr-user-info">
                        <strong>{{ current_user.prenom }} {{ current_user.nom }}</strong>
                        <small>#{{ current_user.idUser }}</small>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div class="cr-kpi-strip">
        <div class="cr-kpi-card cr-kpi-card--amount">
            <div class="cr-kpi-head">
                <div class="cr-kpi-icon cr-kpi-icon-teal">
                    <i class="fa-solid fa-coins"></i>
                </div>
                <div class="cr-kpi-copy">
                    <span class="cr-kpi-label">Montant demande</span>
                    <span class="cr-kpi-sub">Volume global</span>
                </div>
            </div>
            <div class="cr-kpi-metric">
                <strong class="cr-kpi-value">{{ total_amount|number_format(2, '.', ' ') }}</strong>
                <span class="cr-kpi-unit">DT</span>
            </div>
            <div class="cr-kpi-bar"><span style="width:100%"></span></div>
        </div>
        <div class="cr-kpi-card cr-kpi-card--monthly">
            <div class="cr-kpi-head">
                <div class="cr-kpi-icon cr-kpi-icon-blue">
                    <i class="fa-solid fa-calendar-check"></i>
                </div>
                <div class="cr-kpi-copy">
                    <span class="cr-kpi-label">Mensualites</span>
                    <span class="cr-kpi-sub">Charge cumulee</span>
                </div>
            </div>
            <div class="cr-kpi-metric">
                <strong class="cr-kpi-value">{{ total_monthly|number_format(2, '.', ' ') }}</strong>
                <span class="cr-kpi-unit">DT</span>
            </div>
            <div class="cr-kpi-bar"><span style="width:{{ total_amount > 0 ? ((total_monthly / total_amount) * 100)|round : 0 }}%"></span></div>
        </div>
        <div class="cr-kpi-card cr-kpi-card--active">
            <div class="cr-kpi-head">
                <div class="cr-kpi-icon cr-kpi-icon-green">
                    <i class="fa-solid fa-circle-check"></i>
                </div>
                <div class="cr-kpi-copy">
                    <span class="cr-kpi-label">Acceptes / Actifs</span>
                    <span class="cr-kpi-sub">Dossiers valides</span>
                </div>
            </div>
            <div class="cr-kpi-metric">
                <strong class="cr-kpi-value">{{ accepted_total }}</strong>
                <span class="cr-kpi-unit">credits</span>
            </div>
            <div class="cr-kpi-bar"><span style="width:{{ items|length > 0 ? ((accepted_total / items|length) * 100)|round : 0 }}%"></span></div>
        </div>
        <div class="cr-kpi-card cr-kpi-card--risk">
            <div class="cr-kpi-head">
                <div class="cr-kpi-icon cr-kpi-icon-red">
                    <i class="fa-solid fa-triangle-exclamation"></i>
                </div>
                <div class="cr-kpi-copy">
                    <span class="cr-kpi-label">Risque moyen</span>
                    <span class="cr-kpi-sub">Evaluation portefeuille</span>
                </div>
            </div>
            <div class="cr-kpi-metric">
                <strong class="cr-kpi-value">{{ average_risk }}</strong>
                <span class="cr-kpi-unit">/100</span>
            </div>
            <div class="cr-kpi-bar"><span class="is-danger" style="width:{{ average_risk > 100 ? 100 : average_risk }}%"></span></div>
        </div>
    </div>
    {#  MAIN SPLIT LAYOUT #}
    <div class="cr-tools-overlay" id="cr-tools-overlay" hidden></div>
    <section class="cr-tools-modal" id="cr-tools-modal" hidden role="dialog" aria-modal="true" aria-labelledby="cr-tools-title">
        <header class="cr-tools-header">
            <div>
                <h3 id="cr-tools-title">Historique des credits</h3>
                <p id="cr-tools-subtitle">Consultez rapidement l historique complet de vos credits.</p>
            </div>
            <button class="cr-tools-close" id="cr-tools-close" type="button" aria-label="Fermer">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </header>

        <div class="cr-tools-body">
            <section class="cr-tool-panel is-active" data-tool-panel="history">
                {% if items|length > 0 %}
                    <div class="cr-tool-table-wrap">
                        <table class="cr-tool-table">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Type</th>
                                    <th>Montant</th>
                                    <th>Mensualite</th>
                                    <th>Statut</th>
                                    <th>Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for item in items %}
                                    <tr>
                                        <td>#{{ item.idCredit }}</td>
                                        <td>{{ item.typeCredit|default('-') }}</td>
                                        <td>{{ item.montantDemande|default(0)|number_format(2, '.', ' ') }} DT</td>
                                        <td>{{ item.mensualite|default(0)|number_format(2, '.', ' ') }} DT</td>
                                        <td>{{ item.statut|default('-') }}</td>
                                        <td>{{ item.dateDemande|default('-') }}</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% else %}
                    <div class="cr-tool-empty">Aucun historique credit disponible.</div>
                {% endif %}
            </section>

            <section class="cr-tool-panel" data-tool-panel="assistant">
                <div class="cr-assistant-shell">
                    <aside class="cr-assistant-side">
                        <span class="cr-assistant-side-badge" id="cr-assistant-side-badge">Analyse IA Credit & Garantie</span>
                        <h4 id="cr-assistant-side-title">Analyse IA Credit & Garantie</h4>
                        <p id="cr-assistant-side-subtitle">Intelligence decisionnelle bancaire: selectionnez un dossier puis lancez une action rapide.</p>

                        <div class="cr-assistant-quick" id="cr-assistant-quick">
                            <button type="button" class="cr-assistant-quick-btn" data-assistant-intent="simulation" data-assistant-prompt="Simuler un credit sur ce dossier.">
                                <i class="fa-solid fa-calculator"></i>
                                <span id="cr-assistant-q-simulation">Simulation credit</span>
                            </button>
                            <button type="button" class="cr-assistant-quick-btn" data-assistant-intent="comparison" data-assistant-prompt="Comparer les offres disponibles pour ce dossier.">
                                <i class="fa-solid fa-code-compare"></i>
                                <span id="cr-assistant-q-comparison">Comparer offres</span>
                            </button>
                            <button type="button" class="cr-assistant-quick-btn" data-assistant-intent="summary" data-assistant-prompt="Resume dossier">
                                <i class="fa-solid fa-chart-line"></i>
                                <span id="cr-assistant-q-summary">Resume dossier</span>
                            </button>
                            <button type="button" class="cr-assistant-quick-btn" data-assistant-intent="risk" data-assistant-prompt="Analyse risque">
                                <i class="fa-solid fa-gauge-high"></i>
                                <span id="cr-assistant-q-risk">Analyse risque</span>
                            </button>
                            <button type="button" class="cr-assistant-quick-btn" data-assistant-intent="garantie_check" data-assistant-prompt="Verifier garantie">
                                <i class="fa-solid fa-shield-halved"></i>
                                <span id="cr-assistant-q-garanties">Verifier garantie</span>
                            </button>
                            <button type="button" class="cr-assistant-quick-btn" data-assistant-intent="eligibility" data-assistant-prompt="Explique mon eligibilite au credit.">
                                <i class="fa-solid fa-list-check"></i>
                                <span id="cr-assistant-q-eligibility">Eligibilite</span>
                            </button>
                            <button type="button" class="cr-assistant-quick-btn" data-assistant-intent="guidance" data-assistant-prompt="Guide moi et donne les prochaines etapes pour finaliser mon credit.">
                                <i class="fa-solid fa-route"></i>
                                <span id="cr-assistant-q-guidance">Guidage</span>
                            </button>
                            <button type="button" class="cr-assistant-quick-btn" data-assistant-intent="projection" data-assistant-prompt="Projection future">
                                <i class="fa-solid fa-chart-column"></i>
                                <span id="cr-assistant-q-projection">Projection future</span>
                            </button>
                            <button type="button" class="cr-assistant-quick-btn" data-assistant-intent="message_client" data-assistant-prompt="Generer un message client clair.">
                                <i class="fa-solid fa-envelope-open-text"></i>
                                <span id="cr-assistant-q-message">Message client</span>
                            </button>
                            <button type="button" class="cr-assistant-quick-btn" data-assistant-intent="decision" data-assistant-prompt="Donne une decision automatique sur mon dossier.">
                                <i class="fa-solid fa-scale-balanced"></i>
                                <span id="cr-assistant-q-decision">Decision recommandee</span>
                            </button>
                        </div>

                        <div class="cr-assistant-targets">
                            <label class="cr-assistant-target-field" for="cr-assistant-credit-select">
                                <span id="cr-assistant-credit-label">Selectionner un credit</span>
                                <select id="cr-assistant-credit-select">
                                    <option value="" data-assistant-credit-auto>Contexte automatique</option>
                                    {% for item in items %}
                                        <option
                                            value="{{ item.idCredit }}"
                                            data-credit-option
                                            data-credit-id="{{ item.idCredit }}"
                                            data-credit-garantie-id="{{ item.idGarantie|default('') }}"
                                            data-credit-type="{{ item.typeCredit|default('Credit')|e('html_attr') }}"
                                            data-credit-amount="{{ item.montantDemande|default(0) }}"
                                        >
                                            #{{ item.idCredit }} - {{ item.typeCredit|default('Credit') }} - {{ item.montantDemande|default(0)|number_format(0, '.', ' ') }} DT
                                        </option>
                                    {% endfor %}
                                </select>
                            </label>

                            <label class="cr-assistant-target-field" for="cr-assistant-garantie-select">
                                <span id="cr-assistant-garantie-label">Selectionner une garantie</span>
                                <select id="cr-assistant-garantie-select">
                                    <option value="" data-assistant-garantie-auto>Aucune garantie imposee</option>
                                    {% for garantie in garanties %}
                                        <option
                                            value="{{ garantie.idGarantie }}"
                                            data-garantie-option
                                            data-garantie-id="{{ garantie.idGarantie }}"
                                            data-garantie-credit-id="{{ garantie.idCredit|default('') }}"
                                            data-garantie-type-value="{{ garantie.typeGarantieValue|default(garantie.typeGarantie|default(''))|e('html_attr') }}"
                                            data-garantie-type="{{ garantie.typeGarantie|default('Garantie')|e('html_attr') }}"
                                            data-garantie-retained="{{ garantie.valeurRetenue|default(0) }}"
                                        >
                                            #{{ garantie.idGarantie }} - {{ garantie.typeGarantie|default('Garantie') }} - {{ garantie.valeurRetenue|default(0)|number_format(0, '.', ' ') }} DT
                                        </option>
                                    {% endfor %}
                                </select>
                            </label>
                        </div>

                        <div class="cr-assistant-context">
                            <div class="cr-assistant-context-item">
                                <span>Credits</span>
                                <strong>{{ items|length }}</strong>
                            </div>
                            <div class="cr-assistant-context-item">
                                <span>Garanties</span>
                                <strong>{{ garanties|length }}</strong>
                            </div>
                            <div class="cr-assistant-context-item">
                                <span>Risque moyen</span>
                                <strong>{{ average_risk }}/100</strong>
                            </div>
                        </div>
                    </aside>

                    <div class="cr-assistant-main">
                        <div class="cr-assistant-thread" id="cr-assistant-thread" aria-live="polite"></div>

                        <div class="cr-assistant-projection-box" id="cr-assistant-projection-box" hidden>
                            <form class="cr-assistant-projection-form" id="cr-assistant-projection-form">
                                <div class="cr-assistant-projection-grid">
                                    <label class="cr-assistant-projection-field">
                                        <span id="cr-assistant-proj-duration-label">Duree</span>
                                        <select id="cr-assistant-proj-duration">
                                            <option value="6">6 mois</option>
                                            <option value="12" selected>12 mois</option>
                                            <option value="24">24 mois</option>
                                        </select>
                                    </label>
                                    <label class="cr-assistant-projection-field">
                                        <span id="cr-assistant-proj-salary-label">Changement salaire (DT)</span>
                                        <input id="cr-assistant-proj-salary-change" type="number" step="10" value="0">
                                    </label>
                                    <label class="cr-assistant-projection-field">
                                        <span id="cr-assistant-proj-early-label">Remboursement anticipe (DT)</span>
                                        <input id="cr-assistant-proj-early" type="number" step="10" value="0">
                                    </label>
                                </div>
                                <div class="cr-assistant-projection-actions">
                                    <button type="submit" class="cr-assistant-proj-submit" id="cr-assistant-proj-submit">
                                        <i class="fa-solid fa-wave-square"></i>
                                        <span id="cr-assistant-proj-submit-label">Calculer projection</span>
                                    </button>
                                </div>
                            </form>
                            <div class="cr-assistant-projection-result" id="cr-assistant-projection-result" hidden>
                                <div class="cr-assistant-projection-metrics" id="cr-assistant-projection-metrics"></div>
                                <div class="cr-assistant-projection-conclusion" id="cr-assistant-projection-conclusion"></div>
                                <div class="cr-assistant-projection-charts">
                                    <div class="cr-assistant-projection-chart-card">
                                        <h5 id="cr-assistant-proj-remaining-title">Evolution du reste a payer</h5>
                                        <svg id="cr-assistant-proj-remaining-chart" viewBox="0 0 540 180" role="img" aria-label="Evolution du reste a payer"></svg>
                                    </div>
                                    <div class="cr-assistant-projection-chart-card">
                                        <h5 id="cr-assistant-proj-score-title">Evolution du score credit</h5>
                                        <svg id="cr-assistant-proj-score-chart" viewBox="0 0 540 180" role="img" aria-label="Evolution du score credit"></svg>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <form class="cr-assistant-form" id="cr-assistant-form">
                            <label class="cr-assistant-input-wrap" for="cr-assistant-input">
                                <textarea id="cr-assistant-input" rows="3" placeholder="Exemple : simule un credit auto de 30 000 DT sur 48 mois."></textarea>
                            </label>
                            <div class="cr-assistant-form-row">
                                <span class="cr-assistant-status" id="cr-assistant-status" hidden></span>
                                <button type="submit" class="cr-assistant-send-btn" id="cr-assistant-send-btn">
                                    <i class="fa-solid fa-paper-plane"></i>
                                    <span id="cr-assistant-send-label">Envoyer</span>
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </section>
            
            <section class="cr-tool-panel" data-tool-panel="simulate">
                <style>
                    .sim-grid { display: grid; grid-template-columns: 1fr 2fr; gap: 1.5rem; }
                    .sim-card { background: var(--cr-bg-card, #fefefe); padding: 1.5rem; border-radius: 12px; border: 1px solid var(--cr-border, #eaeaea); }
                    .sim-val { font-size: 1.8rem; font-weight: 700; color: var(--cr-primary, #4f46e5); }
                    .sim-val.risk { color: var(--cr-error, #ef4444); }
                    @media (max-width: 768px) { .sim-grid { grid-template-columns: 1fr; } }
                    .proj-bar { width: 100%; border-radius: 4px 4px 0 0; position: relative; transition: height 0.3s ease; }
                    .proj-bar-wrap { flex: 1; display: flex; flex-direction: column; justify-content: flex-end; align-items: center; gap: 5px; height: 100%; }
                    .proj-bar span { font-size: 0.7rem; color: #666; text-align: center; }
                </style>
                <div class="sim-grid">
                    <div class="sim-card">
