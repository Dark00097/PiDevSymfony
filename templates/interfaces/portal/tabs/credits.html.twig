<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
(() => {
  'use strict';

  const ready = (fn) => {
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', fn);
    } else {
      fn();
    }
  };

  ready(() => {
    const root = document.querySelector('.cr-root') || document;

    /* √Ę‚ÄĚ‚ā¨√Ę‚ÄĚ‚ā¨ helpers √Ę‚ÄĚ‚ā¨√Ę‚ÄĚ‚ā¨ */
    const $  = (sel, ctx = root) => ctx.querySelector(sel);
    const $$ = (sel, ctx = root) => Array.from(ctx.querySelectorAll(sel));
    const parseNum = (v) => {
      const normalized = String(v ?? '')
        .replace(/\s+/g, '')
        .replace(',', '.')
        .trim();
      const n = Number(normalized);
      return isFinite(n) ? n : 0;
    };
    const formatDecimalDisplay = (value, decimals = 2) => Number.isFinite(value) && value > 0
      ? value.toFixed(decimals)
      : '';
    const normalizeDecimalInputValue = (field) => {
      if (!(field instanceof HTMLInputElement)) {
        return;
      }

      const normalized = String(field.value ?? '')
        .replace(/\s+/g, '')
        .replace(',', '.')
        .trim();

      if (field.value !== normalized) {
        field.value = normalized;
      }
    };
    const fmtNum = (n, dec = 2) => n.toLocaleString('fr-TN', { minimumFractionDigits: dec, maximumFractionDigits: dec });
    const normalizeSearchValue = (value) => String(value ?? '')
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '')
      .toLowerCase()
      .replace(/\s+/g, ' ')
      .trim();
    const matchesSearchTokens = (searchText, query) => {
      const normalizedQuery = normalizeSearchValue(query);
      if (normalizedQuery === '') {
        return true;
      }

      const haystack = normalizeSearchValue(searchText);
      return normalizedQuery.split(' ').every((token) => haystack.includes(token));
    };
    const creditsLanguageCatalog = {
      fr: {
        chooseLanguage: 'Choisir la langue',
        refresh: 'Actualiser',
        heroTitle: 'Gestion des credits',
        heroSubtitle: 'Demandez des prets, gerez vos credits et suivez les remboursements',
        totalFiles: 'Total dossiers',
        thisMonth: 'Ce mois',
        pending: 'En attente',
        history: 'Historique',
        assistant: 'Assistant IA',
        newCredit: 'Nouveau credit',
        generateAi: 'Generer par IA',
