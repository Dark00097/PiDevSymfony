.cr-topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  padding: 0 28px;
  height: 60px;
  background: #fff;
  border-bottom: 1px solid #dde8f5;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2px 12px rgba(10,37,64,.06);
}

.cr-topbar-left {
  display: flex;
  align-items: center;
  gap: 16px;
}

.cr-topbar-logo {
  display: flex;
  align-items: center;
  gap: 9px;
  font-size: 15px;
  font-weight: 900;
  color: #0a2540;
  letter-spacing: -0.3px;
}

.cr-topbar-logo i {
  font-size: 18px;
  color: #1565c0;
}

.cr-topbar-divider {
  width: 1px;
  height: 22px;
  background: #dde8f5;
}

.cr-breadcrumb {
  display: flex;
  align-items: center;
  gap: 7px;
  font-size: 12px;
  color: rgba(255, 255, 255, 0.75);
}

.cr-breadcrumb i:first-child { color: #fff; }
.cr-bc-sep { font-size: 9px; color: rgba(255, 255, 255, 0.42); }
.cr-bc-active { color: #fff; font-weight: 700; }

.cr-topbar-right {
  display: flex;
  align-items: center;
  gap: 10px;
}

.cr-lang-select {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  min-width: 132px;
  background: rgba(20, 53, 82, 0.48);
  border: 1px solid rgba(255, 255, 255, 0.22);
  border-radius: 14px;
  padding: 0 14px;
  height: 46px;
  cursor: pointer;
  position: relative;
  box-shadow: inset 0 1px 0 rgba(255,255,255,.08);
}

.cr-lang-select i { font-size: 15px; color: rgba(255, 255, 255, 0.9); }

.cr-lang-value {
  flex: 1;
  min-width: 0;
  padding-right: 22px;
  font-size: 14px;
  font-weight: 700;
  color: #fff;
  white-space: nowrap;
  pointer-events: none;
}

.cr-lang-select select {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  margin: 0;
  border: none;
  background: transparent;
  font: inherit;
  color: transparent;
  opacity: 0.01;
  cursor: pointer;
  outline: none;
  appearance: none;
}

.cr-lang-select select option {
  color: #0a2540;
  background: #ffffff;
}

.cr-lang-chevron {
  position: absolute;
  right: 14px;
  top: 50%;
  transform: translateY(-50%);
  font-size: 11px;
  pointer-events: none;
}

.cr-lang-select:focus-within {
  border-color: rgba(255, 255, 255, 0.58);
  box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.16), inset 0 1px 0 rgba(255,255,255,.08);
}

.cr-visually-hidden {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}

.cr-topbar-btn {
  width: 36px;
  height: 36px;
  border-radius: 10px;
  border: 1px solid rgba(255, 255, 255, 0.22);
  background: rgba(255, 255, 255, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 13px;
  cursor: pointer;
  text-decoration: none;
  transition: background .15s, color .15s;
}

.cr-topbar-btn:hover { background: rgba(255, 255, 255, 0.24); color: #fff; }

.cr-user-chip {
  display: flex;
  align-items: center;
  gap: 9px;
  padding: 4px 12px 4px 4px;
  border: 1px solid rgba(255, 255, 255, 0.22);
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.12);
}

.cr-user-avatar {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: linear-gradient(135deg, #1565c0, #00bcd4);
  color: #fff;
  font-size: 10px;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cr-user-info strong {
  display: block;
  font-size: 12px;
  font-weight: 700;
  color: #fff;
  line-height: 1.2;
}

.cr-user-info small {
  display: block;
  font-size: 10px;
  color: rgba(255, 255, 255, 0.7);
}

/* √Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź
   PAGE HEADER
   √Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź */
.cr-page-header {
  background: #fff;
  border-bottom: 1px solid #dde8f5;
  padding: 22px 28px;
}

.cr-page-header-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20px;
  max-width: 1600px;
}

.cr-page-header-left {
  display: flex;
  align-items: center;
  gap: 16px;
}

.cr-page-icon-ring {
  width: 52px;
  height: 52px;
  border-radius: 16px;
  background: linear-gradient(135deg, #1565c0 0%, #00bcd4 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 20px;
  box-shadow: 0 8px 24px rgba(21,101,192,.25);
  flex-shrink: 0;
}

.cr-page-title {
  font-size: clamp(20px,2vw,28px);
  font-weight: 900;
  color: #0a2540;
  letter-spacing: -0.4px;
  line-height: 1.1;
}

.cr-page-sub {
  font-size: 13px;
  color: #7294ae;
  margin-top: 4px;
}

.cr-page-header-actions {
  display: flex;
  align-items: center;
  gap: 10px;
}

.cr-hdr-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  min-height: 42px;
  padding: 0 20px;
  border-radius: 12px;
  font: inherit;
  font-size: 13px;
  font-weight: 700;
  cursor: pointer;
  text-decoration: none;
  border: none;
  transition: all .18s;
}

.cr-hdr-btn-outline {
  background: transparent;
  border: 1.5px solid #c4d9ee;
  color: #1565c0;
}

.cr-hdr-btn-outline:hover { background: #eaf2fd; }

.cr-hdr-btn-primary {
  background: linear-gradient(120deg, #1565c0, #1e88e5);
  color: #fff;
  box-shadow: 0 6px 18px rgba(21,101,192,.28);
}

.cr-hdr-btn-primary:hover { box-shadow: 0 8px 24px rgba(21,101,192,.38); opacity: .93; }

/* √Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź
   KPI STRIP
   √Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź√Ę‚ÄĘ¬ź */
.cr-kpi-strip {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14px;
  padding: 0;
  background: transparent;
}

.cr-kpi-card {
  display: flex;
  flex-direction: column;
  gap: 12px;
  background: #fff;
  border-radius: 16px;
  padding: 16px 18px 12px;
  border: 1px solid #dde8f5;
  box-shadow: 0 6px 20px rgba(23, 54, 84, 0.07);
  position: relative;
  overflow: hidden;
  transition: box-shadow .2s, transform .2s;
}

.cr-kpi-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3px;
  border-radius: 16px 16px 0 0;
}

.cr-kpi-card--amount::before { background: linear-gradient(90deg, #14b8a6, #0f766e); }
.cr-kpi-card--monthly::before { background: linear-gradient(90deg, #2563eb, #1d4ed8); }
.cr-kpi-card--active::before { background: linear-gradient(90deg, #16a34a, #22c55e); }
.cr-kpi-card--risk::before { background: linear-gradient(90deg, #ef4444, #dc2626); }

.cr-kpi-card:hover {
  box-shadow: 0 8px 24px rgba(10,37,64,.10);
  transform: translateY(-2px);
}

.cr-kpi-head {
  display: flex;
  align-items: center;
  gap: 10px;
}

.cr-kpi-icon {
  width: 44px;
  height: 44px;
  border-radius: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  color: #fff;
  flex-shrink: 0;
}

.cr-kpi-icon-blue  { background: linear-gradient(135deg, #1565c0, #1e88e5); }
.cr-kpi-icon-amber { background: linear-gradient(135deg, #f59e0b, #fbbf24); }
.cr-kpi-icon-green { background: linear-gradient(135deg, #16a34a, #22c55e); }
.cr-kpi-icon-red   { background: linear-gradient(135deg, #dc2626, #f87171); }
.cr-kpi-icon-teal  { background: linear-gradient(135deg, #0097a7, #00bcd4); }

.cr-kpi-copy {
  display: flex;
  flex-direction: column;
  gap: 2px;
  z-index: 1;
}

.cr-kpi-metric {
  display: flex;
  align-items: baseline;
  gap: 4px;
}

.cr-kpi-value {
  font-size: clamp(20px, 1.8vw, 28px);
  font-weight: 900;
  color: #0a2540;
  line-height: 1;
  letter-spacing: -0.3px;
}

.cr-kpi-unit {
  font-size: 12px;
  font-weight: 700;
  color: #7294ae;
}

.cr-kpi-label {
  font-size: 10px;
  color: #5d7d97;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

.cr-kpi-sub {
  font-size: 11px;
  color: #94aec2;
}

.cr-kpi-bar {
  height: 6px;
  border-radius: 999px;
  background: #e8eef5;
  overflow: hidden;
}

.cr-kpi-bar span {
  display: block;
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #14b8a6, #0f766e);
}

.cr-restruct-overlay {
  position: fixed;
  inset: 0;
  background: rgba(10, 37, 64, 0.56);
  backdrop-filter: blur(4px);
  z-index: 87;
}

.cr-restruct-modal {
  position: fixed;
  top: 50%;
  left: 50%;
  width: min(980px, calc(100vw - 28px));
  max-height: calc(100vh - 32px);
  transform: translate(-50%, -50%);
  border-radius: 28px;
  border: 1px solid #d7e5f5;
  background: linear-gradient(180deg, #f8fbff, #ffffff);
  box-shadow: 0 30px 70px rgba(10, 37, 64, .28);
  overflow: hidden;
  z-index: 88;
  animation: crRestructIn .22s ease;
}

.cr-restruct-overlay[hidden],
.cr-restruct-modal[hidden] {
  display: none !important;
}

.cr-restruct-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14px;
  padding: 22px 24px 18px;
  color: #fff;
  background: linear-gradient(135deg, #12325d, #1565c0 62%, #4f46e5);
}

.cr-restruct-header h3 {
  margin: 0;
  font-size: 24px;
  font-weight: 900;
}

.cr-restruct-header p {
  margin: 6px 0 0;
  color: rgba(255,255,255,.82);
  font-size: 13px;
}

.cr-restruct-close,
.cr-restruct-dismiss {
  border: none;
  cursor: pointer;
  transition: all .18s ease;
}

.cr-restruct-close {
  width: 42px;
  height: 42px;
  border-radius: 14px;
  border: 1px solid rgba(255,255,255,.22);
  background: rgba(255,255,255,.12);
  color: #fff;
  font-size: 16px;
}

.cr-restruct-close:hover {
  background: rgba(255,255,255,.22);
}

.cr-restruct-body {
  padding: 22px 24px 18px;
  overflow-y: auto;
  max-height: calc(100vh - 190px);
  display: grid;
  gap: 16px;
}

.cr-restruct-alert {
  border-radius: 18px;
  border: 1px solid #fecaca;
  background: linear-gradient(180deg, #fff4f4, #fffafa);
  padding: 16px 18px;
  color: #b91c1c;
}

.cr-restruct-alert strong {
  display: block;
  font-size: 16px;
  font-weight: 900;
}

.cr-restruct-alert-grid {
  margin-top: 12px;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12px;
}

.cr-restruct-alert-item {
  padding: 12px 14px;
  border-radius: 14px;
  background: rgba(255,255,255,.65);
  border: 1px solid #fee2e2;
}

.cr-restruct-alert-item span {
  display: block;
  font-size: 11px;
  font-weight: 800;
  color: #b45309;
  margin-bottom: 5px;
  text-transform: uppercase;
  letter-spacing: .05em;
}

.cr-restruct-alert-item strong {
  font-size: 15px;
  color: #7f1d1d;
}

.cr-restruct-empty {
  padding: 26px 20px;
  text-align: center;
  border-radius: 18px;
  border: 1px dashed #c9d9ec;
  background: #f8fbff;
  color: #557390;
}

.cr-restruct-empty i {
  font-size: 24px;
  color: #1565c0;
  margin-bottom: 10px;
}

.cr-restruct-options {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14px;
}

.cr-restruct-option {
  border-radius: 20px;
  border: 1px solid #dbe7f5;
  background: #fff;
  padding: 18px 16px;
  box-shadow: 0 10px 30px rgba(10, 37, 64, .06);
  display: grid;
  gap: 12px;
}

.cr-restruct-option.is-blue { border-top: 4px solid #2563eb; }
.cr-restruct-option.is-green { border-top: 4px solid #16a34a; }
.cr-restruct-option.is-violet { border-top: 4px solid #7c3aed; }

.cr-restruct-option.is-selected {
  border-color: #c4b5fd;
  box-shadow: 0 20px 45px rgba(124, 58, 237, .16);
}

.cr-restruct-option h4 {
  margin: 0;
  font-size: 16px;
  font-weight: 900;
  color: #0a2540;
}

.cr-restruct-option p {
  margin: 0;
  font-size: 13px;
  line-height: 1.6;
  color: #52708c;
}

.cr-restruct-option-shift {
  padding: 12px 14px;
  border-radius: 14px;
  background: #f8fbff;
  border: 1px solid #e5eef8;
}

.cr-restruct-option-shift span {
  display: block;
  font-size: 11px;
  font-weight: 800;
  color: #6f88a1;
  margin-bottom: 4px;
}

.cr-restruct-option-shift strong {
  display: block;
  font-size: 15px;
  font-weight: 900;
  color: #0a2540;
}

.cr-restruct-option-meta {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10px;
}

.cr-restruct-option-meta div {
  padding: 10px 12px;
  border-radius: 12px;
  background: #fdfefe;
  border: 1px solid #e4edf7;
}

.cr-restruct-option-meta span {
  display: block;
  font-size: 11px;
  font-weight: 800;
  color: #7290aa;
  margin-bottom: 4px;
}

.cr-restruct-option-meta strong {
  display: block;
  font-size: 14px;
  font-weight: 900;
  color: #0a2540;
}

.cr-restruct-option-apply {
  min-height: 42px;
  border-radius: 14px;
  border: none;
  font: inherit;
  font-size: 13px;
  font-weight: 800;
  color: #fff;
  cursor: pointer;
}

.cr-restruct-option.is-blue .cr-restruct-option-apply { background: linear-gradient(120deg, #2563eb, #1d4ed8); }
.cr-restruct-option.is-green .cr-restruct-option-apply { background: linear-gradient(120deg, #16a34a, #22c55e); }
.cr-restruct-option.is-violet .cr-restruct-option-apply { background: linear-gradient(120deg, #7c3aed, #8b5cf6); }

.cr-restruct-option-apply.is-applied {
  opacity: .78;
  cursor: default;
  box-shadow: none;
}

.cr-restruct-apply-state {
  padding: 12px 14px;
  border-radius: 14px;
  background: #eefbf2;
  border: 1px solid #bbf7d0;
  color: #166534;
  font-size: 13px;
  font-weight: 800;
}

.cr-restruct-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14px;
  padding: 16px 24px 22px;
  border-top: 1px solid #e6eef7;
  background: #fff;
}

.cr-restruct-footer p {
  margin: 0;
  font-size: 12px;
  line-height: 1.6;
  color: #617e98;
}

.cr-restruct-dismiss {
  min-width: 120px;
  min-height: 42px;
  border-radius: 14px;
  background: #eef4fb;
  color: #244e7a;
  font: inherit;
  font-size: 13px;
  font-weight: 800;
}

.cr-restruct-dismiss:hover {
  background: #dfeaf7;
}

@keyframes crRestructIn {
  from {
    opacity: 0;
    transform: translate(-50%, -48%);
  }
  to {
    opacity: 1;
    transform: translate(-50%, -50%);
  }
}

.cr-pay-overlay {
  position: fixed;
  inset: 0;
  background: rgba(10, 37, 64, 0.46);
  backdrop-filter: blur(3px);
  z-index: 89;
}

.cr-pay-modal {
  position: fixed;
  top: 50%;
  left: 50%;
  width: min(920px, calc(100vw - 28px));
  max-height: calc(100vh - 36px);
  transform: translate(-50%, -50%);
  background: #f8fbff;
  border: 1px solid #d8e7f6;
  border-radius: 26px;
  box-shadow: 0 22px 60px rgba(10, 37, 64, 0.22);
  z-index: 90;
  overflow: hidden;
}

.cr-pay-overlay[hidden],
.cr-pay-modal[hidden] {
  display: none !important;
}

.cr-pay-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14px;
  padding: 22px 24px 18px;
  color: #fff;
  background: linear-gradient(135deg, #12325d, #1565c0 60%, #00acc1);
}

.cr-pay-header h3 {
  margin: 0;
  font-size: 25px;
  font-weight: 900;
}

.cr-pay-header p {
  margin: 6px 0 0;
  color: rgba(255,255,255,.82);
  font-size: 13px;
}

.cr-pay-close {
  width: 42px;
  height: 42px;
  border-radius: 14px;
  border: 1px solid rgba(255,255,255,.22);
  background: rgba(255,255,255,.12);
  color: #fff;
  font-size: 16px;
  cursor: pointer;
  transition: background .18s ease, transform .18s ease;
}

.cr-pay-close:hover {
  background: rgba(255,255,255,.2);
  transform: translateY(-1px);
}

.cr-pay-body {
  padding: 22px 24px 24px;
  display: flex;
  flex-direction: column;
  gap: 16px;
  overflow-y: auto;
  max-height: calc(100vh - 150px);
}

.cr-pay-summary {
  background: #fff;
  border: 1px solid #deebf7;
  border-radius: 20px;
  padding: 18px 20px;
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.cr-pay-summary-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  flex-wrap: wrap;
}

.cr-pay-summary-main strong {
  font-size: 20px;
  color: #0a2540;
  font-weight: 900;
}

.cr-pay-status-chip,
.cr-pay-otp-state,
.cr-pay-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 32px;
  padding: 0 12px;
  border-radius: 999px;
  font-size: 12px;
  font-weight: 800;
}

.cr-pay-status-chip {
  background: #fef3c7;
  color: #92400e;
}

.cr-pay-otp-state {
  background: #fff7ed;
  color: #c2410c;
  border: 1px solid #fed7aa;
}

.cr-pay-otp-state.is-verified {
  background: #dcfce7;
  color: #166534;
  border-color: #bbf7d0;
}

.cr-pay-badge {
  background: #e0f2fe;
  color: #0369a1;
}

.cr-pay-summary-grid,
.cr-pay-main-grid,
.cr-pay-grid {
  display: grid;
  gap: 14px;
}

.cr-pay-steps {
  display: flex;
  align-items: center;
  gap: 0;
  padding: 2px 2px 6px;
}

.cr-pay-step-item {
  display: flex;
  align-items: center;
  gap: 8px;
  opacity: .45;
  transition: opacity .2s ease;
}

.cr-pay-step-item.is-active,
.cr-pay-step-item.is-done {
  opacity: 1;
}

.cr-pay-step-dot {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  border: 2px solid #b7cde5;
  color: #7b95ad;
  background: #fff;
  font-size: 12px;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cr-pay-step-item.is-active .cr-pay-step-dot {
  background: #1565c0;
  border-color: #1565c0;
  color: #fff;
}

.cr-pay-step-item.is-done .cr-pay-step-dot {
  background: #00bcd4;
  border-color: #00bcd4;
  color: #fff;
}

.cr-pay-step-item span {
  font-size: 12px;
  font-weight: 800;
  color: #5a7a98;
  white-space: nowrap;
}

.cr-pay-step-item.is-active span {
  color: #0a2540;
}

.cr-pay-step-line {
  flex: 1;
  height: 1px;
  margin: 0 10px;
  background: #d7e6f5;
}

.cr-pay-step-body[hidden] {
  display: none !important;
}

.cr-pay-summary-grid,
.cr-pay-main-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.cr-pay-summary-item {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.cr-pay-summary-key {
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: #7b95ad;
  font-weight: 800;
}

.cr-pay-summary-item strong {
  font-size: 22px;
  color: #0a2540;
}

.cr-pay-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.cr-pay-card,
.cr-pay-main-form {
  background: #fff;
  border: 1px solid #deebf7;
  border-radius: 20px;
  box-shadow: 0 10px 24px rgba(21, 101, 192, 0.08);
}

.cr-pay-card {
  padding: 18px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.cr-pay-card-head h4,
.cr-pay-main-head h4 {
  margin: 0;
  color: #0a2540;
  font-size: 17px;
  font-weight: 800;
}

.cr-pay-card-head p,
.cr-pay-main-head p,
.cr-pay-note {
  margin: 4px 0 0;
  color: #6b879f;
  font-size: 12px;
  line-height: 1.5;
}

.cr-pay-field {
  display: flex;
  flex-direction: column;
  gap: 7px;
}

.cr-pay-field span {
  font-size: 12px;
  font-weight: 700;
  color: #416684;
}

.cr-pay-field input,
.cr-pay-field select {
  min-height: 46px;
  padding: 0 14px;
  border-radius: 14px;
  border: 1px solid #c7dbef;
  background: #f8fbff;
  color: #0a2540;
  font: inherit;
}

.cr-pay-field input:focus,
.cr-pay-field select:focus {
  outline: none;
  border-color: #1565c0;
  box-shadow: 0 0 0 3px rgba(21, 101, 192, 0.12);
}

.cr-pay-secondary-btn,
.cr-pay-primary-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  min-height: 46px;
  border-radius: 14px;
  font: inherit;
  font-weight: 800;
  cursor: pointer;
  transition: transform .18s ease, opacity .18s ease, background .18s ease;
}

.cr-pay-secondary-btn {
  border: 1px solid #bfdbfe;
  background: #eff6ff;
  color: #1d4ed8;
}

.cr-pay-primary-btn {
  width: 100%;
  border: none;
  background: linear-gradient(135deg, #12325d, #1565c0);
  color: #fff;
}

.cr-pay-secondary-btn:hover,
.cr-pay-primary-btn:hover {
  transform: translateY(-1px);
}

.cr-pay-primary-btn:disabled {
  cursor: not-allowed;
  opacity: .55;
  transform: none;
}

.cr-pay-main-form {
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.cr-pay-main-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
  flex-wrap: wrap;
}

.cr-pay-note {
  margin: 0;
  padding: 11px 13px;
  border-radius: 14px;
  background: #f0f9ff;
  border: 1px solid #bae6fd;
  color: #075985;
}

@media (max-width: 760px) {
  .cr-pay-modal {
    width: calc(100vw - 16px);
    max-height: calc(100vh - 16px);
  }

  .cr-pay-body {
    padding: 16px;
    max-height: calc(100vh - 120px);
  }

  .cr-pay-grid,
  .cr-pay-main-grid,
  .cr-pay-summary-grid {
    grid-template-columns: 1fr;
  }
}

.cr-kpi-bar span.is-danger {
  background: linear-gradient(90deg, #ef4444, #dc2626);
}

