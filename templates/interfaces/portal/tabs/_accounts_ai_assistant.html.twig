.acc-pred-alert.danger{background:linear-gradient(135deg,#fef2f2,#fee2e2);border-color:#fecaca}
.acc-pred-alert.info{background:linear-gradient(135deg,#eff6ff,#dbeafe);border-color:#bfdbfe}
.acc-pred-income-list{display:flex;flex-direction:column;gap:10px;margin-top:14px}
