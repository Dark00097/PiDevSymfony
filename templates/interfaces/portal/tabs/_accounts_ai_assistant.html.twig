{% set assistant_base_query = query_state|merge({ assistant: '1' }) %}
{% set assistant_home_link = path(route_name, assistant_base_query) %}
{% set assistant_wheel_link = path(route_name, assistant_base_query|merge({ show_wheel: '1' })) %}
{% set assistant_surplus_link = path(route_name, assistant_base_query|merge({ show_surplus: '1' })) %}
{% set assistant_prediction_link = path(route_name, assistant_base_query|merge({ show_prediction: '1' })) %}
{% set assistant_back_link = path(route_name, query_state) %}
{% set active_module = wheel_view ? 'wheel' : (surplus_view ? 'surplus' : (prediction_view ? 'prediction' : 'assistant')) %}
{% set wheel_segments = wheel.segments|default([5, 10, 20, 15, 8, 12, 3, 7, 25, 2, 18, 6]) %}
{% set wheel_conditions = wheel.eligibility.conditions|default({}) %}
{% set failed_conditions = wheel.eligibility.failed_conditions|default([]) %}
{% set wheel_target = wheel.bonus_target|default(100) %}
{% set wheel_reward = wheel.reward_amount|default(50) %}
{% set wheel_points = wheel.total_points|default(0) %}
{% set wheel_progress = wheel_points > wheel_target ? wheel_target : wheel_points %}
{% set can_spin_now = wheel.can_spin|default(false) and not wheel_security.locked|default(false) %}
{% set all_vaults = support.vault_data|default([]) %}
{% set monthly_incomes = surplus.monthly_incomes|default([]) %}
{% set top_prediction_amount = 1 %}
{% for prediction_item in prediction.predictions|default([]) %}
    {% if prediction_item.predicted_amount|default(0) > top_prediction_amount %}
        {% set top_prediction_amount = prediction_item.predicted_amount|default(0) %}
    {% endif %}
{% endfor %}
{% set top_income_amount = 1 %}
{% for income_item in monthly_incomes %}
    {% if income_item.income|default(0) > top_income_amount %}
        {% set top_income_amount = income_item.income|default(0) %}
    {% endif %}
{% endfor %}
{% set surplus_ratio = surplus.average_income|default(0) > 0 ? ((surplus.current_income|default(0) * 100) / surplus.average_income) : 0 %}
{% set superplus_detected = surplus.show|default(false) %}
{% set superplus_display_amount = superplus_detected ? surplus.display_recommended_transfer|default(surplus.recommended_transfer|default(0)) : 0 %}
{% set prediction_status = prediction.projection_status|default('stable') %}
{% set prediction_badge_class = prediction_status == 'danger' ? 'danger' : (prediction_status == 'warning' ? 'warn' : 'ok') %}
{% set prediction_selected_account = prediction.selected_account|default(null) %}
{% set prediction_selected_account_id = prediction_selected_account ? prediction_selected_account.idCompte|default('') : '' %}
{% set assistant_goal_success_count = 0 %}
{% set assistant_goal_overdue_count = 0 %}
{% set assistant_today_key = 'now'|date('Y-m-d') %}
{% for vault in all_vaults %}
    {% set vault_goal_amount = vault.objectifMontant|default(0) + 0 %}
    {% set vault_current_amount = vault.montantActuel|default(0) + 0 %}
    {% set vault_progress_amount = vault_goal_amount > 0 ? ((vault_current_amount * 100) / vault_goal_amount) : 0 %}
    {% set vault_goal_date = vault.dateObjectifs|default('') %}
    {% if vault_goal_amount > 0 and vault_progress_amount >= 100 and (vault_goal_date == '' or vault_goal_date >= assistant_today_key) %}
        {% set assistant_goal_success_count = assistant_goal_success_count + 1 %}
    {% endif %}
    {% if vault_goal_amount > 0 and vault_goal_date != '' and vault_goal_date < assistant_today_key and vault_progress_amount < 100 %}
        {% set assistant_goal_overdue_count = assistant_goal_overdue_count + 1 %}
    {% endif %}
{% endfor %}
{% set assistant_goal_notification_count = assistant_goal_success_count + assistant_goal_overdue_count %}
{% if active_module == 'surplus' %}
    {% if superplus_detected %}
        {% set stage_top = '#e8f8f2' %}
        {% set stage_mid = '#d0f0e4' %}
        {% set stage_glow = 'rgba(20,184,166,.10)' %}
        {% set accent_color = '#0f766e' %}
        {% set button_to = '#14b8a6' %}
    {% else %}
        {% set stage_top = '#e8f8f2' %}
        {% set stage_mid = '#d0f0e4' %}
        {% set stage_glow = 'rgba(20,184,166,.10)' %}
        {% set accent_color = '#0f766e' %}
        {% set button_to = '#14b8a6' %}
    {% endif %}
{% else %}
    {% set stage_top = '#e8f8f2' %}
    {% set stage_mid = '#d0f0e4' %}
    {% set stage_glow = 'rgba(20,184,166,.10)' %}
    {% set accent_color = '#0f766e' %}
    {% set button_to = '#14b8a6' %}
{% endif %}

