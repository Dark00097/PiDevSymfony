<script>
(function () {
  'use strict';

  document.addEventListener('DOMContentLoaded', function () {
    initReveal();
    initCounters();
    initBars();
    initDatetime();
  });

  /* ── Scroll reveal ── */
  function initReveal() {
    var els = document.querySelectorAll('[data-cc-reveal]');
    var obs = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) {
          e.target.classList.add('cc-revealed');
          obs.unobserve(e.target);
        }
      });
    }, { threshold: 0.06 });
    els.forEach(function (el) { obs.observe(el); });
  }

  /* ── Count-up ── */
  function initCounters() {
    var els = document.querySelectorAll('.cc-count[data-target]');
    var obs = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (!e.isIntersecting) return;
        var el     = e.target;
        var target = parseFloat(el.dataset.target);
        var isFloat= target % 1 !== 0;
        var start  = null;
        var dur    = 1400;
        function tick(ts) {
          if (!start) start = ts;
          var p = Math.min((ts - start) / dur, 1);
          var eased = 1 - Math.pow(1 - p, 3);
          var val = eased * target;
          el.textContent = isFloat
            ? val.toFixed(2)
            : Math.floor(val).toLocaleString('fr-FR');
          if (p < 1) requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);
        obs.unobserve(el);
      });
    }, { threshold: 0.3 });
    els.forEach(function (el) { obs.observe(el); });
  }

  /* ── Bar animations ── */
  function initBars() {
    var bars = document.querySelectorAll('.cc-bar-inner, .cc-perf-bar-fill');
    var obs  = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) {
          var w = e.target.style.getPropertyValue('--w');
          e.target.style.width = w;
          obs.unobserve(e.target);
        }
      });
    }, { threshold: 0.2 });
    bars.forEach(function (b) {
      b.style.width = '0%';
      obs.observe(b);
    });
  }

  /* ── Live datetime ── */
  function initDatetime() {
    var el = document.getElementById('ccDatetime');
    if (!el) return;
    function render() {
      var now = new Date();
      var d = now.toLocaleDateString('fr-FR', {
        weekday: 'long', day: '2-digit', month: 'long', year: 'numeric'
      });
      var t = now.toLocaleTimeString('fr-FR', {
        hour: '2-digit', minute: '2-digit', second: '2-digit'
      });
      el.innerHTML =
        '<span class="cc-dt-date">' + d + '</span>' +
        '<span class="cc-dt-time">' + t + '</span>';
    }
    render();
    setInterval(render, 1000);
  }

})();
</script>