{# ============================================================
   NEXORA BANK · Dashboard · Command-Center Layout v2
   Structure: Dark hero → Mosaic KPIs → Split analytics →
              Data feed columns → Actions dock
   Colors: #0A2540 | #00B4A0 | #F8FBFF (unchanged)
============================================================ #}

{% set tx_list = summary.recent_transactions|default([]) %}
{% set credit_list = summary.recent_credits|default([]) %}
{% set tx_count = tx_list|length %}
{% set tx_total_amount = 0 %}
{% set tx_credit_amount = 0 %}
{% set tx_debit_amount = 0 %}
{% set tx_done_count = 0 %}
{% set category_totals = {} %}

{% for tx in tx_list %}
  {% set amount = tx.montant_value|default(0) + 0 %}
  {% set tx_total_amount = tx_total_amount + amount %}
  {% set tx_type = tx.typeTransaction|default('')|lower %}
  {% if 'debit' in tx_type %}
    {% set tx_debit_amount = tx_debit_amount + amount %}
  {% else %}
    {% set tx_credit_amount = tx_credit_amount + amount %}
  {% endif %}
  {% set tx_status = tx.statutTransaction|default('')|lower %}
  {% if 'term' in tx_status or 'valid' in tx_status or 'accept' in tx_status %}
    {% set tx_done_count = tx_done_count + 1 %}
  {% endif %}
  {% set tx_category = tx.categorie|default('Autre') %}
  {% set category_totals = category_totals|merge({
    (tx_category): (category_totals[tx_category]|default(0)) + amount
  }) %}
{% endfor %}

{% set tx_success_rate = tx_count > 0 ? (tx_done_count * 100 / tx_count) : 0 %}
{% set avg_ticket = tx_count > 0 ? (tx_total_amount / tx_count) : 0 %}
{% set cashback_pending = summary.cashback_pending|default(0) + 0 %}
{% set cashback_credited = summary.cashback_credited|default(0) + 0 %}
{% set cashback_total = cashback_pending + cashback_credited %}
{% set cashback_ratio = cashback_total > 0 ? (cashback_credited * 100 / cashback_total) : 0 %}
{% set credit_activity_ratio = summary.transactions_total > 0 ? ((summary.credits_total|default(0) * 100) / summary.transactions_total) : 0 %}

{% set category_max = 0 %}
{% for _, v in category_totals %}
  {% if v > category_max %}{% set category_max = v %}{% endif %}
{% endfor %}
{% set category_base = category_max > 0 ? category_max : 1 %}

{% set health_score = 45 %}
{% set health_score = health_score + (summary.accounts_total|default(0) > 0 ? 10 : 0) %}
{% set health_score = health_score + (summary.transactions_total|default(0) >= 5 ? 15 : (summary.transactions_total|default(0) > 0 ? 8 : 0)) %}
{% set health_score = health_score + (cashback_credited > 0 ? 10 : 0) %}
{% set health_score = health_score + (tx_success_rate > 70 ? 12 : (tx_success_rate > 40 ? 6 : 0)) %}
{% set health_score = health_score + (summary.credits_total|default(0) == 0 ? 8 : 0) %}
{% set health_score = health_score > 100 ? 100 : health_score %}

{% set cat_colors = ['#00B4A0','#4a8fff','#f59e0b','#8b5cf6','#ef4444','#06b6d4','#10b981','#f97316'] %}

<div class="cc-page">

  {# ════════════════════════════════════════════
     COMMAND HERO — full-width dark header
  ════════════════════════════════════════════ #}
  <div class="cc-hero">

    {# Animated BG #}
    <div class="cc-hero-bg" aria-hidden="true">
      <div class="chb-orb chb-orb--1"></div>
      <div class="chb-orb chb-orb--2"></div>
      <div class="chb-grid"></div>
      <div class="chb-scan"></div>
    </div>

    {# Left: title + greeting #}
    <div class="cc-hero-left">
      <div class="cc-hero-eyebrow">
        <span class="cc-hero-led"></span>
        NEXORA BANK · Espace Personnel
      </div>
      <h1 class="cc-hero-title">
        Tableau de bord
      </h1>
      <p class="cc-hero-sub">
        Vue d'ensemble temps réel de votre activité financière
      </p>
      <div class="cc-hero-datetime" id="ccDatetime"></div>
    </div>

    {# Center: health dial #}
    <div class="cc-hero-center">
      <div class="cc-health-dial">
        <svg viewBox="0 0 120 120" width="120" height="120">
          {# Track arc #}
          <circle class="chd-track" cx="60" cy="60" r="50"/>
          {# Fill arc #}
          <circle class="chd-fill" cx="60" cy="60" r="50"
                  style="stroke-dasharray: {{ (health_score * 314.16 / 100)|round(1) }} 314.16"/>
          {# Tick marks #}
          <g class="chd-ticks">
            {% for i in range(0, 10) %}
              <line
                x1="60" y1="10"
                x2="60" y2="16"
                transform="rotate({{ i * 36 }}, 60, 60)"
                class="chd-tick"/>
            {% endfor %}
          </g>
        </svg>
        <div class="cc-health-inner">
          <span class="chd-score">{{ health_score }}</span>
          <span class="chd-label">/ 100</span>
          <span class="chd-name">Santé financière</span>
        </div>
      </div>
    </div>

    {# Right: quick 3 counters #}
    <div class="cc-hero-right">
      <div class="cc-hero-counter">
        <span class="cc-count" data-target="{{ summary.accounts_total|default(0) }}">0</span>
        <small>Comptes</small>
      </div>
      <div class="cc-hero-sep"></div>
      <div class="cc-hero-counter">
        <span class="cc-count" data-target="{{ summary.transactions_total|default(0) }}">0</span>
        <small>Transactions</small>
      </div>
      <div class="cc-hero-sep"></div>
      <div class="cc-hero-counter">
        <span>{{ cashback_total|number_format(2,'.','')|replace({',':''}) }}</span>
        <small>DT cashback</small>
      </div>
    </div>

  </div>

  {# ════════════════════════════════════════════
     MOSAIC KPI BENTO
  ════════════════════════════════════════════ #}
  <div class="cc-mosaic" data-cc-reveal>

    {# Large featured tile #}
    <div class="cc-mosaic-tile cc-mosaic-tile--featured">
      <div class="cmf-glow"></div>
      <div class="cc-mt-icon cc-mt-icon--teal">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2">
          <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/>
          <polyline points="17 6 23 6 23 12"/>
        </svg>
      </div>
      <div class="cc-mt-label">Volume financier récent</div>
      <div class="cc-mt-value">
        {{ tx_total_amount|number_format(2, '.', ' ') }}
        <span>DT</span>
      </div>
      <div class="cc-mt-sub">
        Sur {{ tx_count }} transaction(s) analysée(s)
      </div>
      <div class="cc-flow-mini">
        <div class="cfm-in">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="3">
            <line x1="12" y1="19" x2="12" y2="5"/>
            <polyline points="5 12 12 5 19 12"/>
          </svg>
          +{{ tx_credit_amount|number_format(2,'.',' ') }}
        </div>
        <div class="cfm-out">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="3">
            <line x1="12" y1="5" x2="12" y2="19"/>
            <polyline points="19 12 12 19 5 12"/>
          </svg>
          -{{ tx_debit_amount|number_format(2,'.',' ') }}
        </div>
      </div>
    </div>

    {# Standard tiles #}
    <div class="cc-mosaic-tile">
      <div class="cc-mt-icon cc-mt-icon--blue">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2">
          <rect x="2" y="5" width="20" height="14" rx="2"/>
          <line x1="2" y1="10" x2="22" y2="10"/>
        </svg>
      </div>
      <div class="cc-mt-label">Comptes actifs</div>
      <div class="cc-mt-value cc-mt-value--sm">
        <span class="cc-count" data-target="{{ summary.accounts_total|default(0) }}">0</span>
      </div>
      <div class="cc-mt-chip cc-mt-chip--green">Opérationnel</div>
    </div>

    <div class="cc-mosaic-tile">
      <div class="cc-mt-icon cc-mt-icon--purple">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2">
          <polyline points="17 1 21 5 17 9"/>
          <path d="M3 11V9a4 4 0 0 1 4-4h14"/>
          <polyline points="7 23 3 19 7 15"/>
          <path d="M21 13v2a4 4 0 0 1-4 4H3"/>
        </svg>
      </div>
      <div class="cc-mt-label">Transactions totales</div>
      <div class="cc-mt-value cc-mt-value--sm">
        <span class="cc-count" data-target="{{ summary.transactions_total|default(0) }}">0</span>
      </div>
      <div class="cc-mt-chip cc-mt-chip--blue">Mouvements</div>
    </div>

    <div class="cc-mosaic-tile">
      <div class="cc-mt-icon cc-mt-icon--gold">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2">
          <line x1="12" y1="1" x2="12" y2="23"/>
          <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
        </svg>
      </div>
      <div class="cc-mt-label">Crédits en portefeuille</div>
      <div class="cc-mt-value cc-mt-value--sm">
        <span class="cc-count" data-target="{{ summary.credits_total|default(0) }}">0</span>
      </div>
      <div class="cc-mt-chip cc-mt-chip--amber">Dossiers</div>
    </div>

    <div class="cc-mosaic-tile">
      <div class="cc-mt-icon cc-mt-icon--teal">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2">
          <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
        </svg>
      </div>
      <div class="cc-mt-label">Cashback crédité</div>
      <div class="cc-mt-value cc-mt-value--sm">
        {{ cashback_credited|number_format(2,'.','') }}
        <span style="font-size:14px">DT</span>
      </div>
      <div class="cc-mt-chip cc-mt-chip--green">Disponible</div>
    </div>

    <div class="cc-mosaic-tile">
      <div class="cc-mt-icon cc-mt-icon--orange">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2">
          <path d="M12 20V10"/><path d="M18 20V4"/><path d="M6 20v-4"/>
        </svg>
      </div>
      <div class="cc-mt-label">Ticket moyen</div>
      <div class="cc-mt-value cc-mt-value--sm">
        {{ avg_ticket|number_format(2,'.','') }}
        <span style="font-size:14px">DT</span>
      </div>
      <div class="cc-mt-chip cc-mt-chip--purple">Par transaction</div>
    </div>

    {# Rate tile with radial #}
    <div class="cc-mosaic-tile cc-mosaic-tile--rate">
      <div class="cc-rate-ring">
        <svg viewBox="0 0 80 80" width="80" height="80">
          <circle class="crr-bg" cx="40" cy="40" r="33"/>
          <circle class="crr-fill" cx="40" cy="40" r="33"
                  style="stroke-dasharray:{{ (tx_success_rate * 207.35 / 100)|round(1) }} 207.35"/>
        </svg>
        <span>{{ tx_success_rate|number_format(0,'.','')|replace({',':''}) }}%</span>
      </div>
      <div>
        <div class="cc-mt-label">Taux de succès</div>
        <div class="cc-mt-sub">{{ tx_done_count }} / {{ tx_count }} terminées</div>
      </div>
    </div>

  </div>

  {# ════════════════════════════════════════════
     ANALYTICS SPLIT — chart left, KPI panel right
  ════════════════════════════════════════════ #}
  <div class="cc-analytics-split" data-cc-reveal>

    {# Left: category breakdown #}
    <div class="cc-panel cc-panel--chart">
      <div class="cc-panel-head">
        <div class="cc-panel-icon cc-panel-icon--teal">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2.5">
            <path d="M12 20V10"/><path d="M18 20V4"/><path d="M6 20v-4"/>
          </svg>
        </div>
        <div>
          <h2>Répartition par catégorie</h2>
          <p>{{ tx_count }} transaction(s) analysée(s)</p>
        </div>
        <div class="cc-panel-badge">Récent</div>
      </div>

      <div class="cc-chart-area">
        {% for category, cat_total in category_totals %}
          {% set bar_pct = (cat_total * 100 / category_base) %}
          {% set col_idx = loop.index0 % (cat_colors|length) %}
          {% set col = cat_colors[col_idx] %}
          <div class="cc-bar-row">
            <div class="cc-bar-meta">
              <span class="cc-bar-dot" style="background:{{ col }}"></span>
              <strong>{{ category }}</strong>
              <span class="cc-bar-pct">{{ bar_pct|number_format(0,'.','')|replace({',':''}) }}%</span>
            </div>
            <div class="cc-bar-outer">
              <div class="cc-bar-inner"
                   style="--w:{{ bar_pct|number_format(2,'.','')|replace({',':''}) }}%;
                          --col:{{ col }}"></div>
            </div>
            <span class="cc-bar-val">{{ cat_total|number_format(2,'.',' ') }} DT</span>
          </div>
        {% else %}
          <div class="cc-empty">
            <svg width="44" height="44" viewBox="0 0 24 24" fill="none"
                 stroke="rgba(0,180,160,.2)" stroke-width="1.3">
              <path d="M12 20V10"/><path d="M18 20V4"/><path d="M6 20v-4"/>
            </svg>
            <p>Aucune donnée pour le graphe.</p>
          </div>
        {% endfor %}
      </div>

      {# Flow summary footer #}
      <div class="cc-flow-footer">
        <div class="cff-item cff-item--credit">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="3">
            <line x1="12" y1="19" x2="12" y2="5"/>
            <polyline points="5 12 12 5 19 12"/>
          </svg>
          <div>
            <small>Entrées</small>
            <strong>+{{ tx_credit_amount|number_format(2,'.',' ') }} DT</strong>
          </div>
        </div>
        <div class="cff-sep"></div>
        <div class="cff-item cff-item--debit">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="3">
            <line x1="12" y1="5" x2="12" y2="19"/>
            <polyline points="19 12 12 19 5 12"/>
          </svg>
          <div>
            <small>Sorties</small>
            <strong>-{{ tx_debit_amount|number_format(2,'.',' ') }} DT</strong>
          </div>
        </div>
        <div class="cff-sep"></div>
        <div class="cff-item cff-item--neutral">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="3">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
            <polyline points="22 4 12 14.01 9 11.01"/>
          </svg>
          <div>
            <small>Succès</small>
            <strong>{{ tx_success_rate|number_format(1,'.','')|replace({',':''}) }}%</strong>
          </div>
        </div>
      </div>
    </div>

    {# Right: KPI performance stacked #}
    <div class="cc-panel cc-panel--kpi">
      <div class="cc-panel-head">
        <div class="cc-panel-icon cc-panel-icon--purple">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2.5">
            <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
          </svg>
        </div>
        <div>
          <h2>KPI Performance</h2>
          <p>{{ "now"|date("d/m/Y H:i") }}</p>
        </div>
      </div>

      <div class="cc-perf-stack">

        <div class="cc-perf-card">
          <div class="cc-perf-header">
            <div class="cc-perf-icon" style="background:rgba(0,180,160,.1);color:#00B4A0">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                   stroke="currentColor" stroke-width="2.5">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                <polyline points="22 4 12 14.01 9 11.01"/>
              </svg>
            </div>
            <div class="cc-perf-info">
              <strong>Transactions terminées</strong>
              <small>{{ tx_done_count }} sur {{ tx_count }}</small>
            </div>
            <span class="cc-perf-pct" style="color:#00B4A0">
              {{ tx_success_rate|number_format(1,'.','')|replace({',':''}) }}%
            </span>
          </div>
          <div class="cc-perf-bar-track">
            <div class="cc-perf-bar-fill cc-pbf--teal"
                 style="--w:{{ tx_success_rate|number_format(2,'.','')|replace({',':''}) }}%">
            </div>
          </div>
        </div>

        <div class="cc-perf-card">
          <div class="cc-perf-header">
            <div class="cc-perf-icon" style="background:rgba(245,158,11,.1);color:#f59e0b">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                   stroke="currentColor" stroke-width="2.5">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
            </div>
            <div class="cc-perf-info">
              <strong>Cashback crédité</strong>
              <small>{{ cashback_credited|number_format(2,'.',' ') }} DT</small>
            </div>
            <span class="cc-perf-pct" style="color:#f59e0b">
              {{ cashback_ratio|number_format(1,'.','')|replace({',':''}) }}%
            </span>
          </div>
          <div class="cc-perf-bar-track">
            <div class="cc-perf-bar-fill cc-pbf--gold"
                 style="--w:{{ cashback_ratio|number_format(2,'.','')|replace({',':''}) }}%">
            </div>
          </div>
        </div>

        <div class="cc-perf-card">
          <div class="cc-perf-header">
            <div class="cc-perf-icon" style="background:rgba(139,92,246,.1);color:#8b5cf6">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                   stroke="currentColor" stroke-width="2.5">
                <line x1="12" y1="1" x2="12" y2="23"/>
                <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
              </svg>
            </div>
            <div class="cc-perf-info">
              <strong>Ratio crédits / tx</strong>
              <small>{{ summary.credits_total|default(0) }} vs {{ summary.transactions_total|default(0) }}</small>
            </div>
            <span class="cc-perf-pct" style="color:#8b5cf6">
              {{ credit_activity_ratio|number_format(1,'.','')|replace({',':''}) }}%
            </span>
          </div>
          <div class="cc-perf-bar-track">
            {% set cap_ratio = credit_activity_ratio > 100 ? 100 : credit_activity_ratio %}
            <div class="cc-perf-bar-fill cc-pbf--purple"
                 style="--w:{{ cap_ratio|number_format(2,'.','')|replace({',':''}) }}%">
            </div>
          </div>
        </div>

      </div>

      {# Quartet mini stats #}
      <div class="cc-quartet">
        <div class="cc-quartet-item">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none"
               stroke="#f59e0b" stroke-width="2">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
          <small>En attente</small>
          <strong>{{ cashback_pending|number_format(2,'.',' ') }} DT</strong>
        </div>
        <div class="cc-quartet-item">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none"
               stroke="#3b82f6" stroke-width="2">
            <line x1="12" y1="1" x2="12" y2="23"/>
            <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
          </svg>
          <small>Crédits récents</small>
          <strong>{{ credit_list|length }}</strong>
        </div>
        <div class="cc-quartet-item">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none"
               stroke="#8b5cf6" stroke-width="2">
            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
            <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
          </svg>
          <small>Notifications</small>
          <strong>{{ notifications|length }}</strong>
        </div>
        <div class="cc-quartet-item">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none"
               stroke="#ef4444" stroke-width="2">
            <line x1="12" y1="5" x2="12" y2="19"/>
            <polyline points="19 12 12 19 5 12"/>
          </svg>
          <small>Débits récents</small>
          <strong>{{ tx_debit_amount|number_format(2,'.',' ') }} DT</strong>
        </div>
      </div>
    </div>

  </div>

  {# ════════════════════════════════════════════
     DATA FEED — 3 columns
  ════════════════════════════════════════════ #}
  <div class="cc-feed-grid" data-cc-reveal>

    {# Column 1: Transactions feed #}
    <div class="cc-feed-col cc-feed-col--wide">
      <div class="cc-feed-head">
        <div class="cc-feed-icon cc-feed-icon--blue">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2.5">
            <polyline points="17 1 21 5 17 9"/>
            <path d="M3 11V9a4 4 0 0 1 4-4h14"/>
            <polyline points="7 23 3 19 7 15"/>
            <path d="M21 13v2a4 4 0 0 1-4 4H3"/>
          </svg>
        </div>
        <div>
          <h3>Transactions récentes</h3>
          <p>Flux financier client</p>
        </div>
        <div class="cc-badge">{{ tx_list|length }}</div>
      </div>

      <div class="cc-feed-body">
        {% for item in tx_list %}
          {% set st = item.statutTransaction|default('N/A') %}
          {% set stl = st|lower %}
          {% set sc = ('term' in stl or 'valid' in stl or 'accept' in stl) ? 'success'
                     : (('attente' in stl or 'pending' in stl) ? 'warn' : 'neutral') %}
          {% set type_lower = item.typeTransaction|default('')|lower %}
          {% set is_debit = 'debit' in type_lower %}

          <div class="cc-feed-row {{ is_debit ? 'cc-feed-row--debit' : 'cc-feed-row--credit' }}">
            <div class="cc-feed-row-icon {{ is_debit ? 'ccfri--debit' : 'ccfri--credit' }}">
              {% if is_debit %}
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="3">
                  <line x1="12" y1="5" x2="12" y2="19"/>
                  <polyline points="19 12 12 19 5 12"/>
                </svg>
              {% else %}
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="3">
                  <line x1="12" y1="19" x2="12" y2="5"/>
                  <polyline points="5 12 12 5 19 12"/>
                </svg>
              {% endif %}
            </div>
            <div class="cc-feed-row-body">
              <div class="cc-feed-row-top">
                <strong>{{ item.categorie|default('Autre') }}</strong>
                <span class="cc-feed-amount {{ is_debit ? 'ccfa--neg' : 'ccfa--pos' }}">
                  {{ is_debit ? '−' : '+' }}{{ item.montant_value|default(0)|number_format(2,'.',' ') }} DT
                </span>
              </div>
              <div class="cc-feed-row-bot">
                <span class="cc-feed-id">#{{ item.idTransaction }}</span>
                <span class="cc-feed-date">{{ item.dateTransaction|default('-') }}</span>
                <span class="cc-status-dot cc-status-dot--{{ sc }}"></span>
                <span class="cc-feed-status">{{ st }}</span>
              </div>
            </div>
          </div>

        {% else %}
          <div class="cc-empty">
            <svg width="44" height="44" viewBox="0 0 24 24" fill="none"
                 stroke="rgba(74,143,255,.2)" stroke-width="1.3">
              <polyline points="17 1 21 5 17 9"/>
              <path d="M3 11V9a4 4 0 0 1 4-4h14"/>
            </svg>
            <p>Aucune transaction récente.</p>
          </div>
        {% endfor %}
