      </div>

      <div class="cc-feed-body">
        {% for credit in credit_list %}
          {% set cs  = credit.statut|default('N/A') %}
          {% set csl = cs|lower %}
          {% set csc = ('accepte' in csl or 'en cours' in csl) ? 'success'
                      : (('attente' in csl or 'pending' in csl) ? 'warn' : 'neutral') %}
          <div class="cc-credit-card">
            <div class="cc-credit-top">
              <span class="cc-credit-id">#{{ credit.idCredit }}</span>
              <span class="cc-status-pill cc-status-pill--{{ csc }}">
                <span class="cc-status-dot cc-status-dot--{{ csc }}"></span>
                {{ cs }}
              </span>
            </div>
            <div class="cc-credit-type">{{ credit.typeCredit|default('-') }}</div>
            <div class="cc-credit-bottom">
              <div class="cc-credit-stat">
                <small>Montant</small>
                <strong>{{ credit.montantDemande|default(0)|number_format(2,'.',' ') }} DT</strong>
              </div>
              <div class="cc-credit-stat">
                <small>Durée</small>
                <strong>{{ credit.duree|default('-') }} mois</strong>
              </div>
            </div>
          </div>
        {% else %}
