{% set current_date = 'now'|date('Y-m-d') %}
{% set garantie_feedback = support.garantie_form_feedback|default({}) %}
{% if garantie_feedback is empty %}
    {% set garantie_feedback = {'errors': support.form_errors_garantie|default({}), 'input': support.form_data_garantie|default({})} %}
{% endif %}
{% set garantie_old = garantie_feedback.input|default({}) %}
{% set garantie_errors = garantie_feedback.errors|default({}) %}

<style>
.nx-list-pager {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 10px;
    margin-top: 16px;
    flex-wrap: wrap;
}

.nx-list-pager[hidden] {
    display: none !important;
}

.nx-list-pager-btn {
    width: 40px;
    height: 40px;
    border-radius: 999px;
    border: 1px solid #cfe0f2;
    background: #fff;
    color: #58789a;
    font-size: 14px;
    font-weight: 800;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
}

.nx-list-pager-btn.is-active {
    background: linear-gradient(135deg, #16a34a, #14b8a6);
    border-color: transparent;
    color: #fff;
}

.nx-list-pager-btn:disabled {
    opacity: .45;
    cursor: default;
}

tr.nx-page-hidden {
    display: none;
}
</style>

<section class="panel-card">
    <h2>Garanties</h2>
    <p style="margin:6px 0 16px; color:#6b7280; font-size:13px;">
        Creation, modification, suppression et validation complete des garanties, avec le meme principe que le module compte bancaire.
    </p>

    <form method="post" class="editor-form" id="portal-garantie-form" novalidate enctype="multipart/form-data">
        <input type="hidden" name="tab" value="garanties">
        <input type="hidden" name="action" value="garantie_save">

        <label>
            <span>ID pour modifier</span>
            <input type="number" name="idGarantie" id="portal-garantie-id" placeholder="Laisser vide pour creer" value="{{ garantie_old.idGarantie|default('') }}">
            <span id="g-err-idGarantie" class="g-val-msg">{{ garantie_errors.idGarantie|default('') }}</span>
        </label>
        <label>
            <span>Type garantie <span style="color:#dc2626">*</span></span>
            <select name="typeGarantie" id="portal-garantie-type" class="{{ garantie_errors.typeGarantie is defined ? 'acc-invalid' : '' }}">
                <option value="">Selectionner</option>
                {% for type in ['Hypotheque immobiliere', 'Titre vehicule', 'Caution personnelle', 'Garantie bancaire', 'Police assurance', 'Nantissement', 'Autre garantie'] %}
                    <option value="{{ type }}" {{ garantie_old.typeGarantie|default('') == type ? 'selected' : '' }}>{{ type }}</option>
                {% endfor %}
            </select>
            <span id="g-err-typeGarantie" class="g-val-msg">{{ garantie_errors.typeGarantie|default('') }}</span>
        </label>
        <label>
            <span>Description <span style="color:#dc2626">*</span></span>
            <input type="text" name="description" id="portal-garantie-description" placeholder="Description courte (min. 10 caracteres)" value="{{ garantie_old.description|default('') }}" class="{{ garantie_errors.description is defined ? 'acc-invalid' : '' }}">
            <span id="g-err-description" class="g-val-msg">{{ garantie_errors.description|default('') }}</span>
        </label>
        <label>
            <span>Adresse du bien <span style="color:#dc2626">*</span></span>
            <input type="text" name="adresseBien" id="portal-garantie-address" placeholder="Adresse du bien (min. 5 caracteres)" value="{{ garantie_old.adresseBien|default('') }}" class="{{ garantie_errors.adresseBien is defined ? 'acc-invalid' : '' }}">
            <span id="g-err-adresseBien" class="g-val-msg">{{ garantie_errors.adresseBien|default('') }}</span>
        </label>
        <label>
            <span>Valeur estimee (TND) <span style="color:#dc2626">*</span></span>
            <input type="number" step="0.01" name="valeurEstimee" id="portal-garantie-estimated" placeholder="0.00" value="{{ garantie_old.valeurEstimee|default('') }}" class="{{ garantie_errors.valeurEstimee is defined ? 'acc-invalid' : '' }}">
            <span id="g-err-valeurEstimee" class="g-val-msg">{{ garantie_errors.valeurEstimee|default('') }}</span>
        </label>
        <label>
            <span>Valeur retenue (TND)</span>
            <input type="number" step="0.01" name="valeurRetenue" id="portal-garantie-retained" placeholder="Auto (80% estimee)" value="{{ garantie_old.valeurRetenue|default('') }}" class="{{ garantie_errors.valeurRetenue is defined ? 'acc-invalid' : '' }}">
            <span id="g-err-valeurRetenue" class="g-val-msg">{{ garantie_errors.valeurRetenue|default('') }}</span>
        </label>
        <label>
            <span>Date evaluation <span style="color:#dc2626">*</span></span>
            <input type="date" name="dateEvaluation" id="portal-garantie-date" value="{{ garantie_old.dateEvaluation|default(current_date) }}" min="{{ current_date }}" class="{{ garantie_errors.dateEvaluation is defined ? 'acc-invalid' : '' }}">
            <span id="g-err-dateEvaluation" class="g-val-msg">{{ garantie_errors.dateEvaluation|default('') }}</span>
        </label>
        <label>
            <span>Document justificatif <span style="color:#dc2626">*</span></span>
            <input type="hidden" name="existingDocumentJustificatif" id="portal-garantie-document-existing" value="{{ garantie_old.documentJustificatif|default('') }}">
            <input type="file" name="documentJustificatifFile" id="portal-garantie-document" accept="image/png,image/jpeg,image/webp,image/gif" class="{{ garantie_errors.documentJustificatif is defined ? 'acc-invalid' : '' }}">
            <small id="portal-garantie-document-label" style="display:block; margin-top:6px; color:#6b7280;">{{ garantie_old.documentJustificatif|default('') ? 'Image deja enregistree' : 'Formats acceptes: PNG, JPG, WEBP, GIF' }}</small>
            <a id="portal-garantie-document-link" href="{{ garantie_old.documentJustificatif|default('') ? asset(garantie_old.documentJustificatif) : '#' }}" target="_blank" rel="noopener" {{ garantie_old.documentJustificatif|default('') ? '' : 'hidden' }}>Voir l'image actuelle</a>
            <span id="g-err-documentJustificatif" class="g-val-msg">{{ garantie_errors.documentJustificatif|default('') }}</span>
        </label>
        <label>
            <span>Nom garant <span style="color:#dc2626">*</span></span>
            <input type="text" name="nomGarant" id="portal-garantie-guarantor" placeholder="Nom du garant" value="{{ garantie_old.nomGarant|default('') }}" class="{{ garantie_errors.nomGarant is defined ? 'acc-invalid' : '' }}">
            <span id="g-err-nomGarant" class="g-val-msg">{{ garantie_errors.nomGarant|default('') }}</span>
        </label>
        <div style="display:flex; gap:8px; margin-top:8px;">
            <button class="btn btn-primary" type="submit">Enregistrer</button>
            <button class="btn btn-secondary" type="reset">Vider</button>
        </div>
    </form>

    <div class="table-wrap" style="margin-top:16px;">
        <table class="data-table">
            <thead>
            <tr>
                <th>ID</th>
                <th>Credit</th>
                <th>Type</th>
                <th>Estimee</th>
                <th>Retenue</th>
                <th>Statut</th>
                <th>Actions</th>
            </tr>
            </thead>
            <tbody>
            {% for item in items %}
                <tr
                    data-garantie-row
                    data-garantie-id="{{ item.idGarantie }}"
                    data-garantie-credit-id="{{ item.idCredit }}"
                    data-garantie-type="{{ item.typeGarantie|default('')|e('html_attr') }}"
                    data-garantie-description="{{ item.description|default('')|e('html_attr') }}"
                    data-garantie-address="{{ item.adresseBien|default('')|e('html_attr') }}"
                    data-garantie-estimated="{{ item.valeurEstimee|default('') }}"
                    data-garantie-retained="{{ item.valeurRetenue|default('') }}"
                    data-garantie-document="{{ item.documentJustificatif|default('')|e('html_attr') }}"
                    data-garantie-date="{{ item.dateEvaluation|default(current_date)|slice(0, 10) }}"
                    data-garantie-guarantor="{{ item.nomGarant|default('')|e('html_attr') }}"
                    data-garantie-status="{{ item.statut|default('')|e('html_attr') }}"
                >
                    <td>{{ item.idGarantie }}</td>
                    <td>{{ item.idCredit ? '#' ~ item.idCredit : 'Non associee' }}</td>
                    <td>{{ item.typeGarantie }}</td>
                    <td>{{ item.valeurEstimee|default(0)|number_format(2, '.', ' ') }}</td>
                    <td>{{ item.valeurRetenue|default(0)|number_format(2, '.', ' ') }}</td>
                    <td>{{ item.statut }}</td>
                    <td style="display:flex; gap:8px;">
                        <button class="btn btn-secondary js-garantie-edit" type="button">Modifier</button>
                        <form method="post">
                            <input type="hidden" name="tab" value="garanties">
                            <input type="hidden" name="action" value="garantie_delete">
                            <input type="hidden" name="idGarantie" value="{{ item.idGarantie }}">
                            <button class="btn btn-danger" type="submit" onclick="return confirm('Supprimer cette garantie ?')">Supprimer</button>
                        </form>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="7">Aucune garantie enregistree.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
    <div class="nx-list-pager" id="portal-garanties-pager" hidden></div>
</section>

<script>
(() => {
    const form = document.getElementById('portal-garantie-form');
    if (!(form instanceof HTMLFormElement)) return;

    const estimatedField = document.getElementById('portal-garantie-estimated');
    const retainedField = document.getElementById('portal-garantie-retained');
    const dateField = document.getElementById('portal-garantie-date');
    const idField = document.getElementById('portal-garantie-id');
    const documentField = document.getElementById('portal-garantie-document');
    const existingDocumentField = document.getElementById('portal-garantie-document-existing');
    const documentLabel = document.getElementById('portal-garantie-document-label');
    const documentLink = document.getElementById('portal-garantie-document-link');
    const currentDateIso = '{{ current_date }}';
    const todayDate = new Date(`${currentDateIso}T00:00:00`);
    const fieldNames = ['typeGarantie', 'description', 'adresseBien', 'valeurEstimee', 'valeurRetenue', 'dateEvaluation', 'documentJustificatif', 'nomGarant'];

    const parseNum = (v) => {
        const n = Number(v);
        return Number.isFinite(n) ? n : 0;
    };
    const parseInputDate = (rawValue) => {
        const raw = String(rawValue ?? '').trim();
        if (raw === '') return null;
        const parsed = new Date(`${raw}T00:00:00`);
        return Number.isNaN(parsed.getTime()) ? null : parsed;
    };
    const fieldElement = (name) => form.querySelector(`[name="${name}"]`);
    const messageElement = (name) => document.getElementById(`g-err-${name}`);
    const setError = (field, msgEl, message) => {
        field?.classList.add('acc-invalid');
        field?.classList.remove('acc-valid');
        if (msgEl) {
            msgEl.textContent = '⚠ ' + message;
            msgEl.style.color = '#dc2626';
            msgEl.style.fontWeight = '600';
            msgEl.style.fontSize = '12px';
            msgEl.style.marginTop = '4px';
        }
        return false;
    };
    const setValid = (field, msgEl) => {
        field?.classList.remove('acc-invalid');
        field?.classList.add('acc-valid');
        if (msgEl) {
            msgEl.textContent = '✓ Valide';
            msgEl.style.color = '#16a34a';
            msgEl.style.fontWeight = '600';
            msgEl.style.fontSize = '12px';
            msgEl.style.marginTop = '4px';
        }
        return true;
    };
    const clearValid = (field, msgEl) => {
        field?.classList.remove('acc-invalid', 'acc-valid');
        if (msgEl) {
            msgEl.textContent = '';
        }
        return true;
    };
    const syncDocumentMeta = (path = '', label = '') => {
        const resolvedPath = String(path ?? '').trim();
        if (existingDocumentField instanceof HTMLInputElement) {
            existingDocumentField.value = resolvedPath;
        }
        if (documentLabel) {
            documentLabel.textContent = label || (resolvedPath !== '' ? 'Image deja enregistree' : 'Formats acceptes: PNG, JPG, WEBP, GIF');
        }
        if (documentLink instanceof HTMLAnchorElement) {
            if (resolvedPath !== '') {
                documentLink.href = resolvedPath.startsWith('/') ? resolvedPath : `/${resolvedPath}`;
                documentLink.hidden = false;
            } else {
                documentLink.href = '#';
                documentLink.hidden = true;
            }
        }
    };

    const syncRetained = () => {
        if (!(estimatedField instanceof HTMLInputElement) || !(retainedField instanceof HTMLInputElement)) return;
        if (retainedField.dataset.manual === '1') return;
        const est = parseNum(estimatedField.value);
        retainedField.value = est > 0 ? (est * 0.8).toFixed(2) : '';
    };

    const validateField = (name) => {
        const field = fieldElement(name);
        const msgEl = messageElement(name);
        const value = String(field?.value ?? '').trim();

        switch (name) {
            case 'typeGarantie':
                return value === '' ? setError(field, msgEl, 'Veuillez selectionner un type de garantie.') : setValid(field, msgEl);
            case 'description':
                if (value === '') return setError(field, msgEl, 'La description est obligatoire.');
                if (value.length < 10) return setError(field, msgEl, 'La description doit contenir au moins 10 caracteres.');
                return setValid(field, msgEl);
            case 'adresseBien':
                if (value === '') return setError(field, msgEl, "L'adresse du bien est obligatoire.");
                if (value.length < 5) return setError(field, msgEl, "L'adresse doit contenir au moins 5 caracteres.");
                return setValid(field, msgEl);
            case 'valeurEstimee': {
                const estimated = parseNum(value);
                if (value === '') return setError(field, msgEl, 'La valeur estimee est obligatoire.');
                if (estimated <= 0) return setError(field, msgEl, 'La valeur estimee doit etre positive.');
                if (estimated < 1000 || estimated > 100000000) return setError(field, msgEl, 'La valeur estimee doit etre comprise entre 1000 et 100000000 DT.');
                return setValid(field, msgEl);
            }
            case 'valeurRetenue': {
                if (value === '') return setError(field, msgEl, 'La valeur retenue est obligatoire.');
                const retained = parseNum(value);
                const estimated = parseNum(estimatedField?.value);
                if (retained <= 0) return setError(field, msgEl, 'La valeur retenue doit etre positive.');
                if (estimated > 0 && retained > estimated) return setError(field, msgEl, "La valeur retenue ne doit pas depasser l'estimee.");
                return setValid(field, msgEl);
            }
            case 'dateEvaluation': {
                const parsedDate = parseInputDate(value);
                if (value === '') return setError(field, msgEl, "La date d'evaluation est obligatoire.");
                if (!parsedDate) return setError(field, msgEl, "Date d'evaluation invalide.");
                if (parsedDate < todayDate) return setError(field, msgEl, "La date d'évaluation ne peut pas être dans le passé.");
                return setValid(field, msgEl);
            }
            case 'documentJustificatif': {
                const file = documentField instanceof HTMLInputElement ? documentField.files?.[0] ?? null : null;
                const existingPath = existingDocumentField instanceof HTMLInputElement ? existingDocumentField.value.trim() : '';
                const allowedTypes = ['image/jpeg', 'image/png', 'image/webp', 'image/gif'];
                if (file) {
                    if (!allowedTypes.includes(file.type)) {
                        return setError(documentField, msgEl, 'Le document justificatif doit etre une image JPG, PNG, WEBP ou GIF.');
                    }
                    return setValid(documentField, msgEl);
                }
                if (existingPath === '') return setError(documentField, msgEl, 'Le document justificatif est obligatoire.');
                return setValid(documentField, msgEl);
            }
            case 'nomGarant':
                if (value === '') return setError(field, msgEl, 'Le nom du garant est obligatoire.');
                if (value.length < 2) return setError(field, msgEl, 'Le nom doit contenir au moins 2 caracteres.');
                if (!/^[\p{L}\s\-']+$/u.test(value)) return setError(field, msgEl, 'Le nom du garant ne doit contenir que des lettres.');
                return setValid(field, msgEl);
            default:
                return true;
        }
    };
    const validateForm = () => fieldNames.map((name) => validateField(name)).every((res) => res);

    estimatedField?.addEventListener('input', () => {
        syncRetained();
        validateField('valeurEstimee');
        validateField('valeurRetenue');
    });
    retainedField?.addEventListener('input', () => {
        if (retainedField instanceof HTMLInputElement) {
            retainedField.dataset.manual = retainedField.value.trim() === '' ? '0' : '1';
        }
        validateField('valeurRetenue');
    });
    documentField?.addEventListener('change', () => {
        const file = documentField instanceof HTMLInputElement ? documentField.files?.[0] ?? null : null;
        syncDocumentMeta(existingDocumentField instanceof HTMLInputElement ? existingDocumentField.value : '', file ? `Fichier selectionne: ${file.name}` : '');
        validateField('documentJustificatif');
    });

    fieldNames.forEach((name) => {
        if (name === 'valeurEstimee' || name === 'valeurRetenue' || name === 'documentJustificatif') return;
        const field = fieldElement(name);
        if (!field) return;
        field.addEventListener('input', () => validateField(name));
        field.addEventListener('change', () => validateField(name));
        field.addEventListener('blur', () => validateField(name));
    });

    form.addEventListener('reset', () => {
        requestAnimationFrame(() => {
            if (idField instanceof HTMLInputElement) idField.value = '';
            if (retainedField instanceof HTMLInputElement) retainedField.dataset.manual = '0';
            if (dateField instanceof HTMLInputElement) dateField.value = currentDateIso;
            if (documentField instanceof HTMLInputElement) documentField.value = '';
            syncDocumentMeta('', '');
            fieldNames.forEach((name) => clearValid(fieldElement(name), messageElement(name)));
            syncRetained();
        });
    });

    form.addEventListener('submit', (event) => {
        if (retainedField instanceof HTMLInputElement && retainedField.value.trim() === '') {
            retainedField.dataset.manual = '0';
            syncRetained();
        }
        if (!validateForm()) {
            event.preventDefault();
        }
    });

    const setFieldValue = (name, value) => {
        const field = fieldElement(name);
        if (field instanceof HTMLInputElement || field instanceof HTMLSelectElement || field instanceof HTMLTextAreaElement) {
            field.value = value ?? '';
        }
    };

    document.querySelectorAll('.js-garantie-edit').forEach((btn) => {
        btn.addEventListener('click', () => {
            const row = btn.closest('[data-garantie-row]');
            if (!row) return;
            setFieldValue('idGarantie', row.dataset.garantieId ?? '');
            setFieldValue('typeGarantie', row.dataset.garantieType ?? '');
            setFieldValue('description', row.dataset.garantieDescription ?? '');
            setFieldValue('adresseBien', row.dataset.garantieAddress ?? '');
            setFieldValue('valeurEstimee', row.dataset.garantieEstimated ?? '');
            setFieldValue('valeurRetenue', row.dataset.garantieRetained ?? '');
            setFieldValue('dateEvaluation', (row.dataset.garantieDate ?? '').slice(0, 10));
            setFieldValue('nomGarant', row.dataset.garantieGuarantor ?? '');
            if (documentField instanceof HTMLInputElement) documentField.value = '';
            syncDocumentMeta(row.dataset.garantieDocument ?? '', '');
            if (retainedField instanceof HTMLInputElement) retainedField.dataset.manual = (row.dataset.garantieRetained ?? '').trim() !== '' ? '1' : '0';
            syncRetained();
            validateForm();
            form.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
    });

    syncDocumentMeta(existingDocumentField instanceof HTMLInputElement ? existingDocumentField.value : '', '');

    const pager = document.getElementById('portal-garanties-pager');
    const rows = Array.from(document.querySelectorAll('[data-garantie-row]'));
    const pageSize = 6;
    let currentPage = 1;

    const renderPager = () => {
        if (!(pager instanceof HTMLElement)) return;
        const totalPages = Math.max(1, Math.ceil(rows.length / pageSize));
        currentPage = Math.min(Math.max(1, currentPage), totalPages);
        pager.innerHTML = '';
        pager.hidden = rows.length === 0;
        if (pager.hidden) return;

        const appendButton = (label, page, { icon = '', disabled = false, active = false, ariaLabel = '' } = {}) => {
            const btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'nx-list-pager-btn';
            btn.disabled = disabled;
            btn.setAttribute('aria-label', ariaLabel || String(label));
            btn.innerHTML = icon ? `<i class="${icon}"></i>` : String(label);
            if (active) btn.classList.add('is-active');
            btn.addEventListener('click', () => {
                if (disabled || page === currentPage) return;
                currentPage = page;
                applyPagination();
            });
            pager.appendChild(btn);
        };

        appendButton('Prev', Math.max(1, currentPage - 1), { icon: 'fa-solid fa-chevron-left', disabled: currentPage === 1, ariaLabel: 'Page precedente' });
        for (let page = 1; page <= totalPages; page += 1) {
            appendButton(String(page), page, { active: page === currentPage });
        }
        appendButton('Next', Math.min(totalPages, currentPage + 1), { icon: 'fa-solid fa-chevron-right', disabled: currentPage === totalPages, ariaLabel: 'Page suivante' });
    };

    const applyPagination = () => {
        const start = (currentPage - 1) * pageSize;
        const end = start + pageSize;
        rows.forEach((row, index) => row.classList.toggle('nx-page-hidden', index < start || index >= end));
        renderPager();
    };

    applyPagination();
})();
</script>
