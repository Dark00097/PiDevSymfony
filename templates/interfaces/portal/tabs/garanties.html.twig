{% set current_date = 'now'|date('Y-m-d') %}
{% set garantie_feedback = support.garantie_form_feedback|default({}) %}
{% if garantie_feedback is empty %}
    {% set garantie_feedback = {'errors': support.form_errors_garantie|default({}), 'input': support.form_data_garantie|default({})} %}
{% endif %}
{% set garantie_old = garantie_feedback.input|default({}) %}
{% set garantie_errors = garantie_feedback.errors|default({}) %}
{% set fraud_stats = support.garantie_fraud_stats|default({'analysed': 0, 'valide': 0, 'a_verifier': 0, 'suspect': 0, 'rejete': 0}) %}

<style>
.nx-list-pager {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 10px;
    margin-top: 16px;
    flex-wrap: wrap;
}

.nx-list-pager[hidden] {
    display: none !important;
}

.nx-list-pager-btn {
    width: 40px;
    height: 40px;
    border-radius: 999px;
    border: 1px solid #cfe0f2;
    background: #fff;
    color: #58789a;
    font-size: 14px;
    font-weight: 800;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
}

.nx-list-pager-btn.is-active {
    background: linear-gradient(135deg, #16a34a, #14b8a6);
    border-color: transparent;
    color: #fff;
}

.nx-list-pager-btn:disabled {
    opacity: .45;
    cursor: default;
}

tr.nx-page-hidden {
    display: none;
}

.nx-fraud-overview {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 12px;
    margin: 16px 0 20px;
}

.nx-fraud-card {
    padding: 14px 16px;
    border-radius: 18px;
    background: linear-gradient(180deg, #f8fbff, #eef5fb);
    border: 1px solid #d7e7f4;
}

.nx-fraud-card strong {
    display: block;
    font-size: 22px;
    color: #11324d;
}

.nx-fraud-card span {
    display: block;
    margin-top: 4px;
    color: #5d7388;
    font-size: 12px;
}

.nx-fraud-box {
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-width: 240px;
}

.nx-fraud-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
}

.nx-fraud-badge {
    display: inline-flex;
    align-items: center;
    padding: 5px 10px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 700;
    line-height: 1.2;
}

.fraud-badge--success { background: #dcfce7; color: #166534; }
.fraud-badge--success-soft { background: #ecfdf5; color: #047857; }
.fraud-badge--warning { background: #fef3c7; color: #92400e; }
.fraud-badge--warning-soft { background: #fffbeb; color: #b45309; }
.fraud-badge--danger { background: #fee2e2; color: #b91c1c; }
.fraud-badge--danger-soft { background: #fff1f2; color: #be123c; }
.fraud-badge--dark { background: #e2e8f0; color: #0f172a; }
.fraud-badge--neutral { background: #eaf1f7; color: #5f7488; }

.nx-fraud-reasons {
    margin: 0;
    padding-left: 18px;
    color: #3d556d;
    font-size: 12px;
}

.nx-fraud-ok {
    margin: 0;
    color: #1d6b45;
    font-size: 12px;
    font-weight: 600;
}

.nx-fraud-history {
    border-top: 1px dashed #d7e2ec;
    padding-top: 8px;
}

.nx-fraud-history summary {
    cursor: pointer;
    color: #2c5f8a;
    font-size: 12px;
    font-weight: 700;
}

.nx-fraud-history-list {
    display: grid;
    gap: 8px;
    margin-top: 8px;
}

.nx-fraud-history-item {
    padding: 8px 10px;
    border-radius: 12px;
    background: #f8fbff;
    border: 1px solid #dbe7f1;
}

.nx-fraud-history-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 6px;
}

.nx-fraud-history-date {
    font-size: 11px;
    color: #64748b;
}
</style>

<section class="panel-card">
    <h2>Garanties</h2>
    <p style="margin:6px 0 16px; color:#6b7280; font-size:13px;">
        Creation, modification, suppression et validation complete des garanties, avec le meme principe que le module compte bancaire.
    </p>

    <div class="nx-fraud-overview">
        <article class="nx-fraud-card">
            <strong>{{ fraud_stats.analysed }}</strong>
            <span>analyses documentaires</span>
        </article>
        <article class="nx-fraud-card">
            <strong>{{ fraud_stats.a_verifier }}</strong>
            <span>dossiers a verifier</span>
        </article>
        <article class="nx-fraud-card">
            <strong>{{ fraud_stats.suspect }}</strong>
            <span>documents suspects</span>
        </article>
        <article class="nx-fraud-card">
            <strong>{{ fraud_stats.rejete }}</strong>
            <span>documents rejetes</span>
        </article>
    </div>

    <form method="post" class="editor-form" id="portal-garantie-form" novalidate enctype="multipart/form-data">
        <input type="hidden" name="tab" value="garanties">
        <input type="hidden" name="action" value="garantie_save">

        <label>
            <span>ID pour modifier</span>
            <input type="number" name="idGarantie" id="portal-garantie-id" placeholder="Laisser vide pour creer" value="{{ garantie_old.idGarantie|default('') }}">
            <span id="g-err-idGarantie" class="g-val-msg">{{ garantie_errors.idGarantie|default('') }}</span>
        </label>
        <label>
            <span>Type garantie <span style="color:#dc2626">*</span></span>
            <select name="typeGarantie" id="portal-garantie-type" class="{{ garantie_errors.typeGarantie is defined ? 'acc-invalid' : '' }}">
                <option value="">Selectionner</option>
                {% for type in ['Hypotheque immobiliere', 'Titre vehicule', 'Caution personnelle', 'Garantie bancaire', 'Police assurance', 'Nantissement', 'Autre garantie'] %}
                    <option value="{{ type }}" {{ garantie_old.typeGarantie|default('') == type ? 'selected' : '' }}>{{ type }}</option>
                {% endfor %}
            </select>
            <span id="g-err-typeGarantie" class="g-val-msg">{{ garantie_errors.typeGarantie|default('') }}</span>
        </label>
        <label>
            <span>Description <span style="color:#dc2626">*</span></span>
            <input type="text" name="description" id="portal-garantie-description" placeholder="Description courte (min. 10 caracteres)" value="{{ garantie_old.description|default('') }}" class="{{ garantie_errors.description is defined ? 'acc-invalid' : '' }}">
            <span id="g-err-description" class="g-val-msg">{{ garantie_errors.description|default('') }}</span>
        </label>
        <label>
            <span>Adresse du bien <span style="color:#dc2626">*</span></span>
            <input type="text" name="adresseBien" id="portal-garantie-address" placeholder="Adresse du bien (min. 5 caracteres)" value="{{ garantie_old.adresseBien|default('') }}" class="{{ garantie_errors.adresseBien is defined ? 'acc-invalid' : '' }}">
            <span id="g-err-adresseBien" class="g-val-msg">{{ garantie_errors.adresseBien|default('') }}</span>
        </label>
        <label style="grid-column:1 / -1;">
            <span>Adresse complete OpenStreetMap</span>
            <input type="text" name="adresseComplete" id="portal-garantie-address-complete" placeholder="Commencez a taper une adresse..." value="{{ garantie_old.adresseComplete|default(garantie_old.adresseBien|default('')) }}" class="{{ garantie_errors.adresseComplete is defined ? 'acc-invalid' : '' }}">
            <div id="portal-garantie-address-suggestions" style="display:grid; gap:6px; margin-top:8px;" hidden></div>
            <span id="g-err-adresseComplete" class="g-val-msg">{{ garantie_errors.adresseComplete|default('') }}</span>
        </label>
        <label>
            <span>Ville</span>
            <input type="text" name="ville" id="portal-garantie-city" value="{{ garantie_old.ville|default('') }}" readonly>
            <span id="g-err-ville" class="g-val-msg">{{ garantie_errors.ville|default('') }}</span>
        </label>
        <label>
            <span>Code postal</span>
            <input type="text" name="codePostal" id="portal-garantie-postal" value="{{ garantie_old.codePostal|default('') }}" readonly>
            <span id="g-err-codePostal" class="g-val-msg">{{ garantie_errors.codePostal|default('') }}</span>
        </label>
        <label>
            <span>Pays</span>
            <input type="text" name="pays" id="portal-garantie-country" value="{{ garantie_old.pays|default('') }}" readonly>
            <span id="g-err-pays" class="g-val-msg">{{ garantie_errors.pays|default('') }}</span>
        </label>
        <label>
            <span>Verification adresse</span>
            <input type="text" name="statutVerificationAdresseLabel" id="portal-garantie-address-status-label" value="{{ garantie_old.statutVerificationAdresse|default('A verifier') }}" readonly>
        </label>
        <input type="hidden" name="latitude" id="portal-garantie-latitude" value="{{ garantie_old.latitude|default('') }}">
        <input type="hidden" name="longitude" id="portal-garantie-longitude" value="{{ garantie_old.longitude|default('') }}">
        <input type="hidden" name="statutVerificationAdresse" id="portal-garantie-address-status" value="{{ garantie_old.statutVerificationAdresse|default('A verifier') }}">
        <div style="grid-column:1 / -1;">
            <div
                id="portal-garantie-map"
                title="Carte OpenStreetMap interactive"
                style="width:100%; height:280px; border-radius:18px; border:1px solid #dbe5ef; overflow:hidden; background:linear-gradient(180deg,#f8fbff,#eef4fa);"
            ></div>
            <small style="display:block; margin-top:8px; color:#64748b; font-size:12px;">
                Cliquez sur la carte ou deplacez le marqueur pour choisir l'emplacement exact du bien.
            </small>
        </div>
        <label>
            <span>Valeur estimee (TND) <span style="color:#dc2626">*</span></span>
            <input type="number" step="0.01" name="valeurEstimee" id="portal-garantie-estimated" placeholder="0.00" value="{{ garantie_old.valeurEstimee|default('') }}" class="{{ garantie_errors.valeurEstimee is defined ? 'acc-invalid' : '' }}">
            <span id="g-err-valeurEstimee" class="g-val-msg">{{ garantie_errors.valeurEstimee|default('') }}</span>
        </label>
        <label>
            <span>Valeur retenue (TND)</span>
            <input type="text" inputmode="decimal" name="valeurRetenue" id="portal-garantie-retained" placeholder="Auto selon type" value="{{ garantie_old.valeurRetenue|default('') }}" class="{{ garantie_errors.valeurRetenue is defined ? 'acc-invalid' : '' }}" readonly>
            <span id="g-err-valeurRetenue" class="g-val-msg">{{ garantie_errors.valeurRetenue|default('') }}</span>
            <small id="portal-garantie-retained-hint" style="display:block; margin-top:4px; color:#64748b; font-size:12px;">Calcul auto selon le type de garantie</small>
        </label>
        <label>
            <span>Date evaluation <span style="color:#dc2626">*</span></span>
            <input type="date" name="dateEvaluation" id="portal-garantie-date" value="{{ garantie_old.dateEvaluation|default(current_date) }}" class="{{ garantie_errors.dateEvaluation is defined ? 'acc-invalid' : '' }}">
            <span id="g-err-dateEvaluation" class="g-val-msg">{{ garantie_errors.dateEvaluation|default('') }}</span>
        </label>
        <label>
            <span>Document justificatif <span style="color:#dc2626">*</span></span>
            <input type="hidden" name="existingDocumentJustificatif" id="portal-garantie-document-existing" value="{{ garantie_old.documentJustificatif|default('') }}">
            <input type="file" name="documentJustificatifFile" id="portal-garantie-document" accept="image/png,image/jpeg,image/webp,image/gif" class="{{ garantie_errors.documentJustificatif is defined ? 'acc-invalid' : '' }}">
            <small id="portal-garantie-document-label" style="display:block; margin-top:6px; color:#6b7280;">{{ garantie_old.documentJustificatif|default('') ? 'Image deja enregistree' : 'Formats acceptes: PNG, JPG, WEBP, GIF' }}</small>
            <a id="portal-garantie-document-link" href="{{ garantie_old.documentJustificatif|default('') ? asset(garantie_old.documentJustificatif) : '#' }}" target="_blank" rel="noopener" {{ garantie_old.documentJustificatif|default('') ? '' : 'hidden' }}>Voir l'image actuelle</a>
            <span id="g-err-documentJustificatif" class="g-val-msg">{{ garantie_errors.documentJustificatif|default('') }}</span>
        </label>
        <label>
            <span>Nom garant <span style="color:#dc2626">*</span></span>
            <input type="text" name="nomGarant" id="portal-garantie-guarantor" placeholder="Nom du garant" value="{{ garantie_old.nomGarant|default('') }}" class="{{ garantie_errors.nomGarant is defined ? 'acc-invalid' : '' }}">
            <span id="g-err-nomGarant" class="g-val-msg">{{ garantie_errors.nomGarant|default('') }}</span>
        </label>
        <div style="display:flex; gap:8px; margin-top:8px;">
            <button class="btn btn-primary" type="submit">Enregistrer</button>
            <button class="btn btn-secondary" type="reset">Vider</button>
        </div>
    </form>

    <div class="table-wrap" style="margin-top:16px;">
        <table class="data-table">
            <thead>
            <tr>
                <th>ID</th>
                <th>Credit</th>
                <th>Type</th>
                <th>Estimee</th>
                <th>Retenue</th>
                <th>Statut</th>
                <th>Fraude</th>
                <th>Actions</th>
            </tr>
            </thead>
            <tbody>
            {% for item in items %}
                {% set fraud = item.fraud_analysis|default(null) %}
                {% set fraud_history = item.fraud_history|default([]) %}
                <tr
                    data-garantie-row
                    data-garantie-id="{{ item.idGarantie }}"
                    data-garantie-credit-id="{{ item.idCredit }}"
                    data-garantie-type="{{ item.typeGarantie|default('')|e('html_attr') }}"
                    data-garantie-description="{{ item.description|default('')|e('html_attr') }}"
                    data-garantie-address="{{ item.adresseBien|default('')|e('html_attr') }}"
                    data-garantie-address-complete="{{ item.adresseComplete|default(item.adresseBien|default(''))|e('html_attr') }}"
                    data-garantie-city="{{ item.ville|default('')|e('html_attr') }}"
                    data-garantie-postal="{{ item.codePostal|default('')|e('html_attr') }}"
                    data-garantie-country="{{ item.pays|default('')|e('html_attr') }}"
                    data-garantie-latitude="{{ item.latitude|default('') }}"
                    data-garantie-longitude="{{ item.longitude|default('') }}"
                    data-garantie-address-status="{{ item.statutVerificationAdresse|default('A verifier')|e('html_attr') }}"
                    data-garantie-estimated="{{ item.valeurEstimee|default('') }}"
                    data-garantie-retained="{{ item.valeurRetenue|default('') }}"
                    data-garantie-document="{{ item.documentJustificatif|default('')|e('html_attr') }}"
                    data-garantie-date="{{ item.dateEvaluation|default(current_date)|slice(0, 10) }}"
                    data-garantie-guarantor="{{ item.nomGarant|default('')|e('html_attr') }}"
                    data-garantie-status="{{ item.statut|default('')|e('html_attr') }}"
                >
                    <td>{{ item.idGarantie }}</td>
                    <td>
                        {% if item.linkedCreditCount|default(0) > 1 %}
                            {{ item.linkedCreditCount }} credits
                        {% elseif item.idCredit %}
                            #{{ item.idCredit }}
                        {% else %}
                            Non associee
                        {% endif %}
                    </td>
                    <td>{{ item.typeGarantie }}</td>
                    <td>{{ item.valeurEstimee|default(0)|number_format(2, '.', ' ') }}</td>
                    <td>{{ item.valeurRetenue|default(0)|number_format(2, '.', ' ') }}</td>
                    <td>{{ item.statut }}</td>
                    <td>
                        {% if item.fraud is defined and item.fraud %}
                            <span class="badge {{ item.fraud.badge_class }} px-2 py-1">{{ item.fraud.level|capitalize }} - {{ item.fraud.status }}</span>
                            {% if item.fraud.reasons is defined and item.fraud.reasons|length > 0 %}
                                <div style="margin-top:6px; font-size:12px; color:#475569;">{{ item.fraud.reasons|join(', ') }}</div>
                            {% endif %}
                        {% else %}
                            <span class="badge text-bg-secondary">Non analyse</span>
                        {% endif %}
                    </td>
                    <td style="display:flex; gap:8px;">
                        <button class="btn btn-secondary js-garantie-edit" type="button">Modifier</button>
                        <form method="post">
                            <input type="hidden" name="tab" value="garanties">
                            <input type="hidden" name="action" value="garantie_delete">
                            <input type="hidden" name="idGarantie" value="{{ item.idGarantie }}">
                            <button class="btn btn-danger" type="submit" onclick="return confirm('Supprimer cette garantie ?')">Supprimer</button>
                        </form>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="8">Aucune garantie enregistree.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

    {% if support.garantie_fraud_history is defined and support.garantie_fraud_history|length > 0 %}
        <section class="panel-card" style="margin-top:24px;">
            <h3>Historique des analyses de fraude documentaire</h3>
            <div class="table-wrap" style="margin-top:12px;">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Garantie</th>
                            <th>Date</th>
                            <th>Score</th>
                            <th>Etat</th>
                            <th>Raisons</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for garantieId, events in support.garantie_fraud_history %}
                            {% for event in events %}
                                <tr>
                                    <td>#{{ garantieId }}</td>
                                    <td>{{ event.created_at_label|default(event.created_at|default('N/A')) }}</td>
                                    <td>{{ event.score }}</td>
                                    <td>{{ event.level }} - {{ event.status }}</td>
                                    <td>{{ event.reasons|default([])|join(', ') }}</td>
                                </tr>
                            {% endfor %}
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </section>
    {% endif %}

    <div class="nx-list-pager" id="portal-garanties-pager" hidden></div>
</section>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
(() => {
    const form = document.getElementById('portal-garantie-form');
    if (!(form instanceof HTMLFormElement)) return;

    const estimatedField = document.getElementById('portal-garantie-estimated');
    const retainedField = document.getElementById('portal-garantie-retained');
    const retainedHint = document.getElementById('portal-garantie-retained-hint');
    const dateField = document.getElementById('portal-garantie-date');
    const idField = document.getElementById('portal-garantie-id');
    const typeField = document.getElementById('portal-garantie-type');
    const addressField = document.getElementById('portal-garantie-address');
    const addressCompleteField = document.getElementById('portal-garantie-address-complete');
    const cityField = document.getElementById('portal-garantie-city');
    const postalField = document.getElementById('portal-garantie-postal');
    const countryField = document.getElementById('portal-garantie-country');
    const latitudeField = document.getElementById('portal-garantie-latitude');
    const longitudeField = document.getElementById('portal-garantie-longitude');
    const addressStatusField = document.getElementById('portal-garantie-address-status');
    const addressStatusLabelField = document.getElementById('portal-garantie-address-status-label');
    const mapCanvas = document.getElementById('portal-garantie-map');
    const addressSuggestions = document.getElementById('portal-garantie-address-suggestions');
    const documentField = document.getElementById('portal-garantie-document');
    const existingDocumentField = document.getElementById('portal-garantie-document-existing');
    const documentLabel = document.getElementById('portal-garantie-document-label');
    const documentLink = document.getElementById('portal-garantie-document-link');
    const currentDateIso = '{{ current_date }}';
    const todayDate = new Date(`${currentDateIso}T00:00:00`);
    const fieldNames = ['typeGarantie', 'description', 'adresseBien', 'adresseComplete', 'valeurEstimee', 'valeurRetenue', 'dateEvaluation', 'documentJustificatif', 'nomGarant'];
    let addressSearchTimer = null;
    let mapInstance = null;
    let mapMarker = null;
    let mapResizeTimer = null;
    let reverseLookupToken = 0;
    const defaultMapCenter = { lat: 36.8065, lng: 10.1815, zoom: 11 };

    const parseNum = (v) => {
        const normalized = String(v ?? '')
            .replace(/\s+/g, '')
            .replace(',', '.')
            .trim();
        const n = Number(normalized);
        return Number.isFinite(n) ? n : 0;
    };
    const formatDecimalDisplay = (value, decimals = 2) => Number.isFinite(value) && value > 0
        ? value.toFixed(decimals)
        : '';
    const normalizeDecimalInputValue = (field) => {
        if (!(field instanceof HTMLInputElement)) return;
        const normalized = String(field.value ?? '')
            .replace(/\s+/g, '')
            .replace(',', '.')
            .trim();
        if (field.value !== normalized) {
            field.value = normalized;
        }
    };
    const parseInputDate = (rawValue) => {
        const raw = String(rawValue ?? '').trim();
        if (raw === '') return null;
        const parsed = new Date(`${raw}T00:00:00`);
        return Number.isNaN(parsed.getTime()) ? null : parsed;
    };
    const isEditMode = () => idField instanceof HTMLInputElement && idField.value.trim() !== '' && Number(idField.value) > 0;
    const syncDateFieldConstraint = () => {
        if (!(dateField instanceof HTMLInputElement)) return;
        if (isEditMode()) {
            dateField.removeAttribute('min');
        } else {
            dateField.min = currentDateIso;
        }
    };
    const fieldElement = (name) => form.querySelector(`[name="${name}"]`);
    const messageElement = (name) => document.getElementById(`g-err-${name}`);
    const setError = (field, msgEl, message) => {
        field?.classList.add('acc-invalid');
        field?.classList.remove('acc-valid');
        if (msgEl) {
            msgEl.textContent = '⚠ ' + message;
            msgEl.style.color = '#dc2626';
            msgEl.style.fontWeight = '600';
            msgEl.style.fontSize = '12px';
            msgEl.style.marginTop = '4px';
        }
        return false;
    };
    const setValid = (field, msgEl) => {
        field?.classList.remove('acc-invalid');
        field?.classList.add('acc-valid');
        if (msgEl) {
            msgEl.textContent = '✓ Valide';
            msgEl.style.color = '#16a34a';
            msgEl.style.fontWeight = '600';
            msgEl.style.fontSize = '12px';
            msgEl.style.marginTop = '4px';
        }
        return true;
    };
    const clearValid = (field, msgEl) => {
        field?.classList.remove('acc-invalid', 'acc-valid');
        if (msgEl) {
            msgEl.textContent = '';
        }
        return true;
    };
    const waitLeaflet = (callback) => {
        if (typeof window.L !== 'undefined') {
            callback();
            return;
        }
        let attempts = 0;
        const intervalId = window.setInterval(() => {
            if (typeof window.L !== 'undefined') {
                window.clearInterval(intervalId);
                callback();
                return;
            }
            attempts += 1;
            if (attempts > 40) {
                window.clearInterval(intervalId);
            }
        }, 150);
    };
    const parseCoordinate = (value) => {
        const normalized = String(value ?? '').replace(',', '.').trim();
        const number = Number.parseFloat(normalized);
        return Number.isFinite(number) ? number : null;
    };
    const invalidateMapSize = (delay = 0) => {
        window.setTimeout(() => {
            if (!mapInstance) return;
            try {
                mapInstance.invalidateSize({ pan: false });
            } catch (_error) {
            }
        }, delay);
    };
    const invalidateMapBurst = () => {
        invalidateMapSize(0);
        invalidateMapSize(120);
        invalidateMapSize(320);
    };
    const ensureMapInstance = () => {
        if (!(mapCanvas instanceof HTMLElement) || typeof window.L === 'undefined') {
            return false;
        }
        if (mapInstance) {
            return true;
        }

        mapInstance = window.L.map(mapCanvas, {
            scrollWheelZoom: true,
            preferCanvas: true,
            zoomControl: true,
        }).setView([defaultMapCenter.lat, defaultMapCenter.lng], defaultMapCenter.zoom);

        window.L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 19,
            keepBuffer: 4,
            updateWhenIdle: true,
            attribution: '&copy; OpenStreetMap',
        }).addTo(mapInstance);

        mapInstance.on('click', (event) => {
            applyMapSelection(event.latlng.lat, event.latlng.lng);
        });

        window.addEventListener('resize', () => {
            window.clearTimeout(mapResizeTimer);
            mapResizeTimer = window.setTimeout(() => {
                invalidateMapBurst();
            }, 90);
        });

        invalidateMapBurst();
        return true;
    };
    const setMapMarker = (latValue, lngValue, zoom = 15) => {
        if (!ensureMapInstance()) return;

        const latitude = parseCoordinate(latValue);
        const longitude = parseCoordinate(lngValue);
        if (latitude === null || longitude === null) {
            if (mapMarker) {
                mapInstance.removeLayer(mapMarker);
                mapMarker = null;
            }
            mapInstance.setView([defaultMapCenter.lat, defaultMapCenter.lng], defaultMapCenter.zoom);
            invalidateMapBurst();
            return;
        }

        const latLng = [latitude, longitude];
        if (!mapMarker) {
            mapMarker = window.L.marker(latLng, { draggable: true }).addTo(mapInstance);
            mapMarker.on('dragend', () => {
                const position = mapMarker.getLatLng();
                applyMapSelection(position.lat, position.lng);
            });
        } else {
            mapMarker.setLatLng(latLng);
        }

        mapInstance.setView(latLng, zoom);
        invalidateMapBurst();
    };
    const setAddressVerificationStatus = (status) => {
        const value = String(status ?? '').trim() || 'A verifier';
        if (addressStatusField instanceof HTMLInputElement) addressStatusField.value = value;
        if (addressStatusLabelField instanceof HTMLInputElement) addressStatusLabelField.value = value;
    };
    const updateMapMarker = (lat, lng) => {
        setMapMarker(lat, lng);
    };
    const renderAddressSuggestions = (items) => {
        if (!(addressSuggestions instanceof HTMLElement)) return;
        addressSuggestions.innerHTML = '';
        if (!Array.isArray(items) || items.length === 0) {
            addressSuggestions.hidden = true;
            return;
        }

        items.forEach((item) => {
            const option = document.createElement('button');
            option.type = 'button';
            option.className = 'btn btn-secondary';
            option.style.textAlign = 'left';
            option.textContent = String(item.display_name ?? '').trim();
            option.addEventListener('click', () => syncAddressFieldsFromPlace(item));
            addressSuggestions.appendChild(option);
        });
        addressSuggestions.hidden = false;
    };
    const hideAddressSuggestions = () => {
        if (!(addressSuggestions instanceof HTMLElement)) return;
        addressSuggestions.hidden = true;
        addressSuggestions.innerHTML = '';
    };
    const syncAddressFieldsFromPlace = (place, { overwriteAddress = false } = {}) => {
        const formattedAddress = String(place?.display_name || '');
        const lat = String(place?.lat ?? '');
        const lng = String(place?.lon ?? '');
        const address = place?.address ?? {};
        const city = String(address.city || address.town || address.village || address.county || address.state || '');
        const postalCode = String(address.postcode || '');
        const country = String(address.country || '');

        if (addressCompleteField instanceof HTMLInputElement && formattedAddress !== '') addressCompleteField.value = formattedAddress;
        if (addressField instanceof HTMLInputElement && (overwriteAddress || addressField.value.trim() === '')) addressField.value = formattedAddress;
        if (cityField instanceof HTMLInputElement) cityField.value = city;
        if (postalField instanceof HTMLInputElement) postalField.value = postalCode;
        if (countryField instanceof HTMLInputElement) countryField.value = country;
        if (latitudeField instanceof HTMLInputElement) latitudeField.value = lat;
        if (longitudeField instanceof HTMLInputElement) longitudeField.value = lng;

        setAddressVerificationStatus(formattedAddress !== '' && lat !== '' && lng !== '' ? 'Verifiee' : 'A verifier');
        updateMapMarker(lat, lng);
        hideAddressSuggestions();
        validateField('adresseBien');
        validateField('adresseComplete');
    };
    const reverseGeocodeCoordinates = async (lat, lng) => {
        const response = await fetch(`https://nominatim.openstreetmap.org/reverse?format=jsonv2&addressdetails=1&zoom=18&lat=${encodeURIComponent(String(lat))}&lon=${encodeURIComponent(String(lng))}`, {
            headers: {
                'Accept': 'application/json',
                'Accept-Language': 'fr',
            },
        });
        if (!response.ok) {
            throw new Error('Reverse geocoding indisponible.');
        }
        return response.json();
    };
    const applyMapSelection = async (lat, lng) => {
        const normalizedLat = Number(lat);
        const normalizedLng = Number(lng);
        if (!Number.isFinite(normalizedLat) || !Number.isFinite(normalizedLng)) {
            return;
        }

        const latValue = normalizedLat.toFixed(6);
        const lngValue = normalizedLng.toFixed(6);
        if (latitudeField instanceof HTMLInputElement) latitudeField.value = latValue;
        if (longitudeField instanceof HTMLInputElement) longitudeField.value = lngValue;
        setAddressVerificationStatus('Verification...');
        updateMapMarker(latValue, lngValue);
        hideAddressSuggestions();

        const currentLookupToken = ++reverseLookupToken;
        try {
            const place = await reverseGeocodeCoordinates(latValue, lngValue);
            if (currentLookupToken !== reverseLookupToken) return;
            syncAddressFieldsFromPlace(place, { overwriteAddress: true });
        } catch (_error) {
            if (currentLookupToken !== reverseLookupToken) return;
            const fallbackAddress = `Point choisi sur la carte (${latValue}, ${lngValue})`;
            if (addressCompleteField instanceof HTMLInputElement) addressCompleteField.value = fallbackAddress;
            if (addressField instanceof HTMLInputElement && addressField.value.trim() === '') addressField.value = fallbackAddress;
            setAddressVerificationStatus('Verifiee');
            validateField('adresseBien');
            validateField('adresseComplete');
        }
    };
    const clearAddressDetails = () => {
        if (cityField instanceof HTMLInputElement) cityField.value = '';
        if (postalField instanceof HTMLInputElement) postalField.value = '';
        if (countryField instanceof HTMLInputElement) countryField.value = '';
        if (latitudeField instanceof HTMLInputElement) latitudeField.value = '';
        if (longitudeField instanceof HTMLInputElement) longitudeField.value = '';
        setAddressVerificationStatus('A verifier');
        updateMapMarker('', '');
        hideAddressSuggestions();
    };
    const initGarantieMaps = () => {
        waitLeaflet(() => {
            if (!(addressCompleteField instanceof HTMLInputElement)) {
                return;
            }
            updateMapMarker(
                latitudeField instanceof HTMLInputElement ? latitudeField.value : '',
                longitudeField instanceof HTMLInputElement ? longitudeField.value : ''
            );
        });
    };
    const syncDocumentMeta = (path = '', label = '') => {
        const resolvedPath = String(path ?? '').trim();
        if (existingDocumentField instanceof HTMLInputElement) {
            existingDocumentField.value = resolvedPath;
        }
        if (documentLabel) {
            documentLabel.textContent = label || (resolvedPath !== '' ? 'Image deja enregistree' : 'Formats acceptes: PNG, JPG, WEBP, GIF');
        }
        if (documentLink instanceof HTMLAnchorElement) {
            if (resolvedPath !== '') {
                documentLink.href = resolvedPath.startsWith('/') ? resolvedPath : `/${resolvedPath}`;
                documentLink.hidden = false;
            } else {
                documentLink.href = '#';
                documentLink.hidden = true;
            }
        }
    };

    const normalizeGarantieTypeKey = (value) => String(value ?? '')
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '')
        .toLowerCase()
        .trim();
    const getRetentionRate = () => {
        const retentionRates = {
            'hypotheque immobiliere': 0.8,
            'titre vehicule': 0.7,
            'caution personnelle': 0.5,
            'garantie bancaire': 1,
            'police assurance': 0.6,
            'nantissement': 0.75,
            'autre garantie': 0.5,
        };

        return retentionRates[normalizeGarantieTypeKey(typeField?.value ?? '')] ?? 0.8;
    };
    const syncRetainedHint = () => {
        if (!(retainedHint instanceof HTMLElement)) return;
        const typeLabel = String(typeField?.value ?? '').trim();
        const ratePercent = Math.round(getRetentionRate() * 100);
        retainedHint.textContent = typeLabel !== ''
            ? `Calcul auto: ${ratePercent}% pour ${typeLabel}`
            : 'Calcul auto selon le type de garantie';
    };
    const getExpectedRetained = () => {
        if (!(estimatedField instanceof HTMLInputElement)) return 0;
        const estimated = parseNum(estimatedField.value);
        return estimated > 0 ? Number((estimated * getRetentionRate()).toFixed(2)) : 0;
    };

    const syncRetained = () => {
        if (!(estimatedField instanceof HTMLInputElement) || !(retainedField instanceof HTMLInputElement)) return;
        const retained = getExpectedRetained();
        retainedField.dataset.manual = '0';
        retainedField.value = formatDecimalDisplay(retained);
        syncRetainedHint();
    };

    const validateField = (name) => {
        const field = fieldElement(name);
        const msgEl = messageElement(name);
        const value = String(field?.value ?? '').trim();

        switch (name) {
            case 'typeGarantie':
                return value === '' ? setError(field, msgEl, 'Veuillez selectionner un type de garantie.') : setValid(field, msgEl);
            case 'description':
                if (value === '') return setError(field, msgEl, 'La description est obligatoire.');
                if (value.length < 10) return setError(field, msgEl, 'La description doit contenir au moins 10 caracteres.');
                return setValid(field, msgEl);
            case 'adresseBien':
                if (value === '') return setError(field, msgEl, "L'adresse du bien est obligatoire.");
                if (value.length < 5) return setError(field, msgEl, "L'adresse doit contenir au moins 5 caracteres.");
                return setValid(field, msgEl);
            case 'adresseComplete':
                if (value === '') return clearValid(field, msgEl);
                if (value.length < 5) return setError(field, msgEl, "L'adresse complete est trop courte.");
                return setValid(field, msgEl);
            case 'valeurEstimee': {
                const estimated = parseNum(value);
                if (value === '') return setError(field, msgEl, 'La valeur estimee est obligatoire.');
                if (estimated <= 0) return setError(field, msgEl, 'La valeur estimee doit etre positive.');
                if (estimated < 1000 || estimated > 100000000) return setError(field, msgEl, 'La valeur estimee doit etre comprise entre 1000 et 100000000 DT.');
                return setValid(field, msgEl);
            }
            case 'valeurRetenue': {
                if (value === '') return setError(field, msgEl, 'La valeur retenue est obligatoire.');
                const retained = parseNum(value);
                const estimated = parseNum(estimatedField?.value);
                if (retained <= 0) return setError(field, msgEl, 'La valeur retenue doit etre positive.');
                if (estimated > 0 && retained > estimated) return setError(field, msgEl, "La valeur retenue ne doit pas depasser l'estimee.");
                return setValid(field, msgEl);
            }
            case 'dateEvaluation': {
                const parsedDate = parseInputDate(value);
                if (value === '') return setError(field, msgEl, "La date d'evaluation est obligatoire.");
                if (!parsedDate) return setError(field, msgEl, "Date d'evaluation invalide.");
                if (!isEditMode() && parsedDate < todayDate) return setError(field, msgEl, "La date d'evaluation ne peut pas etre dans le passe.");
                return setValid(field, msgEl);
            }
            case 'documentJustificatif': {
                const file = documentField instanceof HTMLInputElement ? documentField.files?.[0] ?? null : null;
                const existingPath = existingDocumentField instanceof HTMLInputElement ? existingDocumentField.value.trim() : '';
                const allowedTypes = ['image/jpeg', 'image/png', 'image/webp', 'image/gif'];
                if (file) {
                    if (!allowedTypes.includes(file.type)) {
                        return setError(documentField, msgEl, 'Le document justificatif doit etre une image JPG, PNG, WEBP ou GIF.');
                    }
                    return setValid(documentField, msgEl);
                }
                if (existingPath === '') return setError(documentField, msgEl, 'Le document justificatif est obligatoire.');
                return setValid(documentField, msgEl);
            }
            case 'nomGarant':
                if (value === '') return setError(field, msgEl, 'Le nom du garant est obligatoire.');
                if (value.length < 2) return setError(field, msgEl, 'Le nom doit contenir au moins 2 caracteres.');
                if (!/^[\p{L}\s\-']+$/u.test(value)) return setError(field, msgEl, 'Le nom du garant ne doit contenir que des lettres.');
                return setValid(field, msgEl);
            default:
                return true;
        }
    };
    const validateForm = () => fieldNames.map((name) => validateField(name)).every((res) => res);

    estimatedField?.addEventListener('input', () => {
        normalizeDecimalInputValue(estimatedField);
        syncRetained();
        validateField('valeurEstimee');
        validateField('valeurRetenue');
    });
    typeField?.addEventListener('change', () => {
        syncRetained();
        validateField('typeGarantie');
        validateField('valeurRetenue');
    });
    documentField?.addEventListener('change', () => {
        const file = documentField instanceof HTMLInputElement ? documentField.files?.[0] ?? null : null;
        syncDocumentMeta(existingDocumentField instanceof HTMLInputElement ? existingDocumentField.value : '', file ? `Fichier selectionne: ${file.name}` : '');
        validateField('documentJustificatif');
    });
    addressCompleteField?.addEventListener('input', () => {
        window.clearTimeout(addressSearchTimer);
        if (latitudeField instanceof HTMLInputElement) latitudeField.value = '';
        if (longitudeField instanceof HTMLInputElement) longitudeField.value = '';
        setAddressVerificationStatus('A verifier');
        validateField('adresseComplete');
        const query = String(addressCompleteField.value ?? '').trim();
        if (query.length < 4) {
            hideAddressSuggestions();
            updateMapMarker('', '');
            return;
        }
        addressSearchTimer = window.setTimeout(async () => {
            try {
                const response = await fetch(`https://nominatim.openstreetmap.org/search?format=jsonv2&addressdetails=1&limit=5&q=${encodeURIComponent(query)}`, {
                    headers: {
                        'Accept': 'application/json',
                        'Accept-Language': 'fr',
                    },
                });
                if (!response.ok) {
                    throw new Error('OpenStreetMap indisponible');
                }
                const items = await response.json();
                renderAddressSuggestions(items);
            } catch (_error) {
                hideAddressSuggestions();
            }
        }, 350);
    });

    fieldNames.forEach((name) => {
        if (name === 'valeurEstimee' || name === 'valeurRetenue' || name === 'documentJustificatif') return;
        const field = fieldElement(name);
        if (!field) return;
        field.addEventListener('input', () => validateField(name));
        field.addEventListener('change', () => validateField(name));
        field.addEventListener('blur', () => validateField(name));
    });

    form.addEventListener('reset', () => {
        requestAnimationFrame(() => {
            if (idField instanceof HTMLInputElement) idField.value = '';
            if (retainedField instanceof HTMLInputElement) retainedField.dataset.manual = '0';
            if (dateField instanceof HTMLInputElement) dateField.value = currentDateIso;
            syncDateFieldConstraint();
            if (documentField instanceof HTMLInputElement) documentField.value = '';
            if (addressCompleteField instanceof HTMLInputElement) addressCompleteField.value = '';
            syncDocumentMeta('', '');
            clearAddressDetails();
            fieldNames.forEach((name) => clearValid(fieldElement(name), messageElement(name)));
            syncRetained();
        });
    });

    form.addEventListener('submit', (event) => {
        normalizeDecimalInputValue(estimatedField);
        normalizeDecimalInputValue(retainedField);
        syncRetained();
        if (!validateForm()) {
            event.preventDefault();
        }
    });

    const setFieldValue = (name, value) => {
        const field = fieldElement(name);
        if (field instanceof HTMLInputElement || field instanceof HTMLSelectElement || field instanceof HTMLTextAreaElement) {
            field.value = value ?? '';
        }
    };

    document.querySelectorAll('.js-garantie-edit').forEach((btn) => {
        btn.addEventListener('click', () => {
            const row = btn.closest('[data-garantie-row]');
            if (!row) return;
            setFieldValue('idGarantie', row.dataset.garantieId ?? '');
            setFieldValue('typeGarantie', row.dataset.garantieType ?? '');
            setFieldValue('description', row.dataset.garantieDescription ?? '');
            setFieldValue('adresseBien', row.dataset.garantieAddress ?? '');
            setFieldValue('valeurEstimee', row.dataset.garantieEstimated ?? '');
            setFieldValue('valeurRetenue', row.dataset.garantieRetained ?? '');
            setFieldValue('dateEvaluation', (row.dataset.garantieDate ?? '').slice(0, 10));
            syncDateFieldConstraint();
            setFieldValue('nomGarant', row.dataset.garantieGuarantor ?? '');
            if (documentField instanceof HTMLInputElement) documentField.value = '';
            syncDocumentMeta(row.dataset.garantieDocument ?? '', '');
            setFieldValue('adresseComplete', row.dataset.garantieAddressComplete ?? '');
            setFieldValue('ville', row.dataset.garantieCity ?? '');
            setFieldValue('codePostal', row.dataset.garantiePostal ?? '');
            setFieldValue('pays', row.dataset.garantieCountry ?? '');
            setFieldValue('latitude', row.dataset.garantieLatitude ?? '');
            setFieldValue('longitude', row.dataset.garantieLongitude ?? '');
            setAddressVerificationStatus(row.dataset.garantieAddressStatus ?? 'A verifier');
            updateMapMarker(row.dataset.garantieLatitude ?? '', row.dataset.garantieLongitude ?? '');
            syncRetained();
            validateForm();
            form.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
    });

    syncDateFieldConstraint();
    syncDocumentMeta(existingDocumentField instanceof HTMLInputElement ? existingDocumentField.value : '', '');
    initGarantieMaps();
    syncRetained();
    document.addEventListener('click', (event) => {
        if (!(addressSuggestions instanceof HTMLElement) || addressSuggestions.hidden) return;
        if (addressSuggestions.contains(event.target) || addressCompleteField?.contains(event.target)) return;
        hideAddressSuggestions();
    });

    const pager = document.getElementById('portal-garanties-pager');
    const rows = Array.from(document.querySelectorAll('[data-garantie-row]'));
    const pageSize = 6;
    let currentPage = 1;

    const renderPager = () => {
        if (!(pager instanceof HTMLElement)) return;
        const totalPages = Math.max(1, Math.ceil(rows.length / pageSize));
        currentPage = Math.min(Math.max(1, currentPage), totalPages);
        pager.innerHTML = '';
        pager.hidden = rows.length === 0;
        if (pager.hidden) return;

        const appendButton = (label, page, { icon = '', disabled = false, active = false, ariaLabel = '' } = {}) => {
            const btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'nx-list-pager-btn';
            btn.disabled = disabled;
            btn.setAttribute('aria-label', ariaLabel || String(label));
            btn.innerHTML = icon ? `<i class="${icon}"></i>` : String(label);
            if (active) btn.classList.add('is-active');
            btn.addEventListener('click', () => {
                if (disabled || page === currentPage) return;
                currentPage = page;
                applyPagination();
            });
            pager.appendChild(btn);
        };

        appendButton('Prev', Math.max(1, currentPage - 1), { icon: 'fa-solid fa-chevron-left', disabled: currentPage === 1, ariaLabel: 'Page precedente' });
        for (let page = 1; page <= totalPages; page += 1) {
            appendButton(String(page), page, { active: page === currentPage });
        }
        appendButton('Next', Math.min(totalPages, currentPage + 1), { icon: 'fa-solid fa-chevron-right', disabled: currentPage === totalPages, ariaLabel: 'Page suivante' });
    };

    const applyPagination = () => {
        const start = (currentPage - 1) * pageSize;
        const end = start + pageSize;
        rows.forEach((row, index) => row.classList.toggle('nx-page-hidden', index < start || index >= end));
        renderPager();
    };

    applyPagination();
})();
</script>
