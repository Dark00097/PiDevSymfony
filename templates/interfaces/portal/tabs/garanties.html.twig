{% set current_date = 'now'|date('Y-m-d') %}

<section class="panel-card">
    <h2>Garanties</h2>
    <p style="margin:6px 0 16px; color:#6b7280; font-size:13px;">
        Meme logique metier que la version Java: creation, modification, suppression et validation des valeurs.
    </p>

    <form method="post" class="editor-form" id="portal-garantie-form" novalidate>
        <input type="hidden" name="tab" value="garanties">
        <input type="hidden" name="action" value="garantie_save">

        <label>
            <span>ID pour modifier</span>
            <input type="number" name="idGarantie" id="portal-garantie-id" placeholder="Laisser vide pour creer">
        </label>
        <label>
            <span>Credit lie <span style="color:#dc2626">*</span></span>
            <select name="idCredit" id="portal-garantie-credit">
                <option value="">Selectionner</option>
                {% for credit in support.credits|default([]) %}
                    <option value="{{ credit.idCredit }}">#{{ credit.idCredit }} - {{ credit.typeCredit|default('Credit') }}</option>
                {% endfor %}
            </select>
            <span id="g-err-idCredit" class="g-val-msg"></span>
        </label>
        <label>
            <span>Type garantie <span style="color:#dc2626">*</span></span>
            <select name="typeGarantie" id="portal-garantie-type">
                {% for type in ['Hypotheque immobiliere', 'Titre vehicule', 'Caution personnelle', 'Garantie bancaire', 'Police assurance', 'Nantissement', 'Autre garantie'] %}
                    <option value="{{ type }}">{{ type }}</option>
                {% endfor %}
            </select>
            <span id="g-err-typeGarantie" class="g-val-msg"></span>
        </label>
        <label>
            <span>Description <span style="color:#dc2626">*</span></span>
            <input type="text" name="description" id="portal-garantie-description" placeholder="Description courte (min. 10 caractères)">
            <span id="g-err-description" class="g-val-msg"></span>
        </label>
        <label>
            <span>Adresse du bien <span style="color:#dc2626">*</span></span>
            <input type="text" name="adresseBien" id="portal-garantie-address" placeholder="Adresse du bien (min. 5 caractères)">
            <span id="g-err-adresseBien" class="g-val-msg"></span>
        </label>
        <label>
            <span>Valeur estimee (TND) <span style="color:#dc2626">*</span></span>
            <input type="number" step="0.01" name="valeurEstimee" id="portal-garantie-estimated" placeholder="0.00">
            <span id="g-err-valeurEstimee" class="g-val-msg"></span>
        </label>
        <label>
            <span>Valeur retenue (TND)</span>
            <input type="number" step="0.01" name="valeurRetenue" id="portal-garantie-retained" placeholder="Auto (80% estimee)">
            <span id="g-err-valeurRetenue" class="g-val-msg"></span>
        </label>
        <label>
            <span>Date evaluation <span style="color:#dc2626">*</span></span>
            <input type="date" name="dateEvaluation" id="portal-garantie-date" value="{{ current_date }}">
            <span id="g-err-dateEvaluation" class="g-val-msg"></span>
        </label>
        <label>
            <span>Document justificatif <span style="color:#dc2626">*</span></span>
            <input type="text" name="documentJustificatif" id="portal-garantie-document" placeholder="Reference document">
            <span id="g-err-documentJustificatif" class="g-val-msg"></span>
        </label>
        <label>
            <span>Nom garant <span style="color:#dc2626">*</span></span>
            <input type="text" name="nomGarant" id="portal-garantie-guarantor" placeholder="Nom du garant">
            <span id="g-err-nomGarant" class="g-val-msg"></span>
        </label>
        <div style="display:flex; gap:8px; margin-top:8px;">
            <button class="btn btn-primary" type="submit">Enregistrer</button>
            <button class="btn btn-secondary" type="reset">Vider</button>
        </div>
    </form>

    <div class="table-wrap" style="margin-top:16px;">
        <table class="data-table">
            <thead>
            <tr>
                <th>ID</th>
                <th>Credit</th>
                <th>Type</th>
                <th>Estimee</th>
                <th>Retenue</th>
                <th>Statut</th>
                <th>Actions</th>
            </tr>
            </thead>
            <tbody>
            {% for item in items %}
                <tr
                    data-garantie-row
                    data-garantie-id="{{ item.idGarantie }}"
                    data-garantie-credit-id="{{ item.idCredit }}"
                    data-garantie-type="{{ item.typeGarantie|default('')|e('html_attr') }}"
                    data-garantie-description="{{ item.description|default('')|e('html_attr') }}"
                    data-garantie-address="{{ item.adresseBien|default('')|e('html_attr') }}"
                    data-garantie-estimated="{{ item.valeurEstimee|default('') }}"
                    data-garantie-retained="{{ item.valeurRetenue|default('') }}"
                    data-garantie-document="{{ item.documentJustificatif|default('')|e('html_attr') }}"
                    data-garantie-date="{{ item.dateEvaluation|default(current_date)|slice(0, 10) }}"
                    data-garantie-guarantor="{{ item.nomGarant|default('')|e('html_attr') }}"
                    data-garantie-status="{{ item.statut|default('')|e('html_attr') }}"
                >
                    <td>{{ item.idGarantie }}</td>
                    <td>#{{ item.idCredit }}</td>
                    <td>{{ item.typeGarantie }}</td>
                    <td>{{ item.valeurEstimee|default(0)|number_format(2, '.', ' ') }}</td>
                    <td>{{ item.valeurRetenue|default(0)|number_format(2, '.', ' ') }}</td>
                    <td>{{ item.statut }}</td>
                    <td style="display:flex; gap:8px;">
                        <button class="btn btn-secondary js-garantie-edit" type="button">Modifier</button>
                        <form method="post">
                            <input type="hidden" name="tab" value="garanties">
                            <input type="hidden" name="action" value="garantie_delete">
                            <input type="hidden" name="idGarantie" value="{{ item.idGarantie }}">
                            <button class="btn btn-danger" type="submit" onclick="return confirm('Supprimer cette garantie ?')">Supprimer</button>
                        </form>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="7">Aucune garantie enregistree.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</section>

<script>
(() => {
    const form = document.getElementById('portal-garantie-form');
    if (!(form instanceof HTMLFormElement)) return;

    const estimatedField = document.getElementById('portal-garantie-estimated');
    const retainedField  = document.getElementById('portal-garantie-retained');
    const dateField      = document.getElementById('portal-garantie-date');
    const idField        = document.getElementById('portal-garantie-id');

    const parseNum = (v) => { const n = Number(v); return Number.isFinite(n) ? n : 0; };

    const syncRetained = () => {
        if (!estimatedField || !retainedField) return;
        if (retainedField.dataset.manual === '1') return;
        const est = parseNum(estimatedField.value);
        retainedField.value = est > 0 ? (est * 0.8).toFixed(2) : '';
    };

    estimatedField?.addEventListener('input', syncRetained);
    retainedField?.addEventListener('input', () => {
        if (retainedField) retainedField.dataset.manual = retainedField.value.trim() === '' ? '0' : '1';
    });

    form.addEventListener('reset', () => {
        requestAnimationFrame(() => {
            if (idField) idField.value = '';
            if (retainedField) retainedField.dataset.manual = '0';
            if (dateField && !dateField.value) dateField.value = '{{ current_date }}';
            syncRetained();
        });
    });

    const setFieldValue = (name, value) => {
        const f = form.querySelector(`[name="${name}"]`);
        if (f) f.value = value ?? '';
    };

    document.querySelectorAll('.js-garantie-edit').forEach((btn) => {
        btn.addEventListener('click', () => {
            const row = btn.closest('[data-garantie-row]');
            if (!row) return;
            setFieldValue('idGarantie',          row.dataset.garantieId ?? '');
            setFieldValue('idCredit',             row.dataset.garantieCreditId ?? '');
            setFieldValue('typeGarantie',         row.dataset.garantieType ?? '');
            setFieldValue('description',          row.dataset.garantieDescription ?? '');
            setFieldValue('adresseBien',          row.dataset.garantieAddress ?? '');
            setFieldValue('valeurEstimee',        row.dataset.garantieEstimated ?? '');
            setFieldValue('valeurRetenue',        row.dataset.garantieRetained ?? '');
            setFieldValue('documentJustificatif', row.dataset.garantieDocument ?? '');
            setFieldValue('dateEvaluation',       (row.dataset.garantieDate ?? '').slice(0,10));
            setFieldValue('nomGarant',            row.dataset.garantieGuarantor ?? '');
            if (retainedField) retainedField.dataset.manual = (row.dataset.garantieRetained ?? '').trim() !== '' ? '1' : '0';
            syncRetained();
            form.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
    });
})();
</script>

<style>
.g-val-msg{font-size:12px;font-weight:600;margin-top:4px;display:block;min-height:16px}
.g-val-msg.ok{color:#16a34a}
.g-val-msg.err{color:#dc2626}
#portal-garantie-form input.g-invalid,
#portal-garantie-form select.g-invalid{border-color:#dc2626!important;box-shadow:0 0 0 3px rgba(220,38,38,.12)!important;background:#fff5f5!important}
#portal-garantie-form input.g-valid,
#portal-garantie-form select.g-valid{border-color:#16a34a!important;box-shadow:0 0 0 3px rgba(22,163,74,.1)!important;background:#f0fdf4!important}
</style>
<script>
(function(){
function g(id){return document.getElementById(id);}
function setOk(inputId,spanId){
  var el=g(inputId),s=g(spanId);
  if(el){el.classList.remove('g-invalid');el.classList.add('g-valid');}
  if(s){s.className='g-val-msg ok';s.textContent='✓ Valide';}
  return true;
}
function setErr(inputId,spanId,msg){
  var el=g(inputId),s=g(spanId);
  if(el){el.classList.remove('g-valid');el.classList.add('g-invalid');}
  if(s){s.className='g-val-msg err';s.textContent='⚠ '+msg;}
  return false;
}
function clr(inputId,spanId){
  var el=g(inputId),s=g(spanId);
  if(el){el.classList.remove('g-valid','g-invalid');}
  if(s){s.className='g-val-msg';s.textContent='';}
  return true;
}

function vIdCredit(){
  var el=g('portal-garantie-credit');
  if(!el)return true;
  return el.value?setOk('portal-garantie-credit','g-err-idCredit'):setErr('portal-garantie-credit','g-err-idCredit','Le crédit lié est obligatoire.');
}
function vTypeGarantie(){
  var el=g('portal-garantie-type');
  if(!el)return true;
  return el.value?setOk('portal-garantie-type','g-err-typeGarantie'):setErr('portal-garantie-type','g-err-typeGarantie','Le type de garantie est obligatoire.');
}
function vDescription(){
  var el=g('portal-garantie-description');
  if(!el)return true;
  var v=el.value.trim();
  if(!v)return setErr('portal-garantie-description','g-err-description','La description est obligatoire.');
  if(v.length<10)return setErr('portal-garantie-description','g-err-description','Min. 10 caractères.');
  if(v.length>1000)return setErr('portal-garantie-description','g-err-description','Max. 1000 caractères.');
  return setOk('portal-garantie-description','g-err-description');
}
function vAdresse(){
  var el=g('portal-garantie-address');
  if(!el)return true;
  var v=el.value.trim();
  if(!v)return setErr('portal-garantie-address','g-err-adresseBien',"L'adresse du bien est obligatoire.");
  if(v.length<5)return setErr('portal-garantie-address','g-err-adresseBien','Min. 5 caractères.');
  return setOk('portal-garantie-address','g-err-adresseBien');
}
function vValeurEstimee(){
  var el=g('portal-garantie-estimated');
  if(!el)return true;
  if(!el.value)return setErr('portal-garantie-estimated','g-err-valeurEstimee','La valeur estimée est obligatoire.');
  var v=parseFloat(el.value);
  if(v<=0)return setErr('portal-garantie-estimated','g-err-valeurEstimee','Doit être un nombre positif.');
  if(v<1000||v>100000000)return setErr('portal-garantie-estimated','g-err-valeurEstimee','Entre 1 000 et 100 000 000 DT.');
  return setOk('portal-garantie-estimated','g-err-valeurEstimee');
}
function vValeurRetenue(){
  var el=g('portal-garantie-retained');
  if(!el||el.value==='')return clr('portal-garantie-retained','g-err-valeurRetenue');
  var v=parseFloat(el.value);
  if(isNaN(v)||v<0)return setErr('portal-garantie-retained','g-err-valeurRetenue','Doit être positive ou nulle.');
  var est=g('portal-garantie-estimated');
  if(est&&est.value&&v>parseFloat(est.value))return setErr('portal-garantie-retained','g-err-valeurRetenue','Ne peut pas dépasser la valeur estimée.');
  return setOk('portal-garantie-retained','g-err-valeurRetenue');
}
function vDate(){
  var el=g('portal-garantie-date');
  if(!el)return true;
  if(!el.value)return setErr('portal-garantie-date','g-err-dateEvaluation',"La date d'évaluation est obligatoire.");
  if(!/^\d{4}-\d{2}-\d{2}$/.test(el.value))return setErr('portal-garantie-date','g-err-dateEvaluation','Format requis : AAAA-MM-JJ.');
  return setOk('portal-garantie-date','g-err-dateEvaluation');
}
function vDocument(){
  var el=g('portal-garantie-document');
  if(!el)return true;
  var v=el.value.trim();
  if(!v)return setErr('portal-garantie-document','g-err-documentJustificatif','Le document justificatif est obligatoire.');
  if(v.length>255)return setErr('portal-garantie-document','g-err-documentJustificatif','Max. 255 caractères.');
  return setOk('portal-garantie-document','g-err-documentJustificatif');
}
function vNomGarant(){
  var el=g('portal-garantie-guarantor');
  if(!el)return true;
  var v=el.value.trim();
  if(!v)return setErr('portal-garantie-guarantor','g-err-nomGarant','Le nom du garant est obligatoire.');
  if(v.length<2)return setErr('portal-garantie-guarantor','g-err-nomGarant','Min. 2 caractères.');
  if(v.length>150)return setErr('portal-garantie-guarantor','g-err-nomGarant','Max. 150 caractères.');
  return setOk('portal-garantie-guarantor','g-err-nomGarant');
}

/* Live validation */
var liveMap={
  'portal-garantie-credit':vIdCredit,
  'portal-garantie-type':vTypeGarantie,
  'portal-garantie-description':vDescription,
  'portal-garantie-address':vAdresse,
  'portal-garantie-estimated':vValeurEstimee,
  'portal-garantie-retained':vValeurRetenue,
  'portal-garantie-date':vDate,
  'portal-garantie-document':vDocument,
  'portal-garantie-guarantor':vNomGarant
};
Object.keys(liveMap).forEach(function(id){
  var el=g(id);
  if(!el)return;
  ['input','change','blur'].forEach(function(ev){
    el.addEventListener(ev,liveMap[id]);
  });
});

/* Submit */
var form=g('portal-garantie-form');
if(form){
  form.addEventListener('submit',function(e){
    var ok=vIdCredit()&vTypeGarantie()&vDescription()&vAdresse()&vValeurEstimee()&vDate()&vDocument()&vNomGarant();
    vValeurRetenue();
    if(!ok)e.preventDefault();
  });
}
})();
</script>
