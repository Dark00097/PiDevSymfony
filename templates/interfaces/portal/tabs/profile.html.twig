                    <p class="pf-coach-headline" id="pf-coach-headline">{{ ai_coach.headline|default('Lancez une analyse pour recevoir un plan IA personnalise.') }}</p>
                    <p class="pf-coach-summary" id="pf-coach-summary">{{ ai_coach.summary|default('Le coach combine securite, epargne, depenses et surplus mensuel.') }}</p>

                    <div class="pf-coach-security">
                        <div class="pf-coach-security-head">
                            <strong>
                                <i class="fa-solid fa-shield-halved"></i>
                                Donnees securite
                            </strong>
                            <span class="pf-coach-security-score" id="pf-coach-security-score">{{ ai_security.score|default(0) }}/100</span>
                        </div>
                        <p id="pf-coach-security-summary">{{ ai_security.summary|default('Aucune donnee de securite disponible.') }}</p>
                        <ul class="pf-coach-security-list" id="pf-coach-security-list">
                            {% for item in ai_security.recommendations|default([])|slice(0,3) %}
                                <li>
                                    <i class="fa-solid fa-circle-check"></i>
                                    <span>{{ item }}</span>
                                </li>
                            {% else %}
                                <li>
                                    <i class="fa-solid fa-circle-check"></i>
                                    <span>Lancez l analyse pour afficher les recommandations securite.</span>
                                </li>
                            {% endfor %}
                        </ul>
                    </div>

                    <div class="pf-coach-points">
                        <div class="pf-coach-point">
                            <strong><i class="fa-solid fa-triangle-exclamation"></i>Risque</strong>
                            <p id="pf-coach-risk">{{ ai_coach.risk|default('Aucun risque majeur detecte pour le moment.') }}</p>
                        </div>
                        <div class="pf-coach-point">
                            <strong><i class="fa-solid fa-bolt"></i>Opportunite</strong>
                            <p id="pf-coach-opportunity">{{ ai_coach.opportunity|default('Continuez a alimenter vos objectifs d epargne mensuels.') }}</p>
                        </div>
                    </div>

                    <ul class="pf-coach-actions" id="pf-coach-actions">
                        {% for action in ai_coach.actions|default([])|slice(0,3) %}
                            <li>
                                <i class="fa-solid fa-circle-check"></i>
                                <span>{{ action }}</span>
                            </li>
                        {% else %}
                            <li>
                                <i class="fa-solid fa-circle-check"></i>
                                <span>Relancez l analyse pour obtenir 3 actions prioritaires.</span>
                            </li>
                        {% endfor %}
                    </ul>

                    <p class="pf-coach-note" id="pf-coach-note" {% if not coach_is_fallback %}hidden{% endif %}>Mode secours actif: verifiez la cle API pour une reponse IA enrichie.</p>
                </div>
            </div>

            {# Activity + Notifications #}
            <div class="pf-grid-2">

                <div class="pf-card">
                    <div class="pf-card-header">
                        <div class="pf-card-icon"
                             style="background:linear-gradient(135deg,#00838f,#00bcd4);">
                            <i class="fa-solid fa-clock-rotate-left"></i>
                        </div>
                        <div>
                            <h3>Actions recentes</h3>
                            <p>Historique d'activite</p>
                        </div>
                        <span class="pf-count-pill pf-count-pill-blue">{{ activity|length }}</span>
                    </div>
                    <div class="pf-card-body" style="padding-top:0; padding-bottom:0;">
                        <div class="pf-scroll-body">
                            {% if activity is not empty %}
                                <div class="pf-timeline">
                                    {% for row in activity %}
                                        <div class="pf-tl-item">
                                            <div class="pf-tl-left">
                                                <div class="pf-tl-dot pf-tl-dot-{{ loop.index is odd ? 'teal' : 'blue' }}"></div>
                                                {% if not loop.last %}
                                                    <div class="pf-tl-connector"></div>
                                                {% endif %}
                                            </div>
                                            <div class="pf-tl-content">
                                                <strong>{{ row.action_type|default('ACTION')|replace({'_': ' '})|title }}</strong>
                                                <p>{{ row.details|default('Aucun detail') }}</p>
                                                <time>{{ row.created_at|default('Ã¢â‚¬â€') }}</time>
                                            </div>
                                        </div>
                                    {% endfor %}
                                </div>
                            {% else %}
                                <div class="pf-empty">
                                    <i class="fa-solid fa-inbox"></i>
                                    <p>Aucune activite recente.</p>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>

                <div class="pf-card">
                    <div class="pf-card-header">
                        <div class="pf-card-icon"
                             style="background:linear-gradient(135deg,#7c3aed,#8b5cf6);">
                            <i class="fa-solid fa-bell"></i>
                        </div>
                        <div>
                            <h3>Notifications</h3>
                            <p>Alertes et messages</p>
                        </div>
                        {% set notif_count = notifications|default([])|length %}
                        {% if notif_count > 0 %}
                            <span class="pf-count-pill pf-count-pill-purple">{{ notif_count }}</span>
                        {% endif %}
                    </div>
                    <div class="pf-card-body" style="padding-top:0; padding-bottom:0;">
                        <div class="pf-scroll-body">
                            {% if notifications|default([]) is not empty %}
                                <div class="pf-notif-list">
                                    {% for item in notifications|default([])|slice(0,12) %}
                                        <div class="pf-notif-item">
                                            <div class="pf-notif-dot"></div>
                                            <div class="pf-notif-body">
                                                <strong>{{ item.title }}</strong>
                                                <p>{{ item.message }}</p>
                                                <time>{{ item.created_at }}</time>
                                            </div>
                                        </div>
                                    {% endfor %}
                                </div>
                            {% else %}
                                <div class="pf-empty">
                                    <i class="fa-solid fa-bell-slash"></i>
                                    <p>Aucune notification.</p>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>

            </div>
        </div>

    </div>
</div>

