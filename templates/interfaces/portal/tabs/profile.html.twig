   Ã¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢Â */
.pf-scorecard {
    background: #fff;
    border-radius: 16px;
    border: 1px solid #dde8f5;
    padding: 18px;
    display: flex;
    align-items: center;
    gap: 14px;
    box-shadow: 0 2px 10px rgba(10,37,64,.05);
    transition: box-shadow .2s, transform .2s;
    position: relative;
    overflow: hidden;
}

.pf-scorecard:hover { box-shadow: 0 8px 24px rgba(10,37,64,.10); transform: translateY(-2px); }

.pf-scorecard-side {
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 4px;
    border-radius: 16px 0 0 16px;
}

.pf-scorecard-ring {
    position: relative;
    width: 54px; height: 54px;
    flex-shrink: 0;
}

.pf-scorecard-ring svg {
    width: 54px; height: 54px;
    transform: rotate(-90deg);
}

.pf-ring-bg {
    fill: none;
    stroke: #e8f0f8;
    stroke-width: 5;
}

.pf-ring-fill {
    fill: none;
    stroke-width: 5;
    stroke-linecap: round;
    stroke-dasharray: 0 88;
    transition: stroke-dasharray .8s ease;
}

.pf-ring-teal { stroke: #00bcd4; }
.pf-ring-blue { stroke: #1e88e5; }
.pf-ring-purple { stroke: #8b5cf6; }

.pf-scorecard-ring-val {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: 900;
    color: #0a2540;
}

.pf-scorecard-icon {
    width: 48px; height: 48px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    flex-shrink: 0;
}

.pf-scorecard-body { display: flex; flex-direction: column; gap: 2px; }
.pf-scorecard-body strong { font-size: 13px; font-weight: 800; color: #0a2540; }
.pf-scorecard-body span { font-size: 16px; font-weight: 900; color: #0a2540; letter-spacing: -0.3px; }
.pf-scorecard-body small { font-size: 11px; color: #7294ae; font-weight: 600; }

/* AI Insight cards */
.pf-ai-quad {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
}

.pf-insight {
    border-radius: 16px;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    border: 1px solid transparent;
}

.pf-insight-security  { background: linear-gradient(135deg,#f0fdf4,#dcfce7); border-color: #bbf7d0; }
.pf-insight-account   { background: linear-gradient(135deg,#eff6ff,#dbeafe); border-color: #bfdbfe; }
.pf-insight-cashback  { background: linear-gradient(135deg,#fffbeb,#fef3c7); border-color: #fde68a; }
.pf-insight-surplus   { background: linear-gradient(135deg,#f5f3ff,#ede9fe); border-color: #ddd6fe; }

.pf-insight-tag {
    display: flex;
    align-items: center;
    gap: 7px;
    font-size: 11px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.6px;
}

.pf-insight-security .pf-insight-tag  { color: #166534; }
.pf-insight-account  .pf-insight-tag  { color: #1e40af; }
.pf-insight-cashback .pf-insight-tag  { color: #92400e; }
.pf-insight-surplus  .pf-insight-tag  { color: #5b21b6; }

.pf-insight p { font-size: 13px; line-height: 1.55; color: #374151; }

/* AI coach card */
.pf-coach-card {
    background: linear-gradient(140deg,#0f2d4d 0%, #124777 55%, #0ea5a4 100%);
    border-color: rgba(255,255,255,.15);
    color: #f8fbff;
    overflow: hidden;
}

.pf-coach-card .pf-card-header {
    border-bottom: 1px solid #cfe1f5;
    align-items: center;
    background: linear-gradient(120deg,#eef5ff,#e3f2ff);
}

.pf-coach-card .pf-card-icon {
    background: linear-gradient(135deg,#1565c0,#1e88e5) !important;
    color: #fff;
}

.pf-coach-title h3 { color: #0a2540; }
.pf-coach-title p { color: #4d6e8a; }

.pf-coach-header-actions {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 8px;
}

.pf-coach-provider {
    margin-left: 0;
    padding: 4px 10px;
    border-radius: 999px;
    font-size: 10px;
    font-weight: 800;
    letter-spacing: .4px;
    text-transform: uppercase;
    background: #eaf2ff;
    color: #1e40af;
    border: 1px solid #bfd7ff;
}

.pf-coach-trigger {
    border: none;
    border-radius: 10px;
    padding: 8px 12px;
    background: linear-gradient(120deg,#1565c0,#1e88e5);
    color: #fff;
    font-size: 12px;
    font-weight: 800;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    cursor: pointer;
}

.pf-coach-trigger:hover { opacity: .92; }
.pf-coach-trigger i { font-size: 12px; }

.pf-coach-security {
    border-radius: 12px;
    padding: 10px 12px;
    border: 1px solid rgba(255,255,255,.2);
    background: rgba(255,255,255,.08);
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.pf-coach-security-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
}

.pf-coach-security-head strong {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: .5px;
}

.pf-coach-security-score {
    padding: 3px 8px;
    border-radius: 999px;
    background: rgba(255,255,255,.16);
    border: 1px solid rgba(255,255,255,.26);
    font-size: 11px;
    font-weight: 800;
    color: #e9f8ff;
}

.pf-coach-security > p {
    font-size: 12px;
    color: rgba(236,246,255,.95);
}

.pf-coach-security-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 6px;
}

.pf-coach-security-list li {
    display: flex;
    align-items: flex-start;
    gap: 7px;
    font-size: 12px;
    color: rgba(236,246,255,.92);
}

.pf-coach-security-list i {
    margin-top: 2px;
    color: #7dd3fc;
}

.pf-coach-body {
    display: flex;
    flex-direction: column;
    gap: 12px;
}

.pf-coach-headline {
    font-size: 15px;
    line-height: 1.45;
    font-weight: 800;
    color: #fff;
}

.pf-coach-summary {
    font-size: 13px;
    line-height: 1.5;
    color: rgba(236,246,255,.94);
}

.pf-coach-points {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
}

.pf-coach-point {
    border-radius: 12px;
    padding: 10px 12px;
    border: 1px solid rgba(255,255,255,.2);
