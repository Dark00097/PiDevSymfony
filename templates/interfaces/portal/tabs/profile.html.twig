<script>
(function () {
    'use strict';

    /* Ã¢â€â‚¬Ã¢â€â‚¬ helpers Ã¢â€â‚¬Ã¢â€â‚¬ */
    const $ = (sel, ctx = document) => ctx.querySelector(sel);
    const $$ = (sel, ctx = document) => Array.from(ctx.querySelectorAll(sel));

    document.addEventListener('DOMContentLoaded', function () {
        initTabs();
        initEyes();
        initPasswordStrength();
        initMap();
        initBiometric();
        initPhotoUpload();
        initPanelPersist();
        initAiRefresh();
    });

    /* Ã¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢Â
       TAB SYSTEM
    Ã¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢Â */
    function initTabs() {
        const tabBtns  = $$('[data-pf-tab]');
        const panels   = $$('.pf-panel');

        function activateTab(name) {
            tabBtns.forEach(b => b.classList.toggle('active', b.dataset.pfTab === name));
            panels.forEach(p => p.classList.toggle('active', p.id === 'pf-panel-' + name));

            const url = new URL(location.href);
            url.searchParams.set('panel', name);
            history.replaceState(null, '', url.pathname + '?' + url.searchParams.toString());

            document.dispatchEvent(new CustomEvent('nx-profile-panel-change', {
                detail: { panel: name },
            }));
        }

        tabBtns.forEach(btn => btn.addEventListener('click', () => activateTab(btn.dataset.pfTab)));

        const initial = new URLSearchParams(location.search).get('panel');
        if (initial && document.getElementById('pf-panel-' + initial)) {
            activateTab(initial);
        }
    }

    /* Ã¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢Â
       PANEL PERSIST ON FORM SUBMIT
    Ã¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢Â */
    function initPanelPersist() {
        $$('.pf-panel form').forEach(form => {
            form.addEventListener('submit', () => {
                const panelEl = form.closest('.pf-panel');
                if (!panelEl) return;
                const name = panelEl.id.replace('pf-panel-', '');
                let inp = form.querySelector('input[name="panel"]');
                if (!inp) {
                    inp = document.createElement('input');
                    inp.type = 'hidden';
                    inp.name = 'panel';
                    form.appendChild(inp);
                }
                inp.value = name;
            });
        });
    }

    /* Ã¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢Â
       EYE TOGGLES
    Ã¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢Â */
    function initAiRefresh() {
        const refreshForms = $$('.js-profile-ai-refresh-form');
        if (refreshForms.length === 0) return;

        const endpoint = '{{ path('portal_profile_ai_refresh') }}';
        const loadingBox = $('#pf-ai-loading');
        const loadingText = $('#pf-ai-loading-text');
        const refreshButtons = $$('.js-profile-ai-refresh-btn');
        let busy = false;

        function setLoading(state, message = 'Analyse IA en cours...') {
            if (loadingBox) {
                loadingBox.hidden = !state;
            }
            if (loadingText) {
                loadingText.textContent = message;
            }
            refreshButtons.forEach((btn) => {
                btn.disabled = state;
            });
        }

        function clampScore(value) {
            const n = Number(value);
            if (!Number.isFinite(n)) return 0;
            return Math.max(0, Math.min(100, n));
        }

        function setRing(ringId, valueId, score) {
            const ring = $(ringId);
            const scoreEl = $(valueId);
            const normalized = clampScore(score);
            if (ring) {
                ring.style.strokeDasharray = `${Math.round(normalized * 1.382)} 138`;
            }
            if (scoreEl) {
                scoreEl.textContent = String(Math.round(normalized));
            }
        }

        function setText(selector, value, fallback = '') {
            const el = $(selector);
            if (!el) return;
            const finalValue = String(value ?? '').trim();
            el.textContent = finalValue !== '' ? finalValue : fallback;
        }

        function setPredictedSpending(amount) {
            const el = $('#pf-ai-predicted-spending');
            if (!el) return;
            const value = Number(amount);
            const normalized = Number.isFinite(value) ? value : 0;
            el.innerHTML = `${normalized.toFixed(2)}<small style="font-size:11px;"> DT</small>`;
        }

        function renderList(containerId, items, fallbackText) {
            const list = $(containerId);
            if (!list) return;

            list.innerHTML = '';
            const source = Array.isArray(items)
                ? items.map((item) => String(item ?? '').trim()).filter((item) => item !== '').slice(0, 3)
                : [];
            const finalItems = source.length > 0 ? source : [fallbackText];

            finalItems.forEach((text) => {
                const li = document.createElement('li');
                const icon = document.createElement('i');
                const span = document.createElement('span');
                icon.className = 'fa-solid fa-circle-check';
                span.textContent = text;
                li.appendChild(icon);
                li.appendChild(span);
                list.appendChild(li);
            });
        }

        function updateSurplus(data) {
            setText('#pf-ai-insight-surplus', data?.message, 'Aucun surplus detecte.');

            const form = $('#pf-ai-surplus-form');
            const monthInput = $('#pf-ai-surplus-month');
            if (!form) return;

            const show = Boolean(data?.show);
            form.hidden = !show;
            if (monthInput) {
                monthInput.value = String(data?.month ?? '');
            }
        }

        function applyProfileAi(profileAi) {
            const security = profileAi?.security_analysis ?? {};
            const prediction = profileAi?.prediction ?? {};
            const accountAdvice = profileAi?.account_advice ?? {};
            const cashbackAdvice = profileAi?.cashback_advice ?? {};
            const surplus = profileAi?.surplus ?? {};
            const coach = profileAi?.coach ?? {};

            setRing('#pf-ai-security-ring', '#pf-ai-security-score', security?.score);
            setRing('#pf-ai-savings-ring', '#pf-ai-savings-score', prediction?.savings_score);
            setPredictedSpending(prediction?.total_predicted_spending);
            setText('#pf-ai-generated-at', profileAi?.generated_at, 'â€”');

            setText('#pf-ai-insight-security', security?.summary, 'Aucune donnee de securite disponible.');
            setText('#pf-ai-insight-account', accountAdvice?.summary, 'Aucun conseil disponible pour le moment.');
            setText('#pf-ai-insight-cashback', cashbackAdvice?.summary, 'Aucune recommandation cashback.');
            updateSurplus(surplus);

            setText('#pf-coach-provider', coach?.provider, 'Fallback');
            setText('#pf-coach-headline', coach?.headline, 'Lancez une analyse pour recevoir un plan IA personnalise.');
            setText('#pf-coach-summary', coach?.summary, 'Le coach combine securite, epargne, depenses et surplus mensuel.');
            setText('#pf-coach-security-score', `${Math.round(clampScore(security?.score))}/100`, '0/100');
            setText('#pf-coach-security-summary', security?.summary, 'Aucune donnee de securite disponible.');
            setText('#pf-coach-risk', coach?.risk, 'Aucun risque majeur detecte pour le moment.');
            setText('#pf-coach-opportunity', coach?.opportunity, 'Continuez a alimenter vos objectifs d epargne mensuels.');

            renderList(
                '#pf-coach-security-list',
                security?.recommendations,
                'Lancez l analyse pour afficher les recommandations securite.'
            );
            renderList(
                '#pf-coach-actions',
                coach?.actions,
                'Relancez l analyse pour obtenir 3 actions prioritaires.'
            );

            const note = $('#pf-coach-note');
            const provider = String(coach?.provider ?? '').toLowerCase();
            if (note) {
                note.hidden = !provider.startsWith('fallback');
            }
        }

        async function executeRefresh() {
            if (busy) return;
            busy = true;
            setLoading(true, 'Analyse IA en cours...');

            try {
                const response = await fetch(endpoint, {
                    method: 'POST',
                    credentials: 'same-origin',
                    headers: {
                        'Accept': 'application/json',
                    },
                });

                const data = await response.json().catch(() => ({}));
                if (!response.ok || !data?.ok) {
                    throw new Error(String(data?.message ?? 'Impossible d actualiser l analyse IA.'));
                }

                applyProfileAi(data.profile_ai ?? {});
                setLoading(false, 'Analyse IA actualisee.');
            } catch (error) {
                const message = error instanceof Error ? error.message : 'Erreur inconnue.';
                setLoading(false, `Echec: ${message}`);
                if (loadingBox) {
                    loadingBox.hidden = false;
                }
            } finally {
                busy = false;
            }
        }

        refreshForms.forEach((form) => {
            form.addEventListener('submit', (event) => {
                event.preventDefault();
                executeRefresh();
            });
        });
    }

    function initEyes() {
        $$('[data-pf-eye]').forEach(btn => {
            btn.addEventListener('click', () => {
                const wrap = btn.closest('.pf-input-wrap');
                if (!wrap) return;
                const inp = wrap.querySelector('input');
                if (!inp) return;
                const show = inp.type === 'password';
                inp.type = show ? 'text' : 'password';
                const icon = btn.querySelector('i');
                if (icon) icon.className = show ? 'fa-solid fa-eye-slash' : 'fa-solid fa-eye';
            });
        });
    }

    /* Ã¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢Â
       PASSWORD STRENGTH
    Ã¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢Â */
    function initPasswordStrength() {
        const pw    = $('#pf-new-pw');
        const bars  = [1, 2, 3, 4].map(i => $('#pf-bar-' + i));
        const lbl   = $('#pf-pw-label');
        const conf  = $('#pf-conf-pw');
        const cWrap = $('#pf-conf-wrap');

        if (!pw) return;

        const levels = [
            { c: '#e8f0f8', l: 'Ã¢â‚¬â€'           },
            { c: '#e53935', l: 'Tres faible'  },
            { c: '#f59e0b', l: 'Faible'       },
            { c: '#fbbf24', l: 'Moyen'        },
            { c: '#00bcd4', l: 'Fort'         },
            { c: '#22c55e', l: 'Tres fort'    }
        ];

        function score(v) {
            let s = 0;
            if (v.length >= 8)           s++;
            if (v.length >= 12)          s++;
            if (/[A-Z]/.test(v))         s++;
            if (/[0-9]/.test(v))         s++;
            if (/[^A-Za-z0-9]/.test(v))  s++;
            return s;
        }

        pw.addEventListener('input', () => {
            const sc     = pw.value.length ? score(pw.value) : 0;
            const lvl    = levels[Math.min(sc, 5)];
            const filled = Math.ceil(sc * bars.length / 5);
            bars.forEach((bar, i) => {
                if (bar) bar.style.background = i < filled ? lvl.c : '';
            });
            if (lbl) { lbl.textContent = lvl.l; lbl.style.color = lvl.c; }
        });

        if (conf && cWrap) {
            conf.addEventListener('input', () => {
                const match = conf.value.length > 0 && conf.value === pw.value;
                cWrap.classList.toggle('is-valid',   match);
                cWrap.classList.toggle('is-invalid', !match && conf.value.length > 0);
            });
        }
    }

    /* Ã¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢Â
       OPENSTREETMAP
    Ã¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢Â */
    function initMap() {
        const mapEl    = $('#nx-profile-osm-map');
        const fallback = $('#nx-profile-osm-fallback');
        if (!mapEl) return;

        const DEFAULT_CENTER = { lat: 36.8065, lon: 10.1815, label: 'Tunis, Tunisia' };
        let mapInstance = null;
        let mapResizeTimer = null;

        function waitLeaflet(cb) {
            if (typeof window.L !== 'undefined') { cb(); return; }
            let t = 0;
            const iv = setInterval(() => {
                if (typeof window.L !== 'undefined') { clearInterval(iv); cb(); }
                else if (++t > 40) clearInterval(iv);
            }, 150);
        }

        function showFallback(message) {
            if (!fallback) return;
            fallback.hidden = false;
            if (message) {
                fallback.textContent = message;
            }
        }

        function hideFallback() {
            if (!fallback) return;
            fallback.hidden = true;
        }

        function parseCoord(value) {
            const num = parseFloat(String(value || '').trim());
            return Number.isFinite(num) ? num : null;
        }

        function invalidateMapSize(delay = 0) {
            window.setTimeout(() => {
                if (!mapInstance) return;
                try {
                    window.requestAnimationFrame(() => {
                        if (!mapInstance) return;
                        mapInstance.invalidateSize({ pan: false });
                    });
                } catch (_) {
                    // map may be detached during rapid tab switches
                }
            }, delay);
        }

        function invalidateMapBurst() {
            invalidateMapSize(0);
            invalidateMapSize(120);
            invalidateMapSize(320);
        }

        function bindResizeAndPanelHooks() {
            window.addEventListener('resize', () => {
                clearTimeout(mapResizeTimer);
                mapResizeTimer = window.setTimeout(() => {
                    invalidateMapBurst();
                }, 90);
            });

            document.addEventListener('nx-profile-panel-change', (event) => {
                const panel = event && event.detail ? event.detail.panel : '';
                if (panel === 'location') {
                    invalidateMapBurst();
                }
            });
        }

        function buildMap(lat, lon, label, zoom = 13) {
            if (mapInstance) {
                mapInstance.remove();
                mapInstance = null;
            }

            mapInstance = L.map(mapEl, {
                scrollWheelZoom: false,
                preferCanvas: true,
                zoomControl: true,
            }).setView([lat, lon], zoom);

            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                maxZoom: 19,
                keepBuffer: 4,
                updateWhenIdle: true,
                attribution: '(c) OpenStreetMap',
            }).addTo(mapInstance);

            L.marker([lat, lon]).addTo(mapInstance)
                .bindPopup(label || 'Localisation')
                .openPopup();

            invalidateMapBurst();
        }
        function showDefaultMap() {
            buildMap(DEFAULT_CENTER.lat, DEFAULT_CENTER.lon, DEFAULT_CENTER.label, 11);
            showFallback("Position d'ouverture non enregistree. Affichage d'une localisation par defaut.");
        }

        function tryBrowserGeoFallback() {
            if (!navigator.geolocation) {
                showDefaultMap();
                return;
            }

            navigator.geolocation.getCurrentPosition((position) => {
                const lat = position.coords.latitude;
                const lon = position.coords.longitude;
                if (!Number.isFinite(lat) || !Number.isFinite(lon)) {
                    showDefaultMap();
                    return;
                }

                buildMap(lat, lon, 'Position actuelle (navigateur)');
                showFallback("Position d'ouverture non enregistree. Affichage de votre position actuelle.");
            }, () => {
                showDefaultMap();
            }, {
                maximumAge: 60000,
                timeout: 3500,
                enableHighAccuracy: false
            });
        }

        waitLeaflet(() => {
            bindResizeAndPanelHooks();

            const storedLat = parseCoord(mapEl.dataset.lat);
            const storedLng = parseCoord(mapEl.dataset.lng);
            if (storedLat !== null && storedLng !== null) {
                buildMap(storedLat, storedLng, mapEl.dataset.openedLocation || "Localisation d'ouverture", 14);
                hideFallback();
                return;
            }

            const query = (mapEl.dataset.query || '').trim();
            if (!query) {
                tryBrowserGeoFallback();
                return;
            }

            fetch('https://nominatim.openstreetmap.org/search?format=json&limit=1&q=' +
                  encodeURIComponent(query), { headers: { 'Accept-Language': 'fr,en' } })
                .then(r => r.ok ? r.json() : Promise.reject())
                .then(res => {
                    if (!Array.isArray(res) || !res.length) {
                        tryBrowserGeoFallback();
                        return;
                    }

                    const lat = parseCoord(res[0].lat);
                    const lon = parseCoord(res[0].lon);
                    if (lat === null || lon === null) {
                        tryBrowserGeoFallback();
                        return;
                    }

                    buildMap(lat, lon, res[0].display_name || query);
                    hideFallback();
                })
                .catch(() => {
                    tryBrowserGeoFallback();
                });
        });
    }

    /* Ã¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢Â
       BIOMETRIC FACE ID
    Ã¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢Â */
    function initBiometric() {
        const descEl   = $('#nx-profile-bio-face-descriptor');
        const videoEl  = $('#nx-profile-bio-video');
        const startBtn = $('#nx-profile-bio-start');
        const capBtn   = $('#nx-profile-bio-capture');
        const dot      = $('#proBioDot');
        const txt      = $('#proBioText');
        const idle     = $('#proBioIdle');
        const scan     = $('#proBioScan');
        const ok       = $('#proBioOk');
        if (!descEl || !videoEl || !startBtn || !capBtn) return;

        const MODEL_URL   = 'https://cdn.jsdelivr.net/gh/justadudewhohacks/face-api.js@master/weights';
        let   stream      = null;
        let   modelsReady = false;

        function setStatus(msg, state) {
            if (txt) txt.textContent = msg;
            if (dot) dot.className = 'pf-cam-dot ' + (state || '');
        }

        function ensureModels() {
            return new Promise((resolve, reject) => {
                if (modelsReady) { resolve(); return; }
                let tries = 0;
                const iv = setInterval(() => {
                    tries++;
                    if (typeof window.faceapi !== 'undefined') {
                        clearInterval(iv);
                        setStatus('Chargement des modeles IAÃ¢â‚¬Â¦', 'loading');
                        Promise.all([
                            window.faceapi.nets.tinyFaceDetector.loadFromUri(MODEL_URL),
                            window.faceapi.nets.faceLandmark68Net.loadFromUri(MODEL_URL),
                            window.faceapi.nets.faceRecognitionNet.loadFromUri(MODEL_URL)
                        ]).then(() => { modelsReady = true; setStatus('Modeles prets.', 'active'); resolve(); })
                          .catch(reject);
                    } else if (tries > 40) { clearInterval(iv); reject(new Error('faceapi not loaded')); }
                }, 250);
            });
        }

        startBtn.addEventListener('click', () => {
            startBtn.disabled = true;
            setStatus('Initialisation cameraÃ¢â‚¬Â¦', 'loading');
            ensureModels()
                .then(() => navigator.mediaDevices.getUserMedia({
                    video: { facingMode: 'user', width: { ideal: 640 }, height: { ideal: 480 } },
                    audio: false
                }))
                .then(s => { stream = s; videoEl.srcObject = stream; return videoEl.play(); })
                .then(() => {
                    if (idle) idle.style.display = 'none';
                    if (scan) scan.style.display = 'flex';
                    if (ok)   ok.style.display   = 'none';
                    capBtn.disabled = false;
                    startBtn.innerHTML = '<i class="fa-solid fa-circle" style="color:#e53935;font-size:9px;"></i> Active';
                    setStatus('Camera active Ã¢â‚¬â€ placez votre visage dans le cadre.', 'active');
                })
                .catch(() => { setStatus("Impossible d'acceder a la camera.", 'error'); startBtn.disabled = false; });
        });

        capBtn.addEventListener('click', () => {
            capBtn.disabled = true;
            setStatus('Analyse en coursÃ¢â‚¬Â¦', 'loading');
            window.faceapi
                .detectSingleFace(videoEl,
                    new window.faceapi.TinyFaceDetectorOptions({ inputSize: 320, scoreThreshold: 0.45 }))
                .withFaceLandmarks()
                .withFaceDescriptor()
                .then(det => {
                    if (!det) {
                        descEl.value = '';
                        setStatus("Aucun visage detecte. Ameliorez l'eclairage.", 'error');
                        capBtn.disabled = false;
                        return;
                    }
                    descEl.value = JSON.stringify(Array.from(det.descriptor));
                    if (scan) scan.style.display = 'none';
                    if (ok)   ok.style.display   = 'flex';
                    setStatus('Visage capture ! Cliquez sur "Enregistrer Face ID".', 'success');
                    capBtn.disabled = false;
                })
                .catch(() => {
                    descEl.value = '';
                    setStatus('Echec de la capture biometrique.', 'error');
                    capBtn.disabled = false;
                });
        });

        window.addEventListener('beforeunload', () => {
            if (stream) stream.getTracks().forEach(t => t.stop());
        });
    }

    /* Ã¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢Â
       PHOTO UPLOAD
    Ã¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢Â */
    function initPhotoUpload() {
        const fileInput = $('#pf-photo-input');
        if (!fileInput) return;

        const feedback   = $('#pf-photo-feedback');
        const formPreview= $('#pf-photo-preview');
        const heroAvatar = $('#pf-hero-avatar');
        const form       = fileInput.closest('form');
        let   timer      = null;

        function applyImg(container, src) {
            if (!container) return;
            container.innerHTML = '';
            const img = document.createElement('img');
            img.src = src;
            img.alt = 'Photo profil';
            container.appendChild(img);
        }

        fileInput.addEventListener('change', () => {
            const file = fileInput.files && fileInput.files[0];
            if (!file) return;
            const url = URL.createObjectURL(file);
            applyImg(formPreview, url);
            applyImg(heroAvatar, url);
            if (feedback) feedback.textContent = file.name + ' Ã¢â‚¬â€ sauvegardeÃ¢â‚¬Â¦';
            clearTimeout(timer);
            timer = setTimeout(() => {
                if (typeof form.requestSubmit === 'function') form.requestSubmit();
                else form.submit();
            }, 220);
        });
    }

})();
</script>
