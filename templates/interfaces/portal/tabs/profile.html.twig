.pf-stat-strip {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    background: #fff;
    border-radius: 16px;
    border: 1px solid #dde8f5;
    padding: 16px;
    box-shadow: 0 2px 10px rgba(10,37,64,.05);
}

.pf-stat-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 0 12px;
    border-right: 1px solid #e8f0f8;
}

.pf-stat-item:last-child { border-right: none; }

.pf-stat-label {
    font-size: 10px;
    font-weight: 700;
    color: #8aafc8;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.pf-stat-value {
    font-size: 13px;
    font-weight: 700;
    color: #0a2540;
}

/* Ã¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢Â
   FORMS
   Ã¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢Â */
.pf-form { display: flex; flex-direction: column; gap: 14px; }

.pf-section-label {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    font-weight: 800;
    color: #1565c0;
    text-transform: uppercase;
    letter-spacing: 0.8px;
}

.pf-section-label i { font-size: 11px; }

.pf-section-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, #c3d9f5, transparent);
}

.pf-form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
.pf-form-row-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; }

.pf-field { display: flex; flex-direction: column; gap: 5px; }
.pf-field-full { grid-column: 1 / -1; }

.pf-label {
    font-size: 11px;
    font-weight: 700;
    color: #4e7490;
    display: flex;
    align-items: center;
    gap: 5px;
}

.pf-label i { color: #1565c0; font-size: 10px; }
.pf-req { color: #e53935; }

/* Input wrapper with icon */
.pf-input-wrap { position: relative; }

.pf-input-icon {
    position: absolute;
    left: 12px; top: 50%;
    transform: translateY(-50%);
    color: #8aafc8;
    font-size: 13px;
    pointer-events: none;
    z-index: 1;
}

.pf-input {
    width: 100%;
    min-height: 42px;
    border-radius: 12px;
    border: 1.5px solid #ccddef;
    background: #f7faff;
    padding: 0 12px 0 36px;
    font: inherit;
    font-size: 13px;
    color: #0a2540;
    outline: none;
    appearance: none;
    transition: border-color .18s, box-shadow .18s, background .18s;
}

.pf-input:focus {
    border-color: #1e88e5;
    background: #fff;
    box-shadow: 0 0 0 3px rgba(30,136,229,.12);
}

.pf-input::placeholder { color: #aabece; font-size: 12px; }

.pf-input-no-icon { padding-left: 12px; }

.pf-select { cursor: pointer; padding-right: 30px; }

.pf-select-arrow {
    position: absolute;
    right: 11px; top: 50%;
    transform: translateY(-50%);
    color: #8aafc8; font-size: 10px;
    pointer-events: none;
}

/* Eye toggle */
.pf-eye-btn {
    position: absolute;
    right: 10px; top: 50%;
    transform: translateY(-50%);
    background: none; border: none;
    color: #8aafc8; cursor: pointer;
    font-size: 13px; padding: 2px 4px;
    transition: color .15s;
}

.pf-eye-btn:hover { color: #1565c0; }

/* OTP input */
.pf-otp-input {
    letter-spacing: 6px;
    text-align: center;
    font-size: 18px;
    font-weight: 800;
    font-variant-numeric: tabular-nums;
}

/* Valid chip */
.pf-valid-chip {
    padding: 2px 8px;
    border-radius: 999px;
    background: #fef9c3;
    color: #92400e;
    font-size: 10px;
    font-weight: 700;
    margin-left: 6px;
}

/* Password strength */
.pf-pw-strength { display: flex; flex-direction: column; gap: 4px; margin-top: 4px; }

.pf-pw-bars {
    display: flex;
    gap: 3px;
}

.pf-pw-bar {
    flex: 1;
    height: 4px;
    border-radius: 999px;
    background: #e8f0f8;
    transition: background .3s;
}

.pf-pw-label {
    font-size: 11px;
    font-weight: 700;
    color: #8aafc8;
}

/* Input valid/invalid */
.pf-input-wrap.is-valid .pf-input { border-color: #22c55e; background: #f0fdf4; }
.pf-input-wrap.is-invalid .pf-input { border-color: #e53935; background: #fff5f5; }

/* Form footer */
.pf-form-footer {
    display: flex;
    align-items: center;
    gap: 10px;
    padding-top: 8px;
    border-top: 1px solid #edf4fb;
}

/* Ã¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢Â
   BUTTONS
   Ã¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢Â */
.pf-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    min-height: 42px;
    padding: 0 20px;
    border-radius: 12px;
    font: inherit;
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
    border: none;
    text-decoration: none;
    transition: all .18s;
    white-space: nowrap;
}

.pf-btn i { font-size: 13px; }

.pf-btn-primary {
    background: linear-gradient(120deg, #1565c0, #1e88e5);
    color: #fff;
    box-shadow: 0 4px 14px rgba(21,101,192,.25);
}

.pf-btn-primary:hover { opacity: .9; box-shadow: 0 6px 18px rgba(21,101,192,.35); }

.pf-btn-teal {
    background: linear-gradient(120deg, #00838f, #00bcd4);
    color: #fff;
    box-shadow: 0 4px 14px rgba(0,188,212,.22);
}

.pf-btn-teal:hover { opacity: .9; }

.pf-btn-amber {
    background: linear-gradient(120deg, #d97706, #f59e0b);
    color: #fff;
    box-shadow: 0 4px 14px rgba(217,119,6,.22);
}

.pf-btn-amber:hover { opacity: .9; }

.pf-btn-danger {
    background: #fff0f0;
    color: #dc2626;
    border: 1.5px solid #fecaca;
}

.pf-btn-danger:hover { background: #dc2626; color: #fff; border-color: transparent; }

.pf-btn-outline {
    background: transparent;
    color: #1565c0;
    border: 1.5px solid #c3d9f5;
}

.pf-btn-outline:hover { background: #eaf2fd; }

.pf-btn-ghost {
    background: transparent;
    color: #5b80a0;
    border: 1.5px solid #dde8f5;
}

.pf-btn-ghost:hover { background: #f0f4f8; }

.pf-btn-sm {
    min-height: 34px;
    padding: 0 14px;
    font-size: 12px;
    border-radius: 10px;
}

/* Ã¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢Â
   BIOMETRIC CAMERA
   Ã¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢Â */
.pf-cam-wrap {
    display: flex;
    flex-direction: column;
    gap: 10px;
}

.pf-cam-viewport {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    background: #0a1929;
    aspect-ratio: 4/3;
    width: 100%;
    max-width: 320px;
    margin: 0 auto;
}

.pf-cam-viewport video {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
}

.pf-cam-idle {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background: #0a1929;
}

.pf-cam-idle i { font-size: 32px; color: rgba(255,255,255,.2); }
.pf-cam-idle p { font-size: 12px; color: rgba(255,255,255,.4); }

.pf-cam-scan {
    position: absolute;
    inset: 0;
    display: none;
    align-items: center;
    justify-content: center;
}

/* Corner brackets */
.pf-corner {
    position: absolute;
    width: 20px; height: 20px;
    border-color: #00bcd4;
    border-style: solid;
    border-width: 0;
}

.pf-corner-tl { top: 16px; left: 16px; border-top-width: 2.5px; border-left-width: 2.5px; border-radius: 4px 0 0 0; }
.pf-corner-tr { top: 16px; right: 16px; border-top-width: 2.5px; border-right-width: 2.5px; border-radius: 0 4px 0 0; }
.pf-corner-bl { bottom: 16px; left: 16px; border-bottom-width: 2.5px; border-left-width: 2.5px; border-radius: 0 0 0 4px; }
.pf-corner-br { bottom: 16px; right: 16px; border-bottom-width: 2.5px; border-right-width: 2.5px; border-radius: 0 0 4px 0; }

/* Scan oval */
.pf-cam-oval {
    width: 110px; height: 140px;
    border-radius: 50%;
    border: 2px solid rgba(0,188,212,.5);
}

/* Sweep line */
.pf-cam-sweep {
    position: absolute;
    left: 10%; right: 10%;
    height: 1px;
    background: linear-gradient(90deg, transparent, #00bcd4, transparent);
    animation: pf-sweep 2.4s ease-in-out infinite;
    top: 30%;
}

@keyframes pf-sweep {
    0%   { top: 25%; opacity: 0; }
    10%  { opacity: 1; }
    90%  { opacity: 1; }
    100% { top: 75%; opacity: 0; }
}

.pf-cam-ok {
    position: absolute;
    inset: 0;
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background: rgba(0,188,212,.1);
}

.pf-cam-ok-ring {
    width: 60px; height: 60px;
    border-radius: 50%;
    background: rgba(0,188,212,.15);
    border: 2px solid #00bcd4;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
    color: #00bcd4;
}

.pf-cam-ok p { font-size: 12px; color: #00bcd4; font-weight: 700; }

.pf-cam-status {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    color: #7294ae;
    font-weight: 600;
}

.pf-cam-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
    background: #8aafc8;
    transition: background .3s;
}

.pf-cam-dot.active { background: #22c55e; }
.pf-cam-dot.loading { background: #f59e0b; animation: pf-blink .8s ease-in-out infinite; }
.pf-cam-dot.success { background: #00bcd4; }
.pf-cam-dot.error { background: #e53935; }

@keyframes pf-blink { 0%, 100% { opacity: 1; } 50% { opacity: .3; } }

.pf-cam-btns { display: flex; gap: 8px; }

/* Biometric status badge */
.pf-bio-badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 4px 10px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 800;
    margin-left: auto;
}

.pf-bio-badge::before {
    content: '';
    width: 6px; height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
}

.pf-bio-badge-on { background: #dcfce7; color: #166534; }
.pf-bio-badge-on::before { background: #22c55e; }

.pf-bio-badge-off { background: #fee2e2; color: #991b1b; }
.pf-bio-badge-off::before { background: #e53935; }

/* Danger strip */
.pf-danger-strip {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 14px 16px;
    background: #fff5f5;
    border: 1px solid #fecaca;
    border-radius: 13px;
}

.pf-danger-strip-info strong { display: block; font-size: 13px; font-weight: 800; color: #991b1b; }
.pf-danger-strip-info p { font-size: 12px; color: #b91c1c; margin-top: 2px; }

