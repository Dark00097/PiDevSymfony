.pf-loc-chips {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 14px;
}

.pf-loc-chip {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 16px;
    background: #f7faff;
    border: 1px solid #dde8f5;
    border-radius: 13px;
    flex: 1;
    min-width: 180px;
}

.pf-loc-chip-icon {
    width: 34px; height: 34px;
    border-radius: 10px;
    background: linear-gradient(135deg, #1565c0, #00bcd4);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-size: 14px;
    flex-shrink: 0;
}

.pf-loc-chip small { display: block; font-size: 10px; color: #7294ae; font-weight: 700; text-transform: uppercase; letter-spacing: 0.4px; }
.pf-loc-chip strong { display: block; font-size: 13px; font-weight: 700; color: #0a2540; margin-top: 2px; }

.pf-map-box {
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid #dde8f5;
    height: 300px;
}

.pf-map-box #nx-profile-osm-map { width: 100%; height: 100%; }

.pf-map-credit {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 11px;
    color: #8aafc8;
    margin-top: 8px;
}

.pf-map-credit i { font-size: 10px; }

.pf-map-fallback {
    padding: 48px;
    text-align: center;
    font-size: 13px;
    color: #7294ae;
    background: #f7faff;
    border-radius: 14px;
    border: 1px dashed #c3d9f5;
}

/* Ã¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢Â
