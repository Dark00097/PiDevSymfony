.pf-secured-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    border-radius: 999px;
    background: rgba(34,197,94,.15);
    border: 1px solid rgba(34,197,94,.3);
    color: #86efac;
    font-size: 12px;
    font-weight: 700;
    flex-shrink: 0;
}

