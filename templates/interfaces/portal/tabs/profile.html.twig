.pf-hero {
    background: linear-gradient(135deg, #0a2540 0%, #1565c0 60%, #00bcd4 100%);
    padding: 32px 28px 0;
    position: relative;
    overflow: hidden;
}

.pf-hero::before {
    content: '';
    position: absolute;
    width: 400px; height: 400px;
    background: rgba(255,255,255,.04);
    border-radius: 50%;
    top: -160px; right: -100px;
    pointer-events: none;
}

.pf-hero::after {
    content: '';
    position: absolute;
    width: 200px; height: 200px;
    background: rgba(0,188,212,.08);
    border-radius: 50%;
    bottom: -80px; left: 20%;
    pointer-events: none;
}

.pf-hero-inner {
    display: flex;
    align-items: flex-end;
    gap: 24px;
    position: relative;
    z-index: 1;
}

/* Avatar area */
.pf-hero-avatar-wrap {
    position: relative;
    flex-shrink: 0;
    margin-bottom: -24px;
}

.pf-hero-avatar {
    width: 90px; height: 90px;
    border-radius: 50%;
    background: linear-gradient(135deg, #1565c0, #00bcd4);
    border: 4px solid #fff;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8px 24px rgba(0,0,0,.2);
}

.pf-hero-avatar img {
    width: 100%; height: 100%; object-fit: cover;
}

.pf-hero-avatar i {
    font-size: 32px;
    color: rgba(255,255,255,.7);
}

.pf-avatar-cam {
    position: absolute;
    bottom: 2px; right: 2px;
    width: 26px; height: 26px;
    border-radius: 50%;
    background: #fff;
    border: 2px solid #e2eaf4;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #1565c0;
    font-size: 11px;
    transition: background .15s;
}

.pf-avatar-cam:hover { background: #eaf2fd; }

.pf-hero-info {
    flex: 1;
    padding-bottom: 20px;
}

.pf-hero-name {
    font-size: clamp(20px, 2.5vw, 28px);
    font-weight: 900;
    color: #fff;
    letter-spacing: -0.3px;
    line-height: 1.1;
}

.pf-hero-email {
    font-size: 13px;
    color: rgba(255,255,255,.7);
    margin-top: 4px;
}

.pf-hero-chips {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 12px;
    flex-wrap: wrap;
}

.pf-hero-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 12px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 700;
    backdrop-filter: blur(8px);
}

.pf-hero-chip-active {
    background: rgba(34,197,94,.2);
    border: 1px solid rgba(34,197,94,.35);
    color: #86efac;
}

.pf-hero-chip-active::before {
    content: '';
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #22c55e;
    flex-shrink: 0;
    animation: pf-pulse 1.8s ease-out infinite;
}

@keyframes pf-pulse {
    0%   { box-shadow: 0 0 0 0 rgba(34,197,94,.5); }
    100% { box-shadow: 0 0 0 6px transparent; }
}

.pf-hero-chip-info {
    background: rgba(255,255,255,.12);
    border: 1px solid rgba(255,255,255,.18);
    color: rgba(255,255,255,.85);
}

.pf-hero-actions {
    display: flex;
    align-items: flex-end;
    gap: 10px;
    padding-bottom: 20px;
    flex-shrink: 0;
}

/* Tab pills on hero bottom */
.pf-tab-row {
    display: flex;
    align-items: center;
    gap: 2px;
    position: relative;
    z-index: 1;
    margin-top: 20px;
}

.pf-tab-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 18px;
    border: none;
    background: transparent;
    color: rgba(255,255,255,.6);
    font: inherit;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    border-radius: 12px 12px 0 0;
    transition: all .18s;
    white-space: nowrap;
    position: relative;
}

.pf-tab-btn i { font-size: 14px; }

.pf-tab-btn:hover {
    background: rgba(255,255,255,.08);
    color: rgba(255,255,255,.9);
}

.pf-tab-btn.active {
    background: #f0f4f8;
    color: #1565c0;
    font-weight: 800;
}

.pf-tab-btn.active i { color: #1565c0; }

