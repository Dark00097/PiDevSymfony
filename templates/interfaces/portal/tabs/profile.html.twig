{% set activity = support.activity|default([]) %}
{% set opened_location = current_user.account_opened_location|default('Unknown location') %}
{% set opened_from = current_user.account_opened_from|default('Unknown source') %}
{% set opened_at = current_user.created_at|default(current_user.account_opened_at|default('-')) %}
{% set last_online_at = current_user.last_online_at|default('-') %}
{% set last_online_from = current_user.last_online_from|default('-') %}
{% set map_query = opened_location != 'Unknown location' ? opened_location : opened_from %}
{% set profile_ai = support.profile_ai|default({}) %}
{% set ai_security = profile_ai.security_analysis|default({}) %}
{% set ai_prediction = profile_ai.prediction|default({}) %}
{% set ai_account_advice = profile_ai.account_advice|default({}) %}
{% set ai_cashback_advice = profile_ai.cashback_advice|default({}) %}
{% set ai_surplus = profile_ai.surplus|default({}) %}

<style>
/* ══════════════════════════════════════════════════════════════════════
   PROFILE PAGE — Complete Redesign
   White background · Blue/Teal/Purple palette
   ══════════════════════════════════════════════════════════════════════ */

.pf-root *, .pf-root *::before, .pf-root *::after {
    box-sizing: border-box; margin: 0; padding: 0;
}

.pf-root {
    display: flex;
    flex-direction: column;
    background: #f0f4f8;
    font-family: inherit;
    color: #0a2540;
    min-height: 100vh;
}

/* ══════════════════════════════════════════════════════════════════════
   PROFILE HERO BANNER
   ══════════════════════════════════════════════════════════════════════ */
.pf-hero {
    background: linear-gradient(135deg, #0a2540 0%, #1565c0 60%, #00bcd4 100%);
    padding: 32px 28px 0;
    position: relative;
    overflow: hidden;
}

.pf-hero::before {
    content: '';
    position: absolute;
    width: 400px; height: 400px;
    background: rgba(255,255,255,.04);
    border-radius: 50%;
    top: -160px; right: -100px;
    pointer-events: none;
}

.pf-hero::after {
    content: '';
    position: absolute;
    width: 200px; height: 200px;
    background: rgba(0,188,212,.08);
    border-radius: 50%;
    bottom: -80px; left: 20%;
    pointer-events: none;
}

.pf-hero-inner {
    display: flex;
    align-items: flex-end;
    gap: 24px;
    position: relative;
    z-index: 1;
}

/* Avatar area */
.pf-hero-avatar-wrap {
    position: relative;
    flex-shrink: 0;
    margin-bottom: -24px;
}

.pf-hero-avatar {
    width: 90px; height: 90px;
    border-radius: 50%;
    background: linear-gradient(135deg, #1565c0, #00bcd4);
    border: 4px solid #fff;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8px 24px rgba(0,0,0,.2);
}

.pf-hero-avatar img {
    width: 100%; height: 100%; object-fit: cover;
}

.pf-hero-avatar i {
    font-size: 32px;
    color: rgba(255,255,255,.7);
}

.pf-avatar-cam {
    position: absolute;
    bottom: 2px; right: 2px;
    width: 26px; height: 26px;
    border-radius: 50%;
    background: #fff;
    border: 2px solid #e2eaf4;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #1565c0;
    font-size: 11px;
    transition: background .15s;
}

.pf-avatar-cam:hover { background: #eaf2fd; }

.pf-hero-info {
    flex: 1;
    padding-bottom: 20px;
}

.pf-hero-name {
    font-size: clamp(20px, 2.5vw, 28px);
    font-weight: 900;
    color: #fff;
    letter-spacing: -0.3px;
    line-height: 1.1;
}

.pf-hero-email {
    font-size: 13px;
    color: rgba(255,255,255,.7);
    margin-top: 4px;
}

.pf-hero-chips {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 12px;
    flex-wrap: wrap;
}

.pf-hero-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 12px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 700;
    backdrop-filter: blur(8px);
}

.pf-hero-chip-active {
    background: rgba(34,197,94,.2);
    border: 1px solid rgba(34,197,94,.35);
    color: #86efac;
}

.pf-hero-chip-active::before {
    content: '';
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #22c55e;
    flex-shrink: 0;
    animation: pf-pulse 1.8s ease-out infinite;
}

@keyframes pf-pulse {
    0%   { box-shadow: 0 0 0 0 rgba(34,197,94,.5); }
    100% { box-shadow: 0 0 0 6px transparent; }
}

.pf-hero-chip-info {
    background: rgba(255,255,255,.12);
    border: 1px solid rgba(255,255,255,.18);
    color: rgba(255,255,255,.85);
}

.pf-hero-actions {
    display: flex;
    align-items: flex-end;
    gap: 10px;
    padding-bottom: 20px;
    flex-shrink: 0;
}

/* Tab pills on hero bottom */
.pf-tab-row {
    display: flex;
    align-items: center;
    gap: 2px;
    position: relative;
    z-index: 1;
    margin-top: 20px;
}

.pf-tab-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 18px;
    border: none;
    background: transparent;
    color: rgba(255,255,255,.6);
    font: inherit;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    border-radius: 12px 12px 0 0;
    transition: all .18s;
    white-space: nowrap;
    position: relative;
}

.pf-tab-btn i { font-size: 14px; }

.pf-tab-btn:hover {
    background: rgba(255,255,255,.08);
    color: rgba(255,255,255,.9);
}

.pf-tab-btn.active {
    background: #f0f4f8;
    color: #1565c0;
    font-weight: 800;
}

.pf-tab-btn.active i { color: #1565c0; }

/* ══════════════════════════════════════════════════════════════════════
   CONTENT AREA
   ══════════════════════════════════════════════════════════════════════ */
.pf-content {
    flex: 1;
    padding: 24px 28px 32px;
    display: flex;
    flex-direction: column;
    gap: 20px;
}

/* Tab panels */
.pf-panel { display: none; flex-direction: column; gap: 18px; }
.pf-panel.active { display: flex; }

/* ══════════════════════════════════════════════════════════════════════
   CARDS
   ══════════════════════════════════════════════════════════════════════ */
.pf-card {
    background: #fff;
    border-radius: 20px;
    border: 1px solid #dde8f5;
    box-shadow: 0 2px 12px rgba(10,37,64,.06);
    overflow: hidden;
    display: flex;
    flex-direction: column;
}

.pf-card-header {
    display: flex;
    align-items: center;
    gap: 13px;
    padding: 18px 20px;
    background: linear-gradient(135deg, #f7faff, #f0f5fb);
    border-bottom: 1px solid #dde8f5;
}

.pf-card-icon {
    width: 40px; height: 40px;
    border-radius: 13px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    color: #fff;
    flex-shrink: 0;
}

.pf-card-header h3 {
    font-size: 15px;
    font-weight: 800;
    color: #0a2540;
    line-height: 1.2;
}

.pf-card-header p {
    font-size: 12px;
    color: #7294ae;
    margin-top: 2px;
}

.pf-card-body { padding: 20px; display: flex; flex-direction: column; gap: 14px; }

/* ══════════════════════════════════════════════════════════════════════
   GRIDS
   ══════════════════════════════════════════════════════════════════════ */
.pf-grid-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
}

.pf-grid-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
}

.pf-grid-4 {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
}

/* ══════════════════════════════════════════════════════════════════════
   STAT CHIPS (member since, etc.)
   ══════════════════════════════════════════════════════════════════════ */
.pf-stat-strip {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    background: #fff;
    border-radius: 16px;
    border: 1px solid #dde8f5;
    padding: 16px;
    box-shadow: 0 2px 10px rgba(10,37,64,.05);
}

.pf-stat-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 0 12px;
    border-right: 1px solid #e8f0f8;
}

.pf-stat-item:last-child { border-right: none; }

.pf-stat-label {
    font-size: 10px;
    font-weight: 700;
    color: #8aafc8;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.pf-stat-value {
    font-size: 13px;
    font-weight: 700;
    color: #0a2540;
}

/* ══════════════════════════════════════════════════════════════════════
   FORMS
   ══════════════════════════════════════════════════════════════════════ */
.pf-form { display: flex; flex-direction: column; gap: 14px; }

.pf-section-label {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    font-weight: 800;
    color: #1565c0;
    text-transform: uppercase;
    letter-spacing: 0.8px;
}

.pf-section-label i { font-size: 11px; }

.pf-section-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, #c3d9f5, transparent);
}

.pf-form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
.pf-form-row-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; }

.pf-field { display: flex; flex-direction: column; gap: 5px; }
.pf-field-full { grid-column: 1 / -1; }

.pf-label {
    font-size: 11px;
    font-weight: 700;
    color: #4e7490;
    display: flex;
    align-items: center;
    gap: 5px;
}

.pf-label i { color: #1565c0; font-size: 10px; }
.pf-req { color: #e53935; }

/* Input wrapper with icon */
.pf-input-wrap { position: relative; }

.pf-input-icon {
    position: absolute;
    left: 12px; top: 50%;
    transform: translateY(-50%);
    color: #8aafc8;
    font-size: 13px;
    pointer-events: none;
    z-index: 1;
}

.pf-input {
    width: 100%;
    min-height: 42px;
    border-radius: 12px;
    border: 1.5px solid #ccddef;
    background: #f7faff;
    padding: 0 12px 0 36px;
    font: inherit;
    font-size: 13px;
    color: #0a2540;
    outline: none;
    appearance: none;
    transition: border-color .18s, box-shadow .18s, background .18s;
}

.pf-input:focus {
    border-color: #1e88e5;
    background: #fff;
    box-shadow: 0 0 0 3px rgba(30,136,229,.12);
}

.pf-input::placeholder { color: #aabece; font-size: 12px; }

.pf-input-no-icon { padding-left: 12px; }

.pf-select { cursor: pointer; padding-right: 30px; }

.pf-select-arrow {
    position: absolute;
    right: 11px; top: 50%;
    transform: translateY(-50%);
    color: #8aafc8; font-size: 10px;
    pointer-events: none;
}

/* Eye toggle */
.pf-eye-btn {
    position: absolute;
    right: 10px; top: 50%;
    transform: translateY(-50%);
    background: none; border: none;
    color: #8aafc8; cursor: pointer;
    font-size: 13px; padding: 2px 4px;
    transition: color .15s;
}

.pf-eye-btn:hover { color: #1565c0; }

/* OTP input */
.pf-otp-input {
    letter-spacing: 6px;
    text-align: center;
    font-size: 18px;
    font-weight: 800;
    font-variant-numeric: tabular-nums;
}

/* Valid chip */
.pf-valid-chip {
    padding: 2px 8px;
    border-radius: 999px;
    background: #fef9c3;
    color: #92400e;
    font-size: 10px;
    font-weight: 700;
    margin-left: 6px;
}

/* Password strength */
.pf-pw-strength { display: flex; flex-direction: column; gap: 4px; margin-top: 4px; }

.pf-pw-bars {
    display: flex;
    gap: 3px;
}

.pf-pw-bar {
    flex: 1;
    height: 4px;
    border-radius: 999px;
    background: #e8f0f8;
    transition: background .3s;
}

.pf-pw-label {
    font-size: 11px;
    font-weight: 700;
    color: #8aafc8;
}

/* Input valid/invalid */
.pf-input-wrap.is-valid .pf-input { border-color: #22c55e; background: #f0fdf4; }
.pf-input-wrap.is-invalid .pf-input { border-color: #e53935; background: #fff5f5; }

/* Form footer */
.pf-form-footer {
    display: flex;
    align-items: center;
    gap: 10px;
    padding-top: 8px;
    border-top: 1px solid #edf4fb;
}

/* ══════════════════════════════════════════════════════════════════════
   BUTTONS
   ══════════════════════════════════════════════════════════════════════ */
.pf-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    min-height: 42px;
    padding: 0 20px;
    border-radius: 12px;
    font: inherit;
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
    border: none;
    text-decoration: none;
    transition: all .18s;
    white-space: nowrap;
}

.pf-btn i { font-size: 13px; }

.pf-btn-primary {
    background: linear-gradient(120deg, #1565c0, #1e88e5);
    color: #fff;
    box-shadow: 0 4px 14px rgba(21,101,192,.25);
}

.pf-btn-primary:hover { opacity: .9; box-shadow: 0 6px 18px rgba(21,101,192,.35); }

.pf-btn-teal {
    background: linear-gradient(120deg, #00838f, #00bcd4);
    color: #fff;
    box-shadow: 0 4px 14px rgba(0,188,212,.22);
}

.pf-btn-teal:hover { opacity: .9; }

.pf-btn-amber {
    background: linear-gradient(120deg, #d97706, #f59e0b);
    color: #fff;
    box-shadow: 0 4px 14px rgba(217,119,6,.22);
}

.pf-btn-amber:hover { opacity: .9; }

.pf-btn-danger {
    background: #fff0f0;
    color: #dc2626;
    border: 1.5px solid #fecaca;
}

.pf-btn-danger:hover { background: #dc2626; color: #fff; border-color: transparent; }

.pf-btn-outline {
    background: transparent;
    color: #1565c0;
    border: 1.5px solid #c3d9f5;
}

.pf-btn-outline:hover { background: #eaf2fd; }

.pf-btn-ghost {
    background: transparent;
    color: #5b80a0;
    border: 1.5px solid #dde8f5;
}

.pf-btn-ghost:hover { background: #f0f4f8; }

.pf-btn-sm {
    min-height: 34px;
    padding: 0 14px;
    font-size: 12px;
    border-radius: 10px;
}

/* ══════════════════════════════════════════════════════════════════════
   BIOMETRIC CAMERA
   ══════════════════════════════════════════════════════════════════════ */
.pf-cam-wrap {
    display: flex;
    flex-direction: column;
    gap: 10px;
}

.pf-cam-viewport {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    background: #0a1929;
    aspect-ratio: 4/3;
    width: 100%;
    max-width: 320px;
    margin: 0 auto;
}

.pf-cam-viewport video {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
}

.pf-cam-idle {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background: #0a1929;
}

.pf-cam-idle i { font-size: 32px; color: rgba(255,255,255,.2); }
.pf-cam-idle p { font-size: 12px; color: rgba(255,255,255,.4); }

.pf-cam-scan {
    position: absolute;
    inset: 0;
    display: none;
    align-items: center;
    justify-content: center;
}

/* Corner brackets */
.pf-corner {
    position: absolute;
    width: 20px; height: 20px;
    border-color: #00bcd4;
    border-style: solid;
    border-width: 0;
}

.pf-corner-tl { top: 16px; left: 16px; border-top-width: 2.5px; border-left-width: 2.5px; border-radius: 4px 0 0 0; }
.pf-corner-tr { top: 16px; right: 16px; border-top-width: 2.5px; border-right-width: 2.5px; border-radius: 0 4px 0 0; }
.pf-corner-bl { bottom: 16px; left: 16px; border-bottom-width: 2.5px; border-left-width: 2.5px; border-radius: 0 0 0 4px; }
.pf-corner-br { bottom: 16px; right: 16px; border-bottom-width: 2.5px; border-right-width: 2.5px; border-radius: 0 0 4px 0; }

/* Scan oval */
.pf-cam-oval {
    width: 110px; height: 140px;
    border-radius: 50%;
    border: 2px solid rgba(0,188,212,.5);
}

/* Sweep line */
.pf-cam-sweep {
    position: absolute;
    left: 10%; right: 10%;
    height: 1px;
    background: linear-gradient(90deg, transparent, #00bcd4, transparent);
    animation: pf-sweep 2.4s ease-in-out infinite;
    top: 30%;
}

@keyframes pf-sweep {
    0%   { top: 25%; opacity: 0; }
    10%  { opacity: 1; }
    90%  { opacity: 1; }
    100% { top: 75%; opacity: 0; }
}

.pf-cam-ok {
    position: absolute;
    inset: 0;
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background: rgba(0,188,212,.1);
}

.pf-cam-ok-ring {
    width: 60px; height: 60px;
    border-radius: 50%;
    background: rgba(0,188,212,.15);
    border: 2px solid #00bcd4;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
    color: #00bcd4;
}

.pf-cam-ok p { font-size: 12px; color: #00bcd4; font-weight: 700; }

.pf-cam-status {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    color: #7294ae;
    font-weight: 600;
}

.pf-cam-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
    background: #8aafc8;
    transition: background .3s;
}

.pf-cam-dot.active { background: #22c55e; }
.pf-cam-dot.loading { background: #f59e0b; animation: pf-blink .8s ease-in-out infinite; }
.pf-cam-dot.success { background: #00bcd4; }
.pf-cam-dot.error { background: #e53935; }

@keyframes pf-blink { 0%, 100% { opacity: 1; } 50% { opacity: .3; } }

.pf-cam-btns { display: flex; gap: 8px; }

/* Biometric status badge */
.pf-bio-badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 4px 10px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 800;
    margin-left: auto;
}

.pf-bio-badge::before {
    content: '';
    width: 6px; height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
}

.pf-bio-badge-on { background: #dcfce7; color: #166534; }
.pf-bio-badge-on::before { background: #22c55e; }

.pf-bio-badge-off { background: #fee2e2; color: #991b1b; }
.pf-bio-badge-off::before { background: #e53935; }

/* Danger strip */
.pf-danger-strip {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 14px 16px;
    background: #fff5f5;
    border: 1px solid #fecaca;
    border-radius: 13px;
}

.pf-danger-strip-info strong { display: block; font-size: 13px; font-weight: 800; color: #991b1b; }
.pf-danger-strip-info p { font-size: 12px; color: #b91c1c; margin-top: 2px; }

/* ══════════════════════════════════════════════════════════════════════
   PHOTO UPLOAD
   ══════════════════════════════════════════════════════════════════════ */
.pf-photo-row {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px;
    background: #f7faff;
    border: 1.5px dashed #c3d9f5;
    border-radius: 14px;
}

.pf-photo-thumb {
    width: 52px; height: 52px;
    border-radius: 50%;
    background: linear-gradient(135deg, #eaf2fd, #dbeafe);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    flex-shrink: 0;
    border: 2px solid #c3d9f5;
}

.pf-photo-thumb img { width: 100%; height: 100%; object-fit: cover; }
.pf-photo-thumb i { font-size: 20px; color: #7294ae; }

.pf-photo-info { display: flex; flex-direction: column; gap: 6px; }

.pf-upload-btn {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 7px 14px;
    border-radius: 9px;
    background: linear-gradient(120deg, #1565c0, #1e88e5);
    color: #fff;
    font: inherit;
    font-size: 12px;
    font-weight: 700;
    cursor: pointer;
    border: none;
    width: fit-content;
    transition: opacity .15s;
}

.pf-upload-btn:hover { opacity: .88; }

.pf-upload-hint {
    font-size: 11px;
    color: #7294ae;
}

/* ══════════════════════════════════════════════════════════════════════
   SECURITY HERO BANNER
   ══════════════════════════════════════════════════════════════════════ */
.pf-section-hero {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    background: linear-gradient(135deg, #0a2540, #1565c0);
    border-radius: 18px;
    padding: 20px 22px;
    box-shadow: 0 8px 24px rgba(10,37,64,.18);
}

.pf-section-hero-left {
    display: flex;
    align-items: center;
    gap: 14px;
}

.pf-section-hero-icon {
    width: 48px; height: 48px;
    border-radius: 16px;
    background: rgba(255,255,255,.12);
    border: 1px solid rgba(255,255,255,.2);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    color: #7dd3fc;
    flex-shrink: 0;
}

.pf-section-hero h2 { font-size: 17px; font-weight: 800; color: #fff; }
.pf-section-hero p  { font-size: 12px; color: rgba(255,255,255,.65); margin-top: 3px; }

.pf-secured-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    border-radius: 999px;
    background: rgba(34,197,94,.15);
    border: 1px solid rgba(34,197,94,.3);
    color: #86efac;
    font-size: 12px;
    font-weight: 700;
    flex-shrink: 0;
}

/* ══════════════════════════════════════════════════════════════════════
   MAP
   ══════════════════════════════════════════════════════════════════════ */
.pf-loc-chips {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 14px;
}

.pf-loc-chip {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 16px;
    background: #f7faff;
    border: 1px solid #dde8f5;
    border-radius: 13px;
    flex: 1;
    min-width: 180px;
}

.pf-loc-chip-icon {
    width: 34px; height: 34px;
    border-radius: 10px;
    background: linear-gradient(135deg, #1565c0, #00bcd4);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-size: 14px;
    flex-shrink: 0;
}

.pf-loc-chip small { display: block; font-size: 10px; color: #7294ae; font-weight: 700; text-transform: uppercase; letter-spacing: 0.4px; }
.pf-loc-chip strong { display: block; font-size: 13px; font-weight: 700; color: #0a2540; margin-top: 2px; }

.pf-map-box {
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid #dde8f5;
    height: 300px;
}

.pf-map-box #nx-profile-osm-map { width: 100%; height: 100%; }

.pf-map-credit {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 11px;
    color: #8aafc8;
    margin-top: 8px;
}

.pf-map-credit i { font-size: 10px; }

.pf-map-fallback {
    padding: 48px;
    text-align: center;
    font-size: 13px;
    color: #7294ae;
    background: #f7faff;
    border-radius: 14px;
    border: 1px dashed #c3d9f5;
}

/* ══════════════════════════════════════════════════════════════════════
   AI SCORECARDS
   ══════════════════════════════════════════════════════════════════════ */
.pf-scorecard {
    background: #fff;
    border-radius: 16px;
    border: 1px solid #dde8f5;
    padding: 18px;
    display: flex;
    align-items: center;
    gap: 14px;
    box-shadow: 0 2px 10px rgba(10,37,64,.05);
    transition: box-shadow .2s, transform .2s;
    position: relative;
    overflow: hidden;
}

.pf-scorecard:hover { box-shadow: 0 8px 24px rgba(10,37,64,.10); transform: translateY(-2px); }

.pf-scorecard-side {
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 4px;
    border-radius: 16px 0 0 16px;
}

.pf-scorecard-ring {
    position: relative;
    width: 54px; height: 54px;
    flex-shrink: 0;
}

.pf-scorecard-ring svg {
    width: 54px; height: 54px;
    transform: rotate(-90deg);
}

.pf-ring-bg {
    fill: none;
    stroke: #e8f0f8;
    stroke-width: 5;
}

.pf-ring-fill {
    fill: none;
    stroke-width: 5;
    stroke-linecap: round;
    stroke-dasharray: 0 88;
    transition: stroke-dasharray .8s ease;
}

.pf-ring-teal { stroke: #00bcd4; }
.pf-ring-blue { stroke: #1e88e5; }
.pf-ring-purple { stroke: #8b5cf6; }

.pf-scorecard-ring-val {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: 900;
    color: #0a2540;
}

.pf-scorecard-icon {
    width: 48px; height: 48px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    flex-shrink: 0;
}

.pf-scorecard-body { display: flex; flex-direction: column; gap: 2px; }
.pf-scorecard-body strong { font-size: 13px; font-weight: 800; color: #0a2540; }
.pf-scorecard-body span { font-size: 16px; font-weight: 900; color: #0a2540; letter-spacing: -0.3px; }
.pf-scorecard-body small { font-size: 11px; color: #7294ae; font-weight: 600; }

/* AI Insight cards */
.pf-ai-quad {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
}

.pf-insight {
    border-radius: 16px;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    border: 1px solid transparent;
}

.pf-insight-security  { background: linear-gradient(135deg,#f0fdf4,#dcfce7); border-color: #bbf7d0; }
.pf-insight-account   { background: linear-gradient(135deg,#eff6ff,#dbeafe); border-color: #bfdbfe; }
.pf-insight-cashback  { background: linear-gradient(135deg,#fffbeb,#fef3c7); border-color: #fde68a; }
.pf-insight-surplus   { background: linear-gradient(135deg,#f5f3ff,#ede9fe); border-color: #ddd6fe; }

.pf-insight-tag {
    display: flex;
    align-items: center;
    gap: 7px;
    font-size: 11px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.6px;
}

.pf-insight-security .pf-insight-tag  { color: #166534; }
.pf-insight-account  .pf-insight-tag  { color: #1e40af; }
.pf-insight-cashback .pf-insight-tag  { color: #92400e; }
.pf-insight-surplus  .pf-insight-tag  { color: #5b21b6; }

.pf-insight p { font-size: 13px; line-height: 1.55; color: #374151; }

/* ══════════════════════════════════════════════════════════════════════
   TIMELINE / ACTIVITY
   ══════════════════════════════════════════════════════════════════════ */
.pf-timeline { display: flex; flex-direction: column; }

.pf-tl-item {
    display: flex;
    gap: 12px;
    padding: 10px 0;
    border-bottom: 1px solid #f0f4f8;
}

.pf-tl-item:last-child { border-bottom: none; }

.pf-tl-left {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    flex-shrink: 0;
}

.pf-tl-dot {
    width: 10px; height: 10px;
    border-radius: 50%;
    margin-top: 4px;
    flex-shrink: 0;
}

.pf-tl-dot-teal  { background: #00bcd4; box-shadow: 0 0 0 3px rgba(0,188,212,.15); }
.pf-tl-dot-blue  { background: #1e88e5; box-shadow: 0 0 0 3px rgba(30,136,229,.15); }
.pf-tl-dot-purple{ background: #8b5cf6; box-shadow: 0 0 0 3px rgba(139,92,246,.15); }

.pf-tl-connector {
    width: 1px;
    flex: 1;
    background: #e8f0f8;
    margin: 4px 0;
    min-height: 18px;
}

.pf-tl-content { flex: 1; }
.pf-tl-content strong { display: block; font-size: 13px; font-weight: 700; color: #0a2540; }
.pf-tl-content p { font-size: 12px; color: #5b80a0; margin-top: 2px; line-height: 1.4; }
.pf-tl-content time { display: block; font-size: 11px; color: #8aafc8; margin-top: 4px; font-weight: 600; }

/* ══════════════════════════════════════════════════════════════════════
   NOTIFICATIONS
   ══════════════════════════════════════════════════════════════════════ */
.pf-notif-list { display: flex; flex-direction: column; }

.pf-notif-item {
    display: flex;
    gap: 10px;
    padding: 10px 0;
    border-bottom: 1px solid #f0f4f8;
}

.pf-notif-item:last-child { border-bottom: none; }

.pf-notif-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: #8b5cf6;
    flex-shrink: 0;
    margin-top: 5px;
}

.pf-notif-body { flex: 1; }
.pf-notif-body strong { display: block; font-size: 13px; font-weight: 700; color: #0a2540; }
.pf-notif-body p { font-size: 12px; color: #5b80a0; margin-top: 2px; line-height: 1.4; }
.pf-notif-body time { display: block; font-size: 11px; color: #8aafc8; margin-top: 3px; font-weight: 600; }

/* Scrollable tile body */
.pf-scroll-body { max-height: 380px; overflow-y: auto; padding-right: 4px; }

.pf-scroll-body::-webkit-scrollbar { width: 4px; }
.pf-scroll-body::-webkit-scrollbar-track { background: #f0f4f8; border-radius: 999px; }
.pf-scroll-body::-webkit-scrollbar-thumb { background: #c0d4e8; border-radius: 999px; }

/* Empty state */
.pf-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 40px 20px;
    text-align: center;
}

.pf-empty i { font-size: 30px; color: #c4d9ee; margin-bottom: 4px; }
.pf-empty p { font-size: 13px; color: #7294ae; }

/* Count pill */
.pf-count-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 3px 9px;
    border-radius: 999px;
    font-size: 10px;
    font-weight: 800;
    margin-left: auto;
}

.pf-count-pill-blue   { background: linear-gradient(120deg,#1565c0,#1e88e5); color: #fff; }
.pf-count-pill-purple { background: linear-gradient(120deg,#7c3aed,#8b5cf6); color: #fff; }

/* Link button */
.pf-link-btn {
    background: none;
    border: none;
    color: #1565c0;
    font: inherit;
    font-size: 12px;
    font-weight: 700;
    cursor: pointer;
    text-decoration: underline;
    padding: 0;
    transition: color .15s;
}

.pf-link-btn:hover { color: #0d47a1; }

/* Hint text */
.pf-hint {
    display: flex;
    align-items: flex-start;
    gap: 7px;
    font-size: 12px;
    color: #7294ae;
    line-height: 1.5;
    padding: 10px 12px;
    background: #f7faff;
    border-radius: 10px;
    border: 1px solid #dde8f5;
}

.pf-hint i { color: #1565c0; flex-shrink: 0; margin-top: 1px; }

/* ══════════════════════════════════════════════════════════════════════
   RESPONSIVE
   ══════════════════════════════════════════════════════════════════════ */
@media (max-width: 1100px) {
    .pf-grid-4 { grid-template-columns: repeat(2,1fr); }
    .pf-stat-strip { grid-template-columns: repeat(2,1fr); }
}

@media (max-width: 900px) {
    .pf-grid-2 { grid-template-columns: 1fr; }
    .pf-grid-3 { grid-template-columns: 1fr 1fr; }
    .pf-ai-quad { grid-template-columns: 1fr; }
}

@media (max-width: 700px) {
    .pf-hero { padding: 24px 16px 0; }
    .pf-hero-inner { flex-direction: column; align-items: flex-start; }
    .pf-content { padding: 16px; }
    .pf-tab-btn span { display: none; }
    .pf-tab-btn { padding: 10px 14px; }
    .pf-form-row, .pf-form-row-3 { grid-template-columns: 1fr; }
    .pf-stat-strip { grid-template-columns: 1fr 1fr; }
    .pf-grid-4 { grid-template-columns: 1fr 1fr; }
}
</style>

<div class="pf-root">

    {# ════════════ HERO BANNER ════════════ #}
    <header class="pf-hero">
        <div class="pf-hero-inner">

            {# Avatar #}
            <div class="pf-hero-avatar-wrap">
                <div class="pf-hero-avatar" id="pf-hero-avatar">
                    {% if current_user.profile_image_path|default('') %}
                        <img src="{{ asset(current_user.profile_image_path) }}" alt="Photo profil">
                    {% else %}
                        <i class="fa-solid fa-user"></i>
                    {% endif %}
                </div>
                <label class="pf-avatar-cam" for="pf-photo-input" title="Changer la photo">
                    <i class="fa-solid fa-camera"></i>
                </label>
            </div>

            {# Info #}
            <div class="pf-hero-info">
                <div class="pf-hero-name">
                    {{ current_user.prenom }} {{ current_user.nom }}
                </div>
                <div class="pf-hero-email">{{ current_user.email }}</div>
                <div class="pf-hero-chips">
                    <span class="pf-hero-chip pf-hero-chip-active">
                        {{ current_user.status|default('ACTIVE') }}
                    </span>
                    <span class="pf-hero-chip pf-hero-chip-info">
                        <i class="fa-solid fa-crown" style="font-size:10px;"></i>
                        Compte premium
                    </span>
                    <span class="pf-hero-chip pf-hero-chip-info">
                        <i class="fa-solid fa-calendar-day" style="font-size:10px;"></i>
                        Membre depuis {{ opened_at }}
                    </span>
                </div>
            </div>

            {# Hero actions #}
            <div class="pf-hero-actions">
                <a class="pf-btn pf-btn-ghost pf-btn-sm"
                   href="{{ path(route_name, { tab: 'profile' }) }}"
                   style="color:rgba(255,255,255,.8); border-color:rgba(255,255,255,.2); background:rgba(255,255,255,.1);">
                    <i class="fa-solid fa-rotate"></i>
                    <span>Actualiser</span>
                </a>
                <a class="pf-btn pf-btn-teal pf-btn-sm"
                   href="{{ path(route_name, { tab: 'dashboard' }) }}">
                    <i class="fa-solid fa-chart-line"></i>
                    <span>Dashboard</span>
                </a>
            </div>
        </div>

        {# Tab row at bottom of hero #}
        <div class="pf-tab-row">
            <button class="pf-tab-btn active" data-pf-tab="identity" type="button">
                <i class="fa-solid fa-user"></i>
                <span>Identite</span>
            </button>
            <button class="pf-tab-btn" data-pf-tab="security" type="button">
                <i class="fa-solid fa-shield-halved"></i>
                <span>Securite</span>
            </button>
            <button class="pf-tab-btn" data-pf-tab="location" type="button">
                <i class="fa-solid fa-location-dot"></i>
                <span>Localisation</span>
            </button>
            <button class="pf-tab-btn" data-pf-tab="ai" type="button">
                <i class="fa-solid fa-brain"></i>
                <span>IA &amp; Activite</span>
            </button>
        </div>
    </header>

    {# Stat strip #}
    <div style="padding: 16px 28px 0;">
        <div class="pf-stat-strip">
            <div class="pf-stat-item">
                <span class="pf-stat-label">Membre depuis</span>
                <span class="pf-stat-value">{{ opened_at }}</span>
            </div>
            <div class="pf-stat-item">
                <span class="pf-stat-label">Derniere connexion</span>
                <span class="pf-stat-value">{{ last_online_at }}</span>
            </div>
            <div class="pf-stat-item">
                <span class="pf-stat-label">Appareil</span>
                <span class="pf-stat-value">{{ last_online_from }}</span>
            </div>
            <div class="pf-stat-item">
                <span class="pf-stat-label">Source d'inscription</span>
                <span class="pf-stat-value">{{ opened_from }}</span>
            </div>
        </div>
    </div>

    {# ════════════ CONTENT ════════════ #}
    <div class="pf-content">

        {# ══ PANEL: IDENTITY ══ #}
        <div class="pf-panel active" id="pf-panel-identity">
            <div class="pf-grid-2">

                {# Personal info form #}
                <div class="pf-card">
                    <div class="pf-card-header">
                        <div class="pf-card-icon"
                             style="background:linear-gradient(135deg,#1565c0,#1e88e5);">
                            <i class="fa-solid fa-user"></i>
                        </div>
                        <div>
                            <h3>Informations personnelles</h3>
                            <p>Gerez votre profil public</p>
                        </div>
                    </div>
                    <div class="pf-card-body">
                        <form method="post" class="pf-form" enctype="multipart/form-data">
                            <input type="hidden" name="tab" value="profile">
                            <input type="hidden" name="action" value="profile_save">

                            <div class="pf-section-label">
                                <i class="fa-solid fa-id-card"></i>
                                <span>Identite</span>
                                <div class="pf-section-line"></div>
                            </div>

                            <div class="pf-form-row">
                                <div class="pf-field">
                                    <label class="pf-label">
                                        <i class="fa-solid fa-user"></i> Prenom <span class="pf-req">*</span>
                                    </label>
                                    <div class="pf-input-wrap">
                                        <i class="fa-solid fa-user pf-input-icon"></i>
                                        <input class="pf-input" type="text" name="prenom"
                                               value="{{ current_user.prenom }}" required>
                                    </div>
                                </div>
                                <div class="pf-field">
                                    <label class="pf-label">
                                        <i class="fa-solid fa-user"></i> Nom <span class="pf-req">*</span>
                                    </label>
                                    <div class="pf-input-wrap">
                                        <i class="fa-solid fa-user pf-input-icon"></i>
                                        <input class="pf-input" type="text" name="nom"
                                               value="{{ current_user.nom }}" required>
                                    </div>
                                </div>
                            </div>

                            <div class="pf-section-label" style="margin-top:4px;">
                                <i class="fa-solid fa-address-book"></i>
                                <span>Coordonnees</span>
                                <div class="pf-section-line"></div>
                            </div>

                            <div class="pf-field">
                                <label class="pf-label">
                                    <i class="fa-solid fa-envelope"></i> Adresse email <span class="pf-req">*</span>
                                </label>
                                <div class="pf-input-wrap">
                                    <i class="fa-solid fa-envelope pf-input-icon"></i>
                                    <input class="pf-input" type="email" name="email"
                                           value="{{ current_user.email }}" required>
                                </div>
                            </div>

                            <div class="pf-field">
                                <label class="pf-label">
                                    <i class="fa-solid fa-phone"></i> Telephone
                                </label>
                                <div class="pf-input-wrap">
                                    <i class="fa-solid fa-phone pf-input-icon"></i>
                                    <input class="pf-input" type="tel" name="telephone"
                                           value="{{ current_user.telephone|default('') }}"
                                           placeholder="+216 XX XXX XXX">
                                </div>
                            </div>

                            {# Photo upload #}
                            <div class="pf-section-label" style="margin-top:4px;">
                                <i class="fa-solid fa-image"></i>
                                <span>Photo de profil</span>
                                <div class="pf-section-line"></div>
                            </div>

                            <div class="pf-photo-row">
                                <div class="pf-photo-thumb" id="pf-photo-preview">
                                    {% if current_user.profile_image_path|default('') %}
                                        <img src="{{ asset(current_user.profile_image_path) }}" alt="Apercu">
                                    {% else %}
                                        <i class="fa-solid fa-user"></i>
                                    {% endif %}
                                </div>
                                <div class="pf-photo-info">
                                    <label class="pf-upload-btn" for="pf-photo-input">
                                        <i class="fa-solid fa-upload"></i>
                                        Choisir une photo
                                    </label>
                                    <input id="pf-photo-input" type="file" name="profile_image"
                                           accept="image/png,image/jpeg,image/webp,image/gif"
                                           style="display:none">
                                    <span class="pf-upload-hint" id="pf-photo-feedback">
                                        PNG · JPG · WEBP — max 5 Mo
                                    </span>
                                </div>
                            </div>

                            <div class="pf-form-footer">
                                <button class="pf-btn pf-btn-primary" type="submit">
                                    <i class="fa-solid fa-floppy-disk"></i>
                                    Enregistrer
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                {# Biometric card #}
                <div class="pf-card">
                    <div class="pf-card-header">
                        <div class="pf-card-icon"
                             style="background:linear-gradient(135deg,#7c3aed,#8b5cf6);">
                            <i class="fa-solid fa-fingerprint"></i>
                        </div>
                        <div>
                            <h3>Face ID biometrique</h3>
                            <p>Connexion par reconnaissance faciale</p>
                        </div>
                        {% if current_user.biometric_face_descriptor|default('') %}
                            <span class="pf-bio-badge pf-bio-badge-on">Actif</span>
                        {% else %}
                            <span class="pf-bio-badge pf-bio-badge-off">Inactif</span>
                        {% endif %}
                    </div>
                    <div class="pf-card-body">
                        <form method="post" class="pf-form">
                            <input type="hidden" name="tab" value="profile">
                            <input type="hidden" name="action" value="profile_biometric_save">
                            <input type="hidden" name="face_descriptor"
                                   id="nx-profile-bio-face-descriptor">

                            <div class="pf-field">
                                <label class="pf-label">
                                    <i class="fa-solid fa-toggle-on"></i> Authentification biometrique
                                </label>
                                <div class="pf-input-wrap">
                                    <i class="fa-solid fa-shield-halved pf-input-icon"></i>
                                    <select class="pf-input pf-select" name="biometric_enabled">
                                        <option value="1" {{ current_user.biometric_enabled ? 'selected' : '' }}>Activee</option>
                                        <option value="0" {{ not current_user.biometric_enabled ? 'selected' : '' }}>Desactivee</option>
                                    </select>
                                    <i class="fa-solid fa-chevron-down pf-select-arrow"></i>
                                </div>
                            </div>

                            {# Camera #}
                            <div class="pf-cam-wrap">
                                <div class="pf-cam-viewport" id="proBioViewport">
                                    <video id="nx-profile-bio-video" autoplay muted playsinline></video>

                                    <div class="pf-cam-idle" id="proBioIdle">
                                        <i class="fa-solid fa-video-slash"></i>
                                        <p>Camera inactive</p>
                                    </div>

                                    <div class="pf-cam-scan" id="proBioScan">
                                        <div class="pf-corner pf-corner-tl"></div>
                                        <div class="pf-corner pf-corner-tr"></div>
                                        <div class="pf-corner pf-corner-bl"></div>
                                        <div class="pf-corner pf-corner-br"></div>
                                        <div class="pf-cam-oval"></div>
                                        <div class="pf-cam-sweep"></div>
                                    </div>

                                    <div class="pf-cam-ok" id="proBioOk">
                                        <div class="pf-cam-ok-ring">
                                            <i class="fa-solid fa-check"></i>
                                        </div>
                                        <p>Visage capture !</p>
                                    </div>
                                </div>

                                <div class="pf-cam-status">
                                    <div class="pf-cam-dot" id="proBioDot"></div>
                                    <span id="proBioText">
