{# ADVANCED SEARCH JAVASCRIPT #}
{# ══════════════════════════════════════════════════════════════════════════════ #}
<script>
document.addEventListener('DOMContentLoaded', function() {
    const btnToggle = document.getElementById('btn-toggle-advanced-search');
    const panel = document.getElementById('advanced-search-panel');
    const searchInput = document.getElementById('search-input');
    const sortSelect = document.getElementById('sort-select');
    
    // Toggle advanced search panel
    if (btnToggle && panel) {
        btnToggle.addEventListener('click', function() {
            if (panel.style.display === 'none') {
                panel.style.display = 'block';
            } else {
                panel.style.display = 'none';
            }
        });
        
        // Check if filters are active
        const urlParams = new URLSearchParams(window.location.search);
        const hasFilters = urlParams.has('date_from') || urlParams.has('date_to') || 
                          urlParams.has('amount_min') || urlParams.has('amount_max') || 
                          urlParams.has('category') || urlParams.has('account_id');
        
        if (hasFilters) {
            btnToggle.classList.add('has-filters');
            panel.style.display = 'block';
        }
    }
    
    // Real-time search
    if (searchInput) {
        let searchTimeout;
        searchInput.addEventListener('input', function() {
            clearTimeout(searchTimeout);
            searchTimeout = setTimeout(function() {
                const url = new URL(window.location.href);
                url.searchParams.set('tab', 'transactions');
                url.searchParams.set('q', searchInput.value);
                url.searchParams.set('page', '1'); // Reset to first page
                window.location.href = url.toString();
            }, 500);
        });
    }
    
    // Sort change
    if (sortSelect) {
        sortSelect.addEventListener('change', function() {
            const [sort, dir] = this.value.split('-');
            const url = new URL(window.location.href);
            url.searchParams.set('tab', 'transactions');
            url.searchParams.set('sort', sort);
            url.searchParams.set('dir', dir);
            url.searchParams.set('page', '1'); // Reset to first page
            window.location.href = url.toString();
        });
    }
});
</script>


