<script>
(function() {
    const btnPredict = document.getElementById('btn-predict-payments');
    const modal = document.getElementById('prediction-modal');
    const modalOverlay = document.getElementById('prediction-modal-overlay');
    const modalClose = document.getElementById('prediction-modal-close');
    const modalBody = document.getElementById('prediction-modal-body');

    if (!btnPredict || !modal) return;

    // Ouvrir la modal
    btnPredict.addEventListener('click', function() {
        modal.classList.add('is-open');
        document.body.style.overflow = 'hidden';
        loadPredictions();
    });

    // Fermer la modal
    function closeModal() {
        modal.classList.remove('is-open');
        document.body.style.overflow = '';
    }

    modalClose.addEventListener('click', closeModal);
    modalOverlay.addEventListener('click', closeModal);

    // Charger les prédictions
    function loadPredictions() {
        // Afficher le loading
        modalBody.innerHTML = `
            <div class="prediction-loading">
                <div class="prediction-spinner"></div>
                <p>Analyse de vos transactions en cours...</p>
            </div>
        `;

        fetch('{{ path('portal_api_predict_payments') }}', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
        })
        .then(response => response.json())
        .then(data => {
            if (data.error) {
                showError(data.error);
                return;
            }

            displayPredictions(data);
        })
        .catch(error => {
            console.error('Error:', error);
            showError('Une erreur est survenue lors de la génération des prédictions.');
        });
    }

    function displayPredictions(data) {
        let html = '';

        // Analysis section
        if (data.analysis) {
            html += `
                <div class="prediction-analysis">
                    <h3><i class="fa-solid fa-chart-line"></i> Analyse de vos habitudes</h3>
                    <p>${escapeHtml(data.analysis)}</p>
                </div>
            `;
        }
        
        // Next Month Forecast Section
        if (data.next_month_forecast) {
            const forecast = data.next_month_forecast;
            const nextMonth = new Date();
            nextMonth.setMonth(nextMonth.getMonth() + 1);
            const monthName = nextMonth.toLocaleDateString('fr-FR', { month: 'long', year: 'numeric' });
            
            const confidenceClass = forecast.confidence || 'medium';
            const confidenceLabel = {
                'high': 'Élevée',
                'medium': 'Moyenne',
                'low': 'Faible'
            }[confidenceClass] || 'Moyenne';
            
            html += `
                <div class="next-month-forecast">
                    <div class="forecast-header">
                        <h3><i class="fa-solid fa-calendar-days"></i> Prévisions pour ${monthName}</h3>
                        <span class="forecast-confidence ${confidenceClass}">
                            <i class="fa-solid fa-gauge-high"></i> Confiance: ${confidenceLabel}
                        </span>
                    </div>
                    
                    <div class="forecast-grid">
                        <div class="forecast-card forecast-card--deposit">
                            <div class="forecast-card-icon">
                                <i class="fa-solid fa-arrow-down"></i>
                            </div>
                            <div class="forecast-card-content">
                                <span class="forecast-card-label">Dépôts estimés</span>
                                <span class="forecast-card-amount">+${parseFloat(forecast.total_deposits || 0).toFixed(2)} DT</span>
                            </div>
                        </div>
                        
                        <div class="forecast-card forecast-card--withdrawal">
                            <div class="forecast-card-icon">
                                <i class="fa-solid fa-arrow-up"></i>
                            </div>
                            <div class="forecast-card-content">
                                <span class="forecast-card-label">Retraits estimés</span>
                                <span class="forecast-card-amount">-${parseFloat(forecast.total_withdrawals || 0).toFixed(2)} DT</span>
                            </div>
                        </div>
                        
                        <div class="forecast-card forecast-card--payment">
                            <div class="forecast-card-icon">
                                <i class="fa-solid fa-credit-card"></i>
                            </div>
                            <div class="forecast-card-content">
                                <span class="forecast-card-label">Paiements estimés</span>
                                <span class="forecast-card-amount">-${parseFloat(forecast.total_payments || 0).toFixed(2)} DT</span>
                            </div>
                        </div>
                        
                        <div class="forecast-card forecast-card--transfer">
                            <div class="forecast-card-icon">
                                <i class="fa-solid fa-right-left"></i>
                            </div>
                            <div class="forecast-card-content">
                                <span class="forecast-card-label">Virements estimés</span>
                                <span class="forecast-card-amount">-${parseFloat(forecast.total_transfers || 0).toFixed(2)} DT</span>
                            </div>
                        </div>
                    </div>
                    
                    <div class="forecast-net-balance ${forecast.net_balance >= 0 ? 'positive' : 'negative'}">
                        <div class="forecast-net-icon">
                            <i class="fa-solid fa-scale-balanced"></i>
                        </div>
                        <div class="forecast-net-content">
                            <span class="forecast-net-label">Solde net estimé</span>
                            <span class="forecast-net-amount">${forecast.net_balance >= 0 ? '+' : ''}${parseFloat(forecast.net_balance || 0).toFixed(2)} DT</span>
                        </div>
                    </div>
                    
                    ${forecast.key_insights && forecast.key_insights.length > 0 ? `
                        <div class="forecast-insights">
                            <h4><i class="fa-solid fa-lightbulb"></i> Points clés</h4>
                            <ul>
                                ${forecast.key_insights.map(insight => `<li>${escapeHtml(insight)}</li>`).join('')}
                            </ul>
                        </div>
                    ` : ''}
                </div>
            `;
        }

        // Predictions grid
        if (data.predictions && data.predictions.length > 0) {
            html += '<div class="predictions-section"><h3><i class="fa-solid fa-clock"></i> Prochains paiements prévus</h3>';
            html += '<div class="predictions-grid">';
            
            data.predictions.forEach(pred => {
                const confidence = pred.confidence || 'medium';
                const confidenceLabel = {
                    'high': 'Élevée',
                    'medium': 'Moyenne',
                    'low': 'Faible'
                }[confidence] || 'Moyenne';

                html += `
                    <div class="prediction-card">
                        <div class="prediction-card-header">
                            <span class="prediction-category">${escapeHtml(pred.category)}</span>
                            <span class="prediction-confidence ${confidence}">
                                <i class="fa-solid fa-circle"></i> ${confidenceLabel}
                            </span>
                        </div>
                        <div class="prediction-amount">
                            ${parseFloat(pred.estimated_amount).toFixed(2)} <em>DT</em>
                        </div>
                        <div class="prediction-date">
                            <i class="fa-regular fa-calendar"></i>
                            Estimé pour le ${formatDate(pred.estimated_date)}
                        </div>
                        <div class="prediction-reason">
                            ${escapeHtml(pred.reason)}
                        </div>
                    </div>
                `;
            });
            
            html += '</div></div>';
        } else {
            html += `
                <div class="prediction-error">
                    <i class="fa-solid fa-info-circle"></i>
                    <h3>Pas assez de données</h3>
                    <p>Effectuez plus de paiements pour obtenir des prédictions personnalisées.</p>
                </div>
            `;
        }

        // Advice section
        if (data.advice) {
            html += `
                <div class="prediction-advice">
                    <h3><i class="fa-solid fa-lightbulb"></i> Conseils personnalisés</h3>
                    <p>${escapeHtml(data.advice)}</p>
                </div>
            `;
        }

        // Provider badge
        if (data.provider) {
            html += `
                <div class="prediction-provider">
                    <i class="fa-solid fa-robot"></i> Propulsé par ${escapeHtml(data.provider)}
                </div>
            `;
        }

        modalBody.innerHTML = html;
    }

    function showError(message) {
        modalBody.innerHTML = `
            <div class="prediction-error">
                <i class="fa-solid fa-exclamation-triangle"></i>
                <h3>Erreur</h3>
                <p>${escapeHtml(message)}</p>
            </div>
        `;
    }

    function formatDate(dateStr) {
        if (!dateStr) return 'Date inconnue';
        const date = new Date(dateStr);
        return date.toLocaleDateString('fr-FR', { 
            day: 'numeric', 
            month: 'long', 
            year: 'numeric' 
        });
    }

    function escapeHtml(text) {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }
})();
</script>


<script>
// ── Détection de Badwords côté client ──
(function() {
    const badWords = [
        // Français
        'merde', 'putain', 'connard', 'salaud', 'enculé', 'fils de pute',
        'con', 'conne', 'connasse', 'pute', 'salope', 'bordel',
        'chier', 'foutre', 'bite', 'couille', 'cul', 'nique',
        'ta gueule', 'ferme ta gueule', 'va te faire', 'enfoiré',
        'batard', 'bâtard', 'crétin', 'débile', 'idiot', 'imbécile',
        
        // Arabe/Tunisien (translittération)
        'kahba', 'ka7ba', 'zebbi', 'zeb', 'kess', 'omek', 'bouk',
        'ya7chilek', 'nayek', 'nik', 'tfou', 'hmar', '7mar',
        'kelb', 'kalb', 'weld el kahba', 'ibn el kahba',
        
        // Variantes
        'p*tain', 'c*n', 'm*rde', 'sal*pe', 'enc*lé'
    ];

    function detectBadWords(text) {
        const normalized = text.toLowerCase()
            // Remplacer les caractères spéciaux l33t speak
            .replace(/@/g, 'a')
            .replace(/0/g, 'o')
            .replace(/1/g, 'i')
            .replace(/3/g, 'e')
            .replace(/4/g, 'a')
            .replace(/5/g, 's')
            .replace(/7/g, 'h')
            .replace(/8/g, 'b')
            .replace(/\$/g, 's')
            // Enlever les caractères spéciaux
            .replace(/\*/g, '')
            .replace(/_/g, '')
            .replace(/-/g, '')
            .replace(/\./g, '')
            .replace(/\s+/g, ' ')
            // Enlever les accents
            .normalize('NFD')
            .replace(/[\u0300-\u036f]/g, '');

        for (const word of badWords) {
            const normalizedWord = word.toLowerCase()
                .normalize('NFD')
                .replace(/[\u0300-\u036f]/g, '');
            
            if (normalized.includes(normalizedWord)) {
                return true;
            }
        }
        return false;
    }

    // Ajouter la validation sur tous les formulaires de réclamation
    document.querySelectorAll('form input[name="action"][value="reclamation_save"]').forEach(input => {
        const form = input.closest('form');
        if (!form) return;
        
        form.addEventListener('submit', function(e) {
            const textarea = form.querySelector('textarea[name="description"]');
            if (!textarea) return;

            const description = textarea.value.trim();
            
            if (detectBadWords(description)) {
                e.preventDefault();
                
                // Afficher un message d'avertissement
                const existingWarning = form.querySelector('.badword-warning');
                if (existingWarning) {
                    existingWarning.remove();
                }

                const warning = document.createElement('div');
                warning.className = 'badword-warning';
                warning.style.cssText = `
                    background: linear-gradient(135deg, rgba(239, 68, 68, 0.15), rgba(220, 38, 38, 0.1));
                    border: 2px solid #ef4444;
                    border-radius: 12px;
                    padding: 16px 20px;
                    margin-top: 16px;
                    display: flex;
                    align-items: flex-start;
                    gap: 12px;
                    animation: warningShake 0.5s ease;
                `;
                
                warning.innerHTML = `
                    <i class="fa-solid fa-triangle-exclamation" style="color: #ef4444; font-size: 24px; flex-shrink: 0;"></i>
                    <div>
                        <strong style="color: #dc2626; font-size: 15px; display: block; margin-bottom: 6px;">
                            ⚠️ Langage inapproprié détecté
                        </strong>
                        <p style="color: #7f1d1d; font-size: 13px; line-height: 1.5; margin: 0;">
                            Votre réclamation contient des mots inappropriés. Elle sera automatiquement signalée à l'administrateur pour modération. 
                            Veuillez reformuler votre message de manière professionnelle.
                        </p>
                        <div style="margin-top: 12px; display: flex; gap: 8px;">
                            <button type="button" class="btn-cancel-badword" style="
                                padding: 8px 16px;
                                background: #fff;
                                border: 2px solid #ef4444;
                                border-radius: 8px;
                                color: #dc2626;
                                font-weight: 700;
                                font-size: 13px;
                                cursor: pointer;
                                transition: all 0.2s;
                            ">
                                <i class="fa-solid fa-pen"></i> Modifier
                            </button>
                            <button type="button" class="btn-submit-anyway" style="
                                padding: 8px 16px;
                                background: linear-gradient(135deg, #ef4444, #dc2626);
                                border: none;
                                border-radius: 8px;
                                color: #fff;
                                font-weight: 700;
                                font-size: 13px;
                                cursor: pointer;
                                transition: all 0.2s;
                            ">
                                <i class="fa-solid fa-paper-plane"></i> Soumettre quand même
                            </button>
                        </div>
                    </div>
                `;

                textarea.parentElement.appendChild(warning);
                textarea.style.borderColor = '#ef4444';
                textarea.style.boxShadow = '0 0 0 3px rgba(239, 68, 68, 0.2)';
                textarea.focus();

                // Bouton modifier
                warning.querySelector('.btn-cancel-badword').addEventListener('click', function() {
                    warning.remove();
                    textarea.style.borderColor = '';
                    textarea.style.boxShadow = '';
                    textarea.focus();
                });

                // Bouton soumettre quand même
                warning.querySelector('.btn-submit-anyway').addEventListener('click', function() {
                    warning.remove();
                    textarea.style.borderColor = '';
                    textarea.style.boxShadow = '';
                    form.submit();
                });

                return false;
            }
        });
    });

    // Animation de shake
    const style = document.createElement('style');
    style.textContent = `
        @keyframes warningShake {
            0%, 100% { transform: translateX(0); }
            10%, 30%, 50%, 70%, 90% { transform: translateX(-5px); }
            20%, 40%, 60%, 80% { transform: translateX(5px); }
        }
    `;
    document.head.appendChild(style);
})();
</script>


