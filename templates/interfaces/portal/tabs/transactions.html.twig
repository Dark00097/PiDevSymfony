{# MULTI-CURRENCY JAVASCRIPT #}
{# ══════════════════════════════════════════════════════════════════════════════ #}
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Configuration des champs de conversion pour chaque type de transaction
    const conversionConfigs = [
        { amountId: 'f-amount-depot', currencyId: 'f-currency-depot', previewId: 'conversion-preview-depot' },
        { amountId: 'f-amount-retrait', currencyId: 'f-currency-retrait', previewId: 'conversion-preview-retrait' },
        { amountId: 'f-amount-virement', currencyId: 'f-currency-virement', previewId: 'conversion-preview-virement' },
        { amountId: 'f-montant-paye', currencyId: 'f-currency-paiement', previewId: 'conversion-preview-paiement' }
    ];
    
    // Initialiser la conversion pour chaque configuration
    conversionConfigs.forEach(config => {
        const amountInput = document.getElementById(config.amountId);
        const currencySelect = document.getElementById(config.currencyId);
        const previewDiv = document.getElementById(config.previewId);
        
        if (amountInput && currencySelect && previewDiv) {
            let conversionTimeout;
            
            const updateConversion = () => {
                clearTimeout(conversionTimeout);
                conversionTimeout = setTimeout(() => {
                    performConversion(amountInput, currencySelect, previewDiv);
                }, 500);
            };
            
            amountInput.addEventListener('input', updateConversion);
            currencySelect.addEventListener('change', updateConversion);
        }
    });
    
    function performConversion(amountInput, currencySelect, previewDiv) {
        const amount = parseFloat(amountInput.value);
        const currency = currencySelect.value;
        
        // Si TND ou montant invalide, cacher l'aperçu
        if (currency === 'TND' || !amount || amount <= 0) {
            previewDiv.style.display = 'none';
            return;
        }
        
        // Appeler l'API de conversion
        fetch('{{ path('portal_api_currency_convert') }}', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: new URLSearchParams({
                amount: amount,
                from: currency,
                to: 'TND'
            })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                const conv = data.conversion;
                
                previewDiv.innerHTML = `
                    <div class="conversion-row">
                        <span class="label">💱 Taux de change:</span>
                        <span class="value">1 ${conv.from} = ${conv.rate.toFixed(4)} TND</span>
                    </div>
                    <div class="conversion-row">
                        <span class="label">Montant converti:</span>
                        <span class="value">${conv.converted.toFixed(3)} TND</span>
                    </div>
                    <div class="conversion-row">
                        <span class="label">Frais de conversion (0.5%):</span>
                        <span class="value">${conv.fee.toFixed(3)} TND</span>
                    </div>
                    <div class="conversion-row total">
                        <span class="label">Total à débiter:</span>
                        <span class="value">${conv.total.toFixed(3)} TND</span>
                    </div>
                `;
                
                previewDiv.style.display = 'block';
            } else {
                console.error('Conversion error:', data.error);
                previewDiv.style.display = 'none';
            }
        })
        .catch(error => {
            console.error('Fetch error:', error);
            previewDiv.style.display = 'none';
        });
    }
});
</script>


