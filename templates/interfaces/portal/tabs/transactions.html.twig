{% set transaction_total = summary.transactions_total|default(items|length) %}
{% set revenues = 0 %}
{% set expenses = 0 %}
{% set current_month = 'now'|date('Y-m') %}
{% set operations_month = 0 %}
{% for item in items %}
    {% set amount = item.montant_value|default(0) %}
    {% set type_key = item.typeTransaction|default('DEPOT')|upper %}
    {% if type_key in ['RETRAIT', 'PAIEMENT'] %}
        {% set expenses = expenses + amount %}
    {% else %}
        {% set revenues = revenues + amount %}
    {% endif %}
    {% if item.dateTransaction is not empty and item.dateTransaction|date('Y-m') == current_month %}
        {% set operations_month = operations_month + 1 %}
    {% endif %}
{% endfor %}
{% set net_balance = revenues - expenses %}
{% set categories = ['Alimentation', 'Transport', 'Factures', 'Salaire', 'Education', 'Shopping', 'Sante', 'Autre'] %}

{# ── Résolution de la transaction à modifier ── #}
{% set edit_id = app.request.query.get('edit_id')|default('') %}
{% set edit_item = null %}
{% if edit_id %}
    {% for t in items %}
        {% if t.idTransaction ~ '' == edit_id ~ '' %}
            {% set edit_item = t %}
        {% endif %}
    {% endfor %}
{% endif %}

<section class="tnx-shell">

    {# ── TOP BANNER ── #}
    <div class="tnx-banner">
        <div class="tnx-banner-brand">
            <div class="tnx-banner-icon">
                <i class="fa-solid fa-right-left"></i>
            </div>
            <div class="tnx-banner-text">
                <h1>Gestion des transactions</h1>
                <p>Voir, gerer et suivre toutes vos transactions financieres</p>
            </div>
        </div>

        <div class="tnx-banner-center">
            <div class="tnx-banner-stat">
                <span class="tnx-banner-stat-num">{{ transaction_total }}</span>
                <span class="tnx-banner-stat-lbl">Total transactions</span>
            </div>
            <div class="tnx-banner-divider"></div>
            <div class="tnx-banner-stat">
                <span class="tnx-banner-stat-num">{{ operations_month }}</span>
                <span class="tnx-banner-stat-lbl">Ce mois</span>
            </div>
        </div>

        <nav class="tnx-banner-nav">
            <a class="tnx-nav-pill" href="{{ path('portal_feature_pdf_download', { kind: 'transactions' }) }}">
                <i class="fa-solid fa-download"></i><span>PDF</span>
            </a>
            <button type="button" class="tnx-nav-pill tnx-nav-pill--predict" id="btn-predict-payments">
                <i class="fa-solid fa-crystal-ball"></i><span>Prédictions</span>
            </button>
            <a class="tnx-nav-pill tnx-nav-pill--cta" href="#tnx-form-anchor">
                <i class="fa-solid fa-plus"></i><span>Nouvelle</span>
            </a>
        </nav>
    </div>

    {# ── KPI STRIP ── #}
    <div class="tnx-kpi-strip">

        <div class="tnx-kpi-tile tnx-kpi-tile--rev">
            <div class="tnx-kpi-tile-left">
                <div class="tnx-kpi-badge">
                    <i class="fa-solid fa-arrow-trend-up"></i>
                </div>
                <div>
                    <span class="tnx-kpi-label">REVENUS</span>
                    <span class="tnx-kpi-sub">30 derniers jours</span>
                </div>
            </div>
            <div class="tnx-kpi-tile-right">
                <strong class="tnx-kpi-num tnx-kpi-num--up">
                    +{{ revenues|number_format(2, '.', ' ') }}
                </strong>
                <span class="tnx-kpi-currency">DT</span>
            </div>
            <div class="tnx-kpi-bar">
                <span style="width:100%"></span>
            </div>
        </div>

        <div class="tnx-kpi-tile tnx-kpi-tile--exp">
            <div class="tnx-kpi-tile-left">
                <div class="tnx-kpi-badge">
                    <i class="fa-solid fa-arrow-trend-down"></i>
                </div>
                <div>
                    <span class="tnx-kpi-label">DEPENSES</span>
                    <span class="tnx-kpi-sub">30 derniers jours</span>
                </div>
            </div>
            <div class="tnx-kpi-tile-right">
                <strong class="tnx-kpi-num tnx-kpi-num--down">
                    -{{ expenses|number_format(2, '.', ' ') }}
                </strong>
                <span class="tnx-kpi-currency">DT</span>
            </div>
            <div class="tnx-kpi-bar">
                <span class="is-danger" style="width:{{ revenues > 0 ? ((expenses / (revenues + expenses)) * 100)|round : 0 }}%"></span>
            </div>
        </div>

        <div class="tnx-kpi-tile tnx-kpi-tile--net">
            <div class="tnx-kpi-tile-left">
                <div class="tnx-kpi-badge">
                    <i class="fa-solid fa-scale-balanced"></i>
                </div>
                <div>
                    <span class="tnx-kpi-label">SOLDE NET</span>
                    <span class="tnx-kpi-sub">Ce mois</span>
                </div>
            </div>
            <div class="tnx-kpi-tile-right">
                <strong class="tnx-kpi-num {{ net_balance >= 0 ? 'tnx-kpi-num--up' : 'tnx-kpi-num--down' }}">
                    {{ net_balance >= 0 ? '+' : '' }}{{ net_balance|number_format(2, '.', ' ') }}
                </strong>
                <span class="tnx-kpi-currency">DT</span>
            </div>
            <div class="tnx-kpi-bar">
                <span class="{{ net_balance >= 0 ? '' : 'is-danger' }}" style="width:{{ net_balance >= 0 ? '72%' : '38%' }}"></span>
            </div>
        </div>

    </div>

    {# ── BODY: SIDEBAR + CONTENT ── #}
    <div class="tnx-body">

        {# ── LEFT SIDEBAR: FORM ── #}
        <aside class="tnx-sidebar" id="tnx-form-anchor">

            <div class="tnx-sidebar-header">
                <div class="tnx-sidebar-header-icon">
                    <i class="fa-solid fa-receipt"></i>
                </div>
                <div>
                    <h2>{{ edit_item ? 'Modifier la transaction' : 'Nouvelle transaction' }}</h2>
                    <p>{{ edit_item ? 'Modifier les informations de la transaction #' ~ edit_item.idTransaction : 'Creer ou modifier une operation' }}</p>
                </div>
                {% if edit_item %}
                    <a href="{{ path(route_name, { tab: 'transactions' }) }}"
                       style="margin-left:auto;width:32px;height:32px;border-radius:9px;background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.25);color:#fff;display:flex;align-items:center;justify-content:center;text-decoration:none;font-size:13px;"
                       title="Nouvelle transaction">
                        <i class="fa-solid fa-xmark"></i>
                    </a>
                {% endif %}
            </div>

            <form method="post" class="tnx-form" id="transaction-form" novalidate
                  data-turbo="false"
                  action="{{ path(route_name, { tab: 'transactions' }) }}">
                <input type="hidden" name="tab" value="transactions">
                <input type="hidden" name="idTransaction" value="{{ edit_item ? edit_item.idTransaction : '' }}">
                <input type="hidden" name="montant" id="f-montant-hidden" value="">
                <input type="hidden" name="currency" id="f-currency-hidden" value="TND">

                <div class="tnx-form-section">
                    <span class="tnx-form-section-label">
                        <i class="fa-solid fa-fingerprint"></i> Identification
                    </span>
                    <div class="tnx-field">
                        <label for="f-compte">Compte source <em>*</em></label>
                        <select id="f-compte" name="compte" data-solde="{{ edit_item.linked_account.solde|default(0) }}">
                            <option value="">Sans compte</option>
                            {% for account in support.accounts|default([]) %}
                                <option value="{{ account.idCompte }}" data-solde="{{ account.solde }}"
                                    {{ edit_item and edit_item.idCompte ~ '' == account.idCompte ~ '' ? 'selected' : '' }}>
                                    {{ account.numeroCompte }} ({{ account.solde }} DT)
                                </option>
                            {% endfor %}
                        </select>
                        <span class="tnx-field-msg" id="msg-compte"></span>
                    </div>
                    <div class="tnx-field">
                        <label for="f-date">Date <em>*</em></label>
                        <input id="f-date" type="date" name="dateTransaction"
                               value="{{ edit_item ? edit_item.dateTransaction|default('now'|date('Y-m-d')) : 'now'|date('Y-m-d') }}">
                        <span class="tnx-field-msg" id="msg-dateTransaction"></span>
                    </div>
                    <div class="tnx-field">
                        <label for="f-desc">Description</label>
                        <textarea id="f-desc" name="description" rows="3"
                                  placeholder="Details de l'operation...">{{ edit_item ? edit_item.description|default('') : '' }}</textarea>
                        <span id="msg-description" style="font-size:12px;font-weight:600;margin-top:4px;display:block;"></span>
                    </div>
                </div>

                <div class="tnx-form-section">
                    <span class="tnx-form-section-label">
                        <i class="fa-solid fa-tags"></i> Type de transaction
                    </span>
                    <div class="tnx-field">
                        <label for="f-type">Type <em>*</em></label>
                        <div class="tnx-toggle-group">
                            <label class="tnx-toggle-opt">
                                <input type="radio" name="typeTransaction" value="DEPOT"
                                    {{ not edit_item or edit_item.typeTransaction|default('DEPOT')|upper == 'DEPOT' ? 'checked' : '' }}>
                                <span class="tnx-toggle-face tnx-toggle-face--credit">
                                    <i class="fa-solid fa-arrow-down"></i> Dépôt
                                </span>
                            </label>
                            <label class="tnx-toggle-opt">
                                <input type="radio" name="typeTransaction" value="RETRAIT"
                                    {{ edit_item and edit_item.typeTransaction|default('')|upper == 'RETRAIT' ? 'checked' : '' }}>
                                <span class="tnx-toggle-face tnx-toggle-face--debit">
                                    <i class="fa-solid fa-arrow-up"></i> Retrait
                                </span>
                            </label>
                            <label class="tnx-toggle-opt">
                                <input type="radio" name="typeTransaction" value="VIREMENT"
                                    {{ edit_item and edit_item.typeTransaction|default('')|upper == 'VIREMENT' ? 'checked' : '' }}>
                                <span class="tnx-toggle-face tnx-toggle-face--virement">
                                    <i class="fa-solid fa-right-left"></i> Virement
                                </span>
                            </label>
                            <label class="tnx-toggle-opt">
                                <input type="radio" name="typeTransaction" value="PAIEMENT"
                                    {{ edit_item and edit_item.typeTransaction|default('')|upper == 'PAIEMENT' ? 'checked' : '' }}>
                                <span class="tnx-toggle-face tnx-toggle-face--debit">
                                    <i class="fa-solid fa-credit-card"></i> Paiement
                                </span>
                            </label>
                        </div>
                        <span class="tnx-field-msg" id="msg-typeTransaction"></span>
                    </div>
                </div>

                <div class="tnx-form-section section-depot" style="display: none;">
                    <span class="tnx-form-section-label">
                        <i class="fa-solid fa-arrow-down"></i> Dépôt
                    </span>
                    <div class="tnx-field">
                        <label for="f-amount-depot">Montant <em>*</em></label>
                        <div class="tnx-amount-currency-wrap">
                            <div class="amount-input-wrapper">
                                <input id="f-amount-depot" type="number" step="0.01" name="montant_depot"
                                       placeholder="0.00" class="currency-amount-input"
                                       value="{{ edit_item and edit_item.typeTransaction|upper == 'DEPOT' ? edit_item.original_amount|default(edit_item.montant_value)|default('') : '' }}">
                            </div>
                            <div class="currency-selector">
                                <select id="f-currency-depot" name="currency_depot" class="currency-select-modern">
                                    <option value="TND" data-symbol="DT" {{ edit_item and edit_item.original_currency|default('TND') == 'TND' ? 'selected' : '' }}>🇹🇳 TND - Dinar Tunisien</option>
                                    <option value="EUR" data-symbol="€" {{ edit_item and edit_item.original_currency == 'EUR' ? 'selected' : '' }}>🇪🇺 EUR - Euro</option>
                                    <option value="USD" data-symbol="$" {{ edit_item and edit_item.original_currency == 'USD' ? 'selected' : '' }}>🇺🇸 USD - Dollar</option>
                                    <option value="GBP" data-symbol="£" {{ edit_item and edit_item.original_currency == 'GBP' ? 'selected' : '' }}>🇬🇧 GBP - Livre Sterling</option>
                                </select>
                            </div>
                        </div>
                        <span class="tnx-field-msg" id="msg-montant-depot"></span>
                    </div>
                    <div id="conversion-preview-depot" class="conversion-preview" style="display:none;"></div>
                </div>

                <div class="tnx-form-section section-retrait" style="display: none;">
                    <span class="tnx-form-section-label">
                        <i class="fa-solid fa-arrow-up"></i> Retrait
                    </span>
                    <div class="tnx-field">
                        <label for="f-amount-retrait">Montant <em>*</em></label>
                        <div class="tnx-amount-currency-wrap">
                            <div class="amount-input-wrapper">
                                <input id="f-amount-retrait" type="number" step="0.01" name="montant_retrait"
                                       placeholder="0.00" class="currency-amount-input"
                                       value="{{ edit_item and edit_item.typeTransaction|upper == 'RETRAIT' ? edit_item.original_amount|default(edit_item.montant_value)|default('') : '' }}">
                            </div>
                            <div class="currency-selector">
                                <select id="f-currency-retrait" name="currency_retrait" class="currency-select-modern">
                                    <option value="TND" data-symbol="DT" {{ edit_item and edit_item.original_currency|default('TND') == 'TND' ? 'selected' : '' }}>🇹🇳 TND - Dinar Tunisien</option>
                                    <option value="EUR" data-symbol="€" {{ edit_item and edit_item.original_currency == 'EUR' ? 'selected' : '' }}>🇪🇺 EUR - Euro</option>
                                    <option value="USD" data-symbol="$" {{ edit_item and edit_item.original_currency == 'USD' ? 'selected' : '' }}>🇺🇸 USD - Dollar</option>
                                    <option value="GBP" data-symbol="£" {{ edit_item and edit_item.original_currency == 'GBP' ? 'selected' : '' }}>🇬🇧 GBP - Livre Sterling</option>
                                </select>
                            </div>
                        </div>
                        <span class="tnx-field-msg" id="msg-montant-retrait"></span>
                        <small style="font-size:.72rem;color:#ff9800;margin-top:8px;display:block;">
                            <i class="fa-solid fa-triangle-exclamation"></i> Solde disponible: <strong id="solde-disponible">0.00 DT</strong>
                        </small>
                    </div>
                    <div id="conversion-preview-retrait" class="conversion-preview" style="display:none;"></div>
                </div>

                <div class="tnx-form-section section-virement" style="display: none;">
                    <span class="tnx-form-section-label">
                        <i class="fa-solid fa-right-left"></i> Virement
                    </span>
                    <div class="tnx-field">
                        <label for="f-compte-dest">Numéro de compte destinataire <em>*</em></label>
                        <input type="text" id="f-compte-dest" name="compteDestinataire" 
                            placeholder="Ex: 1234567890"
                            value="{{ edit_item and edit_item.typeTransaction|upper == 'VIREMENT' ? edit_item.idCompteDestinataire|default('') : '' }}">
                        <span class="tnx-field-msg" id="msg-compteDestinataire"></span>
                    </div>
                    <div class="tnx-field">
                        <label for="f-nom-dest">Nom du destinataire <em>*</em></label>
                        <input type="text" id="f-nom-dest" name="nomDestinataire" 
                            placeholder="Nom complet"
                            value="{{ edit_item and edit_item.typeTransaction|upper == 'VIREMENT' ? edit_item.nomDestinataire|default('') : '' }}">
                        <span class="tnx-field-msg" id="msg-nomDestinataire"></span>
                    </div>
                    <div class="tnx-field">
                        <label for="f-email-dest">Email du destinataire</label>
                        <input type="email" id="f-email-dest" name="emailDestinataire" 
                            placeholder="email@example.com"
                            value="{{ edit_item and edit_item.typeTransaction|upper == 'VIREMENT' ? edit_item.emailDestinataire|default('') : '' }}">
                        <span class="tnx-field-msg" id="msg-emailDestinataire"></span>
                    </div>
                    <div class="tnx-field">
                        <label for="f-amount-virement">Montant <em>*</em></label>
                        <div class="tnx-amount-currency-wrap">
                            <div class="amount-input-wrapper">
                                <input id="f-amount-virement" type="number" step="0.01" name="montant_virement"
                                       placeholder="0.00" class="currency-amount-input"
                                       value="{{ edit_item and edit_item.typeTransaction|upper == 'VIREMENT' ? edit_item.original_amount|default(edit_item.montant_value)|default('') : '' }}">
                            </div>
                            <div class="currency-selector">
                                <select id="f-currency-virement" name="currency_virement" class="currency-select-modern">
                                    <option value="TND" data-symbol="DT" {{ edit_item and edit_item.original_currency|default('TND') == 'TND' ? 'selected' : '' }}>🇹🇳 TND - Dinar Tunisien</option>
                                    <option value="EUR" data-symbol="€" {{ edit_item and edit_item.original_currency == 'EUR' ? 'selected' : '' }}>🇪🇺 EUR - Euro</option>
                                    <option value="USD" data-symbol="$" {{ edit_item and edit_item.original_currency == 'USD' ? 'selected' : '' }}>🇺🇸 USD - Dollar</option>
                                    <option value="GBP" data-symbol="£" {{ edit_item and edit_item.original_currency == 'GBP' ? 'selected' : '' }}>🇬🇧 GBP - Livre Sterling</option>
                                </select>
                            </div>
                        </div>
                        <span class="tnx-field-msg" id="msg-montant-virement"></span>
                    </div>
                    <div id="conversion-preview-virement" class="conversion-preview" style="display:none;"></div>
                </div>

                {# Section PAIEMENT - cachée par défaut #}
                <div class="tnx-form-section section-paiement" style="display: none;">
                    <span class="tnx-form-section-label">
                        <i class="fa-solid fa-credit-card"></i> Paiement
                    </span>
                    <div class="tnx-field">
                        <label for="f-cat">Catégorie <em>*</em></label>
                        <select id="f-cat" name="categorie">
                            <option value="">Selectionner</option>
                            {% for category in categories %}
                                <option value="{{ category }}"
                                    {{ edit_item and edit_item.categorie == category ? 'selected' : '' }}>
                                    {{ category }}
                                </option>
                            {% endfor %}
                        </select>
                        <span class="tnx-field-msg" id="msg-categorie"></span>
                    </div>
                    <div class="tnx-field">
                        <label for="f-montant-paye">Montant à payer <em>*</em></label>
                        <div class="tnx-amount-currency-wrap">
                            <div class="amount-input-wrapper">
                                <input id="f-montant-paye" type="number" step="0.01" name="montantPaye"
                                       placeholder="0.00" class="currency-amount-input"
                                       value="{{ edit_item and edit_item.typeTransaction|upper == 'PAIEMENT' ? edit_item.original_amount|default(edit_item.montantPaye_value)|default('') : '' }}">
                            </div>
                            <div class="currency-selector">
                                <select id="f-currency-paiement" name="currency_paiement" class="currency-select-modern">
                                    <option value="TND" data-symbol="DT" {{ edit_item and edit_item.original_currency|default('TND') == 'TND' ? 'selected' : '' }}>🇹🇳 TND - Dinar Tunisien</option>
                                    <option value="EUR" data-symbol="€" {{ edit_item and edit_item.original_currency == 'EUR' ? 'selected' : '' }}>🇪🇺 EUR - Euro</option>
                                    <option value="USD" data-symbol="$" {{ edit_item and edit_item.original_currency == 'USD' ? 'selected' : '' }}>🇺🇸 USD - Dollar</option>
                                    <option value="GBP" data-symbol="£" {{ edit_item and edit_item.original_currency == 'GBP' ? 'selected' : '' }}>🇬🇧 GBP - Livre Sterling</option>
                                </select>
                            </div>
                        </div>
                        <span class="tnx-field-msg" id="msg-montantPaye"></span>
                    </div>
                    <div id="conversion-preview-paiement" class="conversion-preview" style="display:none;"></div>
                    <div class="tnx-field">
                        <label for="f-nom-benef">Bénéficiaire</label>
                        <input type="text" id="f-nom-benef" name="nomDestinataire" 
                            placeholder="Nom du bénéficiaire (optionnel)"
                            value="{{ edit_item and edit_item.typeTransaction|upper == 'PAIEMENT' ? edit_item.nomDestinataire|default('') : '' }}">
                    </div>
                    <div class="tnx-field">
                        <label for="f-email-benef">Email du bénéficiaire</label>
                        <input type="email" id="f-email-benef" name="emailDestinataire" 
                            placeholder="email@example.com (optionnel)"
                            value="{{ edit_item and edit_item.typeTransaction|upper == 'PAIEMENT' ? edit_item.emailDestinataire|default('') : '' }}">
                    </div>
                    
                    <div style="margin-top: 20px; padding: 15px; background: rgba(99, 102, 241, 0.1); border-radius: 8px; border: 1px solid rgba(99, 102, 241, 0.3);">
                        <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 10px;">
                            <i class="fa-solid fa-shield-halved" style="color: #6366f1; font-size: 20px;"></i>
                            <strong style="color: #4f46e5;">Paiement sécurisé via Stripe</strong>
                        </div>
                        <p style="font-size: 13px; color: #6b7280; margin: 0 0 15px 0;">
                            Après avoir enregistré cette transaction, vous serez redirigé vers Stripe pour effectuer le paiement de manière sécurisée.
                        </p>
                        <button type="button" id="btn-payer-stripe" class="tnx-act-btn tnx-act-btn--save" 
                            style="width: 100%; background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%); border: none;">
                            <i class="fa-solid fa-lock"></i> Enregistrer et payer avec Stripe
                        </button>
                    </div>
                </div>

                <div class="tnx-form-actions">
                    <a href="{{ path(route_name, { tab: 'transactions' }) }}"
                       class="tnx-act-btn tnx-act-btn--ghost" style="text-decoration:none;">
                        <i class="fa-solid fa-rotate-left"></i> Vider
                    </a>
                    {% if edit_item %}
                        <button class="tnx-act-btn tnx-act-btn--del" type="submit"
                                name="action" value="transaction_delete" formnovalidate
                                onclick="return confirm('Supprimer cette transaction ?')">
                            <i class="fa-solid fa-trash-can"></i> Supprimer
                        </button>
                    {% endif %}
                    <button class="tnx-act-btn tnx-act-btn--save" type="submit"
                            name="action" value="transaction_save">
                        <i class="fa-solid fa-floppy-disk"></i> Enregistrer
                    </button>
                </div>

            </form>
        </aside>

        {# ── RIGHT PANEL: HISTORY ── #}
        <main class="tnx-panel">

            <div class="tnx-panel-topbar">
                <div class="tnx-panel-title">
                    <div class="tnx-panel-title-icon">
                        <i class="fa-solid fa-clock-rotate-left"></i>
                    </div>
                    <div>
                        <h2>Historique</h2>
                        <p>{{ transaction_total }} transaction{{ transaction_total > 1 ? 's' : '' }} enregistree{{ transaction_total > 1 ? 's' : '' }}</p>
                    </div>
                </div>

                <div class="tnx-panel-controls">
                    <div class="tnx-search-box">
                        <i class="fa-solid fa-magnifying-glass"></i>
                        <input type="text" placeholder="Rechercher une transaction..." id="search-input" value="{{ support.transaction_query.q|default('') }}">
                    </div>
                    <button type="button" class="tnx-view-toggle" id="btn-toggle-calendar" title="Vue calendrier">
                        <i class="fa-solid fa-calendar-days"></i>
                        <span>Calendrier</span>
                    </button>
                    <button type="button" class="tnx-advanced-search-btn" id="btn-toggle-advanced-search">
                        <i class="fa-solid fa-sliders"></i>
                        <span>Filtres avancés</span>
                    </button>
                    <select class="tnx-sort-select" id="sort-select">
                        <option value="dateTransaction-desc" {{ support.transaction_query.sort == 'dateTransaction' and support.transaction_query.dir == 'desc' ? 'selected' : '' }}>Date récente</option>
                        <option value="dateTransaction-asc" {{ support.transaction_query.sort == 'dateTransaction' and support.transaction_query.dir == 'asc' ? 'selected' : '' }}>Date ancienne</option>
                        <option value="montant-desc" {{ support.transaction_query.sort == 'montant' and support.transaction_query.dir == 'desc' ? 'selected' : '' }}>Montant décroissant</option>
                        <option value="montant-asc" {{ support.transaction_query.sort == 'montant' and support.transaction_query.dir == 'asc' ? 'selected' : '' }}>Montant croissant</option>
                    </select>
                </div>
            </div>

            {# Advanced Search Panel #}
            <div class="tnx-advanced-search-panel" id="advanced-search-panel" style="display:none;">
                <form method="get" action="{{ path(route_name, {tab: 'transactions'}) }}" class="advanced-search-form">
                    <input type="hidden" name="tab" value="transactions">
                    
                    <div class="advanced-search-grid">
                        <div class="advanced-search-field">
                            <label><i class="fa-solid fa-calendar-days"></i> Date début</label>
                            <input type="date" name="date_from" value="{{ support.transaction_query.date_from|default('') }}">
                        </div>
                        
                        <div class="advanced-search-field">
                            <label><i class="fa-solid fa-calendar-days"></i> Date fin</label>
                            <input type="date" name="date_to" value="{{ support.transaction_query.date_to|default('') }}">
                        </div>
                        
                        <div class="advanced-search-field">
                            <label><i class="fa-solid fa-coins"></i> Montant min (DT)</label>
                            <input type="number" step="0.01" name="amount_min" placeholder="0.00" value="{{ support.transaction_query.amount_min|default('') }}">
                        </div>
                        
                        <div class="advanced-search-field">
                            <label><i class="fa-solid fa-coins"></i> Montant max (DT)</label>
                            <input type="number" step="0.01" name="amount_max" placeholder="1000.00" value="{{ support.transaction_query.amount_max|default('') }}">
                        </div>
                        
                        <div class="advanced-search-field">
                            <label><i class="fa-solid fa-tag"></i> Catégorie</label>
                            <select name="category">
                                <option value="">Toutes les catégories</option>
                                {% for cat in support.transaction_categories|default([]) %}
                                    <option value="{{ cat }}" {{ support.transaction_query.category == cat ? 'selected' : '' }}>{{ cat }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        
                        <div class="advanced-search-field">
                            <label><i class="fa-solid fa-building-columns"></i> Compte</label>
                            <select name="account_id">
                                <option value="">Tous les comptes</option>
                                {% for account in support.accounts|default([]) %}
                                    <option value="{{ account.idCompte }}" {{ support.transaction_query.account_id == account.idCompte ? 'selected' : '' }}>
                                        {{ account.numeroCompte }} ({{ account.solde }} DT)
                                    </option>
                                {% endfor %}
                            </select>
                        </div>
                    </div>
                    
                    <div class="advanced-search-actions">
                        <button type="submit" class="btn-apply-filters">
                            <i class="fa-solid fa-check"></i> Appliquer les filtres
                        </button>
                        <a href="{{ path(route_name, {tab: 'transactions'}) }}" class="btn-reset-filters">
                            <i class="fa-solid fa-rotate-left"></i> Réinitialiser
                        </a>
                    </div>
                </form>
            </div>

            {# Filter chips #}
            <div class="tnx-chips">
                <button class="tnx-chip tnx-chip--active">Tout</button>
                <button class="tnx-chip">Credits</button>
                <button class="tnx-chip">Debits</button>
                <button class="tnx-chip">En attente</button>
                <button class="tnx-chip">Terminees</button>
            </div>

            {# ── CALENDAR VIEW ── #}
            <div id="tnx-calendar-view" style="display:none;">
                <div id="transaction-calendar" style="background:#fff;padding:20px;border-radius:12px;box-shadow:0 2px 12px rgba(0,0,0,.08);"></div>
            </div>

            {# Timeline list #}
            <div class="tnx-timeline" id="tnx-timeline-view">
                {% for item in items %}
                    {% set amount = item.montant_value|default(0) %}
                    {% set type_key = item.typeTransaction|default('DEPOT')|upper %}
                    {% set is_debit = type_key in ['RETRAIT', 'PAIEMENT'] %}

                    <div class="tnx-row {{ is_debit ? 'tnx-row--debit' : 'tnx-row--credit' }} {{ edit_item and edit_item.idTransaction ~ '' == item.idTransaction ~ '' ? 'tnx-row--selected' : '' }}">

                        {# Timeline dot #}
                        <div class="tnx-row-dot">
                            <span class="tnx-row-dot-ring"></span>
                            <i class="fa-solid {{ is_debit ? 'fa-arrow-down' : 'fa-arrow-up' }}"></i>
                        </div>

                        {# Card body — cliquable pour charger dans le formulaire #}
                        <div class="tnx-row-card">

                            <a href="{{ path(route_name, { tab: 'transactions', edit_id: item.idTransaction }) }}#tnx-form-anchor"
                               class="tnx-row-card-main tnx-row-card-clickable"
                               title="Cliquer pour modifier cette transaction">
                                <div class="tnx-row-card-info">
                                    <div class="tnx-row-card-top">
                                        <span class="tnx-row-cat">{{ item.categorie|default('Transaction') }}</span>
                                        <span class="tnx-row-badge tnx-row-badge--is-ok">
                                            <i class="fa-solid fa-check"></i>
                                            {{ item.typeTransaction|default('DEPOT') }}
                                        </span>
                                    </div>
                                    <p class="tnx-row-meta">
                                        <i class="fa-regular fa-calendar"></i>
                                        {{ item.dateTransaction|default('-') }}
                                        &nbsp;·&nbsp;
                                        <i class="fa-regular fa-user"></i>
                                        {{ item.user_name|default('Utilisateur')|trim }}
                                        &nbsp;·&nbsp;
                                        {{ item.typeTransaction|default('Versement') }}
                                    </p>
                                    <div class="tnx-row-progress">
                                        <div class="tnx-row-progress-fill is-ok" style="width: 100%;"></div>
                                    </div>

                                    {# ── Barre de progression paiement ── #}
                                    {% set m  = item.montant_value|default(0) %}
                                    {% set mp = item.montantPaye_value|default(0) %}
                                    {% set pct = m > 0 ? ((mp / m) * 100)|round(1) : 0 %}
                                    {% if m > 0 %}
                                    <div class="pay-progress">
                                        <div class="pay-progress__bar">
                                            <div class="pay-progress__fill {{ pct >= 100 ? 'is-full' : (pct > 0 ? 'is-partial' : '') }}"
                                                 style="width:{{ pct > 100 ? 100 : pct }}%"></div>
                                        </div>
                                        <span class="pay-progress__label">
                                            {% if pct >= 100 %}
                                                <i class="fa-solid fa-circle-check" style="color:#16a34a"></i> Entièrement payé
                                            {% elseif pct > 0 %}
                                                {{ pct }}% payé · reste {{ (m - mp)|number_format(3,'.','') }} DT
                                            {% else %}
                                                Non payé · {{ m|number_format(3,'.','') }} DT
                                            {% endif %}
                                        </span>
                                    </div>
                                    {% endif %}
                                </div>

                                <div class="tnx-row-card-right">
                                    <strong class="tnx-row-amount {{ is_debit ? 'tnx-row-amount--debit' : 'tnx-row-amount--credit' }}">
                                        {{ is_debit ? '−' : '+' }}{{ amount|number_format(2, '.', ' ') }}<em>DT</em>
                                    </strong>
                                    <span class="tnx-row-edit-hint">
                                        <i class="fa-solid fa-pen-to-square"></i>
                                    </span>
                                </div>
                            </a>

                            <div class="tnx-row-card-footer">
                                <a class="tnx-row-action tnx-row-action--edit"
                                   href="{{ path(route_name, { tab: 'transactions', edit_id: item.idTransaction }) }}#tnx-form-anchor"
                                   title="Modifier">
                                    <i class="fa-solid fa-pen-to-square"></i>
                                    <span>Modifier</span>
                                </a>
                                <a class="tnx-row-action tnx-row-action--qr" href="{{ path('portal_feature_transaction_qr', { id: item.idTransaction }) }}" title="QR Code">
                                    <i class="fa-solid fa-qrcode"></i>
                                    <span>QR</span>
                                </a>

                                {% set show_rec_id = app.request.query.get('show_reclamation')|default('') %}
                                {% if show_rec_id ~ '' == item.idTransaction ~ '' %}
                                    <a class="tnx-row-action tnx-row-action--flag"
                                       href="{{ path(route_name, { tab: 'transactions' }) }}"
                                       title="Fermer réclamation"
                                       style="background:rgba(185,28,28,.15);color:#b91c1c;">
                                        <i class="fa-solid fa-xmark"></i>
                                        <span>Fermer</span>
                                    </a>
                                {% else %}
                                    <a class="tnx-row-action tnx-row-action--flag"
                                       href="{{ path(route_name, { tab: 'transactions', show_reclamation: item.idTransaction }) }}"
                                       title="Reclamation">
                                        <i class="fa-solid fa-flag"></i>
                                        <span>Reclamation</span>
                                    </a>
                                {% endif %}
                                <button class="tnx-row-action tnx-row-action--eye"
                                        onclick="tnxShowDetail(this)"
                                        data-id="{{ item.idTransaction }}"
                                        data-type="{{ item.typeTransaction|default('DEPOT') }}"
                                        data-categorie="{{ item.categorie|default('-') }}"
                                        data-date="{{ item.dateTransaction|default('-') }}"
                                        data-montant="{{ amount|number_format(2, '.', ' ') }}"
                                        data-montant-paye="{{ item.montantPaye_value|default(0)|number_format(2, '.', ' ') }}"
                                        data-devise="{{ item.original_currency|default('TND') }}"
                                        data-description="{{ item.description|default('')|e('html_attr') }}"
                                        data-compte="{{ item.numeroCompte|default('-') }}"
                                        data-destinataire="{{ item.nomDestinataire|default('-') }}"
                                        data-compte-dest="{{ item.idCompteDestinataire|default('-') }}"
                                        data-email-dest="{{ item.emailDestinataire|default('-') }}"
                                        data-user="{{ item.user_name|default('-')|trim }}"
                                        title="Voir les détails">
                                    <i class="fa-solid fa-eye"></i>
                                    <span>Voir</span>
                                </button>
                                <form method="post" class="tnx-row-del-form" data-turbo="false">
                                    <input type="hidden" name="tab" value="transactions">
                                    <input type="hidden" name="action" value="transaction_delete">
                                    <input type="hidden" name="idTransaction" value="{{ item.idTransaction }}">
                                    <button class="tnx-row-action tnx-row-action--del" type="submit" title="Supprimer">
                                        <i class="fa-solid fa-trash-can"></i>
                                        <span>Suppr.</span>
                                    </button>
                                </form>
                            </div>

                            {# ── FORMULAIRE RÉCLAMATION INLINE ── #}
                            {% set show_rec_id = app.request.query.get('show_reclamation')|default('') %}
                            {% if show_rec_id ~ '' == item.idTransaction ~ '' %}
                                {% set all_reclamations = support.reclamations|default([]) %}
                                {% set linked_recs = [] %}
                                {% for r in all_reclamations %}
                                    {% if r.idTransaction ~ '' == item.idTransaction ~ '' %}
                                        {% set linked_recs = linked_recs|merge([r]) %}
                                    {% endif %}
                                {% endfor %}

                                {# Résolution de la réclamation à modifier #}
                                {% set edit_rec_id = app.request.query.get('edit_rec')|default('') %}
                                {% set edit_rec = null %}
                                {% if edit_rec_id %}
                                    {% for r in linked_recs %}
                                        {% if r.idReclamation ~ '' == edit_rec_id ~ '' %}
                                            {% set edit_rec = r %}
                                        {% endif %}
                                    {% endfor %}
                                {% endif %}

                                <div class="tnx-reclamations-container">

                                    {# ── FORMULAIRE AJOUT / MODIFICATION RÉCLAMATION ── #}
                                    <div class="rec-form-card">
                                        <div class="rec-form-card__header">
                                            <div class="rec-form-card__header-icon">
                                                <i class="fa-solid fa-flag"></i>
                                            </div>
                                            <div>
                                                <h4>{{ edit_rec ? 'Modifier la réclamation #' ~ edit_rec.idReclamation : 'Nouvelle réclamation' }}</h4>
                                                <p>Transaction #{{ item.idTransaction }} · {{ item.categorie|default('—') }} · {{ item.montant_value|default(0)|number_format(2,'.','') }} DT</p>
                                            </div>
                                            {% if edit_rec %}
                                                <a href="{{ path(route_name, { tab: 'transactions', show_reclamation: item.idTransaction }) }}"
                                                   class="rec-form-card__close" title="Annuler la modification">
                                                    <i class="fa-solid fa-xmark"></i>
                                                </a>
                                            {% endif %}
                                        </div>

                                        <form method="post" class="rec-form-card__body" novalidate data-turbo="false">
                                            <input type="hidden" name="tab"           value="transactions">
                                            <input type="hidden" name="action"        value="reclamation_save">
                                            <input type="hidden" name="idTransaction" value="{{ item.idTransaction }}">
                                            <input type="hidden" name="idReclamation" value="{{ edit_rec ? edit_rec.idReclamation : '' }}">

                                            <div class="rec-form-row">
                                                {# Type #}
                                                <div class="rec-form-field">
                                                    <label><i class="fa-solid fa-tag"></i> Type de réclamation <em>*</em></label>
                                                    <select name="typeReclamation" required>
                                                        <option value="">— Sélectionner —</option>
                                                        {% for rtype in ['Echec de montant','Virement non recu','Erreur de transaction','Probleme de connexion au compte'] %}
                                                            <option value="{{ rtype }}" {{ edit_rec and edit_rec.typeReclamation == rtype ? 'selected' : '' }}>{{ rtype }}</option>
                                                        {% endfor %}
                                                    </select>
                                                    <span class="rec-msg" data-field="typeReclamation"></span>
                                                </div>

                                                {# Date #}
                                                <div class="rec-form-field">
                                                    <label><i class="fa-regular fa-calendar"></i> Date <em>*</em></label>
                                                    <input type="date" name="dateReclamation" required
                                                           value="{{ edit_rec ? edit_rec.dateReclamation|default('now'|date('Y-m-d')) : 'now'|date('Y-m-d') }}">
                                                    <span class="rec-msg" data-field="dateReclamation"></span>
                                                </div>
                                            </div>

                                            {# Description #}
                                            <div class="rec-form-field">
                                                <label style="display:flex;align-items:center;justify-content:space-between;">
                                                    <span><i class="fa-solid fa-align-left"></i> Description <em style="color:#ef4444;font-style:normal">*</em></span>
                                                    <button type="button"
                                                            id="rec-ai-btn-{{ item.idTransaction }}"
                                                            data-tx-id="{{ item.idTransaction }}"
                                                            data-categorie="{{ item.categorie|default('') }}"
                                                            data-montant="{{ item.montant_value|default(0) }}"
                                                            title="Améliorer avec Gemini AI"
                                                            style="display:inline-flex;align-items:center;gap:5px;padding:.25rem .75rem;border-radius:7px;border:none;cursor:pointer;font-size:.72rem;font-weight:700;font-family:inherit;background:linear-gradient(135deg,#6366f1,#8b5cf6);color:#fff;box-shadow:0 2px 8px rgba(99,102,241,.3);transition:all .2s;white-space:nowrap;">
                                                        <i class="fa-solid fa-wand-magic-sparkles"></i> Améliorer
                                                    </button>
                                                </label>
                                                <textarea name="description"
                                                          id="rec-desc-{{ item.idTransaction }}"
                                                          rows="3"
                                                          placeholder="Décrivez le problème rencontré avec cette transaction..."
                                                          required>{{ edit_rec ? edit_rec.description|default('') : '' }}</textarea>
                                                <span class="rec-msg" data-field="description"></span>
                                            </div>

                                            <script>
                                            (function(){
                                                var btn      = document.getElementById('rec-ai-btn-{{ item.idTransaction }}');
                                                var textarea = document.getElementById('rec-desc-{{ item.idTransaction }}');
                                                if (!btn || !textarea) return;
                                                btn.addEventListener('click', function(e){
                                                    e.preventDefault();
                                                    e.stopPropagation();
                                                    var desc = textarea.value.trim();
                                                    if (!desc) {
                                                        textarea.style.outline = '2px solid #f59e0b';
                                                        textarea.focus();
                                                        setTimeout(function(){ textarea.style.outline=''; }, 1500);
                                                        return;
                                                    }
                                                    var form   = btn.closest('form');
                                                    var typeEl = form && form.querySelector('[name="typeReclamation"]');
                                                    btn.disabled = true;
                                                    btn.innerHTML = '<i class="fa-solid fa-circle-notch fa-spin"></i> IA…';
                                                    fetch('{{ path('portal_api_reclamation_improve') }}', {
                                                        method : 'POST',
                                                        headers: {'Content-Type':'application/x-www-form-urlencoded'},
                                                        body   : 'description=' + encodeURIComponent(desc)
                                                               + '&type='      + encodeURIComponent(typeEl ? typeEl.value : '')
                                                               + '&categorie=' + encodeURIComponent('{{ item.categorie|default('')|e('js') }}')
                                                               + '&montant='   + encodeURIComponent('{{ item.montant_value|default(0) }}')
                                                    })
                                                    .then(function(r){ return r.json(); })
                                                    .then(function(d){
                                                        if (d.improved) {
                                                            textarea.value = d.improved;
                                                            textarea.style.boxShadow = '0 0 0 3px rgba(99,102,241,.3)';
                                                            setTimeout(function(){ textarea.style.boxShadow=''; }, 2000);
                                                        } else {
                                                            alert(d.error || 'Erreur IA.');
                                                        }
                                                    })
                                                    .catch(function(err){ alert('Erreur : ' + err.message); })
                                                    .finally(function(){
                                                        btn.disabled = false;
                                                        btn.innerHTML = '<i class="fa-solid fa-wand-magic-sparkles"></i> Améliorer';
                                                    });
                                                });
                                            })();
                                            </script>

                                            <div class="rec-form-footer">
                                                <a href="{{ path(route_name, { tab: 'transactions' }) }}"
                                                   class="rec-form-btn rec-form-btn--cancel">
                                                    <i class="fa-solid fa-xmark"></i> Annuler
                                                </a>
                                                <button type="submit" class="rec-form-btn rec-form-btn--submit">
                                                    <i class="fa-solid fa-paper-plane"></i>
                                                    {{ edit_rec ? 'Mettre à jour' : 'Soumettre la réclamation' }}
                                                </button>
                                            </div>
                                        </form>
                                    </div>

                                    {# ── LISTE DES RÉCLAMATIONS ── #}
                                    {% if linked_recs is not empty %}
                                        <div class="rec-table-wrapper">
                                            <div class="rec-table-header">
                                                <h4><i class="fa-solid fa-list-check"></i> Réclamations liées ({{ linked_recs|length }})</h4>
                                            </div>
                                            <div class="table-responsive">
                                                <table class="rec-table">
                                                    <thead>
                                                        <tr>
                                                            <th>Date</th>
                                                            <th>Type</th>
                                                            <th>Description</th>
                                                            <th>Statut</th>
                                                            <th style="text-align:right">Actions</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        {% for rec in linked_recs %}
                                                            {% set rs = rec.status|default('En attente')|lower %}
                                                            {% set rc_bg  = rs == 'valide' ? 'rgba(34,197,94,.12)'  : (rs == 'ferme' ? 'rgba(220,38,38,.1)'  : 'rgba(37,99,235,.1)') %}
                                                            {% set rc_txt = rs == 'valide' ? '#15803d'              : (rs == 'ferme' ? '#b91c1c'              : '#1d4ed8') %}
                                                            <tr class="rec-row {{ edit_rec and edit_rec.idReclamation ~ '' == rec.idReclamation ~ '' ? 'rec-row--editing' : '' }}">
                                                                <td class="rec-cell-date">{{ rec.dateReclamation|default('—') }}</td>
                                                                <td class="rec-cell-type">
                                                                    {% set sentiment_emoji = {
                                                                        'angry': '😠',
                                                                        'sad': '😢',
                                                                        'worried': '😰',
                                                                        'neutral': '😐',
                                                                        'happy': '😊'
                                                                    } %}
                                                                    <span class="sentiment-emoji" title="Sentiment: {{ rec.sentiment|default('neutral') }}" style="font-size:1.2rem;margin-right:.4rem;display:inline-block;">
                                                                        {{ sentiment_emoji[rec.sentiment|default('neutral')] ?? '😐' }}
                                                                    </span>
                                                                    <strong>{{ rec.typeReclamation|default('—') }}</strong>
                                                                </td>
                                                                <td class="rec-cell-desc" title="{{ rec.description|default('') }}">
                                                                    {{ rec.description|default('')|slice(0,60) }}{{ rec.description|default('')|length > 60 ? '…' : '' }}
                                                                </td>
                                                                <td class="rec-cell-status">
                                                                    <span class="rec-badge" style="background:{{ rc_bg }};color:{{ rc_txt }};">
                                                                        {% if rs == 'valide' %}<i class="fa-solid fa-circle-check"></i>
                                                                        {% elseif rs == 'ferme' %}<i class="fa-solid fa-circle-xmark"></i>
                                                                        {% else %}<i class="fa-solid fa-clock"></i>{% endif %}
                                                                        {{ rec.status|default('En attente') }}
                                                                    </span>
                                                                </td>
                                                                <td class="rec-cell-actions">
                                                                    <a href="{{ path(route_name, { tab: 'transactions', show_reclamation: item.idTransaction, edit_rec: rec.idReclamation }) }}"
                                                                       class="rec-btn rec-btn-edit" title="Modifier">
                                                                        <i class="fa-solid fa-pen"></i>
                                                                    </a>
                                                                    <form method="post" style="display:inline" data-turbo="false" onsubmit="return confirm('Supprimer cette réclamation ?')">
                                                                        <input type="hidden" name="tab"           value="transactions">
                                                                        <input type="hidden" name="action"        value="reclamation_delete">
                                                                        <input type="hidden" name="idReclamation" value="{{ rec.idReclamation }}">
                                                                        <button type="submit" class="rec-btn rec-btn-del" title="Supprimer">
                                                                            <i class="fa-solid fa-trash"></i>
                                                                        </button>
                                                                    </form>
                                                                </td>
                                                            </tr>
                                                        {% endfor %}
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    {% else %}
                                        <div class="rec-empty-state">
                                            <i class="fa-regular fa-flag"></i>
                                            <p>Aucune réclamation pour cette transaction</p>
                                        </div>
                                    {% endif %}

                                </div>
                            {% endif %}

                        </div>
                    </div>

                {% else %}
                    <div class="tnx-empty">
                        <div class="tnx-empty-icon">
                            <i class="fa-solid fa-receipt"></i>
                        </div>
                        <h3>Aucune transaction trouvee</h3>
                        <p>Ajoutez votre premiere operation pour commencer le suivi.</p>
                        <a class="tnx-empty-cta" href="#tnx-form-anchor">
                            <i class="fa-solid fa-plus"></i> Creer une transaction
                        </a>
                    </div>
                {% endfor %}
            </div>

            {# Pagination footer #}
            {% set pagination = support.pagination|default({ current_page: 1, total_pages: 1, total_items: 0, per_page: 3, has_prev: false, has_next: false }) %}
            <div class="tnx-footer">
                <span class="tnx-footer-info">
                    Affichage <strong>{{ items is empty ? '0' : ((pagination.current_page - 1) * pagination.per_page + 1) ~ '–' ~ ((pagination.current_page - 1) * pagination.per_page + items|length) }}</strong> sur <strong>{{ pagination.total_items }}</strong>
                </span>
                <div class="tnx-pager">
                    {% if pagination.has_prev %}
                        <a href="{{ path(route_name, { tab: 'transactions', page: pagination.current_page - 1, q: support.transaction_query.q, filter: support.transaction_query.filter, sort: support.transaction_query.sort, dir: support.transaction_query.dir }) }}" class="tnx-pager-btn" aria-label="Precedent" style="text-decoration:none">
                            <i class="fa-solid fa-chevron-left"></i>
                        </a>
                    {% else %}
                        <span class="tnx-pager-btn" style="opacity:.4;cursor:not-allowed" aria-label="Precedent">
                            <i class="fa-solid fa-chevron-left"></i>
                        </span>
                    {% endif %}
                    
                    {% for page in 1..pagination.total_pages %}
                        {% if page == pagination.current_page %}
                            <span class="tnx-pager-btn tnx-pager-btn--active">{{ page }}</span>
                        {% elseif page == 1 or page == pagination.total_pages or (page >= pagination.current_page - 1 and page <= pagination.current_page + 1) %}
                            <a href="{{ path(route_name, { tab: 'transactions', page: page, q: support.transaction_query.q, filter: support.transaction_query.filter, sort: support.transaction_query.sort, dir: support.transaction_query.dir }) }}" class="tnx-pager-btn" style="text-decoration:none">{{ page }}</a>
                        {% elseif page == pagination.current_page - 2 or page == pagination.current_page + 2 %}
                            <span style="padding:0 .3rem;color:#94a3b8">...</span>
                        {% endif %}
                    {% endfor %}
                    
                    {% if pagination.has_next %}
                        <a href="{{ path(route_name, { tab: 'transactions', page: pagination.current_page + 1, q: support.transaction_query.q, filter: support.transaction_query.filter, sort: support.transaction_query.sort, dir: support.transaction_query.dir }) }}" class="tnx-pager-btn" aria-label="Suivant" style="text-decoration:none">
                            <i class="fa-solid fa-chevron-right"></i>
                        </a>
                    {% else %}
                        <span class="tnx-pager-btn" style="opacity:.4;cursor:not-allowed" aria-label="Suivant">
                            <i class="fa-solid fa-chevron-right"></i>
                        </span>
                    {% endif %}
                </div>
