<script>
/* ── Conversion devise selon localisation ── */
(function(){
  /* ── Taux fixes embarqués (toujours disponibles) ── */
  var RATES = { EUR:0.295, USD:0.320 };

  var EUROZONE = ['FR','DE','IT','ES','BE','NL','AT','PT','GR','IE','LU','FI','SK','SI','EE','LV','LT','CY','MT'];
  var USDZONE  = ['US','CA','MX','PA','EC','SV'];
  var NAMES    = {
    TN:'Tunisie',FR:'France',DE:'Allemagne',IT:'Italie',ES:'Espagne',
    BE:'Belgique',NL:'Pays-Bas',AT:'Autriche',PT:'Portugal',GR:'Grèce',
    US:'États-Unis',CA:'Canada',GB:'Royaume-Uni',CH:'Suisse',
    MA:'Maroc',DZ:'Algérie',LY:'Libye',SA:'Arabie Saoudite',
  };

  var widget    = document.getElementById('cvt-widget');
  var amtInput  = document.getElementById('f-amount');
  var mainLine  = document.getElementById('cvt-main-line');
  var equivLine = document.getElementById('cvt-equiv-line');
  var metaLine  = document.getElementById('cvt-meta-line');
  var currLabel = document.getElementById('cvt-currency-label');
  if (!widget || !amtInput) return;

  /* ── Pays : localStorage d'abord, puis API, puis fallback TN ── */
  var _country = null;

  function getCountry(cb){
    /* 1. Mémoire */
    if(_country){ cb(_country); return; }
    /* 2. localStorage (valide 24h) */
    try {
      var cached = JSON.parse(localStorage.getItem('cvt_country')||'null');
      if(cached && cached.code && (Date.now()-cached.ts) < 86400000){
        _country = cached.code; cb(_country); return;
      }
    } catch(e){}
    /* 3. API avec timeout 3s */
    var done = false;
    var timer = setTimeout(function(){ if(!done){ done=true; _country='TN'; cb(_country); } }, 3000);
    fetch('https://ipapi.co/json/')
      .then(function(r){ return r.json(); })
      .then(function(d){
        if(done) return;
        done = true; clearTimeout(timer);
        _country = (d.country_code||'TN').toUpperCase();
        try{ localStorage.setItem('cvt_country', JSON.stringify({code:_country,ts:Date.now()})); }catch(e){}
        cb(_country);
      })
      .catch(function(){
        if(done) return;
        done = true; clearTimeout(timer);
        _country = 'TN'; cb(_country);
      });
  }

  /* ── Taux : essaie l'API, utilise les fixes si échec ── */
  function getRates(cb){
    /* Toujours appeler cb immédiatement avec les taux fixes */
    /* puis mettre à jour si l'API répond */
    cb(RATES);
    fetch('https://open.er-api.com/v6/latest/TND')
      .then(function(r){ return r.json(); })
      .then(function(d){
        if(d.rates && d.rates.EUR && d.rates.USD){
          RATES = { EUR:d.rates.EUR, USD:d.rates.USD };
        }
      })
      .catch(function(){});
  }

  function fmt(n,d){ return n.toFixed(d!==undefined?d:2); }

  var CURRENCY_LABELS = {
    TND: 'Dinar tunisien (TND)',
    EUR: 'Euro (EUR)',
    USD: 'Dollar américain (USD)',
  };

  function render(amount, country){
    var inEuro = EUROZONE.indexOf(country) !== -1;
    var inUsd  = USDZONE.indexOf(country)  !== -1;
    var cname  = NAMES[country] || country;

    /* Mise à jour du label devise */
    if(currLabel){
      currLabel.textContent = inEuro ? CURRENCY_LABELS.EUR : (inUsd ? CURRENCY_LABELS.USD : CURRENCY_LABELS.TND);
    }

    if(country === 'TN'){
      mainLine.textContent  = fmt(amount,3) + ' TND';
      equivLine.textContent = '≈ ' + fmt(amount*RATES.EUR,2) + ' EUR  ·  ' + fmt(amount*RATES.USD,2) + ' USD';
      metaLine.textContent  = '📍 ' + cname;
      mainLine.className    = 'cvt-widget__line cvt-widget__line--tnd';

    } else if(inEuro){
      mainLine.textContent  = fmt(amount,2) + ' EUR';
      equivLine.textContent = '≈ ' + fmt(amount/RATES.EUR,3) + ' TND';
      metaLine.textContent  = '📍 ' + cname + '  ·  1 EUR = ' + fmt(1/RATES.EUR,3) + ' TND';
      mainLine.className    = 'cvt-widget__line cvt-widget__line--eur';

    } else if(inUsd){
      mainLine.textContent  = fmt(amount,2) + ' USD';
      equivLine.textContent = '≈ ' + fmt(amount/RATES.USD,3) + ' TND';
      metaLine.textContent  = '📍 ' + cname + '  ·  1 USD = ' + fmt(1/RATES.USD,3) + ' TND';
      mainLine.className    = 'cvt-widget__line cvt-widget__line--usd';

    } else {
      mainLine.textContent  = fmt(amount,3) + ' TND';
      equivLine.textContent = '≈ ' + fmt(amount*RATES.EUR,2) + ' EUR  ·  ' + fmt(amount*RATES.USD,2) + ' USD';
      metaLine.textContent  = '📍 ' + cname;
      mainLine.className    = 'cvt-widget__line cvt-widget__line--tnd';
    }
    widget.removeAttribute('hidden');
  }

  function refresh(){
    var amount = parseFloat(amtInput.value);
    if(!amount || amount <= 0){ widget.setAttribute('hidden',''); return; }
    /* Affiche immédiatement avec taux fixes + pays connu ou TN */
    render(amount, _country || 'TN');
    /* Puis affine avec le vrai pays */
    getCountry(function(country){ render(amount, country); });
    /* Taux en arrière-plan */
    getRates(function(){});
  }

  amtInput.addEventListener('input',  refresh);
  amtInput.addEventListener('change', refresh);

  /* Pré-charge le pays dès le chargement de la page */
  getCountry(function(country){
    if(currLabel){
      var inEuro = EUROZONE.indexOf(country) !== -1;
      var inUsd  = USDZONE.indexOf(country)  !== -1;
      currLabel.textContent = inEuro ? CURRENCY_LABELS.EUR : (inUsd ? CURRENCY_LABELS.USD : CURRENCY_LABELS.TND);
    }
  });
  if(amtInput.value) refresh();
})();
</script>

<script>
/* ── Validation formulaires Réclamation ── */
(function(){
function wireRecForm(form){
  /* Helpers — cible le span.rec-msg[data-field=X] dans ce formulaire */
  function getSpan(name){
    return form.querySelector('.rec-msg[data-field="'+name+'"]');
  }
  function getEl(name){
    return form.querySelector('[name="'+name+'"]');
  }
  function setOk(name){
    var el=getEl(name),s=getSpan(name);
    if(el){el.style.borderColor='#16a34a';el.style.background='#f0fdf4';}
    if(s){s.style.color='#16a34a';s.textContent='✓ Valide';}
    return true;
  }
  function setErr(name,msg){
    var el=getEl(name),s=getSpan(name);
    if(el){el.style.borderColor='#dc2626';el.style.background='#fff5f5';}
    if(s){s.style.color='#dc2626';s.textContent='⚠ '+msg;}
    return false;
  }
  function clr(name){
    var el=getEl(name),s=getSpan(name);
    if(el){el.style.borderColor='';el.style.background='';}
    if(s){s.textContent='';}
    return true;
  }

  function vDate(){
    var el=getEl('dateReclamation');
    if(!el)return true;
    return el.value?setOk('dateReclamation'):setErr('dateReclamation','La date est obligatoire.');
  }
  function vType(){
    var el=getEl('typeReclamation');
    if(!el)return true;
    return el.value?setOk('typeReclamation'):setErr('typeReclamation','Sélectionner un type.');
  }
  function vDesc(){
    var el=getEl('description');
    if(!el||el.value.trim()==='')return clr('description');
    return setOk('description');
  }

  /* Live */
  var d=getEl('dateReclamation');
  if(d){['change','blur'].forEach(function(e){d.addEventListener(e,vDate);});}
  var t=getEl('typeReclamation');
  if(t){t.addEventListener('change',vType);}
  var dc=getEl('description');
  if(dc){['input','blur'].forEach(function(e){dc.addEventListener(e,vDesc);});}

  /* Submit */
  form.addEventListener('submit',function(e){
    var ok=vDate()&vType();
    vDesc();
    if(!ok)e.preventDefault();
  });
}

/* Wire tous les formulaires réclamation présents */
document.querySelectorAll('form input[name="action"][value="reclamation_save"]').forEach(function(i){
  var f=i.closest('form');
  if(f)wireRecForm(f);
});
})();
</script>


<script>
// Gestion affichage sections + solde (sans validation — géré par transaction-form-simple.js)
(function() {
    'use strict';

    const form = document.getElementById('transaction-form');
    if (!form) return;

    const compteSelect  = document.getElementById('f-compte');
    const soldeDisplay  = document.getElementById('solde-disponible');
    const typeRadios    = form.querySelectorAll('input[name="typeTransaction"]');

    const sections = {
        DEPOT:    form.querySelector('.section-depot'),
        RETRAIT:  form.querySelector('.section-retrait'),
        VIREMENT: form.querySelector('.section-virement'),
        PAIEMENT: form.querySelector('.section-paiement'),
    };

    function updateSolde() {
        if (!compteSelect || compteSelect.selectedIndex <= 0) return;
        const solde = parseFloat(compteSelect.options[compteSelect.selectedIndex].dataset.solde || 0);
        if (soldeDisplay) soldeDisplay.textContent = solde.toFixed(2) + ' DT';
    }

    // Écouter les changements de compte pour mettre à jour le solde affiché
    compteSelect?.addEventListener('change', updateSolde);

    // Initialiser le solde
    updateSolde();

    // Gérer le bouton "Payer avec Stripe" pour les paiements
    const btnPayerStripe = document.getElementById('btn-payer-stripe');
    if (btnPayerStripe) {
        btnPayerStripe.addEventListener('click', function(e) {
            e.preventDefault();

            const typeChecked = form.querySelector('input[name="typeTransaction"]:checked');
            if (!typeChecked || typeChecked.value !== 'PAIEMENT') return;

            const montant = parseFloat(document.getElementById('f-montant-paye')?.value || 0);
            let montantInput = form.querySelector('input[name="montant"]');
            if (!montantInput) {
                montantInput = document.createElement('input');
                montantInput.type = 'hidden';
                montantInput.name = 'montant';
                form.appendChild(montantInput);
            }
            montantInput.value = montant;

            // S'assurer que action est présent
            let actionInput = form.querySelector('input[name="action"][value="transaction_save"]');
            if (!actionInput) {
                actionInput = document.createElement('input');
                actionInput.type = 'hidden';
                actionInput.name = 'action';
                actionInput.value = 'transaction_save';
                form.appendChild(actionInput);
            }

            form.submit();
        });
    }

})();
</script>

