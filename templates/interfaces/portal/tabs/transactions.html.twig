<div id="tnx-detail-modal" style="display:none;position:fixed;inset:0;z-index:1300;display:none;align-items:center;justify-content:center;padding:1rem;background:rgba(15,23,42,.5);backdrop-filter:blur(6px);">
    <div style="width:min(520px,100%);background:#fff;border-radius:20px;box-shadow:0 24px 64px rgba(15,23,42,.22);overflow:hidden;animation:tnxDetailIn .25s ease;">
        {# Header #}
        <div id="tnx-detail-header" style="padding:1.2rem 1.5rem;display:flex;align-items:center;gap:12px;position:relative;">
            <div id="tnx-detail-icon" style="width:46px;height:46px;border-radius:14px;display:grid;place-items:center;font-size:1.2rem;flex-shrink:0;"></div>
            <div>
                <h3 id="tnx-detail-title" style="margin:0 0 2px;font-size:1rem;font-weight:800;color:#fff;"></h3>
                <p id="tnx-detail-sub" style="margin:0;font-size:.75rem;color:rgba(255,255,255,.7);"></p>
            </div>
            <button onclick="tnxCloseDetail()" style="margin-left:auto;width:34px;height:34px;border-radius:10px;background:rgba(255,255,255,.18);border:1px solid rgba(255,255,255,.25);color:#fff;cursor:pointer;font-size:.9rem;display:grid;place-items:center;">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>

        {# Montant #}
        <div style="padding:.8rem 1.5rem;background:#f8faff;border-top:1px solid #e8f0fb;border-bottom:1px solid #e8f0fb;display:flex;align-items:center;justify-content:space-between;">
            <span style="font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#64748b;">Montant</span>
            <strong id="tnx-detail-montant" style="font-size:1.6rem;font-weight:900;"></strong>
        </div>

        {# Grille de détails #}
        <div style="padding:1.2rem 1.5rem;display:grid;grid-template-columns:1fr 1fr;gap:.85rem;">
            <div class="tnx-d-field">
                <span class="tnx-d-label"><i class="fa-regular fa-calendar"></i> Date</span>
                <span id="tnx-detail-date" class="tnx-d-value"></span>
            </div>
            <div class="tnx-d-field">
                <span class="tnx-d-label"><i class="fa-solid fa-tags"></i> Catégorie</span>
                <span id="tnx-detail-categorie" class="tnx-d-value"></span>
            </div>
            <div class="tnx-d-field">
                <span class="tnx-d-label"><i class="fa-solid fa-building-columns"></i> Compte</span>
                <span id="tnx-detail-compte" class="tnx-d-value"></span>
            </div>
            <div class="tnx-d-field">
                <span class="tnx-d-label"><i class="fa-solid fa-coins"></i> Devise</span>
                <span id="tnx-detail-devise" class="tnx-d-value"></span>
            </div>
            <div class="tnx-d-field" id="tnx-d-dest-wrap">
                <span class="tnx-d-label"><i class="fa-solid fa-user"></i> Destinataire</span>
                <span id="tnx-detail-destinataire" class="tnx-d-value"></span>
            </div>
            <div class="tnx-d-field" id="tnx-d-comptedest-wrap">
                <span class="tnx-d-label"><i class="fa-solid fa-hashtag"></i> Compte dest.</span>
                <span id="tnx-detail-comptedest" class="tnx-d-value"></span>
            </div>
            <div class="tnx-d-field" id="tnx-d-email-wrap" style="grid-column:1/-1;">
                <span class="tnx-d-label"><i class="fa-solid fa-envelope"></i> Email dest.</span>
                <span id="tnx-detail-email" class="tnx-d-value"></span>
            </div>
            <div class="tnx-d-field" id="tnx-d-desc-wrap" style="grid-column:1/-1;">
                <span class="tnx-d-label"><i class="fa-solid fa-align-left"></i> Description</span>
                <span id="tnx-detail-description" class="tnx-d-value" style="font-style:italic;color:#475569;"></span>
            </div>
        </div>

        {# Footer #}
        <div style="padding:.9rem 1.5rem;background:#f8faff;border-top:1px solid #e8f0fb;display:flex;justify-content:flex-end;">
            <button onclick="tnxCloseDetail()" style="padding:.5rem 1.4rem;border-radius:9px;background:#1e293b;color:#fff;border:none;font-size:.83rem;font-weight:700;cursor:pointer;">
                Fermer
            </button>
        </div>
    </div>
</div>

<style>
@keyframes tnxDetailIn {
    from { opacity:0; transform:scale(.94) translateY(12px); }
    to   { opacity:1; transform:scale(1)  translateY(0); }
}
.tnx-d-field { display:flex; flex-direction:column; gap:4px; background:#f8faff; border:1px solid #e8f0fb; border-radius:10px; padding:.65rem .85rem; }
.tnx-d-label { font-size:.68rem; font-weight:700; text-transform:uppercase; letter-spacing:.5px; color:#94a3b8; display:flex; align-items:center; gap:5px; }
.tnx-d-value { font-size:.88rem; font-weight:700; color:#1e293b; word-break:break-word; }
</style>

<script>
function tnxShowDetail(btn) {
    var type       = btn.dataset.type || 'DEPOT';
    var id         = btn.dataset.id;
    var categorie  = btn.dataset.categorie;
    var date       = btn.dataset.date;
    var montant    = btn.dataset.montant;
    var montantPaye= btn.dataset.montantPaye;
    var devise     = btn.dataset.devise;
    var desc       = btn.dataset.description;
    var compte     = btn.dataset.compte;
    var dest       = btn.dataset.destinataire;
    var compteDest = btn.dataset.compteDest;
    var emailDest  = btn.dataset.emailDest;
    var user       = btn.dataset.user;

    var isDebit = ['RETRAIT','PAIEMENT'].indexOf(type) !== -1;
    var isVirement = type === 'VIREMENT';
    var isPaiement = type === 'PAIEMENT';

    // Couleurs par type
    var colors = {
        DEPOT:    { bg: 'linear-gradient(135deg,#065f46,#047857)', icon: '#d1fae5', fa: 'fa-arrow-down' },
        RETRAIT:  { bg: 'linear-gradient(135deg,#991b1b,#b91c1c)', icon: '#fee2e2', fa: 'fa-arrow-up' },
        VIREMENT: { bg: 'linear-gradient(135deg,#1e3a8a,#1d4ed8)', icon: '#dbeafe', fa: 'fa-right-left' },
        PAIEMENT: { bg: 'linear-gradient(135deg,#4c1d95,#6d28d9)', icon: '#ede9fe', fa: 'fa-credit-card' },
    };
    var c = colors[type] || colors.DEPOT;

    // Header
    document.getElementById('tnx-detail-header').style.background = c.bg;
    var iconEl = document.getElementById('tnx-detail-icon');
    iconEl.style.background = c.icon;
    iconEl.innerHTML = '<i class="fa-solid ' + c.fa + '" style="color:' + (isDebit ? '#991b1b' : '#065f46') + '"></i>';
    document.getElementById('tnx-detail-title').textContent = type + ' #' + id;
    document.getElementById('tnx-detail-sub').textContent = user !== '-' ? 'Par ' + user : date;

    // Montant
    var montantEl = document.getElementById('tnx-detail-montant');
    montantEl.textContent = (isDebit ? '−' : '+') + montant + ' DT';
    montantEl.style.color = isDebit ? '#dc2626' : '#047857';

    // Champs
    document.getElementById('tnx-detail-date').textContent       = date;
    document.getElementById('tnx-detail-categorie').textContent  = categorie;
    document.getElementById('tnx-detail-compte').textContent     = compte;
    document.getElementById('tnx-detail-devise').textContent     = devise;

    // Destinataire (virement/paiement seulement)
    var showDest = dest && dest !== '-';
    document.getElementById('tnx-d-dest-wrap').style.display      = showDest ? '' : 'none';
    document.getElementById('tnx-detail-destinataire').textContent = dest;

    var showCompteDest = compteDest && compteDest !== '-';
    document.getElementById('tnx-d-comptedest-wrap').style.display = showCompteDest ? '' : 'none';
    document.getElementById('tnx-detail-comptedest').textContent   = compteDest;

    var showEmail = emailDest && emailDest !== '-';
    document.getElementById('tnx-d-email-wrap').style.display     = showEmail ? '' : 'none';
    document.getElementById('tnx-detail-email').textContent       = emailDest;

    var showDesc = desc && desc.trim() !== '';
    document.getElementById('tnx-d-desc-wrap').style.display      = showDesc ? '' : 'none';
    document.getElementById('tnx-detail-description').textContent = desc;

    // Afficher la modale
    var modal = document.getElementById('tnx-detail-modal');
    modal.style.display = 'flex';
    document.body.style.overflow = 'hidden';
}

function tnxCloseDetail() {
    document.getElementById('tnx-detail-modal').style.display = 'none';
    document.body.style.overflow = '';
}

// Fermer en cliquant sur le fond
document.getElementById('tnx-detail-modal').addEventListener('click', function(e) {
    if (e.target === this) tnxCloseDetail();
});

// Fermer avec Escape
document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') tnxCloseDetail();
});
</script>


