{% extends 'base.html.twig' %}

{% block title %}Nexora Portal â€” {{ tab|replace({'_': ' '})|title }}{% endblock %}
{% block body_class %}nx-portal-body{% endblock %}

{% block stylesheets %}
    {% set css_version = 'now'|date('U') %}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    {% for stylesheet in tab_stylesheets|default([]) %}
        <link rel="stylesheet" href="{{ asset(stylesheet) }}?v={{ css_version }}" data-turbo-track="reload">
    {% endfor %}
{% endblock %}

{% block body %}

{% set active_tab_label = tab %}
{% for item in tabs %}
    {% if item.key == tab %}
        {% set active_tab_label = item.label %}
    {% endif %}
{% endfor %}

{% set primary_keys = ['dashboard', 'accounts', 'transactions', 'credits', 'cashback'] %}
{% set secondary_keys = ['garanties', 'complaints', 'vaults', 'profile', 'notifications'] %}

{% set nav_icons = {
    dashboard:     'fa-chart-line',
    accounts:      'fa-wallet',
    transactions:  'fa-right-left',
    credits:       'fa-hand-holding-dollar',
    cashback:      'fa-hand-holding-heart',
    garanties:     'fa-shield-halved',
    complaints:    'fa-comment-dots',
    vaults:        'fa-lock',
    profile:       'fa-user-circle',
    notifications: 'fa-bell'
} %}

{% set page_subtitles = {
    dashboard:     'Vue globale de toutes vos activites financieres',
    accounts:      'Gerez et suivez vos comptes bancaires',
    transactions:  'Consultez l\'historique complet de vos transactions',
    credits:       'Gestion des credits, mensualites et garanties',
    cashback:      'Suivi de vos recompenses et partenaires cashback',
    garanties:     'Garanties et couvertures associees a vos credits',
    complaints:    'Suivi et gestion de vos reclamations',
    vaults:        'Objectifs d\'epargne et coffres virtuels',
    profile:       'Profil personnel et parametres de securite',
    notifications: 'Alertes, rappels et messages systeme'
} %}

{# â”€â”€ Detect section color for page accent â”€â”€ #}
{% set tab_accent = {
    dashboard:    '#1565c0',
    accounts:     '#0097a7',
    transactions: '#7c3aed',
    credits:      '#1565c0',
    cashback:     '#00838f',
    garanties:    '#0f6f8e',
    complaints:   '#b91c1c',
    vaults:       '#166534',
    profile:      '#374151',
    notifications:'#d97706'
} %}
{% set current_accent = tab_accent[tab]|default('#1565c0') %}

<style>
/* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
   NEXORA PORTAL  â€”  Full Layout + Navbar
   White background Â· Clean banking UI
   â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */

/* â”€â”€ Reset â”€â”€ */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

/* â”€â”€ Body â”€â”€ */
.nx-portal-body {
    font-family: 'Inter', 'Segoe UI', system-ui, -apple-system, sans-serif;
    background: #f0f4f8;
    color: #0a2540;
    min-height: 100vh;
    overflow-x: hidden;
}

/* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
   PORTAL WRAPPER
   â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
.nx-portal {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
}

/* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
   TOP NAVBAR
   â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
.nx-navbar {
    position: sticky;
    top: 0;
    z-index: 200;
    background: #fff;
    border-bottom: 1px solid #e2eaf4;
    box-shadow: 0 2px 16px rgba(10,37,64,.07);
    display: flex;
    align-items: center;
    gap: 0;
    height: 64px;
    padding: 0 24px;
}

/* â”€â”€ Brand â”€â”€ */
.nx-brand {
    display: flex;
    align-items: center;
    gap: 11px;
    text-decoration: none;
    flex-shrink: 0;
    padding-right: 24px;
}

.nx-brand-logo {
    width: 38px;
    height: 38px;
    border-radius: 12px;
    background: linear-gradient(135deg, #0a2540 0%, #1565c0 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    box-shadow: 0 4px 12px rgba(21,101,192,.28);
    flex-shrink: 0;
}

.nx-brand-logo img {
    width: 100%;
    height: 100%;
    object-fit: contain;
}

.nx-brand-logo-fallback {
    font-size: 17px;
    color: #fff;
    font-weight: 900;
    letter-spacing: -1px;
}

.nx-brand-text {
    display: flex;
    flex-direction: column;
}

.nx-brand-name {
    font-size: 15px;
    font-weight: 900;
    color: #0a2540;
    letter-spacing: 1.5px;
    line-height: 1;
}

.nx-brand-tagline {
    font-size: 10px;
    color: #7294ae;
    font-weight: 600;
    letter-spacing: 0.5px;
    margin-top: 2px;
}

/* â”€â”€ Navbar Divider â”€â”€ */
.nx-nav-sep {
    width: 1px;
    height: 28px;
    background: #e2eaf4;
    flex-shrink: 0;
    margin: 0 20px;
}

/* â”€â”€ Primary Nav â”€â”€ */
.nx-nav-primary {
    display: flex;
    align-items: center;
    gap: 2px;
    flex: 1;
}

.nx-nav-link {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    border-radius: 12px;
    text-decoration: none;
    font-size: 13px;
    font-weight: 600;
    color: #5b80a0;
    white-space: nowrap;
    transition: background .18s, color .18s;
    position: relative;
}

.nx-nav-link i {
    font-size: 14px;
    flex-shrink: 0;
    transition: color .18s;
}

.nx-nav-link:hover {
    background: #f0f6ff;
    color: #1565c0;
}

.nx-nav-link:hover i { color: #1565c0; }

/* Active state */
.nx-nav-link-active {
    background: linear-gradient(120deg, rgba(21,101,192,.1), rgba(30,136,229,.07));
    color: #1565c0;
    font-weight: 700;
}

.nx-nav-link-active i { color: #1565c0; }

.nx-nav-link-active::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 14px;
    right: 14px;
    height: 2px;
    background: linear-gradient(90deg, #1565c0, #1e88e5);
    border-radius: 2px 2px 0 0;
}

/* â”€â”€ Status chips â”€â”€ */
.nx-status-row {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
    padding: 0 8px;
}

.nx-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 11px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 700;
    white-space: nowrap;
}

.nx-chip-secure {
    background: #dcfce7;
    color: #166534;
    border: 1px solid #bbf7d0;
}

.nx-chip-secure i { font-size: 10px; color: #16a34a; }

.nx-chip-live {
    background: #dbeafe;
    color: #1e40af;
    border: 1px solid #bfdbfe;
}

/* Pulse dot */
.nx-pulse {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #22c55e;
    position: relative;
    flex-shrink: 0;
}

.nx-pulse::before {
    content: '';
    position: absolute;
    inset: -3px;
    border-radius: 50%;
    background: rgba(34,197,94,.3);
    animation: nx-pulse-ring 1.8s ease-out infinite;
}

@keyframes nx-pulse-ring {
    0%   { transform: scale(.7); opacity: 1; }
    100% { transform: scale(1.6); opacity: 0; }
}

/* â”€â”€ Navbar action buttons â”€â”€ */
.nx-nav-actions {
    display: flex;
    align-items: center;
    gap: 4px;
    flex-shrink: 0;
}

.nx-action-btn {
    position: relative;
    width: 38px;
    height: 38px;
    border-radius: 11px;
    background: transparent;
    border: 1px solid transparent;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #5b80a0;
    font-size: 15px;
    text-decoration: none;
    cursor: pointer;
    transition: background .18s, border-color .18s, color .18s;
}

.nx-action-btn:hover {
    background: #f0f6ff;
    border-color: #dde8f5;
    color: #1565c0;
}

.nx-action-btn.is-active {
    background: #eaf2fd;
    border-color: #c3d9f5;
    color: #1565c0;
}

/* Notification badge */
.nx-notif-badge {
    position: absolute;
    top: 4px;
    right: 4px;
    min-width: 17px;
    height: 17px;
    border-radius: 999px;
    background: #e53935;
    color: #fff;
    font-size: 9px;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 4px;
    border: 2px solid #fff;
    line-height: 1;
}

/* â”€â”€ User profile area â”€â”€ */
.nx-user-area {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
    padding-left: 4px;
}

.nx-user-info {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 1px;
}

.nx-user-name {
    font-size: 13px;
    font-weight: 700;
    color: #0a2540;
    white-space: nowrap;
    line-height: 1.2;
}

.nx-user-type {
    font-size: 10px;
    color: #7294ae;
    font-weight: 600;
    white-space: nowrap;
}

.nx-user-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: linear-gradient(135deg, #0a2540, #1565c0);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    flex-shrink: 0;
    border: 2px solid #e2eaf4;
    box-shadow: 0 2px 8px rgba(21,101,192,.18);
}

.nx-user-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.nx-user-avatar-icon {
    font-size: 15px;
    color: #fff;
}

.nx-signout-btn {
    width: 34px;
    height: 34px;
    border-radius: 10px;
    background: #fff4f4;
    border: 1px solid #fecaca;
    color: #dc2626;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    font-size: 14px;
    flex-shrink: 0;
    transition: background .15s, color .15s;
}

.nx-signout-btn:hover {
    background: #dc2626;
    color: #fff;
    border-color: #dc2626;
}

/* Navbar notifications modal */
.nx-notif-overlay {
    position: fixed;
    inset: 0;
    background: rgba(10, 37, 64, 0.35);
    backdrop-filter: blur(2px);
    z-index: 480;
}

.nx-notif-modal {
    position: fixed;
    top: 76px;
    right: 22px;
    width: min(430px, calc(100vw - 20px));
    max-height: min(72vh, 640px);
    border-radius: 16px;
    background: #fff;
    border: 1px solid #d9e6f3;
    box-shadow: 0 16px 40px rgba(10, 37, 64, 0.18);
    z-index: 490;
    display: flex;
    flex-direction: column;
    overflow: hidden;
}

.nx-notif-overlay[hidden],
.nx-notif-modal[hidden] {
    display: none !important;
}

.nx-notif-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    padding: 12px 14px;
    border-bottom: 1px solid #e6eef7;
    background: #f8fbff;
}

.nx-notif-head h3 {
    font-size: 14px;
    font-weight: 800;
    color: #0a2540;
}

.nx-notif-head p {
    font-size: 11px;
    color: #7294ae;
    margin-top: 2px;
}

.nx-notif-head-actions {
    display: flex;
    align-items: center;
    gap: 8px;
}

.nx-notif-read-btn {
    min-height: 30px;
    border-radius: 8px;
    border: 1px solid #c7dbef;
    background: #fff;
    color: #1565c0;
    padding: 0 10px;
    font-size: 11px;
    font-weight: 700;
    cursor: pointer;
}

.nx-notif-read-btn:hover {
    background: #eef6ff;
}

.nx-notif-close-btn {
    width: 30px;
    height: 30px;
    border-radius: 8px;
    border: 1px solid #d7e5f2;
    background: #fff;
    color: #5b80a0;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
}

.nx-notif-close-btn:hover {
    color: #1565c0;
    background: #eef6ff;
}

.nx-notif-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    overflow-y: auto;
    max-height: 460px;
}

.nx-notif-item {
    padding: 12px 14px;
    border-bottom: 1px solid #edf3fa;
    display: flex;
    flex-direction: column;
    gap: 6px;
}

.nx-notif-item.is-unread {
    background: linear-gradient(90deg, rgba(21, 101, 192, 0.06), rgba(21, 101, 192, 0));
}

.nx-notif-item-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 10px;
}

.nx-notif-item-top strong {
    font-size: 12px;
    font-weight: 800;
    color: #0a2540;
    line-height: 1.25;
}

.nx-notif-item-top span {
    font-size: 10px;
    color: #8aa7bf;
    white-space: nowrap;
}

.nx-notif-item p {
    font-size: 12px;
    color: #4f6f8a;
    line-height: 1.45;
}

.nx-notif-empty {
    min-height: 140px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    color: #8aa7bf;
}

.nx-notif-empty i {
    font-size: 20px;
}

.nx-notif-foot {
    border-top: 1px solid #e6eef7;
    padding: 10px 14px;
    background: #f8fbff;
}

.nx-notif-foot a {
    font-size: 12px;
    font-weight: 700;
    color: #1565c0;
    text-decoration: none;
}

.nx-notif-foot a:hover {
    text-decoration: underline;
}

/* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
   SECONDARY STRIP  (utility nav)
   â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
.nx-subnav {
    background: #fff;
    border-bottom: 1px solid #e2eaf4;
    padding: 0 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    height: 44px;
}

.nx-subnav-links {
    display: flex;
    align-items: center;
    gap: 2px;
}

.nx-subnav-link {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    border-radius: 8px;
    font-size: 12px;
    font-weight: 600;
    color: #7294ae;
    text-decoration: none;
    white-space: nowrap;
    transition: background .15s, color .15s;
}

.nx-subnav-link i { font-size: 12px; }

.nx-subnav-link:hover {
    background: #f0f6ff;
    color: #1565c0;
}

.nx-subnav-link-active {
    background: #eaf2fd;
    color: #1565c0;
    font-weight: 700;
}

/* Breadcrumb */
.nx-breadcrumb {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: #7294ae;
}

.nx-breadcrumb i.nx-bc-home { color: #1565c0; }
.nx-bc-sep { font-size: 9px; color: #b8cfe0; }
.nx-bc-active { color: #0a2540; font-weight: 700; }


/* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
   PAGE HEADER BANNER
   â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
.nx-page-banner {
    background: #fff;
    border-bottom: 1px solid #e2eaf4;
    padding: 20px 28px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
}

.nx-page-banner-left {
    display: flex;
    align-items: center;
    gap: 16px;
}

.nx-page-banner-icon {
    width: 50px;
    height: 50px;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    color: #fff;
    flex-shrink: 0;
    box-shadow: 0 8px 20px rgba(0,0,0,.15);
    background: var(--nx-accent, #1565c0);
    background: linear-gradient(135deg, var(--nx-accent-dark, #0a2540), var(--nx-accent, #1565c0));
}

.nx-page-banner-title {
