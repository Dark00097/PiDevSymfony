<script>
window.nxToggleAiChat = function () {
  const panel = document.getElementById('nx-ai-chat-panel');
  if (!panel) return;
  panel.hidden = !panel.hidden;
  panel.style.display = panel.hidden ? 'none' : 'flex';
};

(() => {
  const panel = document.getElementById('nx-ai-chat-panel');
  const toggle = document.getElementById('nx-ai-chat-toggle');
  const closeBtn = document.getElementById('nx-ai-chat-close');
  const themeBtn = document.getElementById('nx-ai-chat-theme');
  const form = document.getElementById('nx-ai-chat-form');
  const input = document.getElementById('nx-ai-chat-input');
  const thread = document.getElementById('nx-ai-chat-thread');
  const insights = document.getElementById('nx-ai-insights');
  const voiceBtn = document.getElementById('nx-ai-voice');
  if (!panel || !toggle || !form || !input || !thread || !insights) return;

  let mode = 'simulation';
  let lastMessageText = '';
  const addMsg = (role, text) => {
    const normalized = String(text || '').trim();
    if (!normalized) return;
    if (role === 'bot' && lastMessageText === normalized) return;
    if (role === 'bot') lastMessageText = normalized;
    const d = document.createElement('div');
    d.className = `nx-ai-msg ${role}`;
    d.textContent = normalized;
    thread.appendChild(d);
    thread.scrollTop = thread.scrollHeight;
  };
  const setTyping = (on) => {
    let node = document.getElementById('nx-ai-typing');
    if (on && !node) {
      node = document.createElement('div');
      node.id = 'nx-ai-typing';
      node.className = 'nx-ai-typing';
      node.textContent = 'AI is typing...';
      thread.appendChild(node);
    }
    if (!on && node) node.remove();
    thread.scrollTop = thread.scrollHeight;
  };
  const chip = (level) => {
    const v = String(level || '').toLowerCase();
    if (v.includes('low') || v.includes('appr')) return 'green';
    if (v.includes('high') || v.includes('reject')) return 'red';
    return 'orange';
  };
  const renderInsights = (data) => {
    insights.innerHTML = '';
    if (!data || data.hide_insights === true) return;
    const card = document.createElement('div');
    card.className = 'nx-ai-card';
    card.innerHTML = `
      <div style="display:flex;justify-content:space-between;gap:8px;align-items:center;">
        <strong style="font-size:12px;">Financial Snapshot</strong>
        <span class="nx-ai-chip ${chip(data.risk_level || data.decision)}">${data.decision || 'Review Needed'}</span>
      </div>
      <div style="margin-top:6px;font-size:11px;color:#42607a;">
        Score: ${data.score ?? '-'} /100 · Monthly: ${data.monthly_payment ?? '-'} DT · Risk: ${data.risk_level ?? '-'}
      </div>
      <div style="margin-top:6px;font-size:11px;color:#42607a;">Guarantee: ${data.guarantee_strength ?? '-'} · Coverage: ${data.coverage_percent ?? '-'}%</div>
    `;
    insights.appendChild(card);
    const recs = Array.isArray(data.recommendations) ? data.recommendations.slice(0, 3) : [];
    recs.forEach((r) => {
      const li = document.createElement('div');
      li.className = 'nx-ai-card';
      li.style.fontSize = '11px';
      li.textContent = `• ${r}`;
      insights.appendChild(li);
    });
  };

  const sendMessage = async (message) => {
    addMsg('user', message);
    setTyping(true);
    try {
      const res = await fetch('/api/chatbot/message', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message, mode })
      });
      const data = await res.json();
      setTyping(false);
      addMsg('bot', data.message || 'I could not process that request.');
      renderInsights(data);
    } catch (_) {
      setTyping(false);
      addMsg('bot', 'Service unavailable. Please retry or request human support.');
    }
  };

  const fmt = (n) => Number(n || 0).toLocaleString('fr-FR', { maximumFractionDigits: 2 });
  const callJson = async (url) => {
    const res = await fetch(url, { headers: { 'Accept': 'application/json' } });
    return res.json();
  };
  const handleAction = async (action) => {
    setTyping(true);
    try {
      if (action === 'my_credits') {
        mode = 'user_data';
        const data = await callJson('/api/user/credits');
        setTyping(false);
        const items = Array.isArray(data.items) ? data.items : [];
        if (items.length === 0) return addMsg('bot', 'Vous n’avez aucun dossier de crédit disponible.');
        const lines = items.map((x) => `- ${x.type} : ${fmt(x.amount)} DT – ${x.status}`);
        return addMsg('bot', `Voici vos dossiers de crédit :\n${lines.join('\n')}`);
      }
      if (action === 'my_guarantees') {
        mode = 'guarantee';
        const data = await callJson('/api/user/guarantees');
        setTyping(false);
        const items = Array.isArray(data.items) ? data.items : [];
        if (items.length === 0) return addMsg('bot', 'Vous n’avez aucune garantie enregistrée.');
        const lines = items.map((x) => `- ${x.type} : ${fmt(x.value)} DT`);
        return addMsg('bot', `Voici vos garanties disponibles :\n${lines.join('\n')}`);
      }
      if (action === 'my_simulations') {
        mode = 'simulation';
        const data = await callJson('/api/user/simulations');
        setTyping(false);
        const items = Array.isArray(data.items) ? data.items : [];
        if (items.length === 0) return addMsg('bot', 'Vous n’avez aucune simulation enregistrée.');
        const lines = items.map((x) => `- ${fmt(x.amount)} DT sur ${x.duration_months/12} ans : mensualité ${fmt(x.monthly_payment)} DT`);
        return addMsg('bot', `Voici vos dernières simulations :\n${lines.join('\n')}`);
      }
      if (action === 'analyze_profile') {
        mode = 'eligibility';
        const data = await callJson('/api/user/profile-analysis');
        setTyping(false);
        renderInsights(data);
        const advice = (Array.isArray(data.recommendations) && data.recommendations[0]) ? data.recommendations[0] : 'ajoutez une garantie immobilière pour améliorer votre score.';
        return addMsg('bot', `Analyse de votre dossier :\nScore : ${data.score ?? 0}/100\nRisque : ${data.risk_level ?? 'Moyen'}\nDécision : ${data.decision ?? 'À étudier'}\nConseil : ${advice}`);
      }
      if (action === 'improve_score') {
        mode = 'eligibility';
        setTyping(false);
        return addMsg('bot', 'Pour améliorer votre score, vous pouvez :\n- ajouter une garantie plus forte\n- réduire le montant du crédit\n- allonger la durée\n- ajouter un garant\n- diminuer vos dettes actuelles');
      }
      if (action === 'future_projection') {
        mode = 'projection';
        const data = await callJson('/api/user/future-projection');
        setTyping(false);
        if (!Array.isArray(data.timeline) || data.timeline.length === 0) {
          return addMsg('bot', data.message || 'Je n’ai pas assez de données pour faire une projection. Faites d’abord une simulation ou ajoutez un dossier de crédit.');
        }
        const t = data.timeline;
        return addMsg('bot', `Projection future de votre crédit :\n- ${t[0]?.label} : ${t[0]?.status ?? 'stable'}\n- ${t[1]?.label} : score estimé ${fmt(t[1]?.score)} /100\n- ${t[2]?.label} : capacité de remboursement améliorée\n- ${t[3]?.label} : risque faible si les paiements restent réguliers\n\nConseil IA :\n${data.advice || 'Gardez un taux d’endettement inférieur à 35% et ajoutez une garantie forte.'}`);
      }
      if (action === 'compare_banks') {
        mode = 'bank_comparison';
        const data = await callJson('/api/user/bank-comparison');
        setTyping(false);
        const rows = Array.isArray(data.table) ? data.table : [];
        if (rows.length === 0) {
          return addMsg('bot', 'Je ne peux pas comparer les banques sans dossier ou simulation. Faites d’abord une simulation.');
        }
        const best = data.best || rows[0];
        let tableTxt = 'Banque | Taux | Mensualité | Garantie demandée | Score compatibilité | Avis IA\n';
        tableTxt += rows.map((r) => `${r.bank} | ${r.rate}% | ${fmt(r.monthly)} DT | ${r.garantie} | ${r.compatibility} | ${r.opinion}`).join('\n');
        return addMsg('bot', `D’après votre profil, la meilleure banque pour votre crédit est : ${best.bank}.\n\nPourquoi ?\n- taux plus avantageux\n- mensualité plus faible\n- garantie compatible\n- meilleure chance d’acceptation\n\n${tableTxt}`);
      }
      setTyping(false);
    } catch (_) {
      setTyping(false);
      addMsg('bot', 'Erreur de chargement des données utilisateur.');
    }
  };

  const prefillFromAction = (action) => {
    const prompts = {
      my_credits: 'Montre-moi mes dossiers de credit.',
      my_guarantees: 'Montre-moi mes garanties.',
      analyze_profile: 'Analyse mon dossier de credit.',
      my_simulations: 'Montre-moi mes simulations recentes.',
      improve_score: 'Comment ameliorer mon score de credit ?',
      future_projection: 'Fais une projection future de mon credit.',
      compare_banks: 'Compare les banques selon mon profil.'
    };
    const text = prompts[action] || '';
    if (!text) return;
    input.value = text;
    input.focus();
  };

  toggle.addEventListener('click', () => {
    panel.hidden = !panel.hidden;
    panel.style.display = panel.hidden ? 'none' : 'flex';
  });
  const openByQuery = new URLSearchParams(window.location.search).get('panel') === 'ai_chat';
  panel.hidden = !openByQuery;
  panel.style.display = panel.hidden ? 'none' : 'flex';
  closeBtn?.addEventListener('click', () => { panel.hidden = true; panel.style.display = 'none'; });
  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const m = input.value.trim();
    if (!m) return;
    input.value = '';
    sendMessage(m);
  });
  document.querySelectorAll('[data-action]').forEach((b) => b.addEventListener('click', () => prefillFromAction(b.getAttribute('data-action') || '')));
  themeBtn?.addEventListener('click', () => panel.classList.toggle('dark'));

  const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
  if (!SR || !voiceBtn) { if (voiceBtn) voiceBtn.style.display = 'none'; }
  else {
    const rec = new SR();
    rec.lang = 'fr-FR';
    rec.onresult = (e) => { input.value = e.results[0][0].transcript || ''; };
    voiceBtn.addEventListener('click', () => rec.start());
  }
})();
</script>

