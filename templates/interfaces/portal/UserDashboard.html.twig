{# â”€â”€ Determine banner icon per tab â”€â”€ #}
{% set banner_icons = {
    dashboard:     'fa-chart-line',
    accounts:      'fa-wallet',
    transactions:  'fa-right-left',
    credits:       'fa-hand-holding-dollar',
    cashback:      'fa-hand-holding-heart',
    garanties:     'fa-shield-halved',
    complaints:    'fa-comment-dots',
    vaults:        'fa-lock',
    profile:       'fa-user-circle',
    notifications: 'fa-bell'
} %}

{% set banner_accent_dark = {
    dashboard:    '#0d47a1',
    accounts:     '#006064',
    transactions: '#4527a0',
    credits:      '#0d47a1',
    cashback:     '#004d40',
    garanties:    '#01579b',
    complaints:   '#7f1d1d',
    vaults:       '#14532d',
    profile:      '#1f2937',
    notifications:'#78350f'
} %}

<div class="nx-portal">

    {# â•â•â•â•â•â•â•â•â•â•â•â• TOP NAVBAR â•â•â•â•â•â•â•â•â•â•â•â• #}
    <nav class="nx-navbar">

        {# Brand #}
        <a class="nx-brand" href="{{ path(route_name, { tab: 'dashboard' }) }}">
            <div class="nx-brand-logo">
                {% if true %}
                    <img src="{{ asset('images/logo.png') }}" alt="Nexora" onerror="this.style.display='none';this.nextElementSibling.style.display='flex';">
                    <span class="nx-brand-logo-fallback" style="display:none">N</span>
                {% else %}
                    <span class="nx-brand-logo-fallback">N</span>
                {% endif %}
            </div>
            <div class="nx-brand-text">
                <div class="nx-brand-name">NEXORA</div>
                <div class="nx-brand-tagline" id="nx-brand-tagline">Banque privee</div>
            </div>
        </a>

        <div class="nx-nav-sep"></div>

        {# Primary navigation #}
        <nav class="nx-nav-primary">
            {% for item in tabs %}
                {% if item.key in primary_keys %}
                    <a class="nx-nav-link {{ item.key == tab ? 'nx-nav-link-active' : '' }}"
                       data-nav-key="{{ item.key }}"
                       href="{{ path(route_name, { tab: item.key }) }}">
                        <i class="fa-solid {{ nav_icons[item.key]|default('fa-circle') }}"></i>
                        <span class="nx-nav-link-label">{{ item.label }}</span>
                    </a>
                {% endif %}
            {% endfor %}
        </nav>

        {# Spacer #}
        <span style="flex:1; min-width:8px;"></span>

        {# Status chips #}
        <div class="nx-status-row">
            <span class="nx-chip nx-chip-secure">
                <i class="fa-solid fa-shield-halved"></i>
                <span id="nx-chip-secure-label">Securise</span>
            </span>
            <span class="nx-chip nx-chip-live">
                <span class="nx-pulse"></span>
                <span id="nx-chip-live-label">En ligne</span>
            </span>
        </div>

        <div class="nx-nav-sep"></div>

        {# Action buttons #}
        <div class="nx-nav-actions">
            <a class="nx-action-btn"
               href="{{ path(route_name, { tab: 'notifications' }) }}"
               id="nx-notif-toggle"
               data-nx-notif-toggle
               title="Notifications"
               aria-haspopup="dialog"
               aria-controls="nx-notif-modal"
               aria-expanded="false">
                <i class="fa-solid fa-bell"></i>
                {% set display_count = notifications|default([])|filter(n => n.type|default('') != 'AI_ANALYSIS' and n.is_read|default(1) in [0, '0', false])|length %}
                {% if display_count > 0 %}
                    <span class="nx-notif-badge">
                        {{ display_count > 99 ? '99+' : display_count }}
                    </span>
                {% endif %}
            </a>
            <a class="nx-action-btn"
               href="{{ path(route_name, { tab: 'profile' }) }}"
               id="nx-settings-btn"
               title="Parametres">
                <i class="fa-solid fa-cog"></i>
            </a>
        </div>

        <div class="nx-nav-sep"></div>

        {# User area #}
        <div class="nx-user-area">
            <div class="nx-user-info">
                <div class="nx-user-name">
                    {{ current_user.prenom }} {{ current_user.nom }}
                </div>
                <div class="nx-user-type" id="nx-user-type">Compte premium</div>
            </div>
            <div class="nx-user-avatar">
                {% if current_user.profile_image_path|default('') %}
                    <img src="{{ asset(current_user.profile_image_path) }}" alt="Photo profil">
                {% else %}
                    <i class="fa-solid fa-user nx-user-avatar-icon"></i>
                {% endif %}
            </div>
            <a class="nx-signout-btn" href="{{ path('logout') }}" id="nx-signout-btn" title="Deconnexion">
                <i class="fa-solid fa-right-from-bracket"></i>
            </a>
        </div>

    </nav>

    {# â•â•â•â•â•â•â•â•â•â•â• NAVBAR NOTIFICATIONS MODAL â•â•â•â•â•â•â•â•â•â•â• #}
    <div class="nx-notif-overlay" id="nx-notif-overlay" hidden></div>
    <section class="nx-notif-modal" id="nx-notif-modal" role="dialog" aria-modal="true" aria-labelledby="nx-notif-title" hidden>
        <header class="nx-notif-head">
            <div>
                <h3 id="nx-notif-title">Notifications</h3>
                <p>{{ notifications_count|default(0) }} non lue(s)</p>
            </div>
            <div class="nx-notif-head-actions">
                <form method="post" class="nx-notif-mark-form">
                    <input type="hidden" name="tab" value="{{ tab }}">
                    <input type="hidden" name="action" value="notifications_read">
                    <input type="hidden" name="panel" value="notifications">
                    <button class="nx-notif-read-btn" type="submit">Tout lire</button>
                </form>
                <button class="nx-notif-close-btn" id="nx-notif-close" type="button" aria-label="Fermer">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
        </header>

        <div class="nx-notif-list">
            {% set filtered_notifs = notifications|default([])|filter(n => n.type|default('') != 'AI_ANALYSIS') %}
            {% for item in filtered_notifs %}
                {% set unread = item.is_read|default(1) in [0, '0', false] %}
                <article class="nx-notif-item {{ unread ? 'is-unread' : '' }}">
                    <div class="nx-notif-item-top">
                        <strong>{{ item.title|default('Notification') }}</strong>
                        <span>{{ item.created_at|default('') }}</span>
                    </div>
                    <p>{{ item.message|default('Vous avez une nouvelle notification.') }}</p>
                </article>
            {% else %}
                <div class="nx-notif-empty">
                    <i class="fa-solid fa-bell-slash"></i>
                    <span>Aucune notification.</span>
                </div>
            {% endfor %}
        </div>

        <footer class="nx-notif-foot">
            <a href="{{ path(route_name, { tab: 'notifications' }) }}">Voir toutes les notifications</a>
        </footer>
    </section>

    {# â•â•â•â•â•â•â•â•â•â•â•â• FLASH MESSAGES â•â•â•â•â•â•â•â•â•â•â•â• #}
    <div class="nx-flashes" id="nx-flashes">
        {% for type, messages in app.flashes(['success', 'error', 'warning', 'info']) %}
            {% for message in messages %}
                {% set flash_icons = {
                    success: 'fa-circle-check',
                    error:   'fa-circle-xmark',
                    warning: 'fa-triangle-exclamation',
                    info:    'fa-circle-info'
                } %}
                <div class="nx-alert nx-alert-{{ type }}" role="alert">
                    <i class="fa-solid {{ flash_icons[type]|default('fa-info') }}"></i>
                    <span>{{ message }}</span>
                    <button onclick="this.closest('.nx-alert').remove()"
                            style="margin-left:auto; background:none; border:none; cursor:pointer;
                                   color:inherit; font-size:13px; opacity:.6; padding:2px 4px;"
                            type="button" aria-label="Fermer">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                </div>
            {% endfor %}
        {% endfor %}
    </div>

    {# â•â•â•â•â•â•â•â•â•â•â•â• MAIN CONTENT â•â•â•â•â•â•â•â•â•â•â•â• #}
    <main class="nx-content">
        {% include tab_template %}
    </main>

    {# â•â•â•â•â•â•â•â•â•â•â•â• MOBILE BOTTOM NAV â•â•â•â•â•â•â•â•â•â•â•â• #}
    <nav class="nx-mobile-nav" aria-label="Navigation mobile">
        <div class="nx-mobile-nav-inner">
            {% for item in tabs %}
                {% if item.key in primary_keys %}
                    <a class="nx-mobile-nav-link {{ item.key == tab ? 'nx-mobile-nav-link-active' : '' }}"
                       href="{{ path(route_name, { tab: item.key }) }}">
                        <i class="fa-solid {{ nav_icons[item.key]|default('fa-circle') }}"></i>
                        <span>{{ item.label|slice(0, 7) }}</span>
                    </a>
                {% endif %}
            {% endfor %}
            <a class="nx-mobile-nav-link {{ tab == 'profile' ? 'nx-mobile-nav-link-active' : '' }}"
               href="{{ path(route_name, { tab: 'profile' }) }}">
                <i class="fa-solid fa-user-circle"></i>
                <span>Profil</span>
            </a>
        </div>
    </nav>

</div>

{# â•â•â•â•â•â•â•â•â•â•â•â• INLINE SCRIPTS â•â•â•â•â•â•â•â•â•â•â•â• #}
<script>
(function () {
    'use strict';

    /* â”€â”€ Live clock â”€â”€ */
    const timeEl = document.getElementById('nx-live-time');

    const tick = () => {
        if (!timeEl) return;
        const now = new Date();
        const hh  = String(now.getHours()).padStart(2, '0');
        const mm  = String(now.getMinutes()).padStart(2, '0');
        const ss  = String(now.getSeconds()).padStart(2, '0');
        timeEl.textContent = `${hh}:${mm}:${ss}`;
    };

    tick();
    setInterval(tick, 1000);

    /* â”€â”€ Auto-dismiss flash messages after 6 s â”€â”€ */
    const flashes = document.querySelectorAll('.nx-alert');
    flashes.forEach((alert) => {
        setTimeout(() => {
            alert.style.transition = 'opacity .5s, max-height .5s, margin .5s, padding .5s';
            alert.style.opacity = '0';
            alert.style.maxHeight = '0';
            alert.style.overflow = 'hidden';
            alert.style.marginBottom = '0';
            alert.style.padding = '0';
            setTimeout(() => alert.remove(), 520);
        }, 6000);
    });

    /* â”€â”€ Keyboard shortcut: Alt+D â†’ Dashboard â”€â”€ */
    /* Navbar notifications modal */
    const notifToggle = document.getElementById('nx-notif-toggle');
    const notifModal = document.getElementById('nx-notif-modal');
    const notifOverlay = document.getElementById('nx-notif-overlay');
    const notifClose = document.getElementById('nx-notif-close');

    const updatePanelParam = (value) => {
        const url = new URL(window.location.href);
        if (value) {
            url.searchParams.set('panel', value);
        } else {
            url.searchParams.delete('panel');
        }
        const query = url.searchParams.toString();
        window.history.replaceState({}, '', url.pathname + (query ? `?${query}` : ''));
    };

    const openNotifModal = () => {
        if (!notifModal || !notifOverlay) return;
        notifModal.hidden = false;
        notifOverlay.hidden = false;
        notifToggle?.classList.add('is-active');
        notifToggle?.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
        updatePanelParam('notifications');
    };

    const closeNotifModal = () => {
        if (!notifModal || !notifOverlay) return;
        notifModal.hidden = true;
        notifOverlay.hidden = true;
        notifToggle?.classList.remove('is-active');
        notifToggle?.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
        updatePanelParam('');
    };

    notifToggle?.addEventListener('click', (event) => {
        event.preventDefault();
        if (!notifModal) return;
        if (notifModal.hidden) {
            openNotifModal();
        } else {
            closeNotifModal();
        }
    });

    notifClose?.addEventListener('click', closeNotifModal);
    notifOverlay?.addEventListener('click', closeNotifModal);

    if (new URLSearchParams(window.location.search).get('panel') === 'notifications') {
        openNotifModal();
    }

    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && notifModal && !notifModal.hidden) {
            closeNotifModal();
            return;
        }
        if (e.altKey && e.key === 'd') {
            const brand = document.querySelector('.nx-brand');
            if (brand) brand.click();
        }
    });

    const portalLanguageCatalog = {
        fr: {
            brandTagline: 'Banque privee',
            secure: 'Securise',
            online: 'En ligne',
            premium: 'Compte premium',
            notifications: 'Notifications',
            settings: 'Parametres',
            logout: 'Deconnexion',
            nav: {
                dashboard: 'Dashboard',
                accounts: 'Comptes',
                transactions: 'Transactions',
                credits: 'Credits',
                cashback: 'Recompenses',
                garanties: 'Garanties',
                complaints: 'Reclamations',
                vaults: 'Coffres',
                profile: 'Profil',
                notifications: 'Notifications'
            }
        },
        en: {
            brandTagline: 'Private bank',
            secure: 'Secure',
            online: 'Online',
            premium: 'Premium account',
            notifications: 'Notifications',
            settings: 'Settings',
            logout: 'Sign out',
            nav: {
                dashboard: 'Dashboard',
                accounts: 'Accounts',
                transactions: 'Transactions',
                credits: 'Loans',
                cashback: 'Rewards',
                garanties: 'Guarantees',
                complaints: 'Complaints',
                vaults: 'Vaults',
                profile: 'Profile',
                notifications: 'Notifications'
            }
        },
        ar: {
            brandTagline: 'بنك خاص',
            secure: 'آمن',
            online: 'متصل',
            premium: 'حساب مميز',
            notifications: 'الإشعارات',
            settings: 'الإعدادات',
            logout: 'تسجيل الخروج',
            nav: {
                dashboard: 'لوحة التحكم',
                accounts: 'الحسابات',
                transactions: 'المعاملات',
                credits: 'القروض',
                cashback: 'المكافآت',
                garanties: 'الضمانات',
                complaints: 'الشكاوى',
                vaults: 'الخزائن',
                profile: 'الملف الشخصي',
                notifications: 'الإشعارات'
            }
        }
    };

    const resolvePortalLanguage = (language) => Object.prototype.hasOwnProperty.call(portalLanguageCatalog, language) ? language : 'fr';
    const applyPortalChromeLanguage = (language) => {
        const currentLanguage = resolvePortalLanguage(String(language ?? '').toLowerCase().trim());
        const dict = portalLanguageCatalog[currentLanguage];

        const brandTagline = document.getElementById('nx-brand-tagline');
        const chipSecure = document.getElementById('nx-chip-secure-label');
        const chipLive = document.getElementById('nx-chip-live-label');
        const userType = document.getElementById('nx-user-type');
        const signoutBtn = document.getElementById('nx-signout-btn');
        const settingsBtn = document.getElementById('nx-settings-btn');

        if (brandTagline) brandTagline.textContent = dict.brandTagline;
        if (chipSecure) chipSecure.textContent = dict.secure;
        if (chipLive) chipLive.textContent = dict.online;
        if (userType) userType.textContent = dict.premium;
        if (notifToggle) notifToggle.title = dict.notifications;
        if (settingsBtn) settingsBtn.title = dict.settings;
        if (signoutBtn) signoutBtn.title = dict.logout;

        document.querySelectorAll('[data-nav-key]').forEach((link) => {
            const key = link.getAttribute('data-nav-key') || '';
            const label = link.querySelector('.nx-nav-link-label');
            if (label && dict.nav[key]) {
                label.textContent = dict.nav[key];
            }
        });
    };

    const storedPortalLanguage = window.localStorage.getItem('nexora.portal.credits.language');
    applyPortalChromeLanguage(storedPortalLanguage);

    window.addEventListener('storage', (event) => {
        if (event.key === 'nexora.portal.credits.language') {
            applyPortalChromeLanguage(event.newValue);
        }
    });

    window.addEventListener('nexora:portal-language-change', (event) => {
        applyPortalChromeLanguage(event.detail?.language);
    });

})();
</script>

{% endblock %}

