<script>
(function () {
    'use strict';

    /* â”€â”€ Live clock â”€â”€ */
    const timeEl = document.getElementById('nx-live-time');

    const tick = () => {
        if (!timeEl) return;
        const now = new Date();
        const hh  = String(now.getHours()).padStart(2, '0');
        const mm  = String(now.getMinutes()).padStart(2, '0');
        const ss  = String(now.getSeconds()).padStart(2, '0');
        timeEl.textContent = `${hh}:${mm}:${ss}`;
    };

    tick();
    setInterval(tick, 1000);

    /* â”€â”€ Auto-dismiss flash messages after 6 s â”€â”€ */
    const flashes = document.querySelectorAll('.nx-alert');
    flashes.forEach((alert) => {
        setTimeout(() => {
            alert.style.transition = 'opacity .5s, max-height .5s, margin .5s, padding .5s';
            alert.style.opacity = '0';
            alert.style.maxHeight = '0';
            alert.style.overflow = 'hidden';
            alert.style.marginBottom = '0';
            alert.style.padding = '0';
            setTimeout(() => alert.remove(), 520);
        }, 6000);
    });

    /* â”€â”€ Keyboard shortcut: Alt+D â†’ Dashboard â”€â”€ */
    /* Navbar notifications modal */
    const notifToggle = document.getElementById('nx-notif-toggle');
    const notifModal = document.getElementById('nx-notif-modal');
    const notifOverlay = document.getElementById('nx-notif-overlay');
    const notifClose = document.getElementById('nx-notif-close');

    const updatePanelParam = (value) => {
        const url = new URL(window.location.href);
        if (value) {
            url.searchParams.set('panel', value);
        } else {
            url.searchParams.delete('panel');
        }
        const query = url.searchParams.toString();
        window.history.replaceState({}, '', url.pathname + (query ? `?${query}` : ''));
    };

    const openNotifModal = () => {
        if (!notifModal || !notifOverlay) return;
        notifModal.hidden = false;
        notifOverlay.hidden = false;
        notifToggle?.classList.add('is-active');
        notifToggle?.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
        updatePanelParam('notifications');
    };

    const closeNotifModal = () => {
        if (!notifModal || !notifOverlay) return;
        notifModal.hidden = true;
        notifOverlay.hidden = true;
        notifToggle?.classList.remove('is-active');
        notifToggle?.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
        updatePanelParam('');
    };

    notifToggle?.addEventListener('click', (event) => {
        event.preventDefault();
        if (!notifModal) return;
        if (notifModal.hidden) {
            openNotifModal();
        } else {
            closeNotifModal();
        }
    });

    notifClose?.addEventListener('click', closeNotifModal);
    notifOverlay?.addEventListener('click', closeNotifModal);

    if (new URLSearchParams(window.location.search).get('panel') === 'notifications') {
        openNotifModal();
    }

    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && notifModal && !notifModal.hidden) {
            closeNotifModal();
            return;
        }
        if (e.altKey && e.key === 'd') {
            const brand = document.querySelector('.nx-brand');
            if (brand) brand.click();
        }
    });

    const portalLanguageCatalog = {
        fr: {
            brandTagline: 'Banque privee',
            secure: 'Securise',
            online: 'En ligne',
            premium: 'Compte premium',
            notifications: 'Notifications',
            settings: 'Parametres',
            logout: 'Deconnexion',
            nav: {
                dashboard: 'Dashboard',
                accounts: 'Comptes',
                transactions: 'Transactions',
                credits: 'Credits',
                cashback: 'Recompenses',
                support: 'Support',
                garanties: 'Garanties',
                complaints: 'Reclamations',
                vaults: 'Coffres',
                profile: 'Profil',
                notifications: 'Notifications'
            }
        },
        en: {
            brandTagline: 'Private bank',
            secure: 'Secure',
            online: 'Online',
            premium: 'Premium account',
            notifications: 'Notifications',
            settings: 'Settings',
            logout: 'Sign out',
            nav: {
                dashboard: 'Dashboard',
                accounts: 'Accounts',
                transactions: 'Transactions',
                credits: 'Loans',
                cashback: 'Rewards',
                support: 'Support',
                garanties: 'Guarantees',
                complaints: 'Complaints',
                vaults: 'Vaults',
                profile: 'Profile',
                notifications: 'Notifications'
            }
        },
        ar: {
            brandTagline: 'بنك خاص',
            secure: 'آمن',
            online: 'متصل',
            premium: 'حساب مميز',
            notifications: 'الإشعارات',
            settings: 'الإعدادات',
            logout: 'تسجيل الخروج',
            nav: {
                dashboard: 'لوحة التحكم',
                accounts: 'الحسابات',
                transactions: 'المعاملات',
                credits: 'القروض',
                cashback: 'المكافآت',
                garanties: 'الضمانات',
                complaints: 'الشكاوى',
                vaults: 'الخزائن',
                profile: 'الملف الشخصي',
                notifications: 'الإشعارات'
            }
        }
    };

    const resolvePortalLanguage = (language) => Object.prototype.hasOwnProperty.call(portalLanguageCatalog, language) ? language : 'fr';
    const applyPortalChromeLanguage = (language) => {
        const currentLanguage = resolvePortalLanguage(String(language ?? '').toLowerCase().trim());
        const dict = portalLanguageCatalog[currentLanguage];

        const brandTagline = document.getElementById('nx-brand-tagline');
        const chipSecure = document.getElementById('nx-chip-secure-label');
        const chipLive = document.getElementById('nx-chip-live-label');
        const userType = document.getElementById('nx-user-type');
        const signoutBtn = document.getElementById('nx-signout-btn');
        const settingsBtn = document.getElementById('nx-settings-btn');

        if (brandTagline) brandTagline.textContent = dict.brandTagline;
        if (chipSecure) chipSecure.textContent = dict.secure;
        if (chipLive) chipLive.textContent = dict.online;
        if (userType) userType.textContent = dict.premium;
        if (notifToggle) notifToggle.title = dict.notifications;
        if (settingsBtn) settingsBtn.title = dict.settings;
        if (signoutBtn) signoutBtn.title = dict.logout;

        document.querySelectorAll('[data-nav-key]').forEach((link) => {
            const key = link.getAttribute('data-nav-key') || '';
            const label = link.querySelector('.nx-nav-link-label');
            if (label && dict.nav[key]) {
                label.textContent = dict.nav[key];
            }
        });
    };

    const storedPortalLanguage = window.localStorage.getItem('nexora.portal.credits.language');
    applyPortalChromeLanguage(storedPortalLanguage);

    window.addEventListener('storage', (event) => {
        if (event.key === 'nexora.portal.credits.language') {
            applyPortalChromeLanguage(event.newValue);
        }
    });

    window.addEventListener('nexora:portal-language-change', (event) => {
        applyPortalChromeLanguage(event.detail?.language);
    });

})();
</script>

