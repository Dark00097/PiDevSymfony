                            <option value="week">Cette semaine</option>
                            <option value="month" selected>Ce mois</option>
                            <option value="all">Toute période</option>
                        </select>
                    </div>

                    <div class="cashback-list" id="cashbackList">
                        {% for entry in cashback_data.recent_entries %}
                        <div class="cashback-item">
                            <div class="cashback-item-icon">
                                <i class="fas fa-{{ entry.icon|default('shopping-cart') }} cashback-item-icon-glyph"></i>
                            </div>
                            <div class="cashback-item-content">
                                <h4 class="cashback-item-title">{{ entry.partner_name }}</h4>
                                <p class="cashback-item-subtitle">{{ entry.purchase_amount|number_format(2, ',', ' ') }} DT • {{ entry.date_achat|date('d/m/Y') }}</p>
                                <div class="cashback-item-meta">
                                    <span>Taux: {{ entry.taux_applique }}%</span>
                                    <span>Ref: {{ entry.transaction_ref ?: 'N/A' }}</span>
                                </div>
                            </div>
                            <div style="text-align: right;">
                                <p class="cashback-item-value">+{{ entry.montant_cashback|number_format(2, ',', ' ') }} DT</p>
                                <span class="cashback-item-status status-{{ entry.status_css }}">{{ entry.status_label }}</span>
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Flash Messages -->
{% for message in app.flashes('success') %}
<div class="alert alert-success" style="position: fixed; top: 20px; right: 20px; z-index: 1000; padding: 12px 16px; background: #D1FAE5; border: 1px solid #10B981; border-radius: 8px; color: #065F46;">
    {{ message }}
</div>
{% endfor %}

{% for message in app.flashes('error') %}
<div class="alert alert-error" style="position: fixed; top: 20px; right: 20px; z-index: 1000; padding: 12px 16px; background: #FEE2E2; border: 1px solid #EF4444; border-radius: 8px; color: #991B1B;">
    {{ message }}
</div>
{% endfor %}
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
// Real-time cashback calculation
document.getElementById('purchaseAmount').addEventListener('input', calculateCashback);
document.getElementById('partnerSelection').addEventListener('change', updatePartnerRate);
document.getElementById('appliedRate').addEventListener('input', calculateCashback);

function updatePartnerRate() {
    const partnerSelect = document.getElementById('partnerSelection');
    const selectedOption = partnerSelect.options[partnerSelect.selectedIndex];
    const rating = parseFloat(selectedOption.getAttribute('data-rating') || 0);
    const maxRate = parseFloat(selectedOption.getAttribute('data-max-rate') || 5.0);

    // Calculate rate based on partner rating (0-5 scale)
    const baseRate = Math.min(maxRate, 5.0 + (rating / 5.0) * 2.5);
    document.getElementById('appliedRate').value = baseRate.toFixed(2);

    calculateCashback();
}

function calculateCashback() {
    const purchaseAmount = parseFloat(document.getElementById('purchaseAmount').value) || 0;
    const appliedRate = parseFloat(document.getElementById('appliedRate').value) || 0;

    const cashbackAmount = (purchaseAmount * appliedRate / 100);
    document.getElementById('cashbackAmount').value = cashbackAmount.toFixed(2);
    document.getElementById('estimatedCashback').textContent = '+' + cashbackAmount.toFixed(2) + ' DT';
}

function clearCashbackForm() {
    document.getElementById('partnerSelection').selectedIndex = 0;
    document.getElementById('purchaseAmount').value = '';
    document.getElementById('purchaseDate').value = '';
    document.getElementById('appliedRate').value = '5.0';
    document.getElementById('cashbackAmount').value = '0.00';
    document.getElementById('transactionRef').value = '';
    document.getElementById('estimatedCashback').textContent = '+0.00 DT';
}

function recordCashback() {
    const formData = new FormData();
    formData.append('partner_id', document.getElementById('partnerSelection').value);
    formData.append('purchase_amount', document.getElementById('purchaseAmount').value);
    formData.append('purchase_date', document.getElementById('purchaseDate').value);
    formData.append('applied_rate', document.getElementById('appliedRate').value);
    formData.append('transaction_ref', document.getElementById('transactionRef').value);

    fetch('{{ path("app_portal_cashback_record") }}', {
        method: 'POST',
        body: formData,
        headers: {
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            // Refresh the page or update the list
            location.reload();
        } else {
            alert('Erreur: ' + data.message);
        }
    })
    .catch(error => {
        console.error('Error:', error);
        alert('Une erreur est survenue');
    });
}

function analyzeCashbackAI() {
    const button = document.querySelector('.cashback-ai-btn');
    const originalText = button.textContent;
    button.textContent = 'Analyse en cours...';
    button.disabled = true;

    fetch('{{ path("app_portal_cashback_ai_analyze") }}', {
        method: 'POST',
        headers: {
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => response.json())
    .then(data => {
        document.getElementById('cashbackAIOutput').value = data.analysis;
        document.getElementById('cashbackAIUpdated').textContent = 'Mis à jour: ' + new Date().toLocaleString('fr-FR');
        button.textContent = originalText;
        button.disabled = false;
    })
    .catch(error => {
        console.error('Error:', error);
        button.textContent = originalText;
        button.disabled = false;
        alert('Erreur lors de l\'analyse IA');
    });
}

function showAddPartnerModal() {
    // TODO: Implement add partner modal
    alert('Fonctionnalité à venir: Ajouter un partenaire');
}

// Period filter functionality
document.getElementById('periodFilter').addEventListener('change', function() {
    const period = this.value;
    // TODO: Implement period filtering via AJAX
    console.log('Filtering by period:', period);
});

// Initialize calculations on page load
document.addEventListener('DOMContentLoaded', function() {
    calculateCashback();
});
</script>
{% endblock %}