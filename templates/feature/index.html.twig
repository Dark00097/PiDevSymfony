{% extends 'base.html.twig' %}
{% block title %}Nexora Features{% endblock %}
{% block body_class %}dashboard-body{% endblock %}
{% block body %}
<div class="dashboard-shell">
    <aside class="sidebar">
        <div class="sidebar-brand">
            <img src="{{ asset('images/logo.png') }}" alt="Nexora logo">
            <div>
                <span>NEXORA</span>
                <small>{{ mode == 'admin' ? 'Admin Feature Hub' : 'Client Feature Hub' }}</small>
            </div>
        </div>
        <nav class="sidebar-nav">
            <a class="sidebar-link" href="{{ path(dashboard_route) }}">Main Dashboard</a>
            {% for item in sections %}
                <a class="sidebar-link {{ item.key == section ? 'is-active' : '' }}" href="{{ path(feature_route, { section: item.key }) }}">{{ item.label }}</a>
            {% endfor %}
        </nav>
        <div class="sidebar-footer">
            <div class="sidebar-user">
                <strong>{{ current_user.prenom }} {{ current_user.nom }}</strong>
                <span>{{ current_user.role }}</span>
            </div>
            <a class="btn btn-secondary btn-full" href="{{ path('logout') }}">Deconnexion</a>
        </div>
    </aside>

    <main class="dashboard-main">
        <header class="topbar">
            <div>
                <p class="eyebrow">{{ mode == 'admin' ? 'Administration' : 'Client Portal' }}</p>
                <h1>{{ section|replace({'_': ' '})|title }}</h1>
            </div>
            <div class="topbar-meta">
                <span class="notif-pill">{{ notifications_count }} notifications</span>
                <span class="topbar-role">{{ current_user.email }}</span>
            </div>
        </header>

        {% include '_flashes.html.twig' %}

        {% if mode == 'admin' and section == 'security' %}
            <section class="panel-grid">
                <article class="panel-card">
                    <h2>Security Controls</h2>
                    <p class="muted-copy">Stored in {{ settings_file }}</p>
                    <form method="post" class="editor-form">
                        <input type="hidden" name="action" value="save_security_settings">
                        <label><span>Biometric on admin login</span><select name="require_biometric_on_admin_login"><option value="1" {{ settings.require_biometric_on_admin_login ? 'selected' : '' }}>Enabled</option><option value="0" {{ not settings.require_biometric_on_admin_login ? 'selected' : '' }}>Disabled</option></select></label>
                        <label><span>Biometric on sensitive actions</span><select name="require_biometric_on_sensitive_actions"><option value="1" {{ settings.require_biometric_on_sensitive_actions ? 'selected' : '' }}>Enabled</option><option value="0" {{ not settings.require_biometric_on_sensitive_actions ? 'selected' : '' }}>Disabled</option></select></label>
                        <label><span>Email OTP</span><select name="enable_email_otp"><option value="1" {{ settings.enable_email_otp ? 'selected' : '' }}>Enabled</option><option value="0" {{ not settings.enable_email_otp ? 'selected' : '' }}>Disabled</option></select></label>
                        <button class="btn btn-primary" type="submit">Save security settings</button>
                    </form>
                </article>
                <article class="panel-card">
                    <h2>Admin Profile</h2>
                    <form method="post" class="editor-form">
                        <input type="hidden" name="action" value="save_admin_profile">
                        <label><span>Nom</span><input type="text" name="nom" value="{{ current_user.nom }}" required></label>
                        <label><span>Prenom</span><input type="text" name="prenom" value="{{ current_user.prenom }}" required></label>
                        <label><span>Email</span><input type="email" name="email" value="{{ current_user.email }}" required></label>
                        <label><span>Telephone</span><input type="text" name="telephone" value="{{ current_user.telephone }}" required></label>
                        <label><span>Biometric profile flag</span><select name="biometric_enabled"><option value="1" {{ current_user.biometric_enabled ? 'selected' : '' }}>Enabled</option><option value="0" {{ not current_user.biometric_enabled ? 'selected' : '' }}>Disabled</option></select></label>
                        <button class="btn btn-primary" type="submit">Save profile</button>
                    </form>
                    <hr class="divider">
                    <form method="post" class="editor-form">
                        <input type="hidden" name="action" value="change_admin_password">
                        <label><span>Current password</span><input type="password" name="current_password" required></label>
                        <label><span>New password</span><input type="password" name="new_password" required></label>
                        <label><span>Confirm password</span><input type="password" name="confirm_password" required></label>
                        <button class="btn btn-primary" type="submit">Change password</button>
                    </form>
                </article>
            </section>
            <section class="panel-card">
                <h2>Recent Notifications</h2>
                <div class="notification-list">
                    {% for item in notifications %}
                        <div class="notification-item"><strong>{{ item.title }}</strong><p>{{ item.message }}</p><small>{{ item.created_at }}</small></div>
                    {% else %}
                        <p>No notifications.</p>
                    {% endfor %}
                </div>
            </section>
        {% endif %}

        {% if mode == 'admin' and section == 'statistics' %}
            <section class="summary-grid">
                {% for card in statistics.user_management.headline %}
                    <article class="summary-card"><strong>{{ card.value }}</strong><span>{{ card.label }}</span></article>
                {% endfor %}
            </section>
            {% for key, block in statistics %}
                <section class="panel-grid">
                    <article class="panel-card">
                        <h2>{{ key|replace({'_': ' '})|title }}</h2>
                        <div class="bar-list">
                            {% for bar in block.bars %}
                                <div class="bar-item">
                                    <div class="bar-head"><strong>{{ bar.label }}</strong><span>{{ bar.value }}</span></div>
                                    <div class="bar-track"><span style="width: {{ bar.percent }}%"></span></div>
                                </div>
                            {% endfor %}
                        </div>
                    </article>
                    <article class="panel-card">
                        <h2>Recent Activity</h2>
                        <div class="notification-list">
                            {% for item in block.recent %}
                                <div class="notification-item"><strong>{{ item.title }}</strong><p>{{ item.meta }}</p></div>
                            {% endfor %}
                        </div>
                    </article>
                </section>
            {% endfor %}
        {% endif %}

        {% if mode == 'portal' and section == 'insights' %}
            <section class="summary-grid">
                <article class="summary-card"><strong>{{ security_analysis.score }}/100</strong><span>Security score</span></article>
                <article class="summary-card"><strong>{{ prediction.savings_score }}/100</strong><span>Savings score</span></article>
                <article class="summary-card"><strong>{{ prediction.total_predicted_spending|number_format(2, '.', ' ') }}</strong><span>Predicted spending</span></article>
                <article class="summary-card"><strong>{{ surplus.surplus|number_format(2, '.', ' ') }}</strong><span>Monthly surplus</span></article>
            </section>
            <section class="panel-grid">
                <article class="panel-card">
                    <div class="panel-header"><h2>Account Security Analysis</h2><a class="btn btn-secondary" href="{{ path('portal_feature_analysis_download') }}">Download report</a></div>
                    <p>{{ security_analysis.summary }}</p>
                    <div class="feature-list">{% for item in security_analysis.sections %}<div><strong>{{ item.title }}</strong><p>{{ item.text }}</p></div>{% endfor %}</div>
                    <form method="post"><input type="hidden" name="action" value="secure_account"><button class="btn btn-primary" type="submit">Secure my account</button></form>
                </article>
                <article class="panel-card">
                    <h2>Spending Prediction</h2>
                    <p>{{ prediction.summary }}</p>
                    <div class="table-wrap">
                        <table class="data-table"><thead><tr><th>Category</th><th>Prediction</th></tr></thead><tbody>{% for item in prediction.predictions %}<tr><td>{{ item.category }}</td><td>{{ item.predicted_amount|number_format(2, '.', ' ') }} DT</td></tr>{% else %}<tr><td colspan="2">No forecast data available.</td></tr>{% endfor %}</tbody></table>
                    </div>
                    <div class="feature-list">{% for tip in prediction.conseils %}<div>{{ tip }}</div>{% endfor %}</div>
                </article>
            </section>
            <section class="panel-grid">
                <article class="panel-card"><h2>Account Advisor</h2><p>{{ account_advice.summary }}</p><div class="feature-list">{% for item in account_advice.action_items %}<div>{{ item }}</div>{% endfor %}</div></article>
                <article class="panel-card"><h2>Cashback Advisor</h2><p>{{ cashback_advice.summary }}</p><div class="feature-list">{% for item in cashback_advice.recommended_partners %}<div><strong>{{ item.name }}</strong><p>{{ item.category }} | {{ item.rating }}/5</p><small>{{ item.reason }}</small></div>{% endfor %}</div></article>
            </section>
            <section class="panel-grid">
                <article class="panel-card">
                    <h2>Translations</h2>
                    <form method="post" class="editor-form">
                        <input type="hidden" name="action" value="translate_labels">
                        <label><span>Language</span><select name="translation_language"><option value="en" {{ translation.language == 'en' ? 'selected' : '' }}>English</option><option value="fr" {{ translation.language == 'fr' ? 'selected' : '' }}>Francais</option><option value="ar" {{ translation.language == 'ar' ? 'selected' : '' }}>Arabic</option></select></label>
                        <button class="btn btn-secondary" type="submit">Apply translation</button>
                    </form>
                    <div class="table-wrap"><table class="data-table"><thead><tr><th>Key</th><th>Value</th></tr></thead><tbody>{% for key, value in translation.labels %}<tr><td>{{ key }}</td><td>{{ value }}</td></tr>{% endfor %}</tbody></table></div>
                </article>
                <article class="panel-card">
                    <h2>Monthly Surplus</h2>
                    <p>{{ surplus.message }}</p>
                    <div class="feature-list"><div><strong>Current income</strong><p>{{ surplus.current_income|number_format(2, '.', ' ') }} DT</p></div><div><strong>Average income</strong><p>{{ surplus.average_income|number_format(2, '.', ' ') }} DT</p></div></div>
                    {% if surplus.show %}<form method="post"><input type="hidden" name="action" value="ack_surplus"><input type="hidden" name="month" value="{{ surplus.month }}"><button class="btn btn-primary" type="submit">Acknowledge suggestion</button></form>{% endif %}
                </article>
            </section>
            <section class="panel-grid">
                <article class="panel-card">
                    <h2>Voice Note to Account Fields</h2>
                    <form method="post" class="editor-form">
                        <input type="hidden" name="action" value="parse_account_note">
                        <label class="wide"><span>Speech text</span><textarea name="speech_text" rows="5" class="form-textarea" placeholder="Create savings account CB-77 with balance 1200, withdrawal 300, transfer 500">{{ app.request.request.get('speech_text') }}</textarea></label>
                        <button class="btn btn-secondary" type="button" data-speech-fill="speech_text">Use browser speech</button>
                        <button class="btn btn-primary" type="submit">Parse note</button>
                    </form>
                    {% if view_state.parsed_account %}<div class="table-wrap"><table class="data-table"><tbody>{% for key, value in view_state.parsed_account %}<tr><th>{{ key }}</th><td>{{ value }}</td></tr>{% endfor %}</tbody></table></div>{% endif %}
                </article>
                <article class="panel-card">
                    <h2>Complaint Improver</h2>
                    <form method="post" class="editor-form">
                        <input type="hidden" name="action" value="improve_reclamation">
                        <label class="wide"><span>Raw complaint</span><textarea name="raw_reclamation" rows="5" class="form-textarea" placeholder="Describe the issue">{{ app.request.request.get('raw_reclamation') }}</textarea></label>
                        <button class="btn btn-primary" type="submit">Improve complaint</button>
                    </form>
                    {% if view_state.improved_reclamation %}<div class="feature-list"><div><strong>Sentiment</strong><p>{{ view_state.improved_reclamation.sentiment }} | {{ view_state.improved_reclamation.severity }}</p></div><div><strong>Improved text</strong><p>{{ view_state.improved_reclamation.improved }}</p></div></div>{% endif %}
                </article>
            </section>
            <section class="panel-card">
                <h2>Guarantee Description Generator</h2>
                <form method="post" class="editor-form">
                    <input type="hidden" name="action" value="generate_garantie_text">
                    <label><span>Type garantie</span><input type="text" name="typeGarantie" value="{{ app.request.request.get('typeGarantie') }}"></label>
                    <label><span>Nom garant</span><input type="text" name="nomGarant" value="{{ app.request.request.get('nomGarant') }}"></label>
                    <label><span>Adresse</span><input type="text" name="adresseBien" value="{{ app.request.request.get('adresseBien') }}"></label>
                    <label><span>Valeur estimee</span><input type="number" step="0.01" name="valeurEstimee" value="{{ app.request.request.get('valeurEstimee') }}"></label>
                    <button class="btn btn-primary" type="submit">Generate description</button>
                </form>
                {% if view_state.generated_garantie %}<div class="notification-item">{{ view_state.generated_garantie }}</div>{% endif %}
            </section>
        {% endif %}

        {% if mode == 'portal' and section == 'games' %}
            <section class="panel-grid">
                <article class="panel-card dragon-panel">
                    <div class="dragon-hero"><img src="{{ asset(dragon.image) }}" alt="Dragon mood"><div><h2>Dragon Mood: {{ dragon.mood|title }}</h2><p>{{ dragon.message }}</p><p>{{ dragon.advice }}</p></div></div>
                    <section class="summary-grid slim-grid"><article class="summary-card"><strong>{{ dragon.total_balance|number_format(2, '.', ' ') }}</strong><span>Total balance</span></article><article class="summary-card"><strong>{{ dragon.vault_count }}</strong><span>Vaults</span></article><article class="summary-card"><strong>{{ dragon.savings_progress }}%</strong><span>Best progress</span></article></section>
                    <form method="post" class="editor-form">
                        <input type="hidden" name="action" value="dragon_feed">
                        <label><span>Account</span><select name="idCompte">{% for account in payments.accounts %}<option value="{{ account.idCompte }}">{{ account.numeroCompte }} | {{ account.solde }} DT</option>{% endfor %}</select></label>
                        <label><span>Vault</span><select name="idCoffre">{% for vault in vaults %}<option value="{{ vault.idCoffre }}">{{ vault.nom }} | {{ vault.montantActuel }} / {{ vault.objectifMontant }}</option>{% endfor %}</select></label>
                        <label><span>Amount</span><input type="number" step="0.01" name="amount" required></label>
                        <button class="btn btn-primary" type="submit">Feed dragon</button>
                    </form>
                </article>
                <article class="panel-card">
                    <h2>Roue de Fortune</h2>
                    <p>{{ wheel.eligibility.message }}</p>
                    <div class="feature-list"><div><strong>Trusted month</strong><p>{{ wheel.trusted_month }}</p></div><div><strong>Total points</strong><p>{{ wheel.total_points }} / 100</p></div><div><strong>Conditions</strong><p>Solde: {{ wheel.eligibility.condition_solde ? 'OK' : 'KO' }} | Budget: {{ wheel.eligibility.condition_budget ? 'OK' : 'KO' }} | Epargne: {{ wheel.eligibility.condition_epargne ? 'OK' : 'KO' }}</p></div><div><strong>Suggestion</strong><p>{{ wheel.eligibility.suggestion }}</p></div></div>
                    <div class="actions">
                        <form method="post"><input type="hidden" name="action" value="wheel_spin"><button class="btn btn-primary" type="submit" {{ not wheel.can_spin ? 'disabled' : '' }}>Spin wheel</button></form>
                        <form method="post" class="mini-form"><input type="hidden" name="action" value="wheel_bonus"><select name="idCompte">{% for account in payments.accounts %}<option value="{{ account.idCompte }}">{{ account.numeroCompte }}</option>{% endfor %}</select><button class="btn btn-secondary" type="submit" {{ not wheel.bonus_ready ? 'disabled' : '' }}>Claim 50 DT bonus</button></form>
                    </div>
                    {% if view_state.wheel_result %}<div class="notification-item"><strong>Latest wheel action</strong><p>{{ view_state.wheel_result.spin_result.message|default('Bonus credited successfully.') }}</p></div>{% endif %}
                </article>
            </section>
        {% endif %}

        {% if mode == 'portal' and section == 'payments' %}
            <section class="summary-grid">
                <article class="summary-card"><strong>{{ payments.total_paid|number_format(2, '.', ' ') }}</strong><span>Total paid</span></article>
                <article class="summary-card"><strong>{{ payments.weather.risk_score }}</strong><span>Weather risk</span></article>
                <article class="summary-card"><strong>{{ payments.currency.converted_amount|number_format(2, '.', ' ') }}</strong><span>{{ payments.currency.currency }} equivalent</span></article>
                <article class="summary-card"><strong>{{ payments.otp_verified ? 'YES' : 'NO' }}</strong><span>OTP verified</span></article>
            </section>
            <section class="panel-grid">
                <article class="panel-card">
                    <h2>Payment Verification</h2>
                    <form method="post" class="editor-form"><input type="hidden" name="action" value="send_payment_otp"><label><span>Telephone</span><input type="text" name="telephone" value="{{ current_user.telephone }}" required></label><button class="btn btn-secondary" type="submit">Send OTP</button></form>
                    <form method="post" class="editor-form"><input type="hidden" name="action" value="verify_payment_otp"><label><span>Telephone</span><input type="text" name="telephone" value="{{ current_user.telephone }}" required></label><label><span>OTP</span><input type="text" name="otp" required></label><button class="btn btn-primary" type="submit">Verify OTP</button></form>
                </article>
                <article class="panel-card">
                    <h2>Stripe Customer and Subscription</h2>
                    <form method="post"><input type="hidden" name="action" value="create_customer"><button class="btn btn-secondary" type="submit">Init customer</button></form>
                    <div class="notification-item"><strong>Customer</strong><p>{{ view_state.stripe_customer.id|default(payments.stripe_state.customer.id|default('Not initialized')) }}</p></div>
                    <form method="post" class="editor-form">
                        <input type="hidden" name="action" value="create_subscription">
                        <label><span>Credit</span><select name="idCredit">{% for credit in payments.credits %}<option value="{{ credit.idCredit }}">#{{ credit.idCredit }} - {{ credit.typeCredit }}</option>{% endfor %}</select></label>
                        <label><span>Monthly amount</span><input type="number" step="0.01" name="monthly_amount" required></label>
                        <button class="btn btn-primary" type="submit">Create subscription</button>
                    </form>
                    <div class="table-wrap"><table class="data-table"><thead><tr><th>ID</th><th>Credit</th><th>Status</th><th>Cancel</th></tr></thead><tbody>{% for sub in payments.stripe_state.subscriptions %}<tr><td>{{ sub.id }}</td><td>#{{ sub.credit_id }}</td><td>{{ sub.status }}</td><td>{% if sub.status != 'cancelled' %}<form method="post"><input type="hidden" name="action" value="cancel_subscription"><input type="hidden" name="subscription_id" value="{{ sub.id }}"><button class="btn btn-danger" type="submit">Cancel</button></form>{% else %}Cancelled{% endif %}</td></tr>{% else %}<tr><td colspan="4">No subscriptions.</td></tr>{% endfor %}</tbody></table></div>
                </article>
            </section>
            <section class="panel-grid">
                <article class="panel-card">
                    <h2>Pay Credit Installment</h2>
                    <form method="post" class="editor-form">
                        <input type="hidden" name="action" value="pay_credit">
                        <label><span>Credit</span><select name="idCredit">{% for credit in payments.credits %}<option value="{{ credit.idCredit }}">#{{ credit.idCredit }} - {{ credit.typeCredit }}</option>{% endfor %}</select></label>
                        <label><span>Account</span><select name="idCompte">{% for account in payments.accounts %}<option value="{{ account.idCompte }}">{{ account.numeroCompte }} | {{ account.solde }} DT</option>{% endfor %}</select></label>
                        <label><span>Amount</span><input type="number" step="0.01" name="amount" required></label>
                        <label><span>Mode</span><select name="payment_mode"><option value="simulation">Simulation</option><option value="stripe">Stripe</option></select></label>
                        <label><span>Stripe payment method</span><input type="text" name="payment_method" placeholder="pm_card_visa"></label>
                        <button class="btn btn-primary" type="submit">Pay installment</button>
                    </form>
                    {% if view_state.payment_result %}<div class="notification-item"><strong>Payment result</strong><p>{{ view_state.payment_result.provider }} | {{ view_state.payment_result.reference }} | {{ view_state.payment_result.status }}</p></div>{% endif %}
                </article>
                <article class="panel-card">
                    <h2>Weather and Currency</h2>
                    <div class="feature-list"><div><strong>Weather city</strong><p>{{ payments.weather.city }}</p><small>{{ payments.weather.message }}</small></div><div><strong>Detected country</strong><p>{{ payments.currency.country }}</p></div><div><strong>Rate</strong><p>1 TND = {{ payments.currency.rate }} {{ payments.currency.currency }}</p></div><div><strong>Converted amount</strong><p>{{ payments.currency.converted_amount|number_format(2, '.', ' ') }} {{ payments.currency.currency }}</p></div></div>
                </article>
            </section>
            <section class="panel-card">
                <h2>Payment History</h2>
                <div class="table-wrap"><table class="data-table"><thead><tr><th>ID</th><th>Date</th><th>Amount</th><th>Description</th><th>Status</th></tr></thead><tbody>{% for item in payments.history %}<tr><td>{{ item.idTransaction }}</td><td>{{ item.dateTransaction }}</td><td>{{ item.amount|number_format(2, '.', ' ') }} DT</td><td>{{ item.description }}</td><td>{{ item.status }}</td></tr>{% else %}<tr><td colspan="5">No payment history yet.</td></tr>{% endfor %}</tbody></table></div>
            </section>
        {% endif %}

        {% if mode == 'portal' and section == 'exports' %}
            <section class="panel-grid">
                <article class="panel-card"><h2>PDF Exports</h2><div class="actions"><a class="btn btn-secondary" href="{{ path('portal_feature_pdf_download', { kind: 'transactions' }) }}">Transactions PDF</a><a class="btn btn-secondary" href="{{ path('portal_feature_pdf_download', { kind: 'credits' }) }}">Credits PDF</a><a class="btn btn-secondary" href="{{ path('portal_feature_pdf_download', { kind: 'garanties' }) }}">Garanties PDF</a></div></article>
                <article class="panel-card"><h2>Notifications</h2><div class="notification-list">{% for item in notifications %}<div class="notification-item"><strong>{{ item.title }}</strong><p>{{ item.message }}</p></div>{% else %}<p>No notifications.</p>{% endfor %}</div></article>
            </section>
            <section class="panel-card">
                <h2>Transactions and QR Codes</h2>
                <div class="table-wrap"><table class="data-table"><thead><tr><th>ID</th><th>Category</th><th>Amount</th><th>Status</th><th>QR</th></tr></thead><tbody>{% for item in exports_data.transactions %}<tr><td>{{ item.idTransaction }}</td><td>{{ item.categorie }}</td><td>{{ item.montant_value|number_format(2, '.', ' ') }} DT</td><td>{{ item.statutTransaction }}</td><td><a class="btn btn-secondary" href="{{ path('portal_feature_transaction_qr', { id: item.idTransaction }) }}">Open QR</a></td></tr>{% else %}<tr><td colspan="5">No transactions.</td></tr>{% endfor %}</tbody></table></div>
            </section>
            <section class="panel-grid">
                <article class="panel-card"><h2>Credits Export Scope</h2><div class="table-wrap"><table class="data-table"><thead><tr><th>ID</th><th>Type</th><th>Amount</th><th>Status</th></tr></thead><tbody>{% for item in exports_data.credits %}<tr><td>{{ item.idCredit }}</td><td>{{ item.typeCredit }}</td><td>{{ item.montantDemande|number_format(2, '.', ' ') }} DT</td><td>{{ item.statut }}</td></tr>{% else %}<tr><td colspan="4">No credits.</td></tr>{% endfor %}</tbody></table></div></article>
                <article class="panel-card"><h2>Garanties Export Scope</h2><div class="table-wrap"><table class="data-table"><thead><tr><th>ID</th><th>Type</th><th>Value</th><th>Status</th></tr></thead><tbody>{% for item in exports_data.garanties %}<tr><td>{{ item.idGarantie }}</td><td>{{ item.typeGarantie }}</td><td>{{ item.valeurEstimee|number_format(2, '.', ' ') }} DT</td><td>{{ item.statut }}</td></tr>{% else %}<tr><td colspan="4">No garanties.</td></tr>{% endfor %}</tbody></table></div></article>
            </section>
        {% endif %}
    </main>
</div>
{% endblock %}
{% block javascripts %}{{ parent() }}<script>document.addEventListener('click',function(event){const button=event.target.closest('[data-speech-fill]');if(!button){return;}const field=document.querySelector('[name="'+button.getAttribute('data-speech-fill')+'"]');if(!field){return;}const Recognition=window.SpeechRecognition||window.webkitSpeechRecognition;if(!Recognition){window.alert('Browser speech recognition is not available on this device.');return;}const recognition=new Recognition();recognition.lang='en-US';recognition.interimResults=false;recognition.maxAlternatives=1;recognition.onresult=function(speechEvent){field.value=speechEvent.results[0][0].transcript;};recognition.start();});</script>{% endblock %}
